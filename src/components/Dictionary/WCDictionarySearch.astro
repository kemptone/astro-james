---
import WCFloatingLabel from '../WCFloatingLabel.astro'
---

<wc-dictionary-search>
  <form>
    <fieldset>
      <legend>Find words</legend>
      <WCFloatingLabel label="search by missing vowel numbers" adderror={'1'}>
        <input
          type="text"
          name="missing_vowel_numbers"
          inputmode="numeric"
          pattern="^(0|[1-5\\s]+)?$"
          placeholder="0, 3, 12, or 12345"
        />
      </WCFloatingLabel>
      <p class="vowel-help">
        <code>0</code> = has all vowels. <code>1=A</code>, <code>2=E</code>,
        <code>3=I</code>, <code>4=O</code>, <code>5=U</code>. Numbers you type
        mean that vowel is missing, so <code>3</code> means no <code>I</code>
        but <code>A E O U</code> must be there, and <code>12345</code> finds
        words like <code>fly</code> or <code>try</code>.
      </p>
      <div class="action">
        <button type="submit">Search</button>
      </div>
    </fieldset>
  </form>

  <script src="./wc-dictionary-search"></script>

  <style is:inline>
    form > fieldset {
      background-color: white;
      border: 1px solid #e5e7eb;
      padding: 14px;
    }

    form input[type='number'] {
      padding: 0.6rem;
    }

    .action {
      padding-block: 1rem;
    }

    .vowel-help {
      margin: 0.5rem 0 0;
      font-size: 0.95rem;
      line-height: 1.4;
      color: #475569;
    }

    .action button {
      padding: 1rem;
    }

    .action button:disabled {
      opacity: 0.2;
    }
  </style></wc-dictionary-search
>
