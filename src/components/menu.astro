---

<nav class="hamburger-nav">
  <button class="hamburger-btn" aria-label="Toggle menu">
    <span class="hamburger-line"></span>
    <span class="hamburger-line"></span>
    <span class="hamburger-line"></span>
  </button>

  <div class="menu-overlay">
    <button class="reinstall" type="button">Reinstall app</button>
    <ul class="menu-list">
      {
        menuLinks.map(link => (
          <li class="menu-item">
            <a href={link.href} class="menu-link" data-code={link.code || ''}>
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<script>
  import {isPageUnlocked} from '@/core/parental-control'
  import '@/components/wc-parental-gate'

  document.addEventListener('DOMContentLoaded', () => {
    const hamburgerNav = document.querySelector('.hamburger-nav')
    const hamburgerBtn = document.querySelector('.hamburger-btn')
    const menuOverlay = document.querySelector('.menu-overlay')
    const menuLinks = document.querySelectorAll('.menu-link')
    const menuReinstall = document.querySelector('.reinstall')

    // Create parental gate component
    const parentalGate = document.createElement('wc-parental-gate') as any
    document.body.appendChild(parentalGate)

    if (hamburgerBtn && hamburgerNav) {
      hamburgerBtn.addEventListener('click', () => {
        hamburgerNav.classList.toggle('active')
      })

      // Close menu when clicking on overlay
      menuOverlay?.addEventListener('click', e => {
        if (e.target === menuOverlay) {
          hamburgerNav.classList.remove('active')
        }
      })

      // Handle menu link clicks with parental control
      menuLinks.forEach(link => {
        link.addEventListener('click', e => {
          const htmlLink = link as HTMLAnchorElement
          const code = htmlLink.dataset.code
          const href = htmlLink.getAttribute('href')

          // Check if this link requires a code and is not unlocked
          if (code && !isPageUnlocked(href, code)) {
            e.preventDefault()

            // Show parental gate dialog
            parentalGate.show(href, code)

            // Listen for successful validation
            const handleValidation = (event: CustomEvent) => {
              hamburgerNav.classList.remove('active')
              window.location.href = event.detail.route
            }

            // Listen for cancellation
            const handleCancel = () => {
              hamburgerNav.classList.remove('active')
            }

            parentalGate.addEventListener('code-validated', handleValidation, {
              once: true,
            })
            parentalGate.addEventListener('code-cancelled', handleCancel, {
              once: true,
            })
          } else {
            // No code required or already unlocked, just close menu
            hamburgerNav.classList.remove('active')
          }
        })
      })

      // Close menu with Escape key
      document.addEventListener('keydown', e => {
        if (e.key === 'Escape' && hamburgerNav.classList.contains('active')) {
          hamburgerNav.classList.remove('active')
        }
      })

      if (menuReinstall) {
        menuReinstall.addEventListener('click', () => {
          localStorage.clear()
          caches.delete('my-cache')
          setTimeout(() => {
            window.location.href = '/'
          }, 1000)
        })
      }
    }

    // Page-level protection: Check if current page requires a code on load
    const currentPath = window.location.pathname

    // Find if current page has a code requirement
    menuLinks.forEach(link => {
      const htmlLink = link as HTMLAnchorElement
      const href = htmlLink.getAttribute('href')
      const code = htmlLink.dataset.code

      if (href === currentPath && code && !isPageUnlocked(currentPath, code)) {
        // Show parental gate for direct navigation to protected page
        parentalGate.show(currentPath, code)

        // Listen for successful validation
        const handleValidation = () => {
          // Page is now unlocked, dialog will close automatically
        }

        // Listen for cancellation - redirect to home
        const handleCancel = () => {
          window.location.href = '/'
        }

        parentalGate.addEventListener('code-validated', handleValidation, {
          once: true,
        })
        parentalGate.addEventListener('code-cancelled', handleCancel, {
          once: true,
        })
      }
    })
  })
</script>

<style>
  button.reinstall {
    position: fixed;
    top: 14px;
    left: 10px;
    padding: 2px 10px;
    font-size: 21px;
    cursor: pointer;
    margin: 10px;
  }

  .hamburger-nav {
    position: fixed;
    z-index: 1000;
    right: 20px;
    top: 20px;
  }

  .hamburger-btn {
    display: flex;
    flex-direction: column;
    justify-content: space-around;
    width: 50px;
    height: 50px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 1001;
    position: relative;
    box-shadow: none;
  }

  .hamburger-line {
    width: 100%;
    height: 6px;
    background-color: #333;
    border-radius: 2px;
    transition: all 0.3s ease;
    transform-origin: center;
  }

  .hamburger-btn:hover .hamburger-line {
    background-color: #555;
  }

  /* Menu overlay */
  .menu-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    background-color: transparent;
    backdrop-filter: blur(38px);
    -webkit-backdrop-filter: blur(38px);
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 999;
    overflow-y: auto;
    overflow-x: hidden;
  }

  .menu-list {
    list-style: none;
    padding: 4rem 2rem;
    margin: 0;
    text-align: center;
    display: flex;
    flex-wrap: wrap;
    width: 100%;
    max-width: 1200px;
    align-content: flex-start;
    min-height: min-content;
  }

  .menu-item {
    margin: 4px 0 !important;
    padding: 2px 6px !important;
    line-height: 1.4 !important;
  }

  .menu-link {
    color: var(--pico-color);
    text-decoration: none;
    font-size: 24px;
    font-weight: 300;
    font-family: system-ui, sans-serif;
    line-height: 1.2 !important;
    transition: color 0.3s ease;
    display: block;
    padding: 2px 8px !important;
  }

  .menu-link:hover {
    color: #ccc;
  }

  /* Active states */
  .hamburger-nav.active .menu-overlay {
    transform: translateX(0);
  }

  .hamburger-nav.active .hamburger-line:nth-child(1) {
    transform: rotate(45deg) translate(15px, 15px);
  }

  .hamburger-nav.active .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .hamburger-nav.active .hamburger-line:nth-child(3) {
    transform: rotate(-45deg) translate(7px, -9px);
  }

  /* Responsive adjustments */
  @media (max-width: 1024px) {
    .menu-link {
      font-size: 21px;
    }
    .menu-list {
      padding: 3rem 1.5rem;
    }
  }

  @media (max-width: 768px) {
    .menu-link {
      font-size: 18px;
      padding: 2px 6px !important;
    }
    .menu-list {
      padding: 3rem 1rem;
    }
  }

  @media (max-width: 480px) {
    .menu-link {
      font-size: 15px;
      padding: 1px 5px !important;
    }
    .menu-list {
      padding: 2.5rem 0.5rem;
    }
  }

  @media (max-width: 360px) {
    .menu-link {
      font-size: 14px;
      padding: 1px 4px !important;
    }
    .menu-list {
      padding: 2rem 0.5rem;
    }
  }
</style>
