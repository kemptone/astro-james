---
import Menu3 from '@/components/menu.astro'
import '@/layouts/style.css'

const gradeDefinitions = [
  {
    id: '20',
    label: '20',
    tone: 'best',
    description: 'You did a great job.',
  },
  {
    id: '19',
    label: '19',
    tone: 'best',
    description: 'You did amazing.',
  },
  {
    id: '18',
    label: '18',
    tone: 'best',
    description: "You've been steller.",
  },
  {
    id: '17',
    label: '17',
    tone: 'good',
    description: "You'll celebrate.",
  },
  {
    id: '16',
    label: '16',
    tone: 'good',
    description: "You'll have a great day from now on.",
  },
  {
    id: '15',
    label: '15',
    tone: 'good',
    description: 'You had an awesome day.',
  },
  {
    id: '14',
    label: '14',
    tone: 'good',
    description: 'A high-five.',
  },
  {
    id: '13',
    label: '13',
    tone: 'good',
    description: 'You win a prize.',
  },
  {
    id: '12',
    label: '12',
    tone: 'good',
    description: 'You had a great day.',
  },
  {
    id: '11',
    label: '11',
    tone: 'good',
    description: 'You had a good day.',
  },
  {
    id: '10',
    label: '10',
    tone: 'mid',
    description: "You're okay.",
  },
  {
    id: '9',
    label: '9',
    tone: 'mid',
    description: "You've had a rocky day.",
  },
  {
    id: '8',
    label: '8',
    tone: 'warn',
    description: 'You had a bad day.',
  },
  {
    id: '7',
    label: '7',
    tone: 'warn',
    description: 'You had a very bad day.',
  },
  {
    id: '6',
    label: '6',
    tone: 'warn',
    description: 'You had an extremely bad day.',
  },
  {
    id: '5',
    label: '5',
    tone: 'warn',
    description: 'You had a major rocky day.',
  },
  {
    id: '4',
    label: '4',
    tone: 'danger',
    description: 'You had a very very rocky one.',
  },
  {
    id: '3',
    label: '3',
    tone: 'danger',
    description: 'You are off the menu.',
  },
  {
    id: '2',
    label: '2',
    tone: 'danger',
    description: 'You are out!!',
  },
  {
    id: '1',
    label: '1',
    tone: 'danger',
    description: 'You are completely expelled.',
  },
  {
    id: '0',
    label: '0',
    tone: 'danger',
    description: 'YOU HAVE ABSOLUTE ROCKINESS.',
  },
  {
    id: '-0',
    label: '-0',
    tone: 'void',
    description: 'You are removed from the world.',
  },
  {
    id: '⬛️',
    label: '⬛️',
    tone: 'void',
    description: 'You are chopped out of the ocean and never seen again.',
  },
]

const defaultStudents = [
  'Zander',
  'Carmen',
  'Stephanie',
  'Xavior',
  'Dexter the Dog',
]
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Class Grade Game</title>
  </head>
  <body>
    <main class="grade-game">
      <section class="hero">
        <p class="eyebrow">SRO15</p>
        <h1>Class Grade Game</h1>
        <p class="intro">
          Hand out class grades from <strong>20</strong> down to <strong>0</strong>, plus
          <strong>-0</strong> and the even worse <strong>⬛️</strong>.
        </p>
        <p class="intro intro-small">
          Add students, choose their grade, and press <strong>Hand Out Grades</strong> to list
          everyone who got each result.
        </p>
      </section>

      <section class="panel controls-panel">
        <div class="toolbar">
          <label class="student-input">
            <span>Student name</span>
            <input
              id="studentNameInput"
              type="text"
              placeholder="Add another student to class"
              autocomplete="off"
            />
          </label>
          <button id="addStudentBtn" type="button">Add Student</button>
          <button id="handOutBtn" type="button">Hand Out Grades</button>
          <button id="resetBtn" type="button">Reset Grades</button>
          <button id="ivyIntroBtn" type="button">Ivy Introduction</button>
        </div>
      </section>

      <section class="panel roster-panel">
        <div class="section-heading">
          <div>
            <p class="section-kicker">Roster</p>
            <h2>Class List</h2>
          </div>
          <p class="section-copy">Use each student's dropdown here to change their grade.</p>
        </div>

        <div id="roster" class="roster" aria-live="polite"></div>
      </section>

      <section class="panel scale-panel">
        <div class="section-heading">
          <div>
            <p class="section-kicker">Scale</p>
            <h2>Grade Meanings</h2>
          </div>
          <p class="section-copy">20 is the best. ⬛️ is the absolute worst.</p>
        </div>

        <div class="scale-grid">
          {
            gradeDefinitions.map(grade => (
              <article class={`grade-card ${grade.tone}`}>
                <div class="grade-badge">{grade.label}</div>
                <p>{grade.description}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="panel output-panel">
        <div class="section-heading">
          <div>
            <p class="section-kicker">Report</p>
            <h2>Handed Out Grades</h2>
          </div>
          <p class="section-copy">This is where the grouped class results appear.</p>
        </div>

        <div id="output" class="output" aria-live="polite">
          Change grades in the <strong>Class List</strong> section, then press
          <strong>Hand Out Grades</strong>.
        </div>
      </section>
    </main>

    <Menu3 />

    <style>
      :root {
        --page-bg: linear-gradient(180deg, #f7f0d8 0%, #f2f7ff 55%, #ffffff 100%);
        --panel-bg: rgba(255, 255, 255, 0.92);
        --ink: #16213a;
        --muted: #57637a;
        --line: rgba(22, 33, 58, 0.12);
        --best: #2f9e44;
        --good: #5c940d;
        --mid: #f08c00;
        --warn: #e8590c;
        --danger: #c92a2a;
        --void: #111111;
      }

      body {
        margin: 0;
        color: var(--ink);
        background: var(--page-bg);
      }

      .grade-game {
        max-width: 1120px;
        margin: 0 auto;
        padding: 2rem 1rem 4rem;
      }

      .hero {
        padding: 1rem 0 1.5rem;
      }

      .eyebrow,
      .section-kicker {
        margin: 0 0 0.5rem;
        font-size: 0.82rem;
        font-weight: 800;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #7c6f34;
      }

      h1,
      h2,
      h3,
      h4,
      p {
        margin-top: 0;
      }

      h1 {
        margin-bottom: 0.75rem;
        font-size: clamp(2.3rem, 4vw, 4rem);
        line-height: 1;
      }

      .intro {
        max-width: 760px;
        font-size: 1.1rem;
      }

      .intro-small,
      .section-copy {
        color: var(--muted);
      }

      .panel {
        margin-top: 1.5rem;
        padding: 1.25rem;
        background: var(--panel-bg);
        border: 1px solid var(--line);
        border-radius: 24px;
        box-shadow: 0 24px 60px rgba(34, 51, 84, 0.08);
        backdrop-filter: blur(10px);
      }

      .toolbar {
        display: grid;
        gap: 0.9rem;
        grid-template-columns: minmax(240px, 1.8fr) repeat(4, minmax(120px, 1fr));
      }

      .student-input {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        font-weight: 700;
      }

      .student-input span {
        font-size: 0.9rem;
      }

      input,
      select,
      button {
        font: inherit;
      }

      input,
      select {
        width: 100%;
        padding: 0.85rem 0.95rem;
        border: 1px solid rgba(22, 33, 58, 0.18);
        border-radius: 16px;
        background: #ffffff;
        color: var(--ink);
      }

      button {
        border: none;
        border-radius: 16px;
        padding: 0.9rem 1rem;
        background: #1f4bd8;
        color: #ffffff;
        font-weight: 800;
        cursor: pointer;
        transition: transform 0.15s ease, opacity 0.15s ease, box-shadow 0.15s ease;
        box-shadow: 0 14px 24px rgba(31, 75, 216, 0.2);
      }

      button:hover {
        transform: translateY(-1px);
      }

      button:active {
        transform: translateY(0);
      }

      #resetBtn {
        background: #f08c00;
        box-shadow: 0 14px 24px rgba(240, 140, 0, 0.22);
      }

      #ivyIntroBtn {
        background: #7048e8;
        box-shadow: 0 14px 24px rgba(112, 72, 232, 0.22);
      }

      .section-heading {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1rem;
      }

      .section-heading h2 {
        margin-bottom: 0;
      }

      .roster {
        display: grid;
        gap: 0.9rem;
      }

      .student-card {
        display: grid;
        gap: 0.8rem;
        grid-template-columns: minmax(0, 1fr) minmax(180px, 260px) auto;
        align-items: center;
        padding: 1rem;
        border: 1px solid var(--line);
        border-radius: 20px;
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.95), rgba(244, 247, 255, 0.95));
      }

      .student-name {
        font-size: 1.05rem;
        font-weight: 800;
      }

      .student-meaning {
        margin: 0.35rem 0 0;
        font-size: 0.95rem;
        color: var(--muted);
      }

      .remove-student {
        background: #ffffff;
        color: var(--danger);
        border: 1px solid rgba(201, 42, 42, 0.18);
        box-shadow: none;
      }

      .grade-select {
        min-width: 0;
      }

      .scale-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
        gap: 0.85rem;
      }

      .grade-card {
        min-height: 130px;
        padding: 1rem;
        border-radius: 22px;
        color: #ffffff;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
      }

      .grade-card p {
        margin-bottom: 0;
      }

      .grade-card.best {
        background: linear-gradient(145deg, #2f9e44, #74b816);
      }

      .grade-card.good {
        background: linear-gradient(145deg, #5c940d, #82c91e);
      }

      .grade-card.mid {
        background: linear-gradient(145deg, #f08c00, #fab005);
      }

      .grade-card.warn {
        background: linear-gradient(145deg, #e8590c, #f76707);
      }

      .grade-card.danger {
        background: linear-gradient(145deg, #c92a2a, #e03131);
      }

      .grade-card.void {
        background: linear-gradient(145deg, #111111, #343a40);
      }

      .grade-badge {
        width: fit-content;
        min-width: 3.5rem;
        padding: 0.45rem 0.8rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.18);
        font-size: 1.1rem;
        font-weight: 900;
        letter-spacing: 0.05em;
      }

      .output {
        display: grid;
        gap: 0.9rem;
      }

      .summary-group {
        padding: 1rem;
        border-radius: 20px;
        border: 1px solid var(--line);
        background: #ffffff;
      }

      .summary-group h4 {
        margin-bottom: 0.4rem;
      }

      .summary-group ul {
        margin: 0;
        padding-left: 1.2rem;
      }

      .summary-group.best {
        border-left: 8px solid var(--best);
      }

      .summary-group.good {
        border-left: 8px solid var(--good);
      }

      .summary-group.mid {
        border-left: 8px solid var(--mid);
      }

      .summary-group.warn {
        border-left: 8px solid var(--warn);
      }

      .summary-group.danger {
        border-left: 8px solid var(--danger);
      }

      .summary-group.void {
        border-left: 8px solid var(--void);
      }

      .empty-report {
        color: var(--muted);
      }

      @media (max-width: 980px) {
        .toolbar {
          grid-template-columns: 1fr 1fr;
        }

        .student-card {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 640px) {
        .grade-game {
          padding-inline: 0.85rem;
        }

        .panel {
          padding: 1rem;
          border-radius: 20px;
        }

        .toolbar,
        .section-heading {
          grid-template-columns: 1fr;
          display: grid;
        }

        .grade-badge {
          min-width: 3rem;
        }
      }
    </style>

    <script define:vars={{gradeDefinitions, defaultStudents}}>
      const roster = document.getElementById('roster')
      const output = document.getElementById('output')
      const addStudentBtn = document.getElementById('addStudentBtn')
      const handOutBtn = document.getElementById('handOutBtn')
      const resetBtn = document.getElementById('resetBtn')
      const ivyIntroBtn = document.getElementById('ivyIntroBtn')
      const studentNameInput = document.getElementById('studentNameInput')

      const gradeMap = new Map(
        gradeDefinitions.map(grade => [grade.id, grade])
      )

      let students = defaultStudents.map(name => ({
        name,
        grade: '',
      }))

      function escapeHtml(value) {
        return value
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
      }

      function buildGradeOptions(selectedGrade) {
        const baseOption = '<option value="">Choose a grade</option>'
        const options = gradeDefinitions
          .map(grade => {
            const selected = grade.id === selectedGrade ? 'selected' : ''
            return `<option value="${escapeHtml(grade.id)}" ${selected}>${escapeHtml(grade.label)} - ${escapeHtml(grade.description)}</option>`
          })
          .join('')

        return `${baseOption}${options}`
      }

      function renderRoster() {
        if (students.length === 0) {
          roster.innerHTML = `
            <div class="summary-group empty-report">
              No students yet. Add someone to class to start handing out grades.
            </div>
          `
          return
        }

        roster.innerHTML = students
          .map((student, index) => {
            const grade = gradeMap.get(student.grade)
            const meaning = grade
              ? `${grade.label}: ${grade.description}`
              : 'No grade yet.'

            return `
              <article class="student-card">
                <div>
                  <div class="student-name">${escapeHtml(student.name)}</div>
                  <p class="student-meaning">${escapeHtml(meaning)}</p>
                </div>
                <label>
                  <span class="section-kicker">Grade</span>
                  <select class="grade-select" data-grade-index="${index}">
                    ${buildGradeOptions(student.grade)}
                  </select>
                </label>
                <button class="remove-student" data-remove-index="${index}" type="button">
                  Remove
                </button>
              </article>
            `
          })
          .join('')
      }

      function renderSummary() {
        const gradedStudents = students.filter(student => student.grade)

        if (gradedStudents.length === 0) {
          output.innerHTML = `
            <div class="summary-group empty-report">
              No grades handed out yet. Choose a grade for at least one student first.
            </div>
          `
          return
        }

        const summaryBlocks = gradeDefinitions
          .map(grade => {
            const matchingStudents = students.filter(student => student.grade === grade.id)

            if (matchingStudents.length === 0) {
              return ''
            }

            const studentItems = matchingStudents
              .map(student => `<li>${escapeHtml(student.name)}</li>`)
              .join('')

            return `
              <section class="summary-group ${grade.tone}">
                <h4>${escapeHtml(grade.label)} - ${escapeHtml(grade.description)}</h4>
                <ul>${studentItems}</ul>
              </section>
            `
          })
          .filter(Boolean)
          .join('')

        output.innerHTML = `
          <div class="section-kicker">Class Report</div>
          ${summaryBlocks}
        `
      }

      function addStudent() {
        const name = studentNameInput.value.trim()

        if (!name) {
          output.innerHTML = `
            <div class="summary-group empty-report">
              Please type a student name before adding them.
            </div>
          `
          return
        }

        students.push({name, grade: ''})
        studentNameInput.value = ''
        renderRoster()
        renderSummary()
        studentNameInput.focus()
      }

      async function speakIvy(text) {
        try {
          const response = await fetch('/api/polly/say', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              text,
              voiceId: 'Ivy',
              engine: 'neural',
            }),
          })

          if (response.ok) {
            const audioBlob = await response.blob()
            const audioUrl = URL.createObjectURL(audioBlob)
            const audio = new Audio(audioUrl)
            audio.play()
          }
        } catch (error) {
          console.error('Error playing audio:', error)
        }
      }

      roster.addEventListener('change', event => {
        const target = event.target

        if (!target.matches('[data-grade-index]')) {
          return
        }

        const index = Number(target.getAttribute('data-grade-index'))
        students[index].grade = target.value
        renderRoster()
      })

      roster.addEventListener('click', event => {
        const target = event.target
        const removeButton = target.closest('[data-remove-index]')

        if (!removeButton) {
          return
        }

        const index = Number(removeButton.getAttribute('data-remove-index'))
        students.splice(index, 1)
        renderRoster()
        renderSummary()
      })

      addStudentBtn.addEventListener('click', addStudent)

      studentNameInput.addEventListener('keydown', event => {
        if (event.key === 'Enter') {
          event.preventDefault()
          addStudent()
        }
      })

      handOutBtn.addEventListener('click', renderSummary)

      resetBtn.addEventListener('click', () => {
        students = defaultStudents.map(name => ({
          name,
          grade: '',
        }))
        studentNameInput.value = ''
        renderRoster()
        output.innerHTML =
          'Assign grades and press <strong>Hand Out Grades</strong>.'
      })

      ivyIntroBtn.addEventListener('click', () => {
        const introText =
          'Hi, my name is Ivy. Welcome to the class grade game. Twenty is the best. Zero is the worst. Minus zero is even worse, and the black square is the absolute worst. Add students, choose their grades, and press hand out grades to see who got each result.'
        speakIvy(introText)
        output.innerHTML = `
          <div class="summary-group empty-report">
            Ivy is speaking about the grade game.
          </div>
        `
      })

      renderRoster()
    </script>
  </body>
</html>
