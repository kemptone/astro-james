---
import Layout from '../layouts/Layout.astro'

const rowNumbers = Array.from({length: 9}, (_, index) => index + 1)
---

<Layout title="Missing Grid Game">
  <main class="missing-grid-page">
    <section class="panel intro-panel">
      <p class="eyebrow">Missing Grid Game</p>
      <h1>Type the missing columns for each row, then reveal the grid.</h1>
      <p class="lede">
        Use digits <code>1-9</code> with no spaces. A digit in a row makes that
        column unfilled. Leave a row blank to fill the whole row.
      </p>
    </section>

    <section class="panel input-panel">
      <form id="missing-grid-form" novalidate>
        <div class="input-grid">
          {
            rowNumbers.map(rowNumber => (
              <label class="row-card">
                <span class="row-label">Row {rowNumber}</span>
                <input
                  data-row-input
                  type="text"
                  inputmode="numeric"
                  autocomplete="off"
                  autocapitalize="off"
                  spellcheck="false"
                  maxlength="9"
                  placeholder="13579"
                  aria-label={`Numbers to remove from row ${rowNumber}`}
                />
              </label>
            ))
          }
        </div>

        <div class="legend">
          <div class="legend-item">
            <span class="legend-swatch filled"></span>
            <span>Filled</span>
          </div>
          <div class="legend-item">
            <span class="legend-swatch unfilled"></span>
            <span>Unfilled</span>
          </div>
        </div>

        <p class="helper-text">
          The grid is visible below. Press <strong>Submit</strong> to apply the
          inputs again.
        </p>

        <div class="button-row">
          <button type="submit" class="primary-button">Submit</button>
          <button type="button" id="clear-button" class="secondary-button">
            Clear
          </button>
        </div>
      </form>
    </section>

    <section id="result-panel" class="panel result-panel">
      <div class="result-copy">
        <div>
          <p class="eyebrow">Grid Result</p>
          <h2>Your 9 x 9 pattern</h2>
        </div>
        <p id="result-text" class="result-text" aria-live="polite"></p>
      </div>

      <div id="grid" class="grid" role="img" aria-label="Submitted 9 by 9 grid"></div>

      <p id="special-text" class="special-text" hidden aria-live="polite"></p>

      <div id="unlock-panel" class="unlock-panel" hidden>
        <p>The whole grid is filled, so the story book is unlocked.</p>
        <a class="storybook-link" href="/storybook">Open Story Book</a>
      </div>
    </section>
  </main>

  <script>
    const ROW_COUNT = 9
    const COLUMN_COUNT = 9
    const TOTAL_CELLS = ROW_COUNT * COLUMN_COUNT
    const SPECIAL_ROW = '123456789'
    const SPECIAL_AUDIO = ''

    const form = document.querySelector('#missing-grid-form')
    const gridElement = document.querySelector('#grid')
    const resultText = document.querySelector('#result-text')
    const specialText = document.querySelector('#special-text')
    const unlockPanel = document.querySelector('#unlock-panel')
    const clearButton = document.querySelector('#clear-button')
    const rowInputs = Array.from(
      document.querySelectorAll('input[data-row-input]')
    )

    let specialAudio

    const sanitizeRow = value => {
      const seen = new Set()

      return Array.from(value)
        .filter(character => character >= '1' && character <= '9')
        .filter(character => {
          if (seen.has(character)) return false
          seen.add(character)
          return true
        })
        .sort()
        .join('')
    }

    const buildGrid = rows =>
      rows.map(row => {
        const unfilledColumns = new Set(row.split(''))

        return Array.from({length: COLUMN_COUNT}, (_, index) => {
          const column = String(index + 1)
          return !unfilledColumns.has(column)
        })
      })

    const countFilledCells = grid =>
      grid.reduce(
        (total, row) =>
          total + row.reduce((rowTotal, isFilled) => rowTotal + Number(isFilled), 0),
        0
      )

    const isAllFilled = grid => grid.every(row => row.every(Boolean))

    const isSpecialBoard = rows => rows.every(row => row === SPECIAL_ROW)

    const playSpecialAudio = async () => {
      if (!SPECIAL_AUDIO) return false

      if (!specialAudio) specialAudio = new Audio(SPECIAL_AUDIO)
      specialAudio.currentTime = 0

      try {
        await specialAudio.play()
        return true
      } catch {
        return false
      }
    }

    const renderGrid = grid => {
      const fragment = document.createDocumentFragment()

      grid.forEach((row, rowIndex) => {
        row.forEach((isFilled, columnIndex) => {
          const cell = document.createElement('div')
          cell.className = `grid-cell ${isFilled ? 'is-filled' : 'is-unfilled'}`
          cell.setAttribute('aria-hidden', 'true')
          cell.dataset.row = String(rowIndex + 1)
          cell.dataset.column = String(columnIndex + 1)
          cell.textContent = isFilled ? '◼︎' : '◻︎'
          fragment.appendChild(cell)
        })
      })

      gridElement.replaceChildren(fragment)
    }

    const readRows = () =>
      rowInputs.map(input => {
        const cleaned = sanitizeRow(input.value)
        if (input.value !== cleaned) input.value = cleaned
        return cleaned
      })

    const showBoard = (rows, {submitted = false} = {}) => {
      const grid = buildGrid(rows)
      const filledCount = countFilledCells(grid)

      renderGrid(grid)
      resultText.textContent = submitted
        ? `${filledCount} of ${TOTAL_CELLS} squares are filled.`
        : `Starting grid from empty inputs: ${filledCount} of ${TOTAL_CELLS} squares are filled.`
      gridElement.setAttribute(
        'aria-label',
        `${submitted ? 'Submitted' : 'Starting'} 9 by 9 grid with ${filledCount} filled squares`
      )
      unlockPanel.hidden = !submitted || !isAllFilled(grid)

      return grid
    }

    const resetResult = () => {
      unlockPanel.hidden = true
      specialText.hidden = true
      specialText.textContent = ''
      showBoard(Array.from({length: ROW_COUNT}, () => ''), {submitted: false})
    }

    rowInputs.forEach(input => {
      input.addEventListener('input', () => {
        const cleaned = sanitizeRow(input.value)
        if (input.value !== cleaned) input.value = cleaned
      })
    })

    clearButton?.addEventListener('click', () => {
      form?.reset()
      rowInputs.forEach(input => {
        input.value = ''
      })
      resetResult()
      rowInputs[0]?.focus()
    })

    form?.addEventListener('submit', async event => {
      event.preventDefault()

      const rows = readRows()
      showBoard(rows, {submitted: true})
      const specialBoard = isSpecialBoard(rows)

      if (specialBoard) {
        const didPlay = await playSpecialAudio()
        specialText.hidden = false
        specialText.textContent = didPlay
          ? 'All 9 rows were 123456789, so the 6 7 meme is playing.'
          : 'All 9 rows were 123456789. The 6 7 meme trigger is ready, but the audio file still needs to be added.'
      } else {
        specialText.hidden = true
        specialText.textContent = ''
      }
    })

    resetResult()
  </script>
</Layout>

<style>
  :root {
    --page-shell: linear-gradient(180deg, #ffd7a8 0%, #ff9f5a 38%, #182231 100%);
    --panel-bg: rgba(16, 22, 31, 0.84);
    --panel-border: rgba(255, 240, 216, 0.16);
    --ink-main: #fff7e8;
    --ink-muted: rgba(255, 247, 232, 0.76);
    --accent: #ffd166;
    --accent-strong: #ff7b54;
    --filled-cell: #203047;
    --filled-glow: rgba(255, 209, 102, 0.24);
    --unfilled-cell: #f7f1e6;
    --input-bg: rgba(255, 247, 232, 0.08);
    --input-border: rgba(255, 247, 232, 0.18);
  }

  .missing-grid-page {
    min-height: 100vh;
    padding: clamp(1rem, 3vw, 2rem);
    display: grid;
    gap: 1rem;
    background:
      radial-gradient(circle at top left, rgba(255, 255, 255, 0.28), transparent 35%),
      var(--page-shell);
    color: var(--ink-main);
    font-family: 'Trebuchet MS', 'Avenir Next', sans-serif;
  }

  .panel {
    width: min(100%, 1020px);
    margin: 0 auto;
    padding: clamp(1.1rem, 2vw, 1.75rem);
    border-radius: 24px;
    border: 1px solid var(--panel-border);
    background: var(--panel-bg);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.28);
    backdrop-filter: blur(12px);
  }

  .eyebrow {
    margin: 0 0 0.35rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.8rem;
    color: var(--accent);
  }

  h1,
  h2,
  p {
    margin: 0;
  }

  h1,
  h2 {
    line-height: 1.05;
  }

  .intro-panel {
    display: grid;
    gap: 0.75rem;
  }

  .intro-panel h1 {
    max-width: 16ch;
    font-size: clamp(2rem, 5vw, 3.5rem);
  }

  .lede,
  .helper-text,
  .result-text,
  .special-text,
  .unlock-panel p {
    color: var(--ink-muted);
    line-height: 1.5;
  }

  .intro-panel code {
    padding: 0.15rem 0.35rem;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.1);
    font-size: 0.95em;
  }

  .input-panel form {
    display: grid;
    gap: 1rem;
  }

  .input-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 0.85rem;
  }

  .row-card {
    display: grid;
    gap: 0.45rem;
    padding: 0.9rem;
    border-radius: 18px;
    background: rgba(255, 247, 232, 0.05);
    border: 1px solid rgba(255, 247, 232, 0.08);
  }

  .row-label {
    font-size: 0.92rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .row-card input {
    width: 100%;
    padding: 0.8rem 0.9rem;
    border: 1px solid var(--input-border);
    border-radius: 14px;
    background: var(--input-bg);
    color: var(--ink-main);
    font: inherit;
    font-size: 1.1rem;
    letter-spacing: 0.22em;
  }

  .row-card input::placeholder {
    color: rgba(255, 247, 232, 0.35);
  }

  .row-card input:focus {
    outline: 2px solid rgba(255, 209, 102, 0.45);
    outline-offset: 2px;
    border-color: rgba(255, 209, 102, 0.35);
  }

  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    align-items: center;
  }

  .legend-item {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--ink-muted);
    font-size: 0.95rem;
  }

  .legend-swatch {
    width: 1rem;
    height: 1rem;
    border-radius: 0.2rem;
    border: 1px solid rgba(255, 247, 232, 0.16);
  }

  .legend-swatch.filled {
    background: var(--filled-cell);
    box-shadow: inset 0 0 0 1px var(--filled-glow);
  }

  .legend-swatch.unfilled {
    background: var(--unfilled-cell);
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .primary-button,
  .secondary-button,
  .storybook-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.9rem;
    padding: 0.85rem 1.2rem;
    border-radius: 999px;
    border: 0;
    font: inherit;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-decoration: none;
    cursor: pointer;
    transition:
      transform 140ms ease,
      box-shadow 140ms ease,
      background 140ms ease;
  }

  .primary-button:hover,
  .secondary-button:hover,
  .storybook-link:hover {
    transform: translateY(-1px);
  }

  .primary-button {
    color: #171b21;
    background: linear-gradient(135deg, var(--accent), #ffe9a8);
    box-shadow: 0 12px 30px rgba(255, 209, 102, 0.25);
  }

  .secondary-button {
    color: var(--ink-main);
    background: rgba(255, 247, 232, 0.12);
    border: 1px solid rgba(255, 247, 232, 0.16);
  }

  .result-panel {
    display: grid;
    gap: 1rem;
  }

  .result-copy {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: end;
    justify-content: space-between;
  }

  .grid {
    width: min(100%, 420px);
    display: grid;
    grid-template-columns: repeat(9, minmax(0, 1fr));
    gap: 0;
    border-radius: 18px;
    overflow: hidden;
    border: 2px solid rgba(255, 247, 232, 0.18);
    background: rgba(255, 247, 232, 0.08);
    box-shadow: inset 0 0 0 1px rgba(255, 247, 232, 0.05);
  }

  .grid-cell {
    display: grid;
    place-items: center;
    aspect-ratio: 1 / 1;
    border: 1px solid rgba(24, 34, 49, 0.16);
    font-family:
      'SF Pro Display',
      'Segoe UI Symbol',
      'Arial Unicode MS',
      monospace;
    font-size: clamp(1.1rem, 3.5vw, 1.9rem);
    line-height: 1;
  }

  .grid-cell.is-filled {
    color: var(--accent);
    background:
      linear-gradient(180deg, rgba(255, 209, 102, 0.08), transparent 42%),
      rgba(32, 48, 71, 0.78);
    box-shadow: inset 0 0 0 1px var(--filled-glow);
  }

  .grid-cell.is-unfilled {
    color: var(--unfilled-cell);
    background: rgba(247, 241, 230, 0.08);
  }

  .special-text {
    padding: 0.8rem 0.95rem;
    border-radius: 16px;
    background: rgba(255, 123, 84, 0.12);
    border: 1px solid rgba(255, 123, 84, 0.22);
  }

  .unlock-panel {
    display: grid;
    gap: 0.75rem;
    justify-items: start;
    padding: 1rem;
    border-radius: 18px;
    background: rgba(255, 209, 102, 0.12);
    border: 1px solid rgba(255, 209, 102, 0.28);
  }

  .storybook-link {
    color: #171b21;
    background: linear-gradient(135deg, #fff5cf, #ffd166);
  }

  @media (max-width: 720px) {
    .missing-grid-page {
      padding-bottom: 6rem;
    }

    .result-copy {
      align-items: start;
    }

    .grid {
      width: 100%;
    }
  }
</style>
