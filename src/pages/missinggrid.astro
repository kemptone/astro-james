---
import Layout from '../layouts/Layout.astro'

const axisNumbers = Array.from({length: 100}, (_, index) => index + 1)
---

<Layout title="100 x 100 Photo Puzzle">
  <main class="photo-puzzle-page">
    <section class="panel intro-panel">
      <p class="eyebrow">Photo Puzzle</p>
      <h1>Build a puzzle on a 100 x 100 picture grid.</h1>
      <p class="lede">
        The chosen photo is a square flower, so the corners stay simple:
        <code>1,1</code> is the top left and <code>100,100</code> is the bottom
        right. Click or drag on the board to reveal parts of the picture.
      </p>
    </section>

    <section class="panel controls-panel">
      <div class="controls-copy">
        <div>
          <p class="eyebrow">Controls</p>
          <h2>Reveal, cover, or jump to a square.</h2>
        </div>
        <p id="status-text" class="status-text" aria-live="polite">
          0 of 10,000 squares revealed. Brush: reveal.
        </p>
      </div>

      <div class="controls-grid">
        <div class="brush-panel">
          <span class="section-label">Brush</span>
          <div class="button-row">
            <button
              id="reveal-brush"
              type="button"
              class="tool-button is-active"
              data-brush="reveal"
              aria-pressed="true"
            >
              Reveal
            </button>
            <button
              id="cover-brush"
              type="button"
              class="tool-button"
              data-brush="cover"
              aria-pressed="false"
            >
              Cover
            </button>
          </div>
        </div>

        <div class="photo-picker-panel">
          <span class="section-label">Pick A Photo</span>
          <label class="file-picker" for="photo-input">
            <span>Choose an image file</span>
            <input id="photo-input" type="file" accept="image/*" />
          </label>
          <p id="photo-help" class="picker-help">
            Start with the flower, or pick one of your own photos.
          </p>
        </div>

        <form id="coordinate-form" class="coordinate-form">
          <span class="section-label">Jump To A Square</span>

          <label>
            <span>Row</span>
            <input
              id="row-input"
              name="row"
              type="number"
              min="1"
              max="100"
              inputmode="numeric"
              placeholder="1"
              required
            />
          </label>

          <label>
            <span>Column</span>
            <input
              id="column-input"
              name="column"
              type="number"
              min="1"
              max="100"
              inputmode="numeric"
              placeholder="1"
              required
            />
          </label>

          <button type="submit" class="tool-button secondary-button">
            Find Square
          </button>
        </form>

        <div class="button-stack">
          <span class="section-label">Whole Board</span>
          <button id="reveal-all" type="button" class="tool-button secondary-button">
            Reveal All
          </button>
          <button id="cover-all" type="button" class="tool-button secondary-button">
            Cover All
          </button>
        </div>
      </div>

      <p class="helper-text">
        Keyboard help: focus the board, use arrow keys to move, then press
        <strong>Space</strong> or <strong>Enter</strong> to use the current brush.
      </p>
    </section>

    <section class="panel puzzle-panel">
      <div class="puzzle-copy">
        <div>
          <p class="eyebrow">Chosen Photo</p>
          <h2 id="photo-title">Yellow flower on a square board</h2>
        </div>
        <p id="photo-description" class="lede">
          This photo was picked because it is already square, so
          <code>1,1</code>, <code>1,100</code>, <code>100,1</code>, and
          <code>100,100</code> line up cleanly with the corners.
        </p>
      </div>

      <figure class="whole-photo-panel">
        <img
          id="whole-photo-preview"
          src="/spin/flower.jpeg"
          alt="Yellow flower used for the 100 by 100 puzzle"
          class="whole-photo-preview"
        />
      </figure>

      <div class="board-copy">
        <div>
          <p class="eyebrow">Puzzle Board</p>
          <h2>100 x 100 grid view</h2>
        </div>
        <p class="lede">
          The whole photo shows above. The numbered board below keeps the same
          corners: <code>1,1</code> is top left and <code>100,100</code> is
          bottom right.
        </p>
      </div>

      <section id="camera-preview-panel" class="camera-preview-panel" hidden>
        <div class="camera-preview-copy">
          <div>
            <p class="eyebrow">Picked Camera</p>
            <h2 id="camera-preview-title">Camera row 1, column 1</h2>
          </div>
          <button id="show-grid-again" type="button" class="tool-button">
            Show Grid Again
          </button>
        </div>

        <div id="camera-preview" class="camera-preview" aria-hidden="true"></div>
      </section>

      <div id="board-scroll" class="board-scroll">
        <div class="board-shell">
          <div class="board-corner" aria-hidden="true">r/c</div>

          <div class="column-axis" aria-hidden="true">
            {
              axisNumbers.map(number => (
                <span>{number}</span>
              ))
            }
          </div>

          <div class="row-axis" aria-hidden="true">
            {
              axisNumbers.map(number => (
                <span>{number}</span>
              ))
            }
          </div>

          <div class="board-stage">
            <img
              src="/spin/flower.jpeg"
              alt="Yellow flower used for the 100 by 100 puzzle"
              class="board-photo"
            />
            <canvas
              id="puzzle-canvas"
              class="puzzle-canvas"
              width="1000"
              height="1000"
              tabindex="0"
              aria-label="100 by 100 flower puzzle board. 1 1 is top left and 100 100 is bottom right."
            ></canvas>
          </div>
        </div>
      </div>

      <p id="focus-readout" class="focus-readout" aria-live="polite">
        Hover, tap, or use the keyboard on the board to read a square.
      </p>
    </section>
  </main>

  <script>
    const GRID_SIZE = 100
    const TOTAL_CELLS = GRID_SIZE * GRID_SIZE
    const BOARD_PIXELS = 1000
    const CELL_PIXELS = BOARD_PIXELS / GRID_SIZE

    const canvas = document.querySelector('#puzzle-canvas')
    const context = canvas?.getContext('2d')
    const statusText = document.querySelector('#status-text')
    const focusReadout = document.querySelector('#focus-readout')
    const revealBrushButton = document.querySelector('#reveal-brush')
    const coverBrushButton = document.querySelector('#cover-brush')
    const revealAllButton = document.querySelector('#reveal-all')
    const coverAllButton = document.querySelector('#cover-all')
    const coordinateForm = document.querySelector('#coordinate-form')
    const rowInput = document.querySelector('#row-input')
    const columnInput = document.querySelector('#column-input')
    const photoInput = document.querySelector('#photo-input')
    const photoHelp = document.querySelector('#photo-help')
    const photoTitle = document.querySelector('#photo-title')
    const photoDescription = document.querySelector('#photo-description')
    const boardPhoto = document.querySelector('.board-photo')
    const wholePhotoPreview = document.querySelector('#whole-photo-preview')
    const wholePhotoPanel = document.querySelector('.whole-photo-panel')
    const boardCopy = document.querySelector('.board-copy')
    const boardScroll = document.querySelector('#board-scroll')
    const cameraPreviewPanel = document.querySelector('#camera-preview-panel')
    const cameraPreview = document.querySelector('#camera-preview')
    const cameraPreviewTitle = document.querySelector('#camera-preview-title')
    const showGridAgainButton = document.querySelector('#show-grid-again')

    const revealed = new Uint8Array(TOTAL_CELLS)

    let revealedCount = 0
    let brushMode = 'reveal'
    let hoveredCell = null
    let focusedCell = {row: 1, column: 1}
    let lastChangedCell = null
    let isPainting = false
    let currentObjectUrl = ''
    let currentPhotoSrc = '/spin/flower.jpeg'
    let cameraPreviewTimer = 0
    let cameraZoomFrame = 0

    const indexFor = (row, column) => ((row - 1) * GRID_SIZE) + (column - 1)

    const clampCoordinate = value =>
      Math.min(GRID_SIZE, Math.max(1, Math.round(Number(value) || 1)))

    const describeCell = cell => {
      if (!cell) return 'No square selected yet.'

      const cornerName =
        cell.row === 1 && cell.column === 1
          ? ' This is the top-left corner.'
          : cell.row === 100 && cell.column === 100
            ? ' This is the bottom-right corner.'
            : cell.row === 1 && cell.column === 100
              ? ' This is the top-right corner.'
              : cell.row === 100 && cell.column === 1
                ? ' This is the bottom-left corner.'
                : ''

      return `Row ${cell.row}, column ${cell.column}.${cornerName}`
    }

    const syncBrushButtons = () => {
      const isReveal = brushMode === 'reveal'

      revealBrushButton?.classList.toggle('is-active', isReveal)
      coverBrushButton?.classList.toggle('is-active', !isReveal)
      revealBrushButton?.setAttribute('aria-pressed', String(isReveal))
      coverBrushButton?.setAttribute('aria-pressed', String(!isReveal))
    }

    const updateStatus = () => {
      if (!statusText) return

      const cellText = lastChangedCell
        ? ` Last square: ${lastChangedCell.row},${lastChangedCell.column}.`
        : ''

      statusText.textContent =
        `${revealedCount.toLocaleString()} of ${TOTAL_CELLS.toLocaleString()} squares revealed. Brush: ${brushMode}.` +
        cellText
    }

    const updateReadout = cell => {
      if (!focusReadout) return
      focusReadout.textContent = describeCell(cell ?? focusedCell)
    }

    const resetWholePhotoPreview = () => {
      if (!wholePhotoPreview) return

      if (cameraZoomFrame) {
        window.cancelAnimationFrame(cameraZoomFrame)
        cameraZoomFrame = 0
      }

      wholePhotoPreview.style.transition = 'none'
      wholePhotoPreview.style.transformOrigin = '50% 50%'
      wholePhotoPreview.style.transform = 'scale(1)'

      void wholePhotoPreview.offsetWidth

      wholePhotoPreview.style.transition = 'transform 220ms ease'
    }

    const hideCameraPreview = () => {
      if (cameraPreviewTimer) {
        window.clearTimeout(cameraPreviewTimer)
        cameraPreviewTimer = 0
      }

      resetWholePhotoPreview()

      if (cameraPreviewPanel) cameraPreviewPanel.hidden = true
      if (wholePhotoPanel) wholePhotoPanel.hidden = false
      if (boardCopy) boardCopy.hidden = false
      if (boardScroll) boardScroll.hidden = false
      if (focusReadout) focusReadout.hidden = false
    }

    const showCameraPreview = cell => {
      if (!wholePhotoPreview) return

      const rowPercent = ((cell.row - 0.5) / GRID_SIZE) * 100
      const columnPercent = ((cell.column - 0.5) / GRID_SIZE) * 100

      resetWholePhotoPreview()
      wholePhotoPreview.style.transformOrigin = `${columnPercent}% ${rowPercent}%`

      cameraPreviewTimer = window.setTimeout(() => {
        const zoomDuration = 5000
        const startScale = 1
        const endScale = GRID_SIZE
        const startTime = performance.now()

        const animateZoom = now => {
          const rawProgress = Math.min(1, (now - startTime) / zoomDuration)
          // Start gently, then add a clear boost as the zoom continues.
          const easedProgress = Math.pow(rawProgress, 2.2)
          const nextScale =
            startScale * Math.pow(endScale / startScale, easedProgress)

          wholePhotoPreview.style.transform = `scale(${nextScale})`

          if (rawProgress < 1) {
            cameraZoomFrame = window.requestAnimationFrame(animateZoom)
            return
          }

          cameraZoomFrame = 0
        }

        cameraZoomFrame = window.requestAnimationFrame(animateZoom)
      }, 900)
    }

    const updatePhotoCopy = ({title, description, alt}) => {
      if (photoTitle) photoTitle.textContent = title
      if (photoDescription) photoDescription.innerHTML = description
      if (boardPhoto) boardPhoto.alt = alt
      if (wholePhotoPreview) wholePhotoPreview.alt = alt
    }

    const setCellState = (row, column, shouldReveal) => {
      const cellIndex = indexFor(row, column)
      const nextValue = shouldReveal ? 1 : 0

      if (revealed[cellIndex] === nextValue) return false

      revealed[cellIndex] = nextValue
      revealedCount += shouldReveal ? 1 : -1
      lastChangedCell = {row, column}
      return true
    }

    const drawGridLines = () => {
      if (!context) return

      context.save()

      for (let step = 0; step <= GRID_SIZE; step += 1) {
        const pixel = step * CELL_PIXELS

        context.beginPath()
        context.moveTo(pixel, 0)
        context.lineTo(pixel, BOARD_PIXELS)
        context.strokeStyle = 'rgba(255, 243, 212, 0.28)'
        context.lineWidth = 1
        context.stroke()

        context.beginPath()
        context.moveTo(0, pixel)
        context.lineTo(BOARD_PIXELS, pixel)
        context.strokeStyle = 'rgba(255, 243, 212, 0.28)'
        context.lineWidth = 1
        context.stroke()
      }

      context.restore()
    }

    const drawHighlight = (cell, color, lineWidth) => {
      if (!context || !cell) return

      const x = (cell.column - 1) * CELL_PIXELS
      const y = (cell.row - 1) * CELL_PIXELS

      context.save()
      context.strokeStyle = color
      context.lineWidth = lineWidth
      context.strokeRect(x + (lineWidth / 2), y + (lineWidth / 2), CELL_PIXELS - lineWidth, CELL_PIXELS - lineWidth)
      context.restore()
    }

    const drawBoard = () => {
      if (!context) return

      context.clearRect(0, 0, BOARD_PIXELS, BOARD_PIXELS)

      for (let row = 1; row <= GRID_SIZE; row += 1) {
        for (let column = 1; column <= GRID_SIZE; column += 1) {
          if (revealed[indexFor(row, column)]) continue

          context.fillStyle = 'rgba(10, 19, 32, 0.92)'
          context.fillRect(
            (column - 1) * CELL_PIXELS,
            (row - 1) * CELL_PIXELS,
            CELL_PIXELS,
            CELL_PIXELS
          )
        }
      }

      drawGridLines()
      drawHighlight(focusedCell, 'rgba(255, 122, 89, 0.96)', 3)

      if (hoveredCell) {
        drawHighlight(hoveredCell, 'rgba(255, 222, 130, 0.96)', 2)
      }
    }

    const getCellFromPointer = event => {
      if (!canvas) return null

      const bounds = canvas.getBoundingClientRect()
      const x = ((event.clientX - bounds.left) / bounds.width) * BOARD_PIXELS
      const y = ((event.clientY - bounds.top) / bounds.height) * BOARD_PIXELS

      if (x < 0 || y < 0 || x > BOARD_PIXELS || y > BOARD_PIXELS) return null

      return {
        row: Math.min(GRID_SIZE, Math.max(1, Math.floor(y / CELL_PIXELS) + 1)),
        column: Math.min(GRID_SIZE, Math.max(1, Math.floor(x / CELL_PIXELS) + 1)),
      }
    }

    const paintCell = cell => {
      if (!cell) return

      hideCameraPreview()
      focusedCell = cell
      hoveredCell = cell

      const changed = setCellState(cell.row, cell.column, brushMode === 'reveal')

      if (changed) updateStatus()
      updateReadout(cell)
      drawBoard()
    }

    const resetBoard = ({lastCell}) => {
      revealed.fill(0)
      revealedCount = 0
      lastChangedCell = lastCell
      hoveredCell = null
      updateStatus()
      drawBoard()
      updateReadout(focusedCell)
    }

    revealBrushButton?.addEventListener('click', () => {
      brushMode = 'reveal'
      syncBrushButtons()
      updateStatus()
    })

    coverBrushButton?.addEventListener('click', () => {
      brushMode = 'cover'
      syncBrushButtons()
      updateStatus()
    })

    revealAllButton?.addEventListener('click', () => {
      hideCameraPreview()
      revealed.fill(1)
      revealedCount = TOTAL_CELLS
      lastChangedCell = {row: 100, column: 100}
      updateStatus()
      drawBoard()
      updateReadout(focusedCell)
    })

    coverAllButton?.addEventListener('click', () => {
      hideCameraPreview()
      resetBoard({lastCell: {row: 1, column: 1}})
    })

    showGridAgainButton?.addEventListener('click', () => {
      hideCameraPreview()
      drawBoard()
      canvas?.focus()
    })

    photoInput?.addEventListener('change', event => {
      const file = event.target?.files?.[0]
      if (!file || !boardPhoto) return

      if (currentObjectUrl) URL.revokeObjectURL(currentObjectUrl)

      currentObjectUrl = URL.createObjectURL(file)
      boardPhoto.src = currentObjectUrl
      if (wholePhotoPreview) wholePhotoPreview.src = currentObjectUrl
      currentPhotoSrc = currentObjectUrl

      updatePhotoCopy({
        title: `${file.name} on a 100 x 100 board`,
        description:
          'Your chosen file is now under the puzzle grid. The coordinates stay the same: <code>1,1</code> is top left and <code>100,100</code> is bottom right.',
        alt: `Selected puzzle image ${file.name}`,
      })

      if (photoHelp) {
        photoHelp.textContent = `Loaded ${file.name}. The board was covered again so you can start a fresh puzzle.`
      }

      resetWholePhotoPreview()
      resetBoard({lastCell: {row: 1, column: 1}})
    })

    coordinateForm?.addEventListener('submit', event => {
      event.preventDefault()

      const row = clampCoordinate(rowInput?.value)
      const column = clampCoordinate(columnInput?.value)

      if (rowInput) rowInput.value = String(row)
      if (columnInput) columnInput.value = String(column)

      focusedCell = {row, column}
      hoveredCell = null
      revealed.fill(0)
      revealedCount = 0
      setCellState(row, column, true)
      updateStatus()
      drawBoard()
      updateReadout(focusedCell)
      wholePhotoPanel?.scrollIntoView({behavior: 'smooth', block: 'center'})
      showCameraPreview(focusedCell)
    })

    canvas?.addEventListener('pointerdown', event => {
      const cell = getCellFromPointer(event)
      if (!cell) return

      isPainting = true
      paintCell(cell)
      canvas.setPointerCapture(event.pointerId)
    })

    canvas?.addEventListener('pointermove', event => {
      const cell = getCellFromPointer(event)
      hoveredCell = cell

      if (cell) {
        focusedCell = cell
        updateReadout(cell)
      }

      if (isPainting && cell) {
        const changed = setCellState(cell.row, cell.column, brushMode === 'reveal')
        if (changed) updateStatus()
      }

      drawBoard()
    })

    const stopPainting = () => {
      isPainting = false
    }

    canvas?.addEventListener('pointerup', stopPainting)
    canvas?.addEventListener('pointercancel', stopPainting)
    canvas?.addEventListener('pointerleave', () => {
      hoveredCell = null
      stopPainting()
      drawBoard()
      updateReadout(focusedCell)
    })

    canvas?.addEventListener('keydown', event => {
      if (!focusedCell) focusedCell = {row: 1, column: 1}

      const nextCell = {
        row: focusedCell.row,
        column: focusedCell.column,
      }

      if (event.key === 'ArrowUp') nextCell.row = Math.max(1, nextCell.row - 1)
      else if (event.key === 'ArrowDown') nextCell.row = Math.min(100, nextCell.row + 1)
      else if (event.key === 'ArrowLeft') nextCell.column = Math.max(1, nextCell.column - 1)
      else if (event.key === 'ArrowRight') nextCell.column = Math.min(100, nextCell.column + 1)
      else if (event.key === 'Home') {
        nextCell.row = 1
        nextCell.column = 1
      } else if (event.key === 'End') {
        nextCell.row = 100
        nextCell.column = 100
      } else if (event.key === ' ' || event.key === 'Enter') {
        event.preventDefault()
        paintCell(focusedCell)
        return
      } else {
        return
      }

      event.preventDefault()
      focusedCell = nextCell
      hoveredCell = null
      drawBoard()
      updateReadout(focusedCell)
    })

    updatePhotoCopy({
      title: 'Yellow flower on a square board',
      description:
        'This photo was picked because it is already square, so <code>1,1</code>, <code>1,100</code>, <code>100,1</code>, and <code>100,100</code> line up cleanly with the corners.',
      alt: 'Yellow flower used for the 100 by 100 puzzle',
    })
    resetWholePhotoPreview()
    syncBrushButtons()
    updateStatus()
    updateReadout(focusedCell)
    drawBoard()
  </script>
</Layout>

<style>
  :root {
    --page-shell: linear-gradient(180deg, #fed27a 0%, #f4974a 34%, #10213a 100%);
    --panel-bg: rgba(12, 18, 29, 0.86);
    --panel-border: rgba(255, 248, 226, 0.14);
    --ink-main: #fff6e4;
    --ink-muted: rgba(255, 246, 228, 0.78);
    --accent: #ffd15d;
    --accent-strong: #ff7a59;
    --board-size: 1000px;
    --axis-size: 3.4rem;
    --shadow: 0 22px 60px rgba(0, 0, 0, 0.28);
  }

  .photo-puzzle-page {
    min-height: 100vh;
    padding: clamp(1rem, 3vw, 2rem);
    display: grid;
    gap: 1rem;
    background:
      radial-gradient(circle at top left, rgba(255, 255, 255, 0.3), transparent 34%),
      var(--page-shell);
    color: var(--ink-main);
    font-family: 'Trebuchet MS', 'Avenir Next', sans-serif;
  }

  .panel {
    width: min(100%, 1200px);
    margin: 0 auto;
    padding: clamp(1.1rem, 2vw, 1.75rem);
    border-radius: 24px;
    border: 1px solid var(--panel-border);
    background: var(--panel-bg);
    box-shadow: var(--shadow);
    backdrop-filter: blur(12px);
  }

  .eyebrow {
    margin: 0 0 0.35rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.8rem;
    color: var(--accent);
  }

  h1,
  h2,
  p {
    margin: 0;
  }

  h1,
  h2 {
    line-height: 1.05;
  }

  .intro-panel,
  .controls-panel,
  .puzzle-panel {
    display: grid;
    gap: 1rem;
  }

  .intro-panel h1 {
    max-width: 18ch;
    font-size: clamp(2rem, 5vw, 3.4rem);
  }

  .lede,
  .helper-text,
  .status-text,
  .focus-readout {
    color: var(--ink-muted);
    line-height: 1.5;
  }

  code {
    padding: 0.15rem 0.35rem;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.1);
    font-size: 0.95em;
  }

  .controls-copy,
  .puzzle-copy,
  .board-copy {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: 0.85rem;
  }

  .controls-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .brush-panel,
  .photo-picker-panel,
  .coordinate-form,
  .button-stack {
    display: grid;
    gap: 0.7rem;
    padding: 1rem;
    border-radius: 18px;
    background: rgba(255, 248, 226, 0.05);
    border: 1px solid rgba(255, 248, 226, 0.08);
  }

  .section-label {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.78rem;
    color: var(--ink-muted);
  }

  .photo-picker-panel {
    align-content: start;
  }

  .file-picker {
    display: grid;
    gap: 0.55rem;
    padding: 0.95rem 1rem;
    border-radius: 16px;
    border: 1px dashed rgba(255, 248, 226, 0.24);
    background: rgba(255, 248, 226, 0.06);
    color: var(--ink-main);
  }

  .file-picker input[type='file'] {
    width: 100%;
    color: var(--ink-muted);
  }

  .picker-help {
    color: var(--ink-muted);
    font-size: 0.95rem;
  }

  .button-row,
  .button-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: start;
  }

  .coordinate-form {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    align-items: end;
  }

  .coordinate-form .section-label {
    grid-column: 1 / -1;
  }

  .coordinate-form label {
    display: grid;
    gap: 0.45rem;
  }

  .coordinate-form input {
    width: 100%;
    padding: 0.8rem 0.9rem;
    border: 1px solid rgba(255, 248, 226, 0.2);
    border-radius: 14px;
    background: rgba(255, 248, 226, 0.08);
    color: var(--ink-main);
    font: inherit;
  }

  .coordinate-form input:focus,
  .tool-button:focus,
  .puzzle-canvas:focus {
    outline: 2px solid rgba(255, 209, 93, 0.5);
    outline-offset: 2px;
  }

  .tool-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.9rem;
    padding: 0.85rem 1.2rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 248, 226, 0.14);
