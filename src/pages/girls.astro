---
import Empty from '../layouts/Empty.astro'
import '../components/wc-dialog.css'
import '../core/girls/girls.css'
import '../../pico.css'
import WCFloatingLabel from '../components/WCFloatingLabel.astro'
import {girls_names} from '@/data/girls_names'
import {
  behavior_choices,
  ways_to_get_caught,
  randomFromArray,
} from '@/data/bad_stuff'
import {
  behaviorLetterCount,
  behaviorLetterOptions,
  bestBehaviorLetter,
} from '@/core/girls/behaviorLetters'
import {extendedBehaviorNumberNeutral} from '@/core/girls/behaviorNumbers'
import {buildStoryPreviewLines} from '@/core/girls/storyOptions'
import Menu3 from '@/components/menu.astro'
import '../components/wc-texarea-sizer'

const initialPersonName = randomFromArray(girls_names)
const initialChoice = randomFromArray(behavior_choices)
const initialWhatHappened = randomFromArray(ways_to_get_caught)
const initialStoryPreviewLines = buildStoryPreviewLines({
  personName: initialPersonName,
  choice: initialChoice,
  behaviorScore: bestBehaviorLetter,
  howGood: String(extendedBehaviorNumberNeutral),
  whatHappened: initialWhatHappened,
})
---

<Empty title="girls">
  <Menu3 />
  <main>
    <header>
      <h1>Person names</h1>
    </header>
    <p>
      Behavior Letter Day uses {behaviorLetterCount} letter scores for the
      behavior score. <strong>{bestBehaviorLetter}</strong> is the best one,
      <strong>Z</strong> is neutral, and <strong>-Z</strong> is the worst one.
    </p>
    <p>
      Extended Behavior Number Day now uses numbers from <strong>0</strong> to
      <strong>500</strong> for the how-good side. <strong>0</strong> is the
      best, <strong>100</strong> is plain and neutral, and
      <strong>500</strong> is the worst.
    </p>
    <p>
      The behavior letter still controls the behavior explanation. <strong>+A</strong> through
      <strong>+Z</strong> stays extremely strong, <strong>+a</strong> through
      <strong>+z</strong> stays very great, <strong>A</strong> through
      <strong>Z</strong> stays no-trouble, <strong>a</strong> through
      <strong>z</strong> moves into trouble, <strong>-a</strong> through
      <strong>-z</strong> moves into serious trouble, and
      <strong>-A</strong> through <strong>-Z</strong> goes too far into
      trouble.
    </p>
    <p>
      Number ranges: <strong>0-50 Good</strong>, <strong>51-100 Statisfactory</strong>,
      <strong>101-200 Moderately Weak</strong>, <strong>201-300 very weak</strong>,
      <strong>301-400 very bad</strong>, and <strong>401-500 Severely bad</strong>.
    </p>
    <p>
      Each extended number is its own rank with no repeats, so every 1-step
      change means a different tone.
    </p>
    <div id="filters" class="group">
      <input type="search" name="name_filter" placeholder="Filter names" />
      <input type="hidden" value="1000" name="limit" />
    </div>
    <div id="girls">
      {girls_names.map(name => <button>{name}</button>)}
    </div>
  </main>
  <wc-dialog-wrap>
    <dialog id="d_story">
      <details open>
        <summary>Generate story</summary>
        <form id="generate_story">
          <div class="grid">
            <WCFloatingLabel addclear="1">
              <label>person name</label>
              <input
                list="girls_list"
                name="person_name"
                value={initialPersonName}
              />
              <datalist id="girls_list">
                {girls_names.map(name => <option value={name} />)}
              </datalist>
            </WCFloatingLabel>

            <WCFloatingLabel addclear="1">
              <label>choice</label>
              <input
                list="choices"
                name="choice"
                value={initialChoice}
                placeholder="What did they do?"
              />
              <datalist id="choices">
                {behavior_choices.map(name => <option value={name} />)}
              </datalist>
            </WCFloatingLabel>
          </div>

          <div class="grid">
            <WCFloatingLabel addclear="1">
              <label>behavior letter</label>
              <input
                list="behavior_scores"
                name="behavior_score"
                placeholder="Pick a school behavior letter (+A is best)"
                value={bestBehaviorLetter}
              />
              <datalist id="behavior_scores">
                {behaviorLetterOptions.map(v => <option value={v} />)}
              </datalist>
            </WCFloatingLabel>

            <WCFloatingLabel addclear="1">
              <label>extended behavior number</label>
              <input
                type="number"
                min="0"
                max="500"
                step="1"
                name="how_good"
                placeholder="Pick a number from 0 to 500 (100 is neutral)"
                value={String(extendedBehaviorNumberNeutral)}
              />
            </WCFloatingLabel>
          </div>

          <div class="grid">
            <WCFloatingLabel addclear="1">
              <label>what happened next</label>
              <input
                list="got_caught"
                name="what_happened"
                placeholder="What happened next?"
                value={initialWhatHappened}
              />
              <datalist id="got_caught">
                {ways_to_get_caught.map(name => <option value={name} />)}
              </datalist>
            </WCFloatingLabel>
          </div>
          <details open>
            <summary>story preview</summary>
            <p class="story-options-note">
              The behavior letter explains the score, and the extended number
              quietly controls the moment tone.
            </p>
            <div id="story_options_preview">
              {initialStoryPreviewLines.map(line => (
                <p data-preview-line>{line}</p>
              ))}
            </div>
          </details>
          <footer>
            <button type="submit" class="outline secondary"
              >Generate main story</button
            >
          </footer>
        </form>
      </details>
      <form id="speak">
        <details open>
          <summary>main story</summary>
          <wc-textarea-sizer data-min="20" data-max="500">
            <textarea rows="9" name="text" rows="4"></textarea>
          </wc-textarea-sizer>
        </details>
        <footer>
          <button type="button" class="outline close-dialog">close</button>
          <button type="reset" class="outline">reset</button>
          <button type="submit" id="speak_selection" class="">Speak</button>
        </footer>
      </form>
    </dialog>
  </wc-dialog-wrap>
</Empty>
<script src="../core/girls/index.ts"></script>
<script src="../components/wc-dialog-wrap.ts"></script>
