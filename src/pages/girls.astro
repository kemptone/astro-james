---
import Empty from '../layouts/Empty.astro'
import '../components/wc-dialog.css'
import '../core/girls/girls.css'
import '../../pico.css'
import WCFloatingLabel from '../components/WCFloatingLabel.astro'
import {girls_names} from '@/data/girls_names'
import {
  behavior_choices,
  ways_to_get_caught,
  behavior_score,
  best_behavior_score,
  max_behavior_score,
  randomFromArray,
} from '@/data/bad_stuff'
import {
  buildStoryPreviewLines,
  getDefaultStoryOptionScores,
  storyOptionChoices,
  storyOptionFieldOrder,
} from '@/core/girls/storyOptions'
import Menu3 from '@/components/menu.astro'
import '../components/wc-texarea-sizer'

const initialPersonName = randomFromArray(girls_names)
const initialChoice = randomFromArray(behavior_choices)
const initialWhatHappened = randomFromArray(ways_to_get_caught)
const initialStoryOptions = getDefaultStoryOptionScores()
const initialStoryPreviewLines = buildStoryPreviewLines({
  personName: initialPersonName,
  choice: initialChoice,
  behaviorScore: best_behavior_score,
  whatHappened: initialWhatHappened,
  ...initialStoryOptions,
})
const storyOptionInputs = storyOptionFieldOrder.map(({key, label}) => ({
  key,
  label,
  value: initialStoryOptions[key],
  choices: storyOptionChoices[key],
}))
---

<Empty title="girls">
  <Menu3 />
  <main>
    <header>
      <h1>Person names</h1>
    </header>
    <p>
      Behavior Number Day uses {max_behavior_score} numbers. The longest
      YouTube slideshow goes through each one, and {best_behavior_score} is the
      best school behavior score.
    </p>
    <div id="filters" class="group">
      <input type="search" name="name_filter" placeholder="Filter names" />
      <input type="hidden" value="1000" name="limit" />
    </div>
    <div id="girls">
      {girls_names.map(name => <button>{name}</button>)}
    </div>
  </main>
  <wc-dialog-wrap>
    <dialog id="d_story">
      <details open>
        <summary>Generate story</summary>
        <form id="generate_story">
          <div class="grid">
            <WCFloatingLabel addclear="1">
              <label>person name</label>
              <input
                list="girls_list"
                name="person_name"
                value={initialPersonName}
              />
              <datalist id="girls_list">
                {girls_names.map(name => <option value={name} />)}
              </datalist>
            </WCFloatingLabel>

            <WCFloatingLabel addclear="1">
              <label>choice</label>
              <input
                list="choices"
                name="choice"
                value={initialChoice}
                placeholder="What did they do?"
              />
              <datalist id="choices">
                {behavior_choices.map(name => <option value={name} />)}
              </datalist>
            </WCFloatingLabel>
          </div>

          <div class="grid">
            <WCFloatingLabel addclear="1">
              <label>behavior score</label>
              <input
                list="behavior_scores"
                name="behavior_score"
                placeholder="Pick a school behavior score (1000 is best)"
                value={best_behavior_score}
              />
              <datalist id="behavior_scores">
                {behavior_score.map(v => <option value={v} />)}
              </datalist>
            </WCFloatingLabel>

            <WCFloatingLabel addclear="1">
              <label>what happened next</label>
              <input
                list="got_caught"
                name="what_happened"
                placeholder="What happened next?"
                value={initialWhatHappened}
              />
              <datalist id="got_caught">
                {ways_to_get_caught.map(name => <option value={name} />)}
              </datalist>
            </WCFloatingLabel>
          </div>
          <details open>
            <summary>story options before generation</summary>
            <p class="story-options-note">
              Each narrator part is its own option now, so you can mix good and
              bad pieces even if the story does not make sense.
            </p>
            <p class="story-options-note">
              <code>notice lead option</code> starts blank and uses
              <code>Good</code> for <code>Everyone noticed because</code> or
              <code>Bad</code> for
              <code>The problem grew bigger because</code>. 
              <code>handling option</code> starts blank and uses
              <code>Good</code> for
              <code>handled it in a no-trouble way</code> or
              <code>Bad</code> for
              <code>moved through a trouble moment</code>.
            </p>
            <div id="story_option_pieces" class="grid">
              {storyOptionInputs.map(item => (
                <WCFloatingLabel addclear="1">
                  <label>{item.label}</label>
                  <select name={item.key}>
                    {item.choices.map(choice => (
                      <option value={choice} selected={choice === item.value}>
                        {choice}
                      </option>
                    ))}
                  </select>
                </WCFloatingLabel>
              ))}
            </div>
            <p class="story-options-note">
              Full preview using the mixed options:
            </p>
            <div id="story_options_preview">
              {initialStoryPreviewLines.map(line => (
                <p data-preview-line>{line}</p>
              ))}
            </div>
          </details>
          <footer>
            <button type="submit" class="outline secondary"
              >Generate main story</button
            >
          </footer>
        </form>
      </details>
      <form id="speak">
        <details open>
          <summary>main story</summary>
          <wc-textarea-sizer data-min="20" data-max="500">
            <textarea rows="9" name="text" rows="4"></textarea>
          </wc-textarea-sizer>
        </details>
        <footer>
          <button type="button" class="outline close-dialog">close</button>
          <button type="reset" class="outline">reset</button>
          <button type="submit" id="speak_selection" class="">Speak</button>
        </footer>
      </form>
    </dialog>
  </wc-dialog-wrap>
</Empty>
<script src="../core/girls/index.ts"></script>
<script src="../components/wc-dialog-wrap.ts"></script>
