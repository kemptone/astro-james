<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Story Book</title>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: 'Georgia', serif;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding: 30px 15px;
        color: #333;
      }
      .container {
        max-width: 700px;
        width: 100%;
      }
      h1 {
        text-align: center;
        color: #fff;
        margin-bottom: 24px;
        font-size: 2rem;
        text-shadow: 0 2px 8px rgba(0,0,0,0.3);
      }
      .card {
        background: #fff;
        border-radius: 12px;
        padding: 28px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.18);
      }
      label { display: block; font-weight: bold; margin-bottom: 6px; }
      input[type="number"], input[type="text"] {
        width: 100%;
        padding: 10px 14px;
        border: 2px solid #ddd;
        border-radius: 8px;
        font-size: 1rem;
        font-family: inherit;
        outline: none;
        transition: border-color 0.2s;
      }
      input:focus, textarea:focus { border-color: #667eea; }
      textarea {
        width: 100%;
        min-height: 220px;
        padding: 14px;
        border: 2px solid #ddd;
        border-radius: 8px;
        font-size: 1.05rem;
        font-family: inherit;
        resize: vertical;
        outline: none;
        transition: border-color 0.2s;
      }
      .checkbox-row {
        display: flex;
        align-items: center;
        gap: 8px;
        margin: 14px 0;
      }
      .checkbox-row input[type="checkbox"] {
        width: 18px;
        height: 18px;
        cursor: pointer;
      }
      .checkbox-row label { margin: 0; font-weight: normal; cursor: pointer; }
      .btn {
        display: inline-block;
        padding: 10px 22px;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-family: inherit;
        cursor: pointer;
        font-weight: bold;
        transition: background 0.2s, transform 0.1s;
      }
      .btn:active { transform: scale(0.97); }
      .btn-primary { background: #667eea; color: #fff; }
      .btn-primary:hover { background: #5568d3; }
      .btn-secondary { background: #e0e0e0; color: #333; }
      .btn-secondary:hover { background: #ccc; }
      .btn-row { display: flex; gap: 10px; margin-top: 16px; flex-wrap: wrap; }
      .nav-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 18px;
      }
      .arrow-btn {
        background: #667eea;
        color: #fff;
        border: none;
        border-radius: 50%;
        width: 48px;
        height: 48px;
        font-size: 1.4rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s, transform 0.1s;
        user-select: none;
      }
      .arrow-btn:hover { background: #5568d3; }
      .arrow-btn:active { transform: scale(0.92); }
      .arrow-btn:disabled { background: #bbb; cursor: default; transform: none; }
      .page-info {
        font-size: 0.95rem;
        color: #666;
        text-align: center;
      }
      .page-label {
        font-size: 1.1rem;
        font-weight: bold;
        margin-bottom: 10px;
        color: #444;
      }
      .book-page {
        background: #fffef5;
        border: 1px solid #e0d9c8;
        border-radius: 6px;
        min-height: 260px;
        padding: 24px;
        font-size: 1.15rem;
        line-height: 1.7;
        white-space: pre-wrap;
        word-wrap: break-word;
        box-shadow: inset 0 0 20px rgba(0,0,0,0.04);
        position: relative;
      }
      .book-page .page-number {
        position: absolute;
        bottom: 10px;
        right: 16px;
        font-size: 0.85rem;
        color: #aaa;
      }
      .book-page .title-display {
        font-size: 2rem;
        font-weight: bold;
        text-align: center;
        margin-top: 60px;
      }
      .jump-row {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-top: 12px;
      }
      .jump-row input { width: 120px; }
      .jump-row .btn { padding: 8px 14px; font-size: 0.9rem; }
      .hidden { display: none !important; }
      .section-gap { margin-top: 20px; }

      @media print {
        body { background: #fff; padding: 0; }
        .no-print { display: none !important; }
        .book-page {
          border: none;
          box-shadow: none;
          page-break-after: always;
          min-height: auto;
          padding: 40px;
        }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>Story Book</h1>

      <!-- SETUP -->
      <div class="card" id="setup-section">
        <label for="page-count">Number of Pages (including covers)</label>
        <input type="number" id="page-count" min="2" value="10" placeholder="e.g. 56" />
        <div class="checkbox-row">
          <input type="checkbox" id="show-page-numbers" checked />
          <label for="show-page-numbers">Show page numbers</label>
        </div>
        <div class="btn-row">
          <button class="btn btn-primary" id="create-btn">Create Book</button>
        </div>
      </div>

      <!-- WRITE MODE -->
      <div class="card hidden" id="write-section">
        <div class="page-label" id="write-page-label"></div>
        <textarea id="page-editor" placeholder="Write your story here..."></textarea>
        <div class="nav-row no-print">
          <button class="arrow-btn" id="write-prev" aria-label="Previous page">&#8592;</button>
          <span class="page-info" id="write-page-info"></span>
          <button class="arrow-btn" id="write-next" aria-label="Next page">&#8594;</button>
        </div>
        <div class="jump-row no-print">
          <label style="margin:0;white-space:nowrap">Go to page:</label>
          <input type="number" id="jump-page" min="0" />
          <button class="btn btn-secondary" id="jump-btn">Go</button>
        </div>
        <div class="checkbox-row no-print">
          <input type="checkbox" id="show-page-numbers-write" checked />
          <label for="show-page-numbers-write">Show page numbers</label>
        </div>
        <div class="btn-row no-print">
          <button class="btn btn-primary" id="read-btn">Read Book</button>
          <button class="btn btn-secondary" id="print-btn">Print Book</button>
          <button class="btn btn-secondary" id="reset-btn">New Book</button>
        </div>
      </div>

      <!-- READ MODE -->
      <div class="card hidden" id="read-section">
        <div class="book-page" id="read-display"></div>
        <div class="nav-row no-print">
          <button class="arrow-btn" id="read-prev" aria-label="Previous page">&#8592;</button>
          <span class="page-info" id="read-page-info"></span>
          <button class="arrow-btn" id="read-next" aria-label="Next page">&#8594;</button>
        </div>
        <div class="btn-row no-print section-gap">
          <button class="btn btn-secondary" id="edit-btn">Edit Book</button>
          <button class="btn btn-secondary" id="print-read-btn">Print Book</button>
        </div>
      </div>
    </div>

    <script>
      const pages = new Map()
      let totalPages = 0
      let currentPage = 0
      let showPageNumbers = true

      // Elements
      const setupSection = document.getElementById('setup-section')
      const writeSection = document.getElementById('write-section')
      const readSection = document.getElementById('read-section')
      const pageCountInput = document.getElementById('page-count')
      const showPNCheckbox = document.getElementById('show-page-numbers')
      const showPNWriteCheckbox = document.getElementById('show-page-numbers-write')
      const createBtn = document.getElementById('create-btn')
      const pageEditor = document.getElementById('page-editor')
      const writePageLabel = document.getElementById('write-page-label')
      const writePageInfo = document.getElementById('write-page-info')
      const writePrev = document.getElementById('write-prev')
      const writeNext = document.getElementById('write-next')
      const jumpPage = document.getElementById('jump-page')
      const jumpBtn = document.getElementById('jump-btn')
      const readBtn = document.getElementById('read-btn')
      const printBtn = document.getElementById('print-btn')
      const resetBtn = document.getElementById('reset-btn')
      const readDisplay = document.getElementById('read-display')
      const readPageInfo = document.getElementById('read-page-info')
      const readPrev = document.getElementById('read-prev')
      const readNext = document.getElementById('read-next')
      const editBtn = document.getElementById('edit-btn')
      const printReadBtn = document.getElementById('print-read-btn')

      function getPageLabel(idx) {
        if (idx === 0) return 'Front Cover (Page 0)'
        if (idx === totalPages - 1) return 'Back Cover (Page ' + (totalPages - 1) + ')'
        return 'Page ' + idx
      }

      function saveCurrentPage() {
        pages.set(currentPage, pageEditor.value)
      }

      function loadWritePage(idx) {
        if (idx < 0 || idx >= totalPages) return
        saveCurrentPage()
        currentPage = idx
        pageEditor.value = pages.get(currentPage) || ''
        writePageLabel.textContent = getPageLabel(currentPage)
        writePageInfo.textContent = (currentPage + 1) + ' of ' + totalPages
        writePrev.disabled = currentPage === 0
        writeNext.disabled = currentPage === totalPages - 1
        jumpPage.value = currentPage
        pageEditor.focus()
      }

      function renderReadPage(idx) {
        if (idx < 0 || idx >= totalPages) return
        currentPage = idx
        const content = pages.get(currentPage) || ''
        showPageNumbers = showPNWriteCheckbox.checked

        let html = ''
        if (idx === 0) {
          html = '<div class="title-display">' + escapeHtml(content || 'Untitled') + '</div>'
        } else if (idx === totalPages - 1) {
          html = '<div class="title-display">' + escapeHtml(content || 'The End') + '</div>'
        } else {
          html = escapeHtml(content)
        }

        if (showPageNumbers && idx > 0 && idx < totalPages - 1) {
          html += '<div class="page-number">' + idx + '</div>'
        }

        readDisplay.innerHTML = html
        readPageInfo.textContent = (currentPage + 1) + ' of ' + totalPages
        readPrev.disabled = currentPage === 0
        readNext.disabled = currentPage === totalPages - 1
      }

      function escapeHtml(str) {
        const d = document.createElement('div')
        d.textContent = str
        return d.innerHTML
      }

      function showSection(section) {
        setupSection.classList.add('hidden')
        writeSection.classList.add('hidden')
        readSection.classList.add('hidden')
        section.classList.remove('hidden')
      }

      // Create Book
      createBtn.addEventListener('click', () => {
        const count = parseInt(pageCountInput.value)
        if (!count || count < 2) {
          alert('Please enter at least 2 pages (front cover + back cover).')
          return
        }
        totalPages = count
        pages.clear()
        currentPage = 0
        showPNWriteCheckbox.checked = showPNCheckbox.checked
        jumpPage.max = totalPages - 1
        showSection(writeSection)
        loadWritePage(0)
      })

      // Write navigation
      writePrev.addEventListener('click', () => loadWritePage(currentPage - 1))
      writeNext.addEventListener('click', () => loadWritePage(currentPage + 1))

      jumpBtn.addEventListener('click', () => {
        let target = parseInt(jumpPage.value)
        if (isNaN(target)) return
        target = Math.max(0, Math.min(totalPages - 1, target))
        loadWritePage(target)
      })

      jumpPage.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') jumpBtn.click()
      })

      // Auto-save on typing
      pageEditor.addEventListener('input', () => {
        pages.set(currentPage, pageEditor.value)
      })

      // Read mode
      readBtn.addEventListener('click', () => {
        saveCurrentPage()
        currentPage = 0
        showSection(readSection)
        renderReadPage(0)
      })

      // Read navigation
      readPrev.addEventListener('click', () => renderReadPage(currentPage - 1))
      readNext.addEventListener('click', () => renderReadPage(currentPage + 1))

      // Keyboard navigation in read mode
      document.addEventListener('keydown', (e) => {
        if (readSection.classList.contains('hidden')) return
        if (e.key === 'ArrowLeft') renderReadPage(currentPage - 1)
        if (e.key === 'ArrowRight') renderReadPage(currentPage + 1)
      })

      // Edit mode
      editBtn.addEventListener('click', () => {
        showSection(writeSection)
        loadWritePage(currentPage)
      })

      // Print
      printBtn.addEventListener('click', () => {
        saveCurrentPage()
        window.print()
      })
      printReadBtn.addEventListener('click', () => window.print())

      // Reset
      resetBtn.addEventListener('click', () => {
        if (!confirm('Start a new book? All current content will be lost.')) return
        pages.clear()
        totalPages = 0
        currentPage = 0
        pageCountInput.value = 10
        showSection(setupSection)
      })

      // Sync page number checkbox
      showPNWriteCheckbox.addEventListener('change', () => {
        showPageNumbers = showPNWriteCheckbox.checked
      })
    </script>
  </body>
</html>
