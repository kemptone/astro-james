---
import Layout from '../layouts/Layout.astro'

const russianAlphabet = [
  'А',
  'Б',
  'В',
  'Г',
  'Д',
  'Е',
  'Ё',
  'Ж',
  'З',
  'И',
  'Й',
  'К',
  'Л',
  'М',
  'Н',
  'О',
  'П',
  'Р',
  'С',
  'Т',
  'У',
  'Ф',
  'Х',
  'Ц',
  'Ч',
  'Ш',
  'Щ',
  'Ъ',
  'Ы',
  'Ь',
  'Э',
  'Ю',
  'Я',
]

const russianByFrequency = [
  'О',
  'Е',
  'А',
  'И',
  'Н',
  'Т',
  'С',
  'Р',
  'В',
  'Л',
  'К',
  'М',
  'Д',
  'П',
  'У',
  'Я',
  'Ы',
  'Ь',
  'Г',
  'З',
  'Б',
  'Ч',
  'Й',
  'Х',
  'Ж',
  'Ш',
  'Ю',
  'Ц',
  'Щ',
  'Э',
  'Ф',
  'Ъ',
  'Ё',
]

const splitIntoRows = <T,>(items: T[], size: number) =>
  Array.from({length: Math.ceil(items.length / size)}, (_, index) =>
    items.slice(index * size, index * size + size)
  )

const buildNumberRows = (letters: string[]) =>
  splitIntoRows(
    letters.map((letter, index) => ({letter, number: index + 1})),
    10
  )

const encodeExample = (secret: string, letters: string[]) =>
  Array.from(secret)
    .map(letter => {
      if (letter === '/') return '/'
      return String(letters.indexOf(letter) + 1)
    })
    .join(' ')

const exampleSecret = 'ПРИВЕТ/МИР'
const defaultModeKey = 'alpha'
const gameModes = {
  alpha: {
    buttonLabel: 'Alphabet order',
    description: '1 is А and 33 is Я in this version.',
    mapLabel: 'Alphabet Number Map',
    mapNote: 'This version follows the normal Russian alphabet from start to finish.',
    letters: russianAlphabet,
  },
  common: {
    buttonLabel: 'Common to rare',
    description: '1 is the most usual Russian letter and 33 is the least usual in this version.',
    mapLabel: 'Common-to-Rare Number Map',
    mapNote: 'This version ranks the letters from most usual to least usual.',
    letters: russianByFrequency,
  },
}

const modeConfigs = Object.fromEntries(
  Object.entries(gameModes).map(([key, mode]) => [
    key,
    {
      ...mode,
      exampleCode: encodeExample(exampleSecret, mode.letters),
      exampleWord: exampleSecret,
    },
  ])
)

const letterRows = splitIntoRows(russianAlphabet, 10)
const numberRows = buildNumberRows(gameModes[defaultModeKey].letters)
---

<Layout title="Daphne">
  <main class="daphne-page">
    <section class="hero">
      <p class="eyebrow">Two Player • Two Versions</p>
      <h1>Russian Code Hangman</h1>
      <p class="lede">
        Player 1 writes the secret as <strong>numbers 1 to 33</strong> for the
        <strong>33-letter Russian alphabet</strong>. Keep spaces between the
        numbers. Use <strong>/</strong> when you want a space between words.
      </p>

      <div class="mode-toggle" role="tablist" aria-label="Russian code versions">
        <button
          type="button"
          class="mode-pill is-active"
          data-mode-button
          data-mode="alpha"
          aria-selected="true"
        >
          {gameModes.alpha.buttonLabel}
        </button>
        <button
          type="button"
          class="mode-pill"
          data-mode-button
          data-mode="common"
          aria-selected="false"
        >
          {gameModes.common.buttonLabel}
        </button>
      </div>

      <p id="mode-note" class="mode-note">{gameModes[defaultModeKey].description}</p>

      <div class="hero-notes">
        <div class="hero-chip">
          <strong>Example Code</strong>
          <span id="example-code">{modeConfigs[defaultModeKey].exampleCode}</span>
        </div>
        <div class="hero-chip">
          <strong>Means</strong>
          <span>{modeConfigs[defaultModeKey].exampleWord}</span>
        </div>
        <div class="hero-chip">
          <strong>Win</strong>
          <span>Circle every letter in the secret.</span>
        </div>
      </div>
    </section>

    <section class="panel setup-panel">
      <div class="panel-head">
        <div>
          <p class="panel-kicker">Player 1</p>
          <h2>Make the code</h2>
        </div>
        <p id="setup-note" class="panel-note">
          Use numbers <strong>1 to 33</strong>. Use <strong>/</strong> for spaces.
        </p>
      </div>

      <label class="field">
        <span>Secret number code</span>
        <textarea
          id="secret-input"
          rows="4"
          spellcheck="false"
          autocomplete="off"
          inputmode="numeric"
          placeholder={`For example: ${modeConfigs[defaultModeKey].exampleCode}`}
        ></textarea>
      </label>

      <div class="button-row">
        <button id="start-round" type="button" class="primary-button">
          Start Round
        </button>
        <button id="new-round" type="button" class="secondary-button">
          New Round
        </button>
      </div>

      <p id="setup-feedback" class="feedback" aria-live="polite">
        Player 1 writes the number code, then passes the screen to Player 2.
      </p>
    </section>

    <section class="panel code-panel">
      <div class="panel-head">
        <div>
          <p class="panel-kicker">Crack The Code</p>
          <h2>Blanks and number map</h2>
        </div>
        <p class="panel-note">The slash makes a word space. The secret number code stays hidden.</p>
      </div>

      <div class="code-box">
        <p class="output-label">Blanks</p>
        <div id="blank-output" class="blank-output" aria-live="polite">
          Start a round to show the blanks.
        </div>
      </div>

      <div class="map-wrap">
        <p id="map-label" class="output-label">{gameModes[defaultModeKey].mapLabel}</p>
        <p id="map-note" class="map-note">{gameModes[defaultModeKey].mapNote}</p>
        <div id="number-map" class="rows-wrap">
          {
            numberRows.map(row => (
              <div class="letter-row key-row">
                {
                  row.map(item => (
                    <div class="key-card">
                      <strong>{item.number}</strong>
                      <span>{item.letter}</span>
                    </div>
                  ))
                }
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="panel play-panel">
      <div class="panel-head">
        <div>
          <p class="panel-kicker">Player 2</p>
          <h2>Circle the letters</h2>
        </div>
        <p class="panel-note">Correct letters get circled. Wrong letters get crossed out.</p>
      </div>

      <div class="status-grid">
        <article class="status-card">
          <span class="status-label">Stars</span>
          <strong id="star-count">0</strong>
          <p>Win a round to earn 1 star.</p>
        </article>

        <article class="status-card">
          <span class="status-label">Unlock</span>
          <strong>5 stars</strong>
          <p>When you reach 5 stars, Talkers Two opens.</p>
        </article>
      </div>

      <div class="unlock-box" id="unlock-box" hidden>
        <p class="output-label">Unlocked</p>
        <a class="unlock-link" href="/talkers2">Go to Talkers Two</a>
      </div>

      <div class="rows-wrap" aria-label="Russian letters to guess">
        {
          letterRows.map(row => (
            <div class="letter-row">
              {
                row.map(letter => (
                  <button
                    type="button"
                    class="letter-button"
                    data-letter-button
                    data-letter={letter}
                    disabled
                  >
                    {letter}
                  </button>
                ))
              }
            </div>
          ))
        }
      </div>

      <p id="play-feedback" class="feedback" aria-live="polite">
        Start a round to let Player 2 begin guessing.
      </p>
    </section>
  </main>

  <script define:vars={{defaultModeKey, modeConfigs, russianAlphabet}}>
    const secretInput = document.querySelector('#secret-input')
    const startRoundButton = document.querySelector('#start-round')
    const newRoundButton = document.querySelector('#new-round')
    const setupFeedback = document.querySelector('#setup-feedback')
    const codePanel = document.querySelector('.code-panel')
    const blankOutput = document.querySelector('#blank-output')
    const playFeedback = document.querySelector('#play-feedback')
    const starCount = document.querySelector('#star-count')
    const unlockBox = document.querySelector('#unlock-box')
    const modeNote = document.querySelector('#mode-note')
    const setupNote = document.querySelector('#setup-note')
    const exampleCode = document.querySelector('#example-code')
    const mapLabel = document.querySelector('#map-label')
    const mapNote = document.querySelector('#map-note')
    const numberMap = document.querySelector('#number-map')
    const modeButtons = document.querySelectorAll('[data-mode-button]')
    const letterButtons = document.querySelectorAll('[data-letter-button]')
    const russianLetterSet = new Set(russianAlphabet)

    const state = {
      secret: '',
      guessed: new Set(),
      active: false,
      stars: 0,
      mode: defaultModeKey,
    }

    const setSetupFeedback = (message, tone = 'neutral') => {
      if (!setupFeedback) return
      setupFeedback.textContent = message
      setupFeedback.dataset.tone = tone
    }

    const setPlayFeedback = (message, tone = 'neutral') => {
      if (!playFeedback) return
      playFeedback.textContent = message
      playFeedback.dataset.tone = tone
    }

    const getModeConfig = () => modeConfigs[state.mode]

    const splitRows = (items, size) =>
      Array.from({length: Math.ceil(items.length / size)}, (_, index) =>
        items.slice(index * size, index * size + size)
      )

    const renderNumberMap = () => {
      if (!numberMap) return

      numberMap.innerHTML = ''

      const rows = splitRows(
        getModeConfig().letters.map((letter, index) => ({letter, number: index + 1})),
        10
      )

      rows.forEach(row => {
        const rowElement = document.createElement('div')
        rowElement.className = 'letter-row key-row'

        row.forEach(item => {
          const card = document.createElement('div')
          card.className = 'key-card'

          const number = document.createElement('strong')
          number.textContent = String(item.number)

          const letter = document.createElement('span')
          letter.textContent = item.letter

          card.append(number, letter)
          rowElement.appendChild(card)
        })

        numberMap.appendChild(rowElement)
      })
    }

    const renderMode = () => {
      const mode = getModeConfig()

      modeButtons.forEach(button => {
        const isActive = button.dataset.mode === state.mode
        button.classList.toggle('is-active', isActive)
        button.setAttribute('aria-selected', String(isActive))
      })

      if (modeNote) {
        modeNote.textContent = mode.description
      }

      if (setupNote) {
        setupNote.innerHTML =
          `Use numbers <strong>1 to 33</strong>. Use <strong>/</strong> for spaces. ${mode.description}`
      }

      if (exampleCode) {
        exampleCode.textContent = mode.exampleCode
      }

      if (secretInput) {
        secretInput.placeholder = `For example: ${mode.exampleCode}`
      }

      if (mapLabel) {
        mapLabel.textContent = mode.mapLabel
      }

      if (mapNote) {
        mapNote.textContent = mode.mapNote
      }

      renderNumberMap()
    }

    const parseSecretCode = rawValue => {
      const tokens = (rawValue.match(/\/|\d+/g) || [])
      const normalizedTokens = []
      const letters = []
      let invalidNumber = ''
      const activeLetters = getModeConfig().letters

      tokens.forEach(token => {
        if (token === '/') {
          if (!normalizedTokens.length || normalizedTokens[normalizedTokens.length - 1] === '/')
            return

          normalizedTokens.push('/')
          letters.push('/')
          return
        }

        const numericValue = Number.parseInt(token, 10)
        const letter = activeLetters[numericValue - 1]

        if (!letter) {
          if (!invalidNumber) invalidNumber = token
          return
        }

        normalizedTokens.push(String(numericValue))
        letters.push(letter)
      })

      while (normalizedTokens[normalizedTokens.length - 1] === '/') {
        normalizedTokens.pop()
        letters.pop()
      }

      return {
        invalidNumber,
        code: normalizedTokens.join(' '),
        secret: letters.join(''),
      }
    }

    const getUniqueSecretLetters = () =>
      new Set(Array.from(state.secret).filter(letter => russianLetterSet.has(letter)))

    const buildBlanks = () => {
      if (!state.secret) return 'Start a round to show the blanks.'

      return Array.from(state.secret)
        .map(character => {
          if (character === '/') return '   '
          return state.guessed.has(character) ? character : '_'
        })
        .join(' ')
    }

    const updateStars = () => {
      if (starCount) {
        starCount.textContent = String(state.stars)
      }

      if (unlockBox) {
        unlockBox.hidden = state.stars < 5
      }
    }

    const updateLetterButtons = () => {
      letterButtons.forEach(button => {
        const element = button
        const letter = element.dataset.letter || ''
        const guessed = state.guessed.has(letter)
        const correct = guessed && state.secret.includes(letter)
        const wrong = guessed && !state.secret.includes(letter)

        element.disabled = !state.active || guessed
        element.classList.toggle('is-correct', correct)
        element.classList.toggle('is-wrong', wrong)
      })
    }

    const updateBlanks = () => {
      if (!blankOutput) return
      blankOutput.textContent = buildBlanks()
    }

    const clearRound = () => {
      state.secret = ''
      state.guessed.clear()
      state.active = false
      updateLetterButtons()
      updateBlanks()
    }

    const setMode = mode => {
      if (!modeConfigs[mode] || state.mode === mode) return

      state.mode = mode
      clearRound()

      if (secretInput) {
        secretInput.value = ''
      }

      renderMode()
      setSetupFeedback('Version changed. Player 1 can write a new number code.', 'neutral')
      setPlayFeedback('Start a round to let Player 2 begin guessing.', 'neutral')
    }

    const finishRoundIfSolved = () => {
      const uniqueLetters = getUniqueSecretLetters()
      const solved = Array.from(uniqueLetters).every(letter => state.guessed.has(letter))

      if (!solved) return false

      state.active = false
      state.stars = Math.min(5, state.stars + 1)
      updateLetterButtons()
      updateStars()

      if (state.stars >= 5) {
        setPlayFeedback(
          'You circled every secret letter, earned 1 star, and unlocked Talkers Two.',
          'success'
        )
        return true
      }

      setPlayFeedback(
        `You circled every secret letter and earned 1 star. Stars: ${state.stars}/5.`,
        'success'
      )
      return true
    }

    const startRound = () => {
      if (!secretInput) return

      const parsed = parseSecretCode(secretInput.value)
      const cleaned = parsed.secret

      if (!cleaned) {
        setSetupFeedback(
          'Write a real number code first. Use numbers 1 to 33. Use / if you want a space between words.',
          'warning'
        )
        setPlayFeedback('Player 2 cannot start until Player 1 makes a code.', 'warning')
        secretInput.focus()
        return
      }

      if (parsed.invalidNumber) {
        setSetupFeedback(`The number ${parsed.invalidNumber} does not work. Use only 1 to 33.`, 'warning')
        setPlayFeedback('Player 2 cannot start until Player 1 makes a code.', 'warning')
        secretInput.focus()
        return
      }

      state.secret = cleaned
      state.guessed.clear()
      state.active = true

      secretInput.value = ''
      updateLetterButtons()
      updateBlanks()
      setSetupFeedback('Code ready. Pass the screen to Player 2.', 'success')
      setPlayFeedback('Circle the letters that belong in the code.', 'neutral')
      codePanel?.scrollIntoView({behavior: 'smooth', block: 'start'})
    }

    startRoundButton?.addEventListener('click', startRound)

    newRoundButton?.addEventListener('click', () => {
      clearRound()
      setSetupFeedback('Round cleared. Player 1 can write a new secret.', 'neutral')
      setPlayFeedback('Start a round to let Player 2 begin guessing.', 'neutral')
      secretInput?.focus()
    })

    secretInput?.addEventListener('keydown', event => {
      if ((event.metaKey || event.ctrlKey) && event.key === 'Enter') {
        event.preventDefault()
        startRound()
      }
    })

    modeButtons.forEach(button => {
      button.addEventListener('click', () => {
        setMode(button.dataset.mode || defaultModeKey)
      })
    })

    letterButtons.forEach(button => {
      button.addEventListener('click', () => {
        if (!state.active) return

        const letter = button.dataset.letter || ''
        if (!letter || state.guessed.has(letter)) return

        state.guessed.add(letter)
        const isCorrect = state.secret.includes(letter)

        updateLetterButtons()
        updateBlanks()

        if (isCorrect) {
          if (finishRoundIfSolved()) return
          setPlayFeedback(`${letter} is in the secret. Keep circling the right letters.`, 'success')
          return
        }

        setPlayFeedback(`${letter} is not in the secret.`, 'danger')
      })
    })

    renderMode()
    updateStars()
    updateLetterButtons()
    updateBlanks()
  </script>
</Layout>

<style>
  :root {
    color-scheme: light;
    --paper: #efe3c3;
    --ink: #1c1c1b;
    --ink-soft: #65594b;
    --gold: #ba7a14;
    --forest: #335f4a;
    --berry: #872f37;
    --sky: #dceff4;
    --card: rgba(255, 251, 244, 0.88);
    --line: rgba(28, 28, 27, 0.14);
    --shadow: rgba(88, 57, 18, 0.15);
  }

  * {
    box-sizing: border-box;
  }

  :global(body) {
    margin: 0;
    color: var(--ink);
    font-family: 'Avenir Next', 'Gill Sans', 'Trebuchet MS', sans-serif;
    background:
      radial-gradient(circle at top left, rgba(255, 244, 214, 0.92), transparent 30%),
      radial-gradient(circle at top right, rgba(220, 239, 244, 0.92), transparent 34%),
      linear-gradient(180deg, #f2e8cf 0%, #e6d2a2 100%);
  }

  .daphne-page {
    width: min(1120px, calc(100% - 1.4rem));
    margin: 0 auto;
    padding: 1.2rem 0 5rem;
  }

  .hero,
  .panel {
    border: 2px solid var(--line);
    border-radius: 28px;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.84), rgba(255, 246, 227, 0.7)),
      var(--card);
    box-shadow: 0 18px 44px var(--shadow);
    backdrop-filter: blur(8px);
  }

  .hero {
    padding: 1.5rem;
    margin-bottom: 1rem;
  }

  .panel {
    padding: 1.2rem;
    margin-bottom: 1rem;
  }

  .eyebrow,
  .panel-kicker,
  .output-label,
  .status-label {
    margin: 0 0 0.45rem;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold);
  }

  h1,
  h2,
  p {
    margin-top: 0;
  }

  h1 {
    margin-bottom: 0.6rem;
    font-size: clamp(2.6rem, 6vw, 4.8rem);
    line-height: 0.92;
  }

  h2 {
    margin-bottom: 0.45rem;
    font-size: clamp(1.45rem, 3vw, 2rem);
    line-height: 1.02;
  }

  .lede,
  .feedback,
  .panel-note,
  .status-card p {
    font-size: 1rem;
    line-height: 1.55;
  }

  .hero-notes,
  .status-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.8rem;
    margin-top: 1rem;
  }

  .mode-toggle {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .mode-pill {
    border: 0;
    border-radius: 999px;
    padding: 0.85rem 1.1rem;
    font: inherit;
    font-weight: 800;
    color: var(--ink);
    background: rgba(255, 255, 255, 0.85);
    box-shadow: inset 0 0 0 2px rgba(28, 28, 27, 0.08);
    cursor: pointer;
    transition:
      transform 120ms ease,
      box-shadow 120ms ease,
      background 120ms ease,
      color 120ms ease;
  }

  .mode-pill.is-active {
    color: white;
    background: linear-gradient(135deg, var(--forest), #4c8a6e);
    box-shadow: 0 14px 24px rgba(51, 95, 74, 0.24);
  }

  .mode-note,
  .map-note {
    margin-bottom: 0;
    color: var(--ink-soft);
    font-weight: 700;
    line-height: 1.55;
  }

  .mode-note {
    margin-top: 0.85rem;
  }

  .hero-chip,
  .status-card,
  .code-box,
  .unlock-box,
  .key-card {
    border: 2px solid rgba(28, 28, 27, 0.08);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.76);
  }

  .hero-chip,
  .status-card,
  .unlock-box {
    padding: 1rem;
  }

  .hero-chip strong,
  .hero-chip span {
    display: block;
  }

  .hero-chip strong {
    margin-bottom: 0.35rem;
    font-size: 0.96rem;
  }

  .hero-chip span {
    font-weight: 800;
    color: var(--forest);
    word-break: break-word;
  }

  .panel-head {
    display: flex;
    gap: 0.8rem;
    align-items: start;
    justify-content: space-between;
    margin-bottom: 0.85rem;
  }

  .panel-note {
    max-width: 20rem;
    margin-bottom: 0;
    color: var(--ink-soft);
    font-weight: 700;
  }

  .field {
    display: grid;
    gap: 0.45rem;
    font-weight: 700;
  }

  .field span {
    font-size: 0.95rem;
  }

  .field textarea {
    width: 100%;
    min-height: 9.5rem;
    border: 2px solid rgba(28, 28, 27, 0.12);
    border-radius: 18px;
    padding: 0.95rem 1rem;
    font: inherit;
    color: var(--ink);
    background: rgba(255, 255, 255, 0.84);
    resize: vertical;
  }

  .field textarea:focus {
    outline: none;
    border-color: var(--gold);
    box-shadow: 0 0 0 4px rgba(186, 122, 20, 0.18);
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .primary-button,
  .secondary-button,
  .letter-button,
  .unlock-link {
    font: inherit;
    font-weight: 800;
  }

  .primary-button,
  .secondary-button {
    border: 0;
    border-radius: 999px;
    padding: 0.9rem 1.15rem;
    cursor: pointer;
    transition:
      transform 120ms ease,
      box-shadow 120ms ease;
  }

  .primary-button {
    color: white;
    background: linear-gradient(135deg, var(--gold), #d18a20);
    box-shadow: 0 14px 24px rgba(186, 122, 20, 0.24);
  }

  .secondary-button {
    color: var(--ink);
    background: rgba(255, 255, 255, 0.85);
    box-shadow: inset 0 0 0 2px rgba(28, 28, 27, 0.08);
  }

  .primary-button:hover,
  .secondary-button:hover,
  .mode-pill:hover,
  .unlock-link:hover {
    transform: translateY(-1px);
  }

  .feedback {
    min-height: 2.3rem;
    margin: 1rem 0 0;
    font-weight: 700;
  }

  .feedback[data-tone='success'] {
    color: #1d6b49;
  }

  .feedback[data-tone='warning'] {
    color: #8a5711;
  }

  .feedback[data-tone='danger'] {
    color: #9b2f28;
  }

  .code-box,
  .unlock-box {
    padding: 1rem;
  }

  .blank-output {
    min-height: 4rem;
    white-space: pre-wrap;
    word-break: break-word;
