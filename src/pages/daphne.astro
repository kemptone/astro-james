---
import Layout from '../layouts/Layout.astro'

const letters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('')
const reverseLetters = [...letters].reverse()
const vowelMirrorMap: Record<string, string> = {
  A: 'U',
  E: 'O',
  I: 'I',
  O: 'E',
  U: 'A',
}
const vowelMirrorLetters = letters.map(letter => vowelMirrorMap[letter] ?? letter)
const consonantLetters = 'BCDFGHJKLMNPQRSTVWXYZ'.split('')
const reverseConsonantLetters = [...consonantLetters].reverse()
const consonantMirrorMap = Object.fromEntries(
  consonantLetters.map((letter, index) => [letter, reverseConsonantLetters[index]])
)
const consonantMirrorLetters = letters.map(
  letter => consonantMirrorMap[letter] ?? letter
)

const storyModes = [
  {
    mode: 'normal',
    label: 'Normal Code',
    storyLabel: 'Normal story',
    placeholder: 'Write your story in normal text',
    letters,
  },
  {
    mode: 'backwords',
    label: 'Backwords Alphabet Code',
    storyLabel: 'Backwords alphabet story',
    placeholder: 'Write your story for backwords alphabet',
    letters: reverseLetters,
  },
  {
    mode: 'vowel-mirror',
    label: 'Backwords Vowels Code',
    storyLabel: 'Backwords vowels story',
    placeholder: 'Write your story for backwords vowels',
    letters: vowelMirrorLetters,
  },
  {
    mode: 'consonant-mirror',
    label: 'Backwords Consonants Code',
    storyLabel: 'Backwords consonants story',
    placeholder: 'Write your story for backwords consonants',
    letters: consonantMirrorLetters,
  },
] as const
---

<Layout title="Daphne">
  <main class="daphne-page">
    <section class="hero">
      <p class="eyebrow">Story Codes</p>
      <h1>Daphne</h1>
      <p class="lede">
        Pick <strong>1</strong> of the <strong>4</strong> story codes, write
        your story in that box, and press <strong>Submit Story</strong> to read
        it in that code.
      </p>
    </section>

    <section class="panel story-panel">
      <div class="panel-head">
        <div>
          <p class="panel-kicker">Story Maker</p>
          <h2>Pick one code at a time</h2>
        </div>
      </div>

      <div class="story-picker" role="radiogroup" aria-label="Story code picker">
        {
          storyModes.map(item => (
            <label class="story-picker-item">
              <input
                type="radio"
                name="story-mode"
                value={item.mode}
                data-story-mode={item.mode}
                checked={item.mode === 'normal'}
              />
              <span>{item.label}</span>
            </label>
          ))
        }
      </div>

      <div class="story-map-wrap">
        <p class="panel-kicker">Letter Map</p>
        {
          storyModes.map(item => (
            <div
              class="key-grid story-key-grid"
              data-story-key={item.mode}
              hidden={item.mode !== 'normal'}
            >
              {
                letters.map((letter, index) => (
                  <div class="key-card">
                    <strong>{letter}</strong>
                    <span>{item.letters[index]}</span>
                  </div>
                ))
              }
            </div>
          ))
        }
      </div>

      <div class="story-grid">
        {
          storyModes.map(item => (
            <label
              class:list={[
                'field',
                'story-field',
                item.mode === 'normal' ? '' : 'is-disabled',
              ]}
              data-story-field={item.mode}
            >
              <span>{item.storyLabel}</span>
              <textarea
                data-story-input={item.mode}
                rows="5"
                spellcheck="false"
                placeholder={item.placeholder}
                disabled={item.mode !== 'normal'}
              ></textarea>
            </label>
          ))
        }
      </div>

      <div class="button-row">
        <button id="submit-story" type="button" class="primary-button">
          Submit Story
        </button>
        <button id="start-hangman" type="button" class="secondary-button">
          Hangman
        </button>
        <button id="reset-story" type="button" class="secondary-button">
          Reset
        </button>
      </div>

      <div class="output-box read-box">
        <p class="output-label">Read Story</p>
        <div id="story-output" class="output-text" aria-live="polite"></div>
      </div>

      <p id="story-feedback" class="feedback" aria-live="polite">
        Pick a code, write your story, and press submit.
      </p>

      <section class="hangman-panel">
        <div class="panel-head hangman-head">
          <div>
            <p class="panel-kicker">Hangman</p>
            <h2>Guess the letters</h2>
          </div>
        </div>

        <div class="output-box hangman-box">
          <p class="output-label">Hidden Story</p>
          <div id="hangman-puzzle" class="output-text hangman-puzzle">
            Press Hangman to start guessing your selected story.
          </div>
        </div>

        <div id="hangman-letters" class="hangman-letters" aria-label="Guess letters">
          {
            letters.map(letter => (
              <button
                type="button"
                class="hangman-letter"
                data-hangman-letter={letter}
                disabled
              >
                {letter}
              </button>
            ))
          }
        </div>

        <p id="hangman-feedback" class="feedback" aria-live="polite">
          Pick a code and press Hangman to begin.
        </p>
      </section>
    </section>
  </main>

  <script>
    const alphabet = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'
    const reversedAlphabet = alphabet.split('').reverse().join('')
    const consonants = 'BCDFGHJKLMNPQRSTVWXYZ'
    const reversedConsonants = consonants.split('').reverse().join('')
    const vowelMirrorMap = {
      A: 'U',
      E: 'O',
      I: 'I',
      O: 'E',
      U: 'A',
    }
    const consonantMirrorMap = Object.fromEntries(
      consonants.split('').map((letter, index) => [letter, reversedConsonants[index]])
    )

    type StoryMode = 'normal' | 'backwords' | 'vowel-mirror' | 'consonant-mirror'

    type StoryModeConfig = {
      label: string
    }

    const storyModeConfig: Record<StoryMode, StoryModeConfig> = {
      normal: {label: 'Normal Code'},
      backwords: {label: 'Backwords Alphabet Code'},
      'vowel-mirror': {label: 'Backwords Vowels Code'},
      'consonant-mirror': {label: 'Backwords Consonants Code'},
    }

    const page = document.querySelector<HTMLElement>('.daphne-page')

    if (page) {
      const storyModeInputs = document.querySelectorAll<HTMLInputElement>(
        '[data-story-mode]'
      )
      const storyFields = document.querySelectorAll<HTMLElement>('[data-story-field]')
      const storyKeys = document.querySelectorAll<HTMLElement>('[data-story-key]')
      const storyInputs = document.querySelectorAll<HTMLTextAreaElement>(
        '[data-story-input]'
      )
      const submitStoryButton =
        document.querySelector<HTMLButtonElement>('#submit-story')!
      const startHangmanButton =
        document.querySelector<HTMLButtonElement>('#start-hangman')!
      const resetStoryButton =
        document.querySelector<HTMLButtonElement>('#reset-story')!
      const storyOutput = document.querySelector<HTMLElement>('#story-output')!
      const storyFeedback = document.querySelector<HTMLElement>('#story-feedback')!
      const hangmanPuzzle = document.querySelector<HTMLElement>('#hangman-puzzle')!
      const hangmanFeedback = document.querySelector<HTMLElement>('#hangman-feedback')!
      const hangmanLetterButtons = document.querySelectorAll<HTMLButtonElement>(
        '[data-hangman-letter]'
      )
      const hangmanState = {
        answer: '',
        guesses: new Set<string>(),
        active: false,
      }

      const flipAlphabetCharacter = (character: string) => {
        const upper = character.toUpperCase()
        const index = alphabet.indexOf(upper)

        if (index === -1) return character
        return reversedAlphabet[index]
      }

      const flipVowelCharacter = (character: string) => {
        const upper = character.toUpperCase()
        return vowelMirrorMap[upper] ?? upper
      }

      const flipConsonantCharacter = (character: string) => {
        const upper = character.toUpperCase()
        return consonantMirrorMap[upper] ?? upper
      }

      const encodeForMode = (mode: StoryMode, text: string) => {
        const upperText = text.toUpperCase()

        if (mode === 'normal') return upperText
        if (mode === 'backwords') {
          return upperText
            .split('')
            .map((character: string) => flipAlphabetCharacter(character))
            .join('')
        }
        if (mode === 'vowel-mirror') {
          return upperText
            .split('')
            .map((character: string) => flipVowelCharacter(character))
            .join('')
        }

        return upperText
          .split('')
          .map((character: string) => flipConsonantCharacter(character))
          .join('')
      }

      const getStoryMode = (): StoryMode => {
        const selected = document.querySelector<HTMLInputElement>(
          '[data-story-mode]:checked'
        )

        return (selected?.dataset.storyMode as StoryMode) || 'normal'
      }

      const setStoryMode = (mode: StoryMode) => {
        storyModeInputs.forEach(input => {
          const isActive = input.dataset.storyMode === mode
          input.checked = isActive
        })

        storyFields.forEach(field => {
          const isActive = field.dataset.storyField === mode
          field.classList.toggle('is-disabled', !isActive)

          const textarea = field.querySelector<HTMLTextAreaElement>('textarea')
          if (textarea) {
            textarea.disabled = !isActive
          }
        })

        storyKeys.forEach(key => {
          key.hidden = key.dataset.storyKey !== mode
        })
      }

      const submitStory = () => {
        const mode = getStoryMode()
        const textarea = document.querySelector<HTMLTextAreaElement>(
          `[data-story-input="${mode}"]`
        )
        const value = textarea?.value.trim() || ''

        if (!value) {
          storyOutput.textContent = ''
          storyFeedback.textContent = 'Write your story in the active box first.'
          storyFeedback.dataset.tone = 'warning'
          textarea?.focus()
          return
        }

        storyOutput.textContent = encodeForMode(mode, value)
        storyFeedback.textContent = `Reading your story in ${storyModeConfig[mode].label}.`
        storyFeedback.dataset.tone = 'success'
      }

      const buildHangmanPuzzle = () => {
        if (!hangmanState.answer) {
          return 'Press Hangman to start guessing your selected story.'
        }

        return hangmanState.answer
          .split('')
          .map(character => {
            if (character < 'A' || character > 'Z') {
              return character
            }

            return hangmanState.guesses.has(character) ? character : '_'
          })
          .join(' ')
      }

      const updateHangmanButtons = () => {
        hangmanLetterButtons.forEach(button => {
          const letter = button.dataset.hangmanLetter || ''
          const isGuessed = hangmanState.guesses.has(letter)
          const isCorrect =
            isGuessed && hangmanState.answer.includes(letter)
          const isWrong = isGuessed && !hangmanState.answer.includes(letter)

          button.hidden = isCorrect
          button.disabled = !hangmanState.active || isGuessed
          button.classList.toggle('is-wrong', isWrong)
        })
      }

      const updateHangmanPuzzle = () => {
        hangmanPuzzle.textContent = buildHangmanPuzzle()
      }

      const clearHangman = (message = 'Pick a code and press Hangman to begin.') => {
        hangmanState.answer = ''
        hangmanState.guesses.clear()
        hangmanState.active = false
        updateHangmanButtons()
        updateHangmanPuzzle()
        hangmanFeedback.textContent = message
        hangmanFeedback.dataset.tone = 'neutral'
      }

      const finishHangmanIfSolved = () => {
        const uniqueLetters = new Set(
          hangmanState.answer.split('').filter(character => character >= 'A' && character <= 'Z')
        )
        const solved = Array.from(uniqueLetters).every(letter =>
          hangmanState.guesses.has(letter)
        )

        if (!solved) return false

        hangmanState.active = false
        updateHangmanButtons()
        hangmanFeedback.textContent = 'You guessed every letter.'
        hangmanFeedback.dataset.tone = 'success'
        return true
      }

      const startHangman = () => {
        const mode = getStoryMode()
        const textarea = document.querySelector<HTMLTextAreaElement>(
          `[data-story-input="${mode}"]`
        )
        const value = textarea?.value.trim() || ''

        if (!value) {
          clearHangman('Write your story in the active box first.')
          hangmanFeedback.textContent = 'Write your story in the active box first.'
          hangmanFeedback.dataset.tone = 'warning'
          textarea?.focus()
          return
        }

        hangmanState.answer = encodeForMode(mode, value)
        hangmanState.guesses.clear()
        hangmanState.active = true
        updateHangmanButtons()
        updateHangmanPuzzle()
        hangmanFeedback.textContent = `Hangman is on for ${storyModeConfig[mode].label}.`
        hangmanFeedback.dataset.tone = 'neutral'
      }

      storyModeInputs.forEach(input => {
        input.addEventListener('change', () => {
          const nextMode = input.dataset.storyMode as StoryMode | undefined
          if (!nextMode) return

          setStoryMode(nextMode)
          storyOutput.textContent = ''
          storyFeedback.textContent = `Now using ${storyModeConfig[nextMode].label}.`
          storyFeedback.dataset.tone = 'neutral'
          clearHangman(
            `Pick Hangman when you want to guess ${storyModeConfig[nextMode].label}.`
          )

          const textarea = document.querySelector<HTMLTextAreaElement>(
            `[data-story-input="${nextMode}"]`
          )
          textarea?.focus()
        })
      })

      storyInputs.forEach(input => {
        input.addEventListener('keydown', (event: KeyboardEvent) => {
          if ((event.metaKey || event.ctrlKey) && event.key === 'Enter') {
            event.preventDefault()
            submitStory()
          }
        })
      })

      submitStoryButton.addEventListener('click', submitStory)
      startHangmanButton.addEventListener('click', startHangman)
      resetStoryButton.addEventListener('click', () => {
        storyInputs.forEach(input => {
          input.value = ''
        })

        storyOutput.textContent = ''
        storyFeedback.textContent = 'Everything is reset.'
        storyFeedback.dataset.tone = 'neutral'
        clearHangman('Everything is reset. Pick a code and press Hangman to begin.')

        const mode = getStoryMode()
        const textarea = document.querySelector<HTMLTextAreaElement>(
          `[data-story-input="${mode}"]`
        )
        textarea?.focus()
      })
      hangmanLetterButtons.forEach(button => {
        button.addEventListener('click', () => {
          if (!hangmanState.active) return

          const letter = button.dataset.hangmanLetter || ''
          if (!letter || hangmanState.guesses.has(letter)) return

          hangmanState.guesses.add(letter)
          const isCorrect = hangmanState.answer.includes(letter)

          updateHangmanButtons()
          updateHangmanPuzzle()

          if (isCorrect) {
            if (finishHangmanIfSolved()) return

            hangmanFeedback.textContent = `${letter} is in the story.`
            hangmanFeedback.dataset.tone = 'success'
            return
          }

          hangmanFeedback.textContent = `${letter} is not in the story.`
          hangmanFeedback.dataset.tone = 'danger'
        })
      })

      setStoryMode(getStoryMode())
      updateHangmanButtons()
      updateHangmanPuzzle()
    }
  </script>
</Layout>

<style>
  :root {
    color-scheme: light;
    --paper: #f7f0dc;
    --ink: #1e1b18;
    --ink-soft: #5f564b;
    --sun-deep: #c77711;
    --moss: #4b705e;
    --berry: #923d2f;
    --card: rgba(255, 251, 244, 0.82);
    --line: rgba(30, 27, 24, 0.14);
    --shadow: rgba(77, 48, 18, 0.16);
  }

  * {
    box-sizing: border-box;
  }

  :global(body) {
    margin: 0;
    color: var(--ink);
    font-family: 'Avenir Next', 'Gill Sans', 'Trebuchet MS', sans-serif;
    background:
      radial-gradient(circle at top left, rgba(255, 249, 224, 0.92), transparent 28%),
      radial-gradient(circle at top right, rgba(223, 242, 239, 0.8), transparent 30%),
      linear-gradient(180deg, #f5ead3 0%, #eadab2 42%, #dcc38f 100%);
  }

  .daphne-page {
    width: min(1120px, calc(100% - 1.4rem));
    margin: 0 auto;
    padding: 1.25rem 0 6rem;
  }

  .hero,
  .panel {
    border: 2px solid var(--line);
    border-radius: 28px;
    background:
      linear-gradient(140deg, rgba(255, 255, 255, 0.78), rgba(255, 247, 230, 0.55)),
      var(--card);
    box-shadow: 0 20px 48px var(--shadow);
    backdrop-filter: blur(8px);
  }

  .hero {
    padding: 1.5rem;
    margin-bottom: 1rem;
  }

  .panel {
    padding: 1.2rem;
  }

  .eyebrow,
  .panel-kicker,
  .output-label {
    margin: 0 0 0.45rem;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--sun-deep);
  }

  h1,
  h2,
  p {
    margin-top: 0;
  }

  h1 {
    margin-bottom: 0.6rem;
    font-size: clamp(2.4rem, 6vw, 4.6rem);
    line-height: 0.92;
  }

  h2 {
    margin-bottom: 0.45rem;
    font-size: clamp(1.45rem, 3vw, 2rem);
    line-height: 1.02;
  }

  .lede,
  .feedback {
    font-size: 1rem;
    line-height: 1.55;
  }

  .panel-head {
    display: flex;
    gap: 0.8rem;
    align-items: start;
    justify-content: space-between;
    margin-bottom: 0.8rem;
  }

  .story-picker {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
    margin-bottom: 1rem;
  }

  .story-picker-item {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.9rem 1rem;
    border: 2px solid rgba(30, 27, 24, 0.08);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.72);
    font-weight: 700;
    cursor: pointer;
  }

  .story-picker-item:has(input:checked) {
    border-color: rgba(146, 61, 47, 0.32);
    background: rgba(255, 245, 236, 0.96);
    box-shadow: 0 10px 20px rgba(146, 61, 47, 0.12);
  }

  .story-picker-item input {
    margin: 0;
  }

  .story-map-wrap {
    margin-bottom: 1rem;
  }

  .story-key-grid {
    margin-top: 0.6rem;
  }

  .story-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .field {
    display: grid;
    gap: 0.45rem;
    font-weight: 700;
  }

  .field span {
    font-size: 0.95rem;
  }

  .story-field.is-disabled {
    opacity: 0.48;
  }

  .field textarea {
    width: 100%;
    border: 2px solid rgba(30, 27, 24, 0.12);
    border-radius: 18px;
    padding: 0.9rem 1rem;
    font: inherit;
    color: var(--ink);
    background: rgba(255, 255, 255, 0.84);
    resize: vertical;
    min-height: 10rem;
  }

  .field textarea:focus {
    outline: none;
    border-color: var(--sun-deep);
    box-shadow: 0 0 0 4px rgba(241, 168, 59, 0.18);
  }

  .field textarea:disabled {
    cursor: not-allowed;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .primary-button,
  .secondary-button {
    border: 0;
    border-radius: 999px;
    padding: 0.9rem 1.15rem;
    font: inherit;
    font-weight: 800;
    cursor: pointer;
    transition:
      transform 120ms ease,
      box-shadow 120ms ease;
  }

  .primary-button {
    color: white;
    background: linear-gradient(135deg, var(--sun-deep), #da8b1f);
    box-shadow: 0 14px 24px rgba(199, 119, 17, 0.24);
  }

  .secondary-button {
    color: var(--ink);
    background: rgba(255, 255, 255, 0.82);
    box-shadow: inset 0 0 0 2px rgba(30, 27, 24, 0.08);
  }

  .primary-button:hover {
    transform: translateY(-1px);
  }

  .secondary-button:hover {
    transform: translateY(-1px);
  }

  .output-box,
  .key-card {
    border: 2px solid rgba(30, 27, 24, 0.08);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.72);
  }

  .output-box {
    padding: 1rem;
    margin-top: 1rem;
  }

  .output-text {
    min-height: 6rem;
    white-space: pre-wrap;
    word-break: break-word;
    font-size: 1.08rem;
    line-height: 1.55;
    font-weight: 800;
    letter-spacing: 0.06em;
    color: var(--berry);
  }

  .feedback {
    min-height: 2.3rem;
    margin: 1rem 0 0;
    font-weight: 700;
  }

  .feedback[data-tone='success'] {
    color: #1e6b45;
  }

  .feedback[data-tone='warning'] {
    color: #8a5711;
  }

  .feedback[data-tone='danger'] {
    color: #962f29;
  }

  .hangman-panel {
    margin-top: 1rem;
  }

  .hangman-head {
    margin-bottom: 0;
  }

  .hangman-box {
    margin-bottom: 1rem;
  }

  .hangman-puzzle {
    letter-spacing: 0.18em;
  }

  .hangman-letters {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(56px, 1fr));
    gap: 0.65rem;
  }

  .hangman-letter {
    position: relative;
    min-height: 3rem;
    border: 2px solid rgba(30, 27, 24, 0.1);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.82);
    color: var(--ink);
    font: inherit;
    font-weight: 800;
    cursor: pointer;
  }

  .hangman-letter:disabled {
    cursor: default;
  }

  .hangman-letter.is-wrong {
    color: #962f29;
    border-color: rgba(150, 47, 41, 0.35);
    background: rgba(255, 238, 238, 0.94);
  }

  .hangman-letter.is-wrong::after {
    content: 'X';
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-size: 1.35rem;
    font-weight: 900;
    color: #c12020;
    pointer-events: none;
  }

  .key-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(92px, 1fr));
    gap: 0.7rem;
  }

  .key-card {
    padding: 0.85rem 0.7rem;
    text-align: center;
  }

  .key-card strong,
  .key-card span {
    display: block;
  }

  .key-card strong {
    font-size: 1.25rem;
  }

  .key-card span {
    margin-top: 0.2rem;
    font-weight: 800;
    color: var(--moss);
  }

  @media (max-width: 920px) {
    .story-grid,
    .story-picker {
      grid-template-columns: 1fr;
    }

    .panel-head {
      flex-direction: column;
    }
  }

  @media (max-width: 640px) {
    .daphne-page {
      width: min(100%, calc(100% - 0.8rem));
      padding-top: 0.8rem;
    }

    .hero,
    .panel {
      border-radius: 22px;
      padding: 1rem;
    }

    .button-row {
      flex-direction: column;
    }

    .primary-button {
      width: 100%;
    }

    .secondary-button {
      width: 100%;
    }

    .key-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
