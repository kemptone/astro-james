---
import Menu from '@/components/menu.astro'

const CHROMATIC_SCALE = [
  'C',
  'C#',
  'D',
  'D#',
  'E',
  'F',
  'F#',
  'G',
  'G#',
  'A',
  'A#',
  'B',
]

function midiToNote(midi: number) {
  const pitchClass = CHROMATIC_SCALE[midi % 12]
  const octave = Math.floor(midi / 12) - 1
  return `${pitchClass}${octave}`
}

const noteRange = Array.from({length: 132 - 21 + 1}, (_, index) =>
  midiToNote(21 + index),
)

const octaveGroups = noteRange.reduce((groups, note) => {
  const octave = note.replace(/^[A-G]#?/, '')
  const existing = groups.get(octave) ?? []
  existing.push(note)
  groups.set(octave, existing)
  return groups
}, new Map<string, string[]>())

const groupedNotes = Array.from(octaveGroups.entries())

const starterSong = `A0 C1 E1 A1 C2 E2 A2 C3
C4:4n E4:8n G4:8n C5:2n R:8n G4:8n E4:8n C4:2n`
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Extra Special Piano</title>
    <style>
      @font-face {
        font-family: 'Short Stack';
        src: url('/Short_Stack/ShortStack-Regular.ttf') format('truetype');
        font-display: swap;
      }

      @font-face {
        font-family: 'Cooper Hewitt';
        src: url('/CooperHewitt-WebFonts-public/CooperHewitt-Book.woff')
          format('woff');
        font-display: swap;
      }

      :root {
        --paper: #f7f2e7;
        --ink: #15233f;
        --ink-soft: #38527d;
        --accent: #ff8f3f;
        --accent-deep: #de5f2f;
        --sky: #9ad3f5;
        --panel: rgba(255, 255, 255, 0.86);
        --panel-strong: rgba(255, 255, 255, 0.94);
        --shadow: 0 18px 50px rgba(24, 39, 70, 0.15);
        --line: rgba(21, 35, 63, 0.12);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: 'Cooper Hewitt', 'Trebuchet MS', sans-serif;
        color: var(--ink);
        background:
          radial-gradient(circle at top left, rgba(255, 219, 140, 0.75), transparent 30%),
          radial-gradient(circle at top right, rgba(122, 198, 255, 0.8), transparent 28%),
          linear-gradient(180deg, #fefaf3 0%, #edf5ff 52%, #f7f2e7 100%);
      }

      .page-shell {
        width: min(1180px, calc(100% - 24px));
        margin: 0 auto;
        padding: 18px 0 48px;
      }

      .hero {
        background: var(--panel);
        border: 1px solid rgba(255, 255, 255, 0.8);
        border-radius: 28px;
        box-shadow: var(--shadow);
        padding: 30px 24px 24px;
        backdrop-filter: blur(18px);
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 7px 12px;
        border-radius: 999px;
        background: rgba(255, 143, 63, 0.16);
        color: var(--accent-deep);
        font-size: 0.92rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      h1 {
        font-family: 'Short Stack', 'Cooper Hewitt', sans-serif;
        font-size: clamp(2.2rem, 6vw, 4.6rem);
        line-height: 1.02;
        margin: 16px 0 12px;
      }

      .hero p {
        font-size: 1.14rem;
        line-height: 1.55;
        max-width: 60ch;
        margin: 0;
        color: var(--ink-soft);
      }

      .stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 12px;
        margin-top: 24px;
      }

      .stat-card {
        background: var(--panel-strong);
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 16px;
      }

      .stat-label {
        display: block;
        font-size: 0.82rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--ink-soft);
      }

      .stat-value {
        display: block;
        font-family: 'Short Stack', 'Cooper Hewitt', sans-serif;
        font-size: 1.8rem;
        margin-top: 10px;
      }

      .workspace {
        display: grid;
        grid-template-columns: minmax(280px, 380px) minmax(0, 1fr);
        gap: 18px;
        margin-top: 20px;
      }

      .panel {
        background: var(--panel);
        border: 1px solid rgba(255, 255, 255, 0.8);
        border-radius: 24px;
        box-shadow: var(--shadow);
        padding: 20px;
        backdrop-filter: blur(18px);
      }

      .panel h2 {
        font-family: 'Short Stack', 'Cooper Hewitt', sans-serif;
        margin: 0 0 10px;
        font-size: 1.5rem;
      }

      .panel p,
      .panel li {
        color: var(--ink-soft);
      }

      .control-stack {
        display: grid;
        gap: 16px;
      }

      .control {
        display: grid;
        gap: 8px;
      }

      .control label,
      .toggle-row label,
      .input-header label {
        font-size: 0.92rem;
        font-weight: 700;
        letter-spacing: 0.03em;
        text-transform: uppercase;
      }

      .range-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }

      .range-value,
      .status {
        font-family: ui-monospace, 'SF Mono', Menlo, monospace;
      }

      input[type='range'] {
        width: 100%;
        accent-color: var(--accent);
      }

      select,
      textarea,
      button {
        font: inherit;
      }

      select,
      textarea {
        width: 100%;
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 14px 16px;
        background: rgba(255, 255, 255, 0.92);
        color: var(--ink);
      }

      textarea {
        min-height: 180px;
        resize: vertical;
        line-height: 1.5;
      }

      .toggle-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 14px 16px;
        background: rgba(255, 255, 255, 0.72);
      }

      .toggle-row input {
        width: 20px;
        height: 20px;
      }

      .button-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      button {
        border: none;
        border-radius: 999px;
        padding: 12px 18px;
        cursor: pointer;
        transition:
          transform 0.18s ease,
          box-shadow 0.18s ease,
          background 0.18s ease;
      }

      button:hover {
        transform: translateY(-1px);
        box-shadow: 0 10px 18px rgba(21, 35, 63, 0.12);
      }

      button:active {
        transform: translateY(0);
      }

      button:disabled {
        opacity: 0.55;
        cursor: not-allowed;
        transform: none;
        box-shadow: none;
      }

      .primary {
        background: linear-gradient(135deg, var(--accent), #ffb15f);
        color: #fffef8;
      }

      .secondary {
        background: rgba(21, 35, 63, 0.09);
        color: var(--ink);
      }

      .ghost {
        background: rgba(255, 255, 255, 0.75);
        color: var(--ink);
        border: 1px solid var(--line);
      }

      .status {
        margin-top: 14px;
        padding: 14px 16px;
        border-radius: 16px;
        background: rgba(21, 35, 63, 0.08);
        color: var(--ink);
      }

      .status.error {
        background: rgba(222, 95, 47, 0.15);
        color: #7d2608;
      }

      .helper {
        font-size: 0.94rem;
        line-height: 1.55;
        margin: 10px 0 0;
      }

      .piano-wall {
        display: grid;
        gap: 12px;
        max-height: 62vh;
        overflow: auto;
        padding-right: 6px;
      }

      .octave-band {
        border: 1px solid var(--line);
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.68);
        padding: 12px;
      }

      .octave-band h3 {
        margin: 0 0 10px;
        font-size: 1rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--ink-soft);
      }

      .key-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .key {
        min-width: 70px;
        border-radius: 14px;
        padding: 12px 10px;
        text-align: center;
        font-weight: 700;
        border: 1px solid transparent;
      }

      .key.is-white {
        background: linear-gradient(180deg, #fffdfa 0%, #ebe3d0 100%);
        color: #22334f;
        border-color: rgba(34, 51, 79, 0.12);
      }

      .key.is-black {
        background: linear-gradient(180deg, #2a3447 0%, #111722 100%);
        color: #fdf5e6;
        border-color: rgba(255, 255, 255, 0.1);
      }

      .key.active {
        background: linear-gradient(180deg, #ffcf59 0%, #ff8f3f 100%);
        color: #231405;
        border-color: rgba(35, 20, 5, 0.2);
      }

      .song-panel {
        display: grid;
        gap: 18px;
      }

      .input-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
      }

      .hint-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 12px;
      }

      .hint-card {
        background: rgba(255, 255, 255, 0.72);
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 14px;
      }

      .hint-card strong {
        display: block;
        margin-bottom: 6px;
      }

      @media (max-width: 900px) {
        .workspace {
          grid-template-columns: 1fr;
        }

        .page-shell {
          width: min(100%, calc(100% - 16px));
        }
      }

      @media (max-width: 640px) {
        .hero,
        .panel {
          border-radius: 20px;
          padding: 18px;
        }

        .stats {
          grid-template-columns: 1fr 1fr;
        }

        .key {
          min-width: calc(50% - 4px);
        }
      }
    </style>
  </head>
  <body>
    <Menu />
    <main class="page-shell">
      <section class="hero">
        <span class="eyebrow">Extra Special</span>
        <h1>The Whole Page Is a Piano Now</h1>
        <p>
          Tap notes from <strong>A0</strong> to <strong>C10</strong>, build a song,
          and play it back with your own volume, tempo, and note length settings.
          The volume ladder runs from <strong>0</strong> to <strong>500</strong>,
          and the top end is supposed to get ugly. Click notes to hear them
          instantly, or turn on compose mode to drop them right into the song box.
        </p>

        <div class="stats">
          <div class="stat-card">
            <span class="stat-label">Playable Range</span>
            <span class="stat-value">A0 to C10</span>
          </div>
          <div class="stat-card">
            <span class="stat-label">Total Notes</span>
            <span class="stat-value">{noteRange.length}</span>
          </div>
          <div class="stat-card">
            <span class="stat-label">Volume Scale</span>
            <span class="stat-value">0 to 500</span>
          </div>
          <div class="stat-card">
            <span class="stat-label">Song Input</span>
            <span class="stat-value">Notes + rests</span>
          </div>
        </div>
      </section>

      <section class="workspace">
        <aside class="panel">
          <h2>Controls</h2>
          <div class="control-stack">
            <div class="control">
              <div class="range-head">
                <label for="volumeControl">Volume</label>
                <span class="range-value" id="volumeValue">50 / 500</span>
              </div>
              <input
                id="volumeControl"
                type="range"
                min="0"
                max="500"
                value="50"
              />
              <p class="helper" id="volumeDescription">
                50 means you dance at this level. It's louder.
              </p>
            </div>

            <div class="control">
              <div class="range-head">
                <label for="tempoControl">Tempo</label>
                <span class="range-value" id="tempoValue">108 BPM</span>
              </div>
              <input
                id="tempoControl"
                type="range"
                min="40"
                max="220"
                value="108"
              />
            </div>

            <div class="control">
              <label for="durationControl">Default Note Length</label>
              <select id="durationControl">
                <option value="16n">16th note</option>
                <option value="8n" selected>8th note</option>
                <option value="4n">Quarter note</option>
                <option value="2n">Half note</option>
                <option value="1n">Whole note</option>
                <option value="8t">Triplet 8th</option>
              </select>
            </div>

            <div class="toggle-row">
              <label for="composeToggle">Add clicked notes to the song</label>
              <input id="composeToggle" type="checkbox" />
            </div>

            <div class="button-row">
              <button class="primary" id="playSong" type="button">Play Song</button>
              <button class="secondary" id="stopSong" type="button">Stop</button>
              <button class="ghost" id="loadDemoSong" type="button">Load Demo</button>
              <button class="ghost" id="clearSong" type="button">Clear</button>
            </div>
          </div>

          <div class="status" id="statusMessage">
            Tap any note or press Play Song to start audio.
          </div>

          <p class="helper">
            Song format: <code>C4 E4 G4 C5</code> or
            <code>C4:4n E4:8n G4:8n R:8n</code>. Use <code>R</code> or
            <code>rest</code> for silence.
          </p>
        </aside>

        <section class="song-panel">
          <div class="panel">
            <div class="input-header">
              <h2>Song Builder</h2>
              <label for="songInput">Write notes separated by spaces</label>
            </div>
            <textarea id="songInput" data-demo={starterSong}>{starterSong}</textarea>

            <div class="hint-grid">
              <article class="hint-card">
                <strong>Quick Example</strong>
                <span><code>A0 C1 E1 A1</code> climbs upward one note at a time.</span>
              </article>
              <article class="hint-card">
                <strong>Custom Lengths</strong>
                <span><code>C4:2n G4:4n C5:8n</code> mixes half, quarter, and eighth notes.</span>
              </article>
              <article class="hint-card">
                <strong>Space to Breathe</strong>
                <span><code>C4 R E4 rest:4n G4</code> adds pauses between notes.</span>
              </article>
            </div>
          </div>

          <div class="panel">
            <h2>Play Every Note</h2>
            <p class="helper">
              The full range lives here. Sharp notes are dark keys, natural notes are
              light keys, and any active key flashes gold when it plays.
            </p>

            <div class="piano-wall">
              {groupedNotes.map(([octave, notes]) => (
                <section class="octave-band">
                  <h3>Octave {octave}</h3>
                  <div class="key-row">
                    {notes.map((note) => (
                      <button
                        type="button"
                        class={`key ${note.includes('#') ? 'is-black' : 'is-white'}`}
                        data-note={note}
                      >
                        {note}
                      </button>
                    ))}
                  </div>
                </section>
              ))}
            </div>
          </div>
        </section>
      </section>
    </main>

    <script>
      import * as Tone from 'tone'

      const MIN_MIDI = 21
      const MAX_MIDI = 132
      const PITCH_CLASSES = [
        'C',
        'C#',
        'D',
        'D#',
        'E',
        'F',
        'F#',
        'G',
        'G#',
        'A',
        'A#',
        'B',
      ]
      const NATURAL_PITCHES = {
        C: 0,
        D: 2,
        E: 4,
        F: 5,
        G: 7,
        A: 9,
        B: 11,
      }
      const DURATION_BEATS = {
        '1n': 4,
        '2n': 2,
        '4n': 1,
        '8n': 0.5,
        '16n': 0.25,
        '32n': 0.125,
        '8t': 1 / 3,
      }

      const volumeControl = document.getElementById('volumeControl')
      const volumeValue = document.getElementById('volumeValue')
      const volumeDescription = document.getElementById('volumeDescription')
      const tempoControl = document.getElementById('tempoControl')
      const tempoValue = document.getElementById('tempoValue')
      const durationControl = document.getElementById('durationControl')
      const composeToggle = document.getElementById('composeToggle')
      const songInput = document.getElementById('songInput')
      const playSongButton = document.getElementById('playSong')
      const stopSongButton = document.getElementById('stopSong')
      const clearSongButton = document.getElementById('clearSong')
      const loadDemoSongButton = document.getElementById('loadDemoSong')
      const statusMessage = document.getElementById('statusMessage')
      const keyButtons = Array.from(document.querySelectorAll('[data-note]'))

      let synth = null
      let outputGain = null
      let toneFilter = null
      let distortionEffect = null
      let bitCrusher = null
      let limiter = null
      let playbackToken = 0

      function clamp(value, min, max) {
        return Math.min(Math.max(value, min), max)
      }

      function lerp(start, end, amount) {
        return start + (end - start) * amount
      }

      function midiToNote(midi) {
        const pitchClass = PITCH_CLASSES[midi % 12]
        const octave = Math.floor(midi / 12) - 1
        return `${pitchClass}${octave}`
      }

      function getVolumeProfile(rawValue) {
        const value = clamp(Number(rawValue), 0, 500)

        if (value === 0) {
          return {
            gain: 0,
            distortion: 0,
            distortionWet: 0,
            crusherBits: 12,
            crusherWet: 0,
            filterFrequency: 2600,
            shortLabel: 'silent',
            description: "0 isn't anything.",
          }
        }

        if (value <= 10) {
          const mix = value / 10
          return {
            gain: lerp(0.015, 0.08, mix),
            distortion: 0,
            distortionWet: 0,
            crusherBits: 12,
            crusherWet: 0,
            filterFrequency: 2600,
            shortLabel: '3:00 AM quiet',
            description: '10 or under is expected at 3:00 AM.',
          }
        }

        if (value < 50) {
          const mix = (value - 10) / 40
          return {
            gain: lerp(0.08, 0.32, mix),
            distortion: lerp(0, 0.02, mix),
            distortionWet: lerp(0, 0.03, mix),
            crusherBits: 12,
            crusherWet: 0,
            filterFrequency: 2600,
            shortLabel: 'warming up',
            description: 'Still climbing from quiet toward dance level.',
          }
        }

        if (value < 100) {
          const mix = (value - 50) / 50
          return {
            gain: lerp(0.32, 0.52, mix),
            distortion: lerp(0.02, 0.08, mix),
            distortionWet: lerp(0.03, 0.08, mix),
            crusherBits: 12,
            crusherWet: 0,
            filterFrequency: lerp(2600, 2450, mix),
            shortLabel: 'dance level',
            description: "50 means you dance at this level. It's louder.",
          }
        }

        if (value < 200) {
          const mix = (value - 100) / 100
          return {
            gain: lerp(0.52, 0.66, mix),
            distortion: lerp(0.08, 0.22, mix),
            distortionWet: lerp(0.08, 0.18, mix),
            crusherBits: lerp(12, 10, mix),
            crusherWet: lerp(0, 0.08, mix),
            filterFrequency: lerp(2450, 2100, mix),
            shortLabel: 'REALLY loud',
            description: "100 means it's REALLY loud, where you can REALLY dance.",
          }
        }

        if (value < 300) {
          const mix = (value - 200) / 100
          return {
            gain: lerp(0.66, 0.74, mix),
            distortion: lerp(0.22, 0.48, mix),
            distortionWet: lerp(0.18, 0.42, mix),
            crusherBits: lerp(10, 6, mix),
            crusherWet: lerp(0.08, 0.26, mix),
            filterFrequency: lerp(2100, 1650, mix),
            shortLabel: 'a little ruined',
            description: "200 sounds a little ruined because it's so loud.",
          }
        }

        if (value < 400) {
          const mix = (value - 300) / 100
          return {
            gain: lerp(0.74, 0.8, mix),
            distortion: lerp(0.48, 0.72, mix),
            distortionWet: lerp(0.42, 0.66, mix),
            crusherBits: lerp(6, 4, mix),
            crusherWet: lerp(0.26, 0.5, mix),
            filterFrequency: lerp(1650, 1100, mix),
            shortLabel: 'really ruined',
            description:
              '300 is really ruined. You can hear the piano, but not much else.',
          }
        }

        if (value < 499) {
          const mix = (value - 400) / 99
          return {
            gain: lerp(0.8, 0.85, mix),
            distortion: lerp(0.72, 0.92, mix),
            distortionWet: lerp(0.66, 0.9, mix),
            crusherBits: lerp(4, 2, mix),
            crusherWet: lerp(0.5, 0.82, mix),
            filterFrequency: lerp(1100, 680, mix),
            shortLabel: 'ugly and awful',
            description:
              "400 sounds ugly and awful and might hurt people's ears.",
          }
        }

        if (value < 500) {
          return {
            gain: 0.85,
            distortion: 0.96,
            distortionWet: 0.95,
            crusherBits: 2,
            crusherWet: 0.9,
            filterFrequency: 620,
            shortLabel: 'not music',
            description:
              '499 is still not music, but there is a tiny bit of piano.',
          }
        }

        return {
          gain: 0.88,
          distortion: 1,
          distortionWet: 1,
          crusherBits: 1,
          crusherWet: 1,
          filterFrequency: 520,
          shortLabel: 'crumbly and loud',
          description: '500 is NOT music. It sounds really crumbly and loud.',
        }
      }

      function setStatus(message, isError = false) {
        statusMessage.textContent = message
        statusMessage.classList.toggle('error', isError)
      }

      function setPlaybackState(playing) {
        playSongButton.disabled = playing
        stopSongButton.disabled = !playing
      }

      function updateDisplays() {
        const profile = getVolumeProfile(volumeControl.value)
        volumeValue.textContent = `${volumeControl.value} / 500`
        volumeDescription.textContent = profile.description
        tempoValue.textContent = `${tempoControl.value} BPM`
      }

      function applyVolume() {
        if (!outputGain || !toneFilter || !distortionEffect || !bitCrusher) return

        const profile = getVolumeProfile(volumeControl.value)

        outputGain.gain.rampTo(profile.gain, 0.05)
        toneFilter.frequency.rampTo(profile.filterFrequency, 0.05)
        distortionEffect.distortion = profile.distortion
        distortionEffect.wet.rampTo(profile.distortionWet, 0.05)
        bitCrusher.bits.rampTo(profile.crusherBits, 0.05)
        bitCrusher.wet.rampTo(profile.crusherWet, 0.05)
      }

      async function ensureAudio() {
        await Tone.start()

        if (!outputGain) {
          outputGain = new Tone.Gain(0)
          bitCrusher = new Tone.BitCrusher({
            bits: 12,
            wet: 0,
          })
          distortionEffect = new Tone.Distortion({
            distortion: 0,
            wet: 0,
          })
          toneFilter = new Tone.Filter({
            type: 'lowpass',
            frequency: 2600,
            rolloff: -24,
          })
          limiter = new Tone.Limiter(-8).toDestination()

          bitCrusher.connect(distortionEffect)
          distortionEffect.connect(toneFilter)
          toneFilter.connect(outputGain)
          outputGain.connect(limiter)

          synth = new Tone.PolySynth(Tone.Synth, {
            oscillator: {
              type: 'triangle',
            },
            envelope: {
              attack: 0.01,
              decay: 0.24,
              sustain: 0.18,
              release: 1.4,
            },
          }).connect(bitCrusher)
        }

        applyVolume()
      }

      function flashKey(note, durationMs = 220) {
        const key = document.querySelector(`[data-note="${note}"]`)
        if (!key) return
        key.classList.add('active')
        window.setTimeout(() => key.classList.remove('active'), Math.max(150, durationMs * 0.85))
      }

      function getDurationBeats(durationToken) {
        return DURATION_BEATS[durationToken] ?? null
      }

      function durationToMilliseconds(durationToken) {
        const beats = getDurationBeats(durationToken)
        const bpm = Number(tempoControl.value)
        return (beats * 60000) / bpm
      }

      function normalizeNoteToken(rawToken) {
        const token = rawToken.trim()
        const match = token.match(/^([A-Ga-g])([#b]?)(-?\d{1,2})$/)

        if (!match) return null

        const [, rawLetter, accidental = '', octaveValue] = match
        let pitch = NATURAL_PITCHES[rawLetter.toUpperCase()]
        let octave = Number(octaveValue)

        if (accidental === '#') pitch += 1
        if (accidental === 'b') pitch -= 1

        if (pitch < 0) {
          pitch += 12
          octave -= 1
        } else if (pitch > 11) {
          pitch -= 12
          octave += 1
        }

        const midi = (octave + 1) * 12 + pitch
        if (midi < MIN_MIDI || midi > MAX_MIDI) return null

        return midiToNote(midi)
      }

      function parseSong(text) {
        const tokens = text
          .replaceAll('|', ' ')
          .replaceAll('\n', ' ')
          .split(/[\s,]+/)
          .map(token => token.trim())
          .filter(Boolean)

        if (!tokens.length) {
          throw new Error('Add a few notes before pressing Play Song.')
        }

        return tokens.map(token => {
          const [noteToken, durationToken, extraToken] = token.split(':')

          if (extraToken) {
            throw new Error(`"${token}" has too many ":" separators.`)
          }

          const resolvedDuration = durationToken || durationControl.value
          if (!getDurationBeats(resolvedDuration)) {
            throw new Error(
              `"${resolvedDuration}" is not supported. Try 16n, 8n, 4n, 2n, 1n, or 8t.`,
            )
          }

          if (/^(r|rest)$/i.test(noteToken)) {
            return {
              note: null,
              duration: resolvedDuration,
            }
          }

          const normalizedNote = normalizeNoteToken(noteToken)
          if (!normalizedNote) {
            throw new Error(
              `"${noteToken}" is outside the playable range A0 to C10.`,
            )
          }

          return {
            note: normalizedNote,
            duration: resolvedDuration,
          }
        })
      }

      function stopPlayback(showMessage = true) {
        playbackToken += 1
        if (synth) synth.releaseAll()
        setPlaybackState(false)
        if (showMessage) setStatus('Playback stopped.')
      }

      function appendTokenToSong(token) {
        const current = songInput.value.trim()
        songInput.value = current ? `${current} ${token}` : token
      }

      async function playSingleNote(note) {
        await ensureAudio()
        const durationToken = durationControl.value
        const durationMs = durationToMilliseconds(durationToken)
        const profile = getVolumeProfile(volumeControl.value)
        synth.triggerAttackRelease(note, durationMs / 1000)
        flashKey(note, durationMs)
        setStatus(
          `Played ${note} at ${volumeControl.value} / 500 (${profile.shortLabel}).`,
        )
      }

      async function playSongFromInput() {
        let songEvents

        try {
          songEvents = parseSong(songInput.value)
        } catch (error) {
          setStatus(error.message, true)
          return
        }

        await ensureAudio()
        stopPlayback(false)

        const currentPlayback = playbackToken
        setPlaybackState(true)
        setStatus(`Playing ${songEvents.length} step${songEvents.length === 1 ? '' : 's'} at ${tempoControl.value} BPM.`)

        for (let index = 0; index < songEvents.length; index += 1) {
          if (currentPlayback !== playbackToken) return

          const event = songEvents[index]
          const durationMs = durationToMilliseconds(event.duration)

          if (event.note) {
            synth.triggerAttackRelease(event.note, durationMs / 1000)
            flashKey(event.note, durationMs)
            setStatus(
              `Playing ${event.note} (${index + 1}/${songEvents.length}) at ${tempoControl.value} BPM.`,
            )
          } else {
            setStatus(
              `Rest (${index + 1}/${songEvents.length}) at ${tempoControl.value} BPM.`,
            )
          }

          await new Promise(resolve => window.setTimeout(resolve, durationMs))
        }

        setPlaybackState(false)
        setStatus(`Finished ${songEvents.length} step${songEvents.length === 1 ? '' : 's'}.`)
      }

      updateDisplays()
      setPlaybackState(false)

      volumeControl.addEventListener('input', () => {
        updateDisplays()
        applyVolume()
      })

      tempoControl.addEventListener('input', updateDisplays)

      playSongButton.addEventListener('click', () => {
        playSongFromInput().catch(error => {
          setPlaybackState(false)
          setStatus(error.message || 'The song could not be played.', true)
        })
      })

      stopSongButton.addEventListener('click', () => stopPlayback(true))

      clearSongButton.addEventListener('click', () => {
        songInput.value = ''
        setStatus('Song cleared. Tap notes to build a new one.')
      })

      loadDemoSongButton.addEventListener('click', () => {
        songInput.value = songInput.dataset.demo || ''
        setStatus('Demo song loaded.')
      })

      keyButtons.forEach(button => {
        button.addEventListener('click', async () => {
          const note = button.dataset.note
          if (!note) return

          if (composeToggle.checked) {
            const durationToken = durationControl.value
            appendTokenToSong(`${note}:${durationToken}`)
          }

          try {
            await playSingleNote(note)
          } catch (error) {
            setStatus(error.message || 'That note could not be played.', true)
          }
        })
      })
    </script>
  </body>
</html>
