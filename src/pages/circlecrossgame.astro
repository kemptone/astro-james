---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Circle Cross Game">
  <main class="choice-arcade">
    <section class="hero-card">
      <p class="eyebrow">Three Versions</p>
      <h1>Circle or Cross Out Game</h1>
      <p class="hero-copy">
        Version 1 lets you keep adding words, then tap each one after Submit to
        reveal the result you picked. Version 2 turns your typed text into
        backwards-alphabet letters, one second at a time. Version 3 walks
        through all 33 Russian letters one at a time with Circle or Cross out
        choices.
      </p>

      <div class="version-switch" role="tablist" aria-label="Game versions">
        <button type="button" class="version-pill is-active" data-version="1" aria-selected="true">
          Version 1
        </button>
        <button type="button" class="version-pill" data-version="2" aria-selected="false">
          Version 2
        </button>
        <button type="button" class="version-pill" data-version="3" aria-selected="false">
          Version 3
        </button>
      </div>
    </section>

    <section class="game-panel is-active" data-panel="1">
      <div class="panel-grid">
        <article class="panel-card">
          <p class="panel-tag">Setup</p>
          <h2>Build your word list</h2>
          <p class="panel-note">
            Pick <strong>Circle</strong> or <strong>Cross out</strong> for each
            text. The game reveals that same choice when you press the word later.
          </p>

          <div id="v1-builder" class="stack">
            <label class="field">
              <span>Text</span>
              <input id="v1-text" type="text" placeholder="Type a word or short phrase" maxlength="80" />
            </label>

            <label class="field">
              <span>Choice</span>
              <select id="v1-choice">
                <option value="circle">Circle</option>
                <option value="cross">Cross out</option>
              </select>
            </label>

            <div class="button-row">
              <button type="button" class="primary-button" id="v1-add">Add text</button>
              <button type="button" class="ghost-button" id="v1-clear">Clear list</button>
            </div>
          </div>
        </article>

        <article class="panel-card">
          <p class="panel-tag">Queue</p>
          <div class="panel-header">
            <h2>Saved texts</h2>
            <span id="v1-count" class="count-badge">0 items</span>
          </div>
          <div id="v1-list" class="saved-list" aria-live="polite">
            <p class="empty-state">Add a text to start the game.</p>
          </div>
          <div class="button-row">
            <button type="button" class="primary-button" id="v1-submit">Submit</button>
            <button type="button" class="ghost-button" id="v1-back" hidden>Back to setup</button>
          </div>
        </article>
      </div>

      <article id="v1-play-wrap" class="panel-card play-card" hidden>
        <div class="panel-header">
          <div>
            <p class="panel-tag">Play</p>
            <h2>Tap each text</h2>
          </div>
          <span class="count-badge inverse-badge">Reveal mode</span>
        </div>
        <p class="panel-note">
          If you picked circle, this word gets circled. If you picked cross
          out, this word gets crossed out.
        </p>
        <div id="v1-play-board" class="play-board" aria-live="polite"></div>
      </article>
    </section>

    <section class="game-panel" data-panel="2">
      <div class="panel-grid single-panel">
        <article class="panel-card">
          <p class="panel-tag">Backwards Alphabet</p>
          <h2>Backwards letters, one second apart</h2>
          <p class="panel-note">
            Your typed text gets converted with the backwards alphabet. Spaces
            stay exactly where you typed them, and each converted character
            appears one second after the other.
          </p>

          <div class="stack">
            <label class="field">
              <span>Your choice</span>
              <input id="v2-input" type="text" placeholder="Type characters here" />
            </label>

            <div class="button-row">
              <button type="button" class="primary-button" id="v2-start">Start typing</button>
              <button type="button" class="ghost-button" id="v2-reset">Reset</button>
            </div>
          </div>

          <div class="output-shell">
            <div id="v2-output" class="letter-output" aria-live="polite"></div>
          </div>
        </article>
      </div>
    </section>

    <section class="game-panel" data-panel="3">
      <div class="panel-grid">
        <article class="panel-card">
          <p class="panel-tag">Russian Alphabet</p>
          <h2>Set all 33 letters</h2>
          <p class="panel-note">
            This mode goes in order from Russian letter 1 to 33. The choices are
            opposite here: if you pick <strong>Cross out</strong>, that letter is
            treated like an actual circle letter later.
          </p>

          <div class="russian-step-shell">
            <span id="v3-progress" class="count-badge">Letter 1 of 33</span>

            <div class="russian-letter-stage" aria-live="polite">
              <span id="v3-current-letter" class="russian-letter">А</span>
              <span id="v3-current-number" class="russian-letter-number">Russian letter 1</span>
            </div>
          </div>

          <label class="field">
            <span>Option for this letter</span>
            <select id="v3-choice">
              <option value="circle">Circle</option>
              <option value="cross">Cross out</option>
            </select>
          </label>

          <p id="v3-status" class="panel-note">
            Pick one option, then press Next to move to the next Russian letter.
            Press any saved letter below to see the real circle or cross result.
          </p>

          <div class="button-row">
            <button type="button" class="ghost-button" id="v3-prev">Previous</button>
            <button type="button" class="primary-button" id="v3-next">Save and next</button>
            <button type="button" class="ghost-button" id="v3-reset">Reset all 33</button>
          </div>
        </article>

        <article class="panel-card">
          <div class="panel-header">
            <div>
              <p class="panel-tag">Collected</p>
              <h2>Cross out picks</h2>
            </div>
            <span id="v3-count" class="count-badge">0 / 33 saved</span>
          </div>
          <p class="panel-note">
            Because the options are opposite in this version, every letter saved
            as <strong>Cross out</strong> becomes a real circle later. If the
            real result is a cross, you lose the game.
          </p>

          <div class="output-shell russian-output-shell">
            <p class="output-label">Press a saved letter below</p>
            <div id="v3-result" class="collected-output" aria-live="polite">No letter pressed yet.</div>
            <p id="v3-result-note" class="russian-result-note">
              Safe letters are the ones you saved as <strong>Cross out</strong>.
            </p>
          </div>

          <p id="v3-collected" class="russian-safe-list">Safe letters: None yet.</p>

          <div id="v3-summary" class="saved-list russian-summary" aria-live="polite"></div>
        </article>
      </div>
    </section>
  </main>

  <script is:inline>
    const versionButtons = Array.from(document.querySelectorAll('.version-pill'));
    const panels = Array.from(document.querySelectorAll('.game-panel'));

    const v1Text = document.querySelector('#v1-text');
    const v1Choice = document.querySelector('#v1-choice');
    const v1Add = document.querySelector('#v1-add');
    const v1Clear = document.querySelector('#v1-clear');
    const v1Submit = document.querySelector('#v1-submit');
    const v1Back = document.querySelector('#v1-back');
    const v1List = document.querySelector('#v1-list');
    const v1Count = document.querySelector('#v1-count');
    const v1PlayWrap = document.querySelector('#v1-play-wrap');
    const v1PlayBoard = document.querySelector('#v1-play-board');
    const v1Builder = document.querySelector('#v1-builder');

    const v2Input = document.querySelector('#v2-input');
    const v2Start = document.querySelector('#v2-start');
    const v2Reset = document.querySelector('#v2-reset');
    const v2Output = document.querySelector('#v2-output');
    const v3Progress = document.querySelector('#v3-progress');
    const v3CurrentLetter = document.querySelector('#v3-current-letter');
    const v3CurrentNumber = document.querySelector('#v3-current-number');
    const v3Choice = document.querySelector('#v3-choice');
    const v3Status = document.querySelector('#v3-status');
    const v3Prev = document.querySelector('#v3-prev');
    const v3Next = document.querySelector('#v3-next');
    const v3Reset = document.querySelector('#v3-reset');
    const v3Count = document.querySelector('#v3-count');
    const v3Result = document.querySelector('#v3-result');
    const v3ResultNote = document.querySelector('#v3-result-note');
    const v3Collected = document.querySelector('#v3-collected');
    const v3Summary = document.querySelector('#v3-summary');

    const alphabet = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
    const reversedAlphabet = alphabet.split('').reverse().join('');
    const russianAlphabet = [
      'А',
      'Б',
      'В',
      'Г',
      'Д',
      'Е',
      'Ё',
      'Ж',
      'З',
      'И',
      'Й',
      'К',
      'Л',
      'М',
      'Н',
      'О',
      'П',
      'Р',
      'С',
      'Т',
      'У',
      'Ф',
      'Х',
      'Ц',
      'Ч',
      'Ш',
      'Щ',
      'Ъ',
      'Ы',
      'Ь',
      'Э',
      'Ю',
      'Я',
    ];
    const v1Entries = [];
    const v3Entries = russianAlphabet.map((letter, index) => ({
      letter,
      number: index + 1,
      choice: null,
    }));
    let v2Timers = [];
    let v3CurrentIndex = 0;
    let v3PressedIndex = null;

    const pluralize = (count, singular, plural) => `${count} ${count === 1 ? singular : plural}`;
    const formatChoice = choice =>
      choice === 'circle' ? 'Circle' : choice === 'cross' ? 'Cross out' : 'Not set yet';
    const getVersion3ActualResult = choice =>
      choice === 'cross' ? 'circle' : choice === 'circle' ? 'cross' : null;
    const stopVersion2 = () => {
      v2Timers.forEach(timerId => window.clearTimeout(timerId));
      v2Timers = [];
      v2Start.disabled = false;
    };

    const setActiveVersion = version => {
      versionButtons.forEach(button => {
        const isActive = button.dataset.version === version;
        button.classList.toggle('is-active', isActive);
        button.setAttribute('aria-selected', String(isActive));
      });

      panels.forEach(panel => {
        panel.classList.toggle('is-active', panel.dataset.panel === version);
      });

      if (version !== '2') stopVersion2();
    };

    const saveVersion3Choice = () => {
      v3Entries[v3CurrentIndex].choice = v3Choice.value;
    };

    const renderVersion3 = () => {
      const currentEntry = v3Entries[v3CurrentIndex];
      const savedCount = v3Entries.filter(entry => entry.choice).length;
      const collectedLetters = v3Entries
        .filter(entry => entry.choice === 'cross')
        .map(entry => entry.letter);
      const pressedEntry = v3PressedIndex === null ? null : v3Entries[v3PressedIndex];
      const pressedResult = pressedEntry ? getVersion3ActualResult(pressedEntry.choice) : null;

      v3Progress.textContent = `Letter ${currentEntry.number} of ${v3Entries.length}`;
      v3CurrentLetter.textContent = currentEntry.letter;
      v3CurrentNumber.textContent = `Russian letter ${currentEntry.number}`;
      v3Choice.value = currentEntry.choice ?? 'circle';
      v3Count.textContent = `${savedCount} / ${v3Entries.length} saved`;
      v3Prev.disabled = v3CurrentIndex === 0;
      v3Next.textContent =
        v3CurrentIndex === v3Entries.length - 1 ? 'Save letter 33' : 'Save and next';

      if (currentEntry.choice) {
        v3Status.innerHTML = `Saved for <strong>${currentEntry.letter}</strong>: ${formatChoice(currentEntry.choice)}.`;
      } else {
        v3Status.textContent = 'Pick one option, then press Next to move to the next Russian letter.';
      }

      if (!pressedEntry) {
        v3Result.textContent = 'No letter pressed yet.';
        v3Result.dataset.tone = 'neutral';
        v3ResultNote.innerHTML =
          'Safe letters are the ones you saved as <strong>Cross out</strong>.';
      } else if (!pressedEntry.choice) {
        v3Result.textContent = `${pressedEntry.letter} is not set yet.`;
        v3Result.dataset.tone = 'neutral';
        v3ResultNote.textContent = 'Pick Circle or Cross out for this letter first.';
      } else if (pressedResult === 'circle') {
        v3Result.textContent = `${pressedEntry.letter} is really circled.`;
        v3Result.dataset.tone = 'success';
        v3ResultNote.textContent = 'This one is safe.';
      } else {
        v3Result.textContent = `${pressedEntry.letter} is really crossed out. You lose.`;
        v3Result.dataset.tone = 'danger';
        v3ResultNote.textContent = 'A real cross means the game is over.';
      }

      v3Collected.textContent = collectedLetters.length
        ? `Safe letters: ${collectedLetters.join(' ')}`
        : 'Safe letters: None yet.';
      v3Summary.innerHTML = '';

      v3Entries.forEach((entry, index) => {
        const actualResult = getVersion3ActualResult(entry.choice);
        const item = document.createElement('button');
        item.type = 'button';
        item.className = 'saved-item summary-item';
        item.classList.toggle('is-current', index === v3CurrentIndex);
        item.classList.toggle('is-pressed', index === v3PressedIndex);
        item.classList.toggle('is-real-circle', actualResult === 'circle');
        item.classList.toggle('is-real-cross', actualResult === 'cross');
        item.setAttribute(
          'aria-label',
          `${entry.letter}. ${entry.choice
            ? `${formatChoice(entry.choice)}${entry.choice === 'cross' ? ', actually circled' : ', actually crossed out'}`
            : 'Not set yet'}`
        );

        const title = document.createElement('strong');
        title.className = 'summary-letter';
        title.textContent = entry.letter;
        item.appendChild(title);

        item.addEventListener('click', () => {
          saveVersion3Choice();
          v3CurrentIndex = index;
          v3PressedIndex = index;
          renderVersion3();
        });

        v3Summary.appendChild(item);
      });
    };

    const renderVersion1Count = () => {
      v1Count.textContent = pluralize(v1Entries.length, 'item', 'items');
    };

    const renderVersion1List = () => {
      renderVersion1Count();

      if (!v1Entries.length) {
        v1List.innerHTML = '<p class="empty-state">Add a text to start the game.</p>';
        return;
      }

      v1List.innerHTML = '';

      v1Entries.forEach((entry, index) => {
        const item = document.createElement('div');
        item.className = 'saved-item';

        const textWrap = document.createElement('div');
        textWrap.className = 'saved-copy';

        const title = document.createElement('strong');
        title.textContent = entry.text;

        const sub = document.createElement('span');
        sub.textContent = `Choice ${index + 1}: ${entry.choice === 'circle' ? 'Circle' : 'Cross out'}`;

        textWrap.append(title, sub);

        const removeButton = document.createElement('button');
        removeButton.type = 'button';
        removeButton.className = 'mini-button';
        removeButton.textContent = 'Remove';
        removeButton.hidden = v1Builder.hidden;
        removeButton.addEventListener('click', () => {
          const entryIndex = v1Entries.findIndex(itemEntry => itemEntry.id === entry.id);
          if (entryIndex >= 0) {
            v1Entries.splice(entryIndex, 1);
            renderVersion1List();
          }
        });

        item.append(textWrap, removeButton);
        v1List.appendChild(item);
      });
    };

    const renderVersion1Board = () => {
      v1PlayBoard.innerHTML = '';

      v1Entries.forEach(entry => {
        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'word-chip';

        const mark = document.createElement('span');
        mark.className = 'word-chip-mark';

        const label = document.createElement('span');
        label.className = 'word-chip-text';
        label.textContent = entry.text;

        mark.appendChild(label);

        const hint = document.createElement('span');
        hint.className = 'word-chip-hint';

        const applyState = () => {
          const result = entry.choice;
          button.classList.toggle('is-revealed', entry.revealed);
          button.classList.toggle('is-circled', entry.revealed && result === 'circle');
          button.classList.toggle('is-crossed', entry.revealed && result === 'cross');
          hint.textContent = entry.revealed
            ? result === 'circle'
              ? 'Circled'
              : 'Crossed out'
            : 'Tap to reveal';
        };

        button.addEventListener('click', () => {
          entry.revealed = !entry.revealed;
          applyState();
        });

        button.append(mark, hint);
        v1PlayBoard.appendChild(button);
        applyState();
      });
    };

    const resetVersion1Play = () => {
      v1Entries.forEach(entry => {
        entry.revealed = false;
      });
      renderVersion1Board();
    };

    const addVersion1Entry = () => {
      const text = v1Text.value.trim();
      const choice = v1Choice.value;

      if (!text) {
        v1Text.focus();
        return;
      }

      v1Entries.push({
        id: `entry-${Date.now()}-${Math.random().toString(16).slice(2)}`,
        text,
        choice,
        revealed: false,
      });

      v1Text.value = '';
      v1Text.focus();
      renderVersion1List();
    };

    const clearVersion1Entries = () => {
      v1Entries.length = 0;
      renderVersion1List();
      v1PlayBoard.innerHTML = '';
      v1PlayWrap.hidden = true;
      v1Back.hidden = true;
      v1Builder.hidden = false;
      renderVersion1List();
      v1Text.focus();
    };

    const submitVersion1 = () => {
      if (!v1Entries.length) {
        v1Text.focus();
        return;
      }

      v1Builder.hidden = true;
      v1Back.hidden = false;
      v1PlayWrap.hidden = false;
      renderVersion1List();
      resetVersion1Play();
    };

    const backToVersion1Setup = () => {
      v1Builder.hidden = false;
      v1Back.hidden = true;
      v1PlayWrap.hidden = true;
      renderVersion1List();
      v1Text.focus();
    };

    const flipAlphabetCharacter = character => {
      const upper = character.toUpperCase();
      const index = alphabet.indexOf(upper);

      if (index === -1) return character;
      const flipped = reversedAlphabet[index];
      return character === upper ? flipped : flipped.toLowerCase();
    };
    const convertToBackwardsAlphabet = value =>
      Array.from(value).map(character => flipAlphabetCharacter(character));

    const resetVersion2 = () => {
      stopVersion2();
      v2Input.value = '';
      v2Output.innerHTML = '';
    };

    const startVersion2 = () => {
      const typedValue = v2Input.value;
      const convertedCharacters = convertToBackwardsAlphabet(typedValue);
      const characterCount = convertedCharacters.length;
      resetVersion2();

      if (!characterCount) {
        v2Input.focus();
        return;
      }

      v2Input.value = '';
      v2Start.disabled = true;

      for (let index = 0; index < characterCount; index += 1) {
        const timerId = window.setTimeout(() => {
          const chip = document.createElement('span');
          chip.className = 'letter-chip';
          chip.textContent = convertedCharacters[index] === ' ' ? '\u00A0' : convertedCharacters[index];
          v2Output.appendChild(chip);

          const shownCount = index + 1;
          if (shownCount === characterCount) {
            v2Start.disabled = false;
          }
        }, (index + 1) * 1000);

        v2Timers.push(timerId);
      }
    };

    const nextVersion3Letter = () => {
      saveVersion3Choice();

      if (v3CurrentIndex < v3Entries.length - 1) {
        v3CurrentIndex += 1;
        renderVersion3();
        return;
      }

      renderVersion3();
      v3Status.innerHTML =
        'All 33 Russian letters are saved. Every <strong>Cross out</strong> pick above is one of the actual circled letters in this opposite-mode version.';
    };

    const previousVersion3Letter = () => {
      saveVersion3Choice();

      if (v3CurrentIndex === 0) {
        renderVersion3();
        return;
      }

      v3CurrentIndex -= 1;
      renderVersion3();
    };

    const resetVersion3 = () => {
      v3Entries.forEach(entry => {
        entry.choice = null;
      });
      v3CurrentIndex = 0;
      v3PressedIndex = null;
      v3Choice.value = 'circle';
      renderVersion3();
      v3Status.textContent = 'All 33 Russian letters are cleared. Start again from letter 1.';
    };

    versionButtons.forEach(button => {
      button.addEventListener('click', () => {
        setActiveVersion(button.dataset.version);
      });
    });

    v1Add.addEventListener('click', addVersion1Entry);
    v1Text.addEventListener('keydown', event => {
      if (event.key === 'Enter') {
        event.preventDefault();
        addVersion1Entry();
      }
    });
    v1Clear.addEventListener('click', clearVersion1Entries);
    v1Submit.addEventListener('click', submitVersion1);
    v1Back.addEventListener('click', backToVersion1Setup);

    v2Start.addEventListener('click', startVersion2);
    v2Reset.addEventListener('click', resetVersion2);
    v3Next.addEventListener('click', nextVersion3Letter);
    v3Prev.addEventListener('click', previousVersion3Letter);
    v3Reset.addEventListener('click', resetVersion3);

    renderVersion1List();
    renderVersion3();
    setActiveVersion('1');
  </script>
</Layout>

<style>
  @font-face {
    font-family: 'Fuzzy Bubbles';
    src: url('/Fuzzy_Bubbles/FuzzyBubbles-Regular.ttf') format('truetype');
    font-display: swap;
  }

  :global(body) {
    margin: 0;
    color: #1f1a12;
    background:
      radial-gradient(circle at top left, rgba(255, 231, 179, 0.95), transparent 34%),
      radial-gradient(circle at 85% 12%, rgba(111, 197, 173, 0.46), transparent 27%),
      linear-gradient(160deg, #fff5d6 0%, #ffc98d 47%, #ff9a7a 100%);
  }

  .choice-arcade {
    width: min(1080px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 2rem 0 7rem;
  }

  .hero-card,
  .panel-card {
    background: rgba(255, 249, 236, 0.86);
    border: 1px solid rgba(110, 72, 31, 0.15);
    border-radius: 28px;
    box-shadow: 0 24px 80px rgba(121, 69, 18, 0.16);
    backdrop-filter: blur(16px);
  }

  .hero-card {
    padding: 1.8rem;
    margin-bottom: 1.5rem;
  }

  .eyebrow,
  .panel-tag {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.78rem;
    color: #9a5621;
  }

  h1,
  h2 {
    margin: 0;
    font-family: 'Fuzzy Bubbles', 'Trebuchet MS', sans-serif;
    line-height: 1.05;
  }

  h1 {
    font-size: clamp(2.5rem, 5vw, 4.8rem);
    color: #5b2414;
    margin-top: 0.5rem;
  }

  h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: #5a2813;
  }

  .hero-copy,
  .panel-note {
    margin: 0;
    font-size: 1rem;
    line-height: 1.6;
    color: #61442f;
  }

  .hero-copy {
    max-width: 60ch;
    margin-top: 0.85rem;
  }

  .version-switch {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.25rem;
  }

  .version-pill,
  .primary-button,
  .ghost-button,
  :global(.mini-button),
  :global(.word-chip) {
    border: none;
    border-radius: 999px;
    cursor: pointer;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      background-color 180ms ease,
      color 180ms ease;
    font: inherit;
  }

  .version-pill,
  .primary-button,
  .ghost-button,
  :global(.mini-button) {
    padding: 0.9rem 1.2rem;
    font-weight: 700;
  }

  .version-pill {
    background: rgba(255, 255, 255, 0.6);
    color: #7b4620;
    box-shadow: inset 0 0 0 1px rgba(123, 70, 32, 0.14);
  }

  .version-pill.is-active,
  .primary-button {
    background: linear-gradient(135deg, #ff8f3f 0%, #ff5d5d 100%);
    color: white;
    box-shadow: 0 16px 30px rgba(207, 84, 48, 0.28);
  }

  .ghost-button {
    background: #fff2d7;
    color: #74431e;
    box-shadow: inset 0 0 0 1px rgba(116, 67, 30, 0.18);
  }

  :global(.mini-button) {
    padding: 0.6rem 0.95rem;
    background: #5d948a;
    color: white;
  }

  .version-pill:hover,
  .primary-button:hover,
