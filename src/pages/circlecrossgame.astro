---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Circle Cross Game">
  <main class="choice-arcade">
    <section class="hero-card">
      <p class="eyebrow">Three Versions</p>
      <h1>Circle or Cross Out Game</h1>
      <p class="hero-copy">
        Version 1 lets you keep adding words, then tap each one after Submit to
        reveal the result you picked. Version 2 turns your typed text into
        backwards-alphabet letters, one second at a time. Version 3 turns an
        English spelling into Russian Cyrillic, then uses a common-to-rare
        Russian letter map to find the secret.
      </p>

      <div class="version-switch" role="tablist" aria-label="Game versions">
        <button type="button" class="version-pill is-active" data-version="1" aria-selected="true">
          Version 1
        </button>
        <button type="button" class="version-pill" data-version="2" aria-selected="false">
          Version 2
        </button>
        <button type="button" class="version-pill" data-version="3" aria-selected="false">
          Version 3
        </button>
      </div>
    </section>

    <section class="game-panel is-active" data-panel="1">
      <div class="panel-grid">
        <article class="panel-card">
          <p class="panel-tag">Setup</p>
          <h2>Build your word list</h2>
          <p class="panel-note">
            Pick <strong>Circle</strong> or <strong>Cross out</strong> for each
            text. The game reveals that same choice when you press the word later.
          </p>

          <div id="v1-builder" class="stack">
            <label class="field">
              <span>Text</span>
              <input id="v1-text" type="text" placeholder="Type a word or short phrase" maxlength="80" />
            </label>

            <label class="field">
              <span>Choice</span>
              <select id="v1-choice">
                <option value="circle">Circle</option>
                <option value="cross">Cross out</option>
              </select>
            </label>

            <div class="button-row">
              <button type="button" class="primary-button" id="v1-add">Add text</button>
              <button type="button" class="ghost-button" id="v1-clear">Clear list</button>
            </div>
          </div>
        </article>

        <article class="panel-card">
          <p class="panel-tag">Queue</p>
          <div class="panel-header">
            <h2>Saved texts</h2>
            <span id="v1-count" class="count-badge">0 items</span>
          </div>
          <div id="v1-list" class="saved-list" aria-live="polite">
            <p class="empty-state">Add a text to start the game.</p>
          </div>
          <div class="button-row">
            <button type="button" class="primary-button" id="v1-submit">Submit</button>
            <button type="button" class="ghost-button" id="v1-back" hidden>Back to setup</button>
          </div>
        </article>
      </div>

      <article id="v1-play-wrap" class="panel-card play-card" hidden>
        <div class="panel-header">
          <div>
            <p class="panel-tag">Play</p>
            <h2>Tap each text</h2>
          </div>
          <span class="count-badge inverse-badge">Reveal mode</span>
        </div>
        <p class="panel-note">
          If you picked circle, this word gets circled. If you picked cross
          out, this word gets crossed out.
        </p>
        <div id="v1-play-board" class="play-board" aria-live="polite"></div>
      </article>
    </section>

    <section class="game-panel" data-panel="2">
      <div class="panel-grid single-panel">
        <article class="panel-card">
          <p class="panel-tag">Backwards Alphabet</p>
          <h2>Backwards letters, one second apart</h2>
          <p class="panel-note">
            Your typed text gets converted with the backwards alphabet. Spaces
            stay exactly where you typed them, and each converted character
            appears one second after the other.
          </p>

          <div class="stack">
            <label class="field">
              <span>Your choice</span>
              <input id="v2-input" type="text" placeholder="Type characters here" />
            </label>

            <div class="button-row">
              <button type="button" class="primary-button" id="v2-start">Start typing</button>
              <button type="button" class="ghost-button" id="v2-reset">Reset</button>
            </div>
          </div>

          <div class="output-shell">
            <div id="v2-output" class="letter-output" aria-live="polite"></div>
          </div>
        </article>
      </div>
    </section>

    <section class="game-panel" data-panel="3">
      <div class="panel-grid">
        <article class="panel-card">
          <p class="panel-tag">Russian Secret</p>
          <h2>Type it in English first</h2>
          <p class="panel-note">
            Write the word with English letters like <strong>privet mir</strong>.
            Version 3 turns it into Russian Cyrillic and hides the answer so you
            can find the secret with the Russian letter map.
          </p>

          <div class="stack">
            <label class="field">
              <span>English word or phrase</span>
              <input
                id="v3-input"
                type="text"
                placeholder="Type something like privet mir"
                autocomplete="off"
              />
            </label>

            <div class="button-row">
              <button type="button" class="primary-button" id="v3-start">Make secret</button>
              <button type="button" class="ghost-button" id="v3-reset">Reset</button>
            </div>

            <p id="v3-status" class="panel-note">
              Type an English spelling, then press Make secret.
            </p>
          </div>
        </article>

        <article class="panel-card">
          <div class="panel-header">
            <div>
              <p class="panel-tag">Find It</p>
              <h2>Russian secret finder</h2>
            </div>
            <span id="v3-count" class="count-badge">0 / 0 found</span>
          </div>
          <p class="panel-note">
            This map goes from the most usual Russian letter to the least usual
            one. Number <strong>1</strong> is the most usual and number
            <strong>33</strong> is the least usual.
          </p>

          <div class="output-shell russian-output-shell">
            <p class="output-label">Secret blanks</p>
            <div id="v3-result" class="collected-output" aria-live="polite">
              Make a secret to start.
            </div>
            <p id="v3-result-note" class="russian-result-note">
              Correct letters get circled. Wrong letters get crossed out.
            </p>
          </div>

          <p id="v3-collected" class="russian-safe-list">Found letters: None yet.</p>

          <div class="map-shell">
            <p class="output-label">Common-to-Rare Letter Map</p>
            <div id="v3-summary" class="russian-summary" aria-live="polite"></div>
          </div>
        </article>
      </div>
    </section>
  </main>

  <script is:inline>
    const versionButtons = Array.from(document.querySelectorAll('.version-pill'));
    const panels = Array.from(document.querySelectorAll('.game-panel'));

    const v1Text = document.querySelector('#v1-text');
    const v1Choice = document.querySelector('#v1-choice');
    const v1Add = document.querySelector('#v1-add');
    const v1Clear = document.querySelector('#v1-clear');
    const v1Submit = document.querySelector('#v1-submit');
    const v1Back = document.querySelector('#v1-back');
    const v1List = document.querySelector('#v1-list');
    const v1Count = document.querySelector('#v1-count');
    const v1PlayWrap = document.querySelector('#v1-play-wrap');
    const v1PlayBoard = document.querySelector('#v1-play-board');
    const v1Builder = document.querySelector('#v1-builder');

    const v2Input = document.querySelector('#v2-input');
    const v2Start = document.querySelector('#v2-start');
    const v2Reset = document.querySelector('#v2-reset');
    const v2Output = document.querySelector('#v2-output');
    const v3Input = document.querySelector('#v3-input');
    const v3Start = document.querySelector('#v3-start');
    const v3Status = document.querySelector('#v3-status');
    const v3Reset = document.querySelector('#v3-reset');
    const v3Count = document.querySelector('#v3-count');
    const v3Result = document.querySelector('#v3-result');
    const v3ResultNote = document.querySelector('#v3-result-note');
    const v3Collected = document.querySelector('#v3-collected');
    const v3Summary = document.querySelector('#v3-summary');

    const alphabet = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
    const reversedAlphabet = alphabet.split('').reverse().join('');
    const russianAlphabet = [
      'О',
      'Е',
      'А',
      'И',
      'Н',
      'Т',
      'С',
      'Р',
      'В',
      'Л',
      'К',
      'М',
      'Д',
      'П',
      'У',
      'Я',
      'Ы',
      'Ь',
      'Г',
      'З',
      'Б',
      'Ч',
      'Й',
      'Х',
      'Ж',
      'Ш',
      'Ю',
      'Ц',
      'Щ',
      'Э',
      'Ф',
      'Ъ',
      'Ё',
    ];
    const v1Entries = [];
    let v2Timers = [];
    const v3LetterSet = new Set(russianAlphabet);
    const v3State = {
      secret: '',
      guessed: new Set(),
      active: false,
    };
    const v3Rules = [
      ['shch', 'щ'],
      ['yo', 'ё'],
      ['zh', 'ж'],
      ['kh', 'х'],
      ['ts', 'ц'],
      ['ch', 'ч'],
      ['sh', 'ш'],
      ['yu', 'ю'],
      ['ya', 'я'],
      ['ye', 'е'],
      ['eh', 'э'],
    ];
    const v3LetterMap = {
      a: 'а',
      b: 'б',
      c: 'к',
      d: 'д',
      e: 'е',
      f: 'ф',
      g: 'г',
      h: 'х',
      i: 'и',
      j: 'й',
      k: 'к',
      l: 'л',
      m: 'м',
      n: 'н',
      o: 'о',
      p: 'п',
      q: 'к',
      r: 'р',
      s: 'с',
      t: 'т',
      u: 'у',
      v: 'в',
      w: 'в',
      x: 'кс',
      y: 'ы',
      z: 'з',
    };

    const pluralize = (count, singular, plural) => `${count} ${count === 1 ? singular : plural}`;
    const stopVersion2 = () => {
      v2Timers.forEach(timerId => window.clearTimeout(timerId));
      v2Timers = [];
      v2Start.disabled = false;
    };

    const setActiveVersion = version => {
      versionButtons.forEach(button => {
        const isActive = button.dataset.version === version;
        button.classList.toggle('is-active', isActive);
        button.setAttribute('aria-selected', String(isActive));
      });

      panels.forEach(panel => {
        panel.classList.toggle('is-active', panel.dataset.panel === version);
      });

      if (version !== '2') stopVersion2();
    };

    const splitIntoRows = (items, size) =>
      Array.from({ length: Math.ceil(items.length / size) }, (_, index) =>
        items.slice(index * size, index * size + size)
      );

    const transliterateToRussian = value => {
      const lower = value.toLowerCase();
      let index = 0;
      let result = '';

      while (index < lower.length) {
        const currentCharacter = lower[index];

        if (currentCharacter === ' ') {
          result += ' ';
          index += 1;
          continue;
        }

        if (currentCharacter === '/' || currentCharacter === '-') {
          result += currentCharacter;
          index += 1;
          continue;
        }

        const matchingRule = v3Rules.find(([latin]) => lower.startsWith(latin, index));
        if (matchingRule) {
          result += matchingRule[1];
          index += matchingRule[0].length;
          continue;
        }

        const mappedLetter = v3LetterMap[currentCharacter];
        if (mappedLetter) {
          result += mappedLetter;
          index += 1;
          continue;
        }

        result += value[index];
        index += 1;
      }

      return result.toUpperCase().replace(/\s+/g, ' ').trim();
    };

    const getVersion3UniqueLetters = () =>
      Array.from(new Set(Array.from(v3State.secret).filter(letter => v3LetterSet.has(letter))));

    const buildVersion3Blanks = () => {
      if (!v3State.secret) return 'Make a secret to start.';

      return Array.from(v3State.secret)
        .map(letter => {
          if (letter === ' ') return '   ';
          if (!v3LetterSet.has(letter)) return letter;
          return v3State.guessed.has(letter) ? letter : '_';
        })
        .join(' ');
    };

    const renderVersion3 = () => {
      const uniqueLetters = getVersion3UniqueLetters();
      const foundLetters = uniqueLetters.filter(letter => v3State.guessed.has(letter));
      const solved = uniqueLetters.length > 0 && foundLetters.length === uniqueLetters.length;

      if (solved) {
        v3State.active = false;
      }

      v3Count.textContent = `${foundLetters.length} / ${uniqueLetters.length} found`;
      v3Result.textContent = buildVersion3Blanks();

      if (!v3State.secret) {
        v3Result.dataset.tone = 'neutral';
        v3ResultNote.textContent = 'Correct letters get circled. Wrong letters get crossed out.';
      } else if (solved) {
        v3Result.dataset.tone = 'success';
        v3ResultNote.textContent = 'You found the whole Russian secret.';
      } else {
        v3Result.dataset.tone = 'neutral';
        v3ResultNote.textContent = 'Press the Russian letters below to test the secret.';
      }

      v3Collected.textContent = foundLetters.length
        ? `Found letters: ${foundLetters.join(' ')}`
        : 'Found letters: None yet.';
      v3Summary.innerHTML = '';

      splitIntoRows(russianAlphabet.map((letter, index) => ({ letter, number: index + 1 })), 7)
        .forEach(row => {
          row.forEach(entry => {
            const button = document.createElement('button');
            const guessed = v3State.guessed.has(entry.letter);
            const correct = guessed && v3State.secret.includes(entry.letter);
            const wrong = guessed && !v3State.secret.includes(entry.letter);

            button.type = 'button';
            button.className = 'saved-item secret-map-button';
            button.disabled = !v3State.active || guessed;
            button.classList.toggle('is-correct', correct);
            button.classList.toggle('is-wrong', wrong);
            button.setAttribute(
              'aria-label',
              `Russian letter ${entry.number}: ${entry.letter}`
            );

            const number = document.createElement('strong');
            number.className = 'secret-map-number';
            number.textContent = String(entry.number);

            const letter = document.createElement('span');
            letter.className = 'secret-map-letter';
            letter.textContent = entry.letter;

            button.append(number, letter);
            button.addEventListener('click', () => {
              if (!v3State.active) return;

              v3State.guessed.add(entry.letter);
              const isCorrect = v3State.secret.includes(entry.letter);

              if (isCorrect) {
                const nextFoundLetters = getVersion3UniqueLetters().filter(letterItem =>
                  v3State.guessed.has(letterItem)
                );
                const nextSolved =
                  getVersion3UniqueLetters().length > 0 &&
                  nextFoundLetters.length === getVersion3UniqueLetters().length;

                v3Status.innerHTML = nextSolved
                  ? `You found the Russian secret: <strong>${v3State.secret}</strong>.`
                  : `<strong>${entry.letter}</strong> is in the secret. Keep going.`;
              } else {
                v3Status.innerHTML = `<strong>${entry.letter}</strong> is not in the secret.`;
              }

              renderVersion3();
            });

            v3Summary.appendChild(button);
          });
        });
    };

    const renderVersion1Count = () => {
      v1Count.textContent = pluralize(v1Entries.length, 'item', 'items');
    };

    const renderVersion1List = () => {
      renderVersion1Count();

      if (!v1Entries.length) {
        v1List.innerHTML = '<p class="empty-state">Add a text to start the game.</p>';
        return;
      }

      v1List.innerHTML = '';

      v1Entries.forEach((entry, index) => {
        const item = document.createElement('div');
        item.className = 'saved-item';

        const textWrap = document.createElement('div');
        textWrap.className = 'saved-copy';

        const title = document.createElement('strong');
        title.textContent = entry.text;

        const sub = document.createElement('span');
        sub.textContent = `Choice ${index + 1}: ${entry.choice === 'circle' ? 'Circle' : 'Cross out'}`;

        textWrap.append(title, sub);

        const removeButton = document.createElement('button');
        removeButton.type = 'button';
        removeButton.className = 'mini-button';
        removeButton.textContent = 'Remove';
        removeButton.hidden = v1Builder.hidden;
        removeButton.addEventListener('click', () => {
          const entryIndex = v1Entries.findIndex(itemEntry => itemEntry.id === entry.id);
          if (entryIndex >= 0) {
            v1Entries.splice(entryIndex, 1);
            renderVersion1List();
          }
        });

        item.append(textWrap, removeButton);
        v1List.appendChild(item);
      });
    };

    const renderVersion1Board = () => {
      v1PlayBoard.innerHTML = '';

      v1Entries.forEach(entry => {
        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'word-chip';

        const mark = document.createElement('span');
        mark.className = 'word-chip-mark';

        const label = document.createElement('span');
        label.className = 'word-chip-text';
        label.textContent = entry.text;

        mark.appendChild(label);

        const hint = document.createElement('span');
        hint.className = 'word-chip-hint';

        const applyState = () => {
          const result = entry.choice;
          button.classList.toggle('is-revealed', entry.revealed);
          button.classList.toggle('is-circled', entry.revealed && result === 'circle');
          button.classList.toggle('is-crossed', entry.revealed && result === 'cross');
          hint.textContent = entry.revealed
            ? result === 'circle'
              ? 'Circled'
              : 'Crossed out'
            : 'Tap to reveal';
        };

        button.addEventListener('click', () => {
          entry.revealed = !entry.revealed;
          applyState();
        });

        button.append(mark, hint);
        v1PlayBoard.appendChild(button);
        applyState();
      });
    };

    const resetVersion1Play = () => {
      v1Entries.forEach(entry => {
        entry.revealed = false;
      });
      renderVersion1Board();
    };

    const addVersion1Entry = () => {
      const text = v1Text.value.trim();
      const choice = v1Choice.value;

      if (!text) {
        v1Text.focus();
        return;
      }

      v1Entries.push({
        id: `entry-${Date.now()}-${Math.random().toString(16).slice(2)}`,
        text,
        choice,
        revealed: false,
      });

      v1Text.value = '';
      v1Text.focus();
      renderVersion1List();
    };

    const clearVersion1Entries = () => {
      v1Entries.length = 0;
      renderVersion1List();
      v1PlayBoard.innerHTML = '';
      v1PlayWrap.hidden = true;
      v1Back.hidden = true;
      v1Builder.hidden = false;
      renderVersion1List();
      v1Text.focus();
    };

    const submitVersion1 = () => {
      if (!v1Entries.length) {
        v1Text.focus();
        return;
      }

      v1Builder.hidden = true;
      v1Back.hidden = false;
      v1PlayWrap.hidden = false;
      renderVersion1List();
      resetVersion1Play();
    };

    const backToVersion1Setup = () => {
      v1Builder.hidden = false;
      v1Back.hidden = true;
      v1PlayWrap.hidden = true;
      renderVersion1List();
      v1Text.focus();
    };

    const flipAlphabetCharacter = character => {
      const upper = character.toUpperCase();
      const index = alphabet.indexOf(upper);

      if (index === -1) return character;
      const flipped = reversedAlphabet[index];
      return character === upper ? flipped : flipped.toLowerCase();
    };
    const convertToBackwardsAlphabet = value =>
      Array.from(value).map(character => flipAlphabetCharacter(character));

    const resetVersion2 = () => {
      stopVersion2();
      v2Input.value = '';
      v2Output.innerHTML = '';
    };

    const startVersion2 = () => {
      const typedValue = v2Input.value;
      const convertedCharacters = convertToBackwardsAlphabet(typedValue);
      const characterCount = convertedCharacters.length;
      resetVersion2();

      if (!characterCount) {
        v2Input.focus();
        return;
      }

      v2Input.value = '';
      v2Start.disabled = true;

      for (let index = 0; index < characterCount; index += 1) {
        const timerId = window.setTimeout(() => {
          const chip = document.createElement('span');
          chip.className = 'letter-chip';
          chip.textContent = convertedCharacters[index] === ' ' ? '\u00A0' : convertedCharacters[index];
          v2Output.appendChild(chip);

          const shownCount = index + 1;
          if (shownCount === characterCount) {
            v2Start.disabled = false;
          }
        }, (index + 1) * 1000);

        v2Timers.push(timerId);
      }
    };

    const startVersion3 = () => {
      const typedValue = v3Input.value.trim();
      const secret = transliterateToRussian(typedValue);
      const hasRussianLetters = Array.from(secret).some(letter => v3LetterSet.has(letter));

      if (!typedValue || !hasRussianLetters) {
        v3Status.textContent = 'Type an English spelling like privet mir first.';
        v3Input.focus();
        return;
      }

      v3State.secret = secret;
      v3State.guessed.clear();
      v3State.active = true;
      v3Input.value = '';
      v3Status.innerHTML =
        `Secret ready from <strong>${typedValue}</strong>. Now find the Russian letters.`;
      renderVersion3();
    };

    const resetVersion3 = () => {
      v3State.secret = '';
      v3State.guessed.clear();
      v3State.active = false;
      v3Input.value = '';
      renderVersion3();
      v3Status.textContent = 'Type an English spelling, then press Make secret.';
    };

    versionButtons.forEach(button => {
      button.addEventListener('click', () => {
        setActiveVersion(button.dataset.version);
      });
    });

    v1Add.addEventListener('click', addVersion1Entry);
    v1Text.addEventListener('keydown', event => {
      if (event.key === 'Enter') {
        event.preventDefault();
        addVersion1Entry();
      }
    });
    v1Clear.addEventListener('click', clearVersion1Entries);
    v1Submit.addEventListener('click', submitVersion1);
    v1Back.addEventListener('click', backToVersion1Setup);

    v2Start.addEventListener('click', startVersion2);
    v2Reset.addEventListener('click', resetVersion2);
    v3Start.addEventListener('click', startVersion3);
    v3Input.addEventListener('keydown', event => {
      if (event.key === 'Enter') {
        event.preventDefault();
        startVersion3();
      }
    });
    v3Reset.addEventListener('click', resetVersion3);

    renderVersion1List();
    renderVersion3();
    setActiveVersion('1');
  </script>
</Layout>

<style>
  @font-face {
    font-family: 'Fuzzy Bubbles';
    src: url('/Fuzzy_Bubbles/FuzzyBubbles-Regular.ttf') format('truetype');
    font-display: swap;
  }

  :global(body) {
    margin: 0;
    color: #1f1a12;
    background:
      radial-gradient(circle at top left, rgba(255, 231, 179, 0.95), transparent 34%),
      radial-gradient(circle at 85% 12%, rgba(111, 197, 173, 0.46), transparent 27%),
      linear-gradient(160deg, #fff5d6 0%, #ffc98d 47%, #ff9a7a 100%);
  }

  .choice-arcade {
    width: min(1080px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 2rem 0 7rem;
  }

  .hero-card,
  .panel-card {
    background: rgba(255, 249, 236, 0.86);
    border: 1px solid rgba(110, 72, 31, 0.15);
    border-radius: 28px;
    box-shadow: 0 24px 80px rgba(121, 69, 18, 0.16);
    backdrop-filter: blur(16px);
  }

  .hero-card {
    padding: 1.8rem;
    margin-bottom: 1.5rem;
  }

  .eyebrow,
  .panel-tag {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.78rem;
    color: #9a5621;
  }

  h1,
  h2 {
    margin: 0;
    font-family: 'Fuzzy Bubbles', 'Trebuchet MS', sans-serif;
    line-height: 1.05;
  }

  h1 {
    font-size: clamp(2.5rem, 5vw, 4.8rem);
    color: #5b2414;
    margin-top: 0.5rem;
  }

  h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: #5a2813;
  }

  .hero-copy,
  .panel-note {
    margin: 0;
    font-size: 1rem;
    line-height: 1.6;
    color: #61442f;
  }

  .hero-copy {
    max-width: 60ch;
    margin-top: 0.85rem;
  }

  .version-switch {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.25rem;
