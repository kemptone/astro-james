---
import Layout from '../layouts/Layout.astro'

const reachModes = [
  {
    key: 'jumpReach',
    title: 'Jump Reach',
    start: 80,
    end: 81,
    display: '80-81',
    summary: '80 touches the word bottom when the square jumps, and 81 still catches the top.',
  },
  {
    key: 'liftPoint',
    title: 'Lift + Point',
    start: 85,
    end: 86,
    display: '85-86',
    summary: '85 touches the word bottom when the square lifts a little and grows a right-side point.',
  },
  {
    key: 'pointReach',
    title: 'Point Right',
    start: 90,
    end: 91,
    display: '90-91',
    summary: '90 touches the word bottom with the point on the right side without the lift.',
  },
  {
    key: 'jumpTop',
    title: 'Jump Top',
    start: 95,
    end: 96,
    display: '95-96',
    summary: '95 touches the word bottom when the square jumps, and 96 still catches the word top.',
  },
  {
    key: 'pointTop',
    title: 'High Point',
    start: 100,
    end: 101,
    display: '100-101',
    summary: '100 is the higher point touching the bottom of the word, and 101 still catches the top.',
  },
  {
    key: 'lift',
    title: 'Lift Top',
    start: 110,
    end: 111,
    display: '110-111',
    summary: '110 is the lifted top of the square touching the word bottom.',
  },
  {
    key: 'body',
    title: 'Square Body',
    start: 120,
    end: 200,
    display: '120-200',
    summary: 'The black square body itself runs from 120 at the top down to 200 at the bottom.',
  },
]

---

<Layout title="Reach Game">
  <main class="reach-lab">
    <section class="hero-card">
      <div class="hero-copy">
        <p class="eyebrow">Reach Game</p>
        <h1>Give each word a number, then see if the black square reaches it.</h1>
        <p class="lede">
          Every word is always <strong>1 number tall</strong>. If a word bottom
          is <strong>1</strong>, its top is <strong>0</strong>, so it sits right
          at the top of the game. If a word bottom is <strong>0</strong>, the
          word starts above the screen and you need to scroll up to see it. The
          square body itself runs from <strong>120</strong> to
          <strong>200</strong>.
        </p>
      </div>

      <div class="hero-grid">
        {
          reachModes.map(mode => (
            <article class="hero-chip">
              <p>{mode.title}</p>
              <strong>{mode.display}</strong>
              <span>{mode.summary}</span>
            </article>
          ))
        }
      </div>
    </section>

    <section class="builder-grid">
      <article class="panel">
        <div class="panel-head">
          <div>
            <p class="eyebrow">Build The Texts</p>
            <h2>Keep adding words before you play.</h2>
          </div>
          <p class="panel-note">The number is the word bottom. Its top is always 1 less.</p>
        </div>

        <form id="word-form" class="word-form" novalidate>
          <label>
            <span>Word</span>
            <input
              id="word-input"
              name="word"
              type="text"
              autocomplete="off"
              maxlength="40"
              placeholder="Black thing"
            />
          </label>

          <label>
            <span>Bottom Number</span>
            <input
              id="bottom-input"
              name="bottom"
              type="number"
              step="0.1"
              inputmode="decimal"
              placeholder="95"
            />
          </label>

          <div class="form-side-note">
            <p>`1` means the top of the word is at the top of the game.</p>
            <p>`0` means the word is just above the top and needs scrolling.</p>
            <p>`80`, `85`, `90`, `95`, `100`, `110`, `120`, and `200` are the square lines.</p>
          </div>
        </form>

        <p id="form-message" class="message" aria-live="polite">
          Add text, give it a number, then play the game.
        </p>

        <div class="button-row">
          <button id="add-word" type="button" class="primary-button">
            Add Text
          </button>
          <button id="clear-words" type="button" class="ghost-button">
            Clear Texts
          </button>
          <button id="play-button" type="button" class="secondary-button">
            Play The Game
          </button>
        </div>
      </article>

      <article class="panel">
        <div class="panel-head">
          <div>
            <p class="eyebrow">Saved Texts</p>
            <h2>Pick a word to test.</h2>
          </div>
          <p id="word-count" class="count-pill">0 words</p>
        </div>

        <div class="summary-grid">
          <article class="summary-card">
            <span class="summary-label">Highest text</span>
            <strong id="highest-word">None yet</strong>
          </article>

          <article class="summary-card">
            <span class="summary-label">Square body</span>
            <strong>120 to 200</strong>
          </article>

          <article class="summary-card">
            <span class="summary-label">Whole scale</span>
            <strong>0, 1, 80, 81, 85, 86, 90, 91, 95, 96, 100, 101, 110, 111, 120, 200</strong>
          </article>
        </div>

        <div id="selected-summary" class="selected-summary"></div>
        <div id="saved-words" class="saved-words" aria-live="polite"></div>
      </article>
    </section>

    <section id="game-panel" class="game-grid">
      <article class="panel stage-panel">
        <div class="panel-head">
          <div>
            <p class="eyebrow">The Game</p>
            <h2>Scroll around and see where the words land.</h2>
          </div>
          <p class="panel-note">The `0` line is the top of the game screen.</p>
        </div>

        <div id="stage-viewport" class="stage-viewport">
          <div id="stage-world" class="stage-world">
            <div id="player-figure" class="player-figure" data-mode="jumpReach" aria-hidden="true">
              <span class="player-point"></span>
            </div>

            <div id="word-layer" class="word-layer"></div>
          </div>
        </div>
      </article>

      <aside class="panel control-panel">
        <div class="panel-head">
          <div>
            <p class="eyebrow">Reach Modes</p>
            <h2>Choose how the square tries.</h2>
          </div>
          <p class="panel-note">A word counts if its bottom number lands inside the colored range.</p>
        </div>

        <div id="mode-buttons" class="mode-buttons">
          {
            reachModes.map(mode => (
              <button
                type="button"
                class="mode-button"
                data-mode={mode.key}
              >
                <span>{mode.title}</span>
                <strong>{mode.display}</strong>
              </button>
            ))
          }
        </div>

        <div id="mode-readout" class="mode-readout"></div>

        <p id="play-message" class="message play-message" aria-live="polite">
          Pick a saved word to see whether the square reaches it.
        </p>

        <div class="button-stack">
          <button id="show-top" type="button" class="secondary-button">
            Show The Top
          </button>
          <button id="show-selected" type="button" class="secondary-button">
            Show Selected Word
          </button>
        </div>
      </aside>
    </section>
  </main>

  <script define:vars={{reachModes}}>
    const WORD_HEIGHT = 1
    const PLAYER_BODY_TOP = 120
    const PLAYER_BODY_BOTTOM = 200
    const UNIT_PX = 8
    const PLAYER_BODY_HEIGHT = PLAYER_BODY_BOTTOM - PLAYER_BODY_TOP

    const state = {
      words: [],
      nextId: 1,
      activeMode: 'jumpReach',
      selectedId: null,
      worldTop: -8,
      worldBottom: 208,
    }

    const modeByKey = new Map(reachModes.map(mode => [mode.key, mode]))

    const wordForm = document.querySelector('#word-form')
    const wordInput = document.querySelector('#word-input')
    const bottomInput = document.querySelector('#bottom-input')
    const addWordButton = document.querySelector('#add-word')
    const clearWordsButton = document.querySelector('#clear-words')
    const playButton = document.querySelector('#play-button')
    const formMessage = document.querySelector('#form-message')
    const savedWords = document.querySelector('#saved-words')
    const selectedSummary = document.querySelector('#selected-summary')
    const wordCount = document.querySelector('#word-count')
    const highestWord = document.querySelector('#highest-word')
    const stageViewport = document.querySelector('#stage-viewport')
    const stageWorld = document.querySelector('#stage-world')
    const wordLayer = document.querySelector('#word-layer')
    const playerFigure = document.querySelector('#player-figure')
    const modeButtons = document.querySelector('#mode-buttons')
    const modeReadout = document.querySelector('#mode-readout')
    const playMessage = document.querySelector('#play-message')
    const showTopButton = document.querySelector('#show-top')
    const showSelectedButton = document.querySelector('#show-selected')

    const formatNumber = value => {
      if (Number.isInteger(value)) return String(value)
      return value.toFixed(2).replace(/\.?0+$/, '')
    }

    const makeWord = (text, bottom) => ({
      id: `word-${state.nextId++}`,
      text,
      bottom,
    })

    const getSortedWords = () => [...state.words].sort((a, b) => a.bottom - b.bottom)

    const getSelectedWord = () =>
      state.words.find(word => word.id === state.selectedId) ?? null

    const getWordTop = word => word.bottom - WORD_HEIGHT

    const getActiveMode = () => modeByKey.get(state.activeMode)

    const isReachable = (word, mode) =>
      word.bottom >= mode.start && word.bottom <= mode.end

    const getVisibilityText = word => {
      if (word.bottom < 0)
        return `This word is above the top. Scroll up ${formatNumber(Math.abs(word.bottom))} more to find it.`
      if (word.bottom === 0)
        return 'This word starts above the top line. Scroll up a little to see it.'
      if (word.bottom > 0 && word.bottom < 1)
        return 'This word is peeking over the top line, so only part of it is showing.'
      if (word.bottom === 1)
        return 'This word sits right on the top of the game.'
      if (word.bottom === 80)
        return 'This word matches the jump reach touching its bottom edge.'
      if (word.bottom === 81)
        return 'This word matches the jump reach touching its top edge.'
      if (word.bottom === 85)
        return 'This word matches the lift-and-point reach touching its bottom edge.'
      if (word.bottom === 86)
        return 'This word matches the lift-and-point reach touching its top edge.'
      if (word.bottom === 90)
        return 'This word matches the point-right reach touching its bottom edge.'
      if (word.bottom === 91)
        return 'This word matches the point-right reach touching its top edge.'
      if (word.bottom === 95)
        return 'This word matches the jump top touching its bottom edge.'
      if (word.bottom === 96)
        return 'This word matches the jump top touching its top edge.'
      if (word.bottom === 100)
        return 'This word matches the square point touching its bottom edge.'
      if (word.bottom === 101)
        return 'This word matches the square point touching its top edge.'
      if (word.bottom === 110)
        return 'This word matches the lifted top of the square touching its bottom edge.'
      if (word.bottom === 111)
        return 'This word matches the lifted top of the square touching its top edge.'
      if (word.bottom === 120)
        return 'This word touches the very top of the square body.'
      if (word.bottom === 200)
        return 'This word touches the very bottom of the square body.'
      return 'This word starts on the screen without extra scrolling.'
    }

    const setFormMessage = (text, tone = 'neutral') => {
      formMessage.textContent = text
      formMessage.dataset.tone = tone
    }

    const setPlayMessage = (text, tone = 'neutral') => {
      playMessage.textContent = text
      playMessage.dataset.tone = tone
    }

    const coordinateToPixel = value => (value - state.worldTop) * UNIT_PX

    const focusTopLine = () => {
      stageViewport.scrollTop = coordinateToPixel(0)
    }

    const focusWord = word => {
      if (!word) return

      const wordMiddle = coordinateToPixel(word.bottom - 0.5)
      const nextScrollTop = wordMiddle - stageViewport.clientHeight / 2
      stageViewport.scrollTop = Math.max(0, nextScrollTop)
    }

    const triggerSquareJump = () => {
      const activeMode = getActiveMode()
      const rise = Math.max(0, PLAYER_BODY_TOP - activeMode.start)

      playerFigure.style.setProperty('--jump-rise', `${rise * UNIT_PX}px`)
      playerFigure.classList.remove('is-jumping')
      void playerFigure.offsetWidth
      playerFigure.classList.add('is-jumping')
    }

    const ensureSelection = () => {
      const selectedWord = getSelectedWord()

      if (selectedWord) return

      const sortedWords = getSortedWords()
      state.selectedId = sortedWords[0]?.id ?? null
    }

    const renderWordCount = () => {
      const count = state.words.length
      wordCount.textContent = `${count} word${count === 1 ? '' : 's'}`

      if (!count) {
        highestWord.textContent = 'None yet'
        return
      }

      const highest = getSortedWords()[0]
      highestWord.textContent = `${highest.text} at ${formatNumber(highest.bottom)}`
    }

    const renderSelectedSummary = () => {
      const selectedWord = getSelectedWord()
      selectedSummary.replaceChildren()

      if (!selectedWord) {
        const empty = document.createElement('p')
        empty.className = 'summary-empty'
        empty.textContent = 'Pick a word from the list or the game board.'
        selectedSummary.append(empty)
        return
      }

      const card = document.createElement('article')
      card.className = 'selected-card'

      const title = document.createElement('h3')
      title.textContent = selectedWord.text

      const numbers = document.createElement('p')
      numbers.className = 'selected-copy'
      numbers.textContent =
        `Bottom ${formatNumber(selectedWord.bottom)} · ` +
        `Top ${formatNumber(getWordTop(selectedWord))}`

      const visibility = document.createElement('p')
      visibility.className = 'selected-copy'
      visibility.textContent = getVisibilityText(selectedWord)

      card.append(title, numbers, visibility)
      selectedSummary.append(card)
    }

    const renderSavedWords = () => {
      savedWords.replaceChildren()

      if (!state.words.length) {
        const empty = document.createElement('p')
        empty.className = 'summary-empty'
        empty.textContent = 'No texts yet. Add one on the left to start the game.'
        savedWords.append(empty)
        return
      }

      const selectedWord = getSelectedWord()

      getSortedWords().forEach(word => {
        const card = document.createElement('article')
        card.className = 'word-card'

        if (selectedWord?.id === word.id) {
          card.classList.add('is-selected')
        }

        const topRow = document.createElement('div')
        topRow.className = 'word-card-top'

        const selectButton = document.createElement('button')
        selectButton.type = 'button'
        selectButton.className = 'word-select'
        selectButton.dataset.selectId = word.id

        const selectTitle = document.createElement('strong')
        selectTitle.textContent = word.text

        const selectMeta = document.createElement('span')
        selectMeta.textContent =
          `Bottom ${formatNumber(word.bottom)} · Top ${formatNumber(getWordTop(word))}`

        selectButton.append(selectTitle, selectMeta)

        const removeButton = document.createElement('button')
        removeButton.type = 'button'
        removeButton.className = 'remove-button'
        removeButton.dataset.removeId = word.id
        removeButton.textContent = 'Remove'

        topRow.append(selectButton, removeButton)

        const visibility = document.createElement('p')
        visibility.className = 'word-visibility'
        visibility.textContent = getVisibilityText(word)

        card.append(topRow, visibility)
        savedWords.append(card)
      })
    }

    const renderWordsOnStage = () => {
      wordLayer.replaceChildren()

      const activeMode = getActiveMode()
      const selectedWord = getSelectedWord()

      getSortedWords().forEach((word, index) => {
        const button = document.createElement('button')
        button.type = 'button'
        button.className = 'stage-word'
        button.dataset.wordId = word.id
        button.style.top = `${coordinateToPixel(getWordTop(word))}px`

        if (selectedWord?.id === word.id) {
          button.classList.add('is-selected')
        }

        if (isReachable(word, activeMode)) {
          button.classList.add('is-reachable')
        } else if (word.bottom < activeMode.start) {
          button.classList.add('is-too-high')
        } else {
          button.classList.add('is-below')
        }

        const label = document.createElement('span')
        label.className = 'stage-word-label'
        label.textContent = word.text

        button.append(label)
        wordLayer.append(button)
      })
    }

    const renderModeReadout = () => {
      const activeMode = getActiveMode()
      const selectedWord = getSelectedWord()

      modeReadout.replaceChildren()

      const title = document.createElement('h3')
      title.textContent =
        `${activeMode.title} covers bottom ${formatNumber(activeMode.start)} to ${formatNumber(activeMode.end)}`

      const body = document.createElement('p')
      body.textContent =
        `The square reaches every 1-number word whose bottom is between ` +
        `${formatNumber(activeMode.start)} and ${formatNumber(activeMode.end)}.`

      modeReadout.append(title, body)

      if (!selectedWord) {
        setPlayMessage('Pick a saved word to see whether the square reaches it.')
        return
      }

      if (isReachable(selectedWord, activeMode)) {
        setPlayMessage(
          `${activeMode.title} reaches "${selectedWord.text}". ` +
            `Its bottom is ${formatNumber(selectedWord.bottom)}, so it fits inside that exact range.`,
          'success',
        )
        return
      }

      if (selectedWord.bottom < activeMode.start) {
        setPlayMessage(
          `"${selectedWord.text}" is too high for ${activeMode.title}. ` +
            `Its bottom is ${formatNumber(selectedWord.bottom)}, but this mode starts at ${formatNumber(activeMode.start)}.`,
          'warning',
        )
        return
      }

      setPlayMessage(
        `"${selectedWord.text}" is below the square. ` +
          `Its bottom is ${formatNumber(selectedWord.bottom)}, but this mode ends at ${formatNumber(activeMode.end)}.`,
        'warning',
      )
    }

    const renderStageFrame = () => {
      const bottoms = state.words.map(word => word.bottom)
      const minBottom = Math.min(
        0,
        PLAYER_BODY_TOP,
        ...reachModes.flatMap(mode => [mode.start, mode.end]),
        ...bottoms,
      )
      const maxBottom = Math.max(
        PLAYER_BODY_BOTTOM,
        ...reachModes.flatMap(mode => [mode.start, mode.end]),
        ...bottoms,
        205,
      )

      state.worldTop = Math.floor(minBottom - 8)
      state.worldBottom = Math.ceil(maxBottom + 8)

      const worldHeight = coordinateToPixel(state.worldBottom) + UNIT_PX
      stageWorld.style.height = `${worldHeight}px`

      const activeMode = getActiveMode()
      playerFigure.style.top = `${coordinateToPixel(PLAYER_BODY_TOP)}px`
      playerFigure.style.height = `${PLAYER_BODY_HEIGHT * UNIT_PX}px`
      playerFigure.style.setProperty(
        '--point-offset',
        `${(activeMode.start - PLAYER_BODY_TOP) * UNIT_PX}px`,
      )
      playerFigure.dataset.mode = activeMode.key

      renderWordsOnStage()
    }

    const render = () => {
      ensureSelection()
      renderWordCount()
      renderSelectedSummary()
      renderSavedWords()
      renderStageFrame()
      renderModeReadout()

      modeButtons.querySelectorAll('.mode-button').forEach(button => {
        button.classList.toggle('is-active', button.dataset.mode === state.activeMode)
      })
    }

    const addWord = () => {
      const text = wordInput.value.trim()
      const bottom = Number(bottomInput.value)

      if (!text.length) {
        setFormMessage('Write a word first.', 'warning')
        wordInput.focus()
        return
      }

      if (!Number.isFinite(bottom)) {
        setFormMessage('Give the word a number first.', 'warning')
        bottomInput.focus()
        return
      }

      const nextWord = makeWord(text, bottom)
      state.words.push(nextWord)
      state.selectedId = nextWord.id
      render()
      focusWord(nextWord)

      wordForm.reset()
      wordInput.focus()
      setFormMessage(`Added "${nextWord.text}" at ${formatNumber(nextWord.bottom)}.`, 'success')
    }

    wordForm.addEventListener('submit', event => {
      event.preventDefault()
      addWord()
    })

    addWordButton.addEventListener('click', event => {
      event.preventDefault()
      addWord()
    })

    clearWordsButton.addEventListener('click', () => {
      state.words = []
      state.selectedId = null
      render()
      focusTopLine()
      setFormMessage('Cleared every saved text.', 'warning')
    })

    playButton.addEventListener('click', () => {
      document.querySelector('#game-panel')?.scrollIntoView({
        behavior: 'smooth',
        block: 'start',
      })

      if (!state.words.length) {
        setFormMessage('Add at least one text before you play.', 'warning')
        return
      }

      window.setTimeout(() => {
        showSelectedButton.click()
      }, 350)
    })

    savedWords.addEventListener('click', event => {
      const target = event.target

      if (!(target instanceof HTMLElement)) return

      const selectId = target.closest('[data-select-id]')?.dataset.selectId

      if (selectId) {
        state.selectedId = selectId
        render()
        focusWord(getSelectedWord())
        triggerSquareJump()
        return
      }

      const removeId = target.closest('[data-remove-id]')?.dataset.removeId

      if (removeId) {
        state.words = state.words.filter(word => word.id !== removeId)

        if (state.selectedId === removeId) {
          state.selectedId = null
        }

        render()
      }
    })

    wordLayer.addEventListener('click', event => {
      const target = event.target

      if (!(target instanceof HTMLElement)) return

      const wordId = target.closest('[data-word-id]')?.dataset.wordId

      if (!wordId) return

      state.selectedId = wordId
      render()
      triggerSquareJump()
    })

    modeButtons.addEventListener('click', event => {
      const target = event.target

      if (!(target instanceof HTMLElement)) return

      const modeKey = target.closest('[data-mode]')?.dataset.mode

      if (!modeKey || !modeByKey.has(modeKey)) return

      state.activeMode = modeKey
      render()
      triggerSquareJump()
    })

    showTopButton.addEventListener('click', focusTopLine)

    showSelectedButton.addEventListener('click', () => {
      const selectedWord = getSelectedWord()

      if (!selectedWord) {
        setPlayMessage('Pick a word first so the game can scroll to it.', 'warning')
        return
      }

      focusWord(selectedWord)
      triggerSquareJump()
    })

    render()
    focusTopLine()
  </script>

  <style is:global>
    body {
      margin: 0;
      background:
        radial-gradient(circle at top, rgb(255 244 208 / 0.82), transparent 30%),
        linear-gradient(180deg, rgb(243 249 255) 0%, rgb(222 236 255) 48%, rgb(245 236 224) 100%);
    }

    .reach-lab {
      --ink: rgb(17 35 63);
      --muted: rgb(84 102 134);
      --line: rgb(45 73 118 / 0.14);
      --panel: rgb(255 255 255 / 0.84);
      --cream: rgb(255 247 232);
      --sky: rgb(228 241 255);
      --accent: rgb(203 98 44);
      --accent-deep: rgb(127 53 19);
      --good: rgb(18 121 74);
      --warn: rgb(184 109 23);
      min-height: 100vh;
      padding: 1rem 1rem 7rem;
      color: var(--ink);
      font-family: 'Avenir Next', 'Gill Sans', 'Trebuchet MS', sans-serif;
    }

    .reach-lab h1,
    .reach-lab h2,
    .reach-lab h3,
    .reach-lab p {
      margin: 0;
    }

    .hero-card,
    .panel {
      width: min(1180px, 100%);
      margin: 0 auto;
      border-radius: 30px;
      border: 1px solid var(--line);
      background: var(--panel);
      box-shadow: 0 22px 80px rgb(39 74 122 / 0.16);
      backdrop-filter: blur(18px);
    }

    .hero-card {
      display: grid;
      gap: 1.25rem;
      padding: 1.5rem;
      background:
        radial-gradient(circle at top right, rgb(255 255 255 / 0.85), transparent 34%),
        linear-gradient(135deg, rgb(255 252 244 / 0.92), rgb(232 244 255 / 0.88));
    }

    .eyebrow {
      margin-bottom: 0.45rem;
      color: rgb(31 88 157);
      font-size: 0.82rem;
      font-weight: 900;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .hero-copy h1 {
      font-size: clamp(2rem, 4.3vw, 3.5rem);
      line-height: 0.96;
    }

    .lede {
      max-width: 52rem;
      margin-top: 0.85rem;
      color: var(--muted);
      font-size: 1.03rem;
      line-height: 1.6;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
      gap: 0.9rem;
    }

    .hero-chip {
      display: grid;
      gap: 0.45rem;
      padding: 1rem;
      border-radius: 24px;
      border: 1px solid var(--line);
      background: linear-gradient(180deg, rgb(247 251 255), rgb(255 246 230));
    }

    .hero-chip p {
      color: rgb(52 73 109);
      font-size: 0.92rem;
      font-weight: 900;
