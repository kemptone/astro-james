---
import Layout from '../layouts/Layout.astro'

const reachActions = [
  {
    key: 'bumpHead',
    title: 'Bump Head',
    prompt: 'What do you bump your head on?',
    placeholder: 'Ceiling',
    buttonLabel: 'Bump Head',
  },
  {
    key: 'fullHand',
    title: 'Full Hand',
    prompt: 'What do you reach with your full hand?',
    placeholder: 'Button',
    buttonLabel: 'Full Hand',
  },
  {
    key: 'fingertips',
    title: 'Only Fingertips',
    prompt: 'What do you reach with only your fingertips?',
    placeholder: 'Shelf',
    buttonLabel: 'Fingertips',
  },
  {
    key: 'tiptoes',
    title: 'Tiptoes',
    prompt: 'What do you reach on tiptoes?',
    placeholder: 'Handle',
    buttonLabel: 'Tiptoes',
  },
  {
    key: 'jump',
    title: 'Jump',
    prompt: 'What do you reach when you jump?',
    placeholder: 'Sign',
    buttonLabel: 'Jump',
  },
]
---

<Layout title="Reach Game">
  <main class="reach-page">
    <section id="setup-screen" class="panel intro-panel">
      <div class="headline">
        <p class="eyebrow">Reach Game</p>
        <h1>Set the reach levels, then start the game.</h1>
        <p class="lede">
          Use two decimal places for every setup height. During the game, the
          player only types whole numbers.
        </p>
      </div>

      <form id="setup-form" novalidate>
        <div class="setup-grid">
          {
            reachActions.map(action => (
              <article class="setup-card">
                <h2>{action.title}</h2>
                <label>
                  <span>{action.prompt}</span>
                  <input
                    type="text"
                    name={`${action.key}Target`}
                    placeholder={action.placeholder}
                    autocomplete="off"
                    required
                  />
                </label>

                <label>
                  <span>How high do you need to be?</span>
                  <input
                    type="number"
                    name={`${action.key}Height`}
                    placeholder="4.00"
                    step="0.01"
                    min="0"
                    inputmode="decimal"
                    data-decimal
                    required
                  />
                </label>
              </article>
            ))
          }
        </div>

        <p class="helper-text">Examples: `4.00`, `1.25`, `0.50`</p>
        <p id="setup-error" class="message error" hidden></p>

        <div class="button-row">
          <button type="submit" class="primary-button">Start Game</button>
        </div>
      </form>
    </section>

    <section id="game-screen" class="panel game-panel" hidden>
      <div class="headline">
        <p class="eyebrow">Game Time</p>
        <h1>Make the character higher and try the action buttons.</h1>
        <p class="lede">
          If the typed height goes above the bump-head height, the whole game
          resets.
        </p>
      </div>

      <div class="game-grid">
        <div class="play-area">
          <div id="height-guide" class="height-guide"></div>

          <div id="target-thing" class="target-thing" aria-hidden="true"></div>
          <p id="target-name" class="target-name">Black thing</p>

          <div id="player" class="player" aria-hidden="true">
            <div class="player-head"></div>
            <div class="player-body"></div>
          </div>

          <div class="floor"></div>
        </div>

        <div class="control-panel">
          <div class="readout">
            <p class="readout-label">Current target</p>
            <p id="active-action" class="readout-title">Only Fingertips</p>
            <p id="active-rule" class="readout-value">Black thing at 0.00</p>
          </div>

          <label class="game-input">
            <span>How high are you?</span>
            <input
              id="game-height"
              type="number"
              min="0"
              step="1"
              inputmode="numeric"
              placeholder="1"
              autocomplete="off"
            />
          </label>

          <p class="helper-text">Whole numbers only in the game: 1, 2, 3, 4...</p>

          <div id="action-buttons" class="actions">
            {
              reachActions.map(action => (
                <button
                  type="button"
                  class="action-button"
                  data-action={action.key}
                >
                  {action.buttonLabel}
                </button>
              ))
            }
          </div>

          <div id="rule-list" class="rule-list"></div>

          <p id="game-message" class="message" aria-live="polite">
            Type a whole-number height and press an action button.
          </p>

          <div id="win-panel" class="win-panel" hidden>
            <p>You reached it with your fingertips.</p>
            <a
              href="https://clever.com/in/nvusd"
              target="_blank"
              rel="noreferrer noopener"
            >
              Open Clever NVUSD for eSpark: Devin and Nyla Stuck on the Moon
            </a>
          </div>

          <button id="reset-game" type="button" class="secondary-button">
            Reset Game
          </button>
        </div>
      </div>
    </section>

    <div id="fail-overlay" class="fail-overlay" hidden>
      <div class="fail-text">FAIL</div>
    </div>
  </main>

  <script>
    const reachActions = [
      {
        key: 'bumpHead',
        title: 'Bump Head',
        buttonLabel: 'Bump Head',
        successMessage: target => `You bumped your head on ${target}.`,
      },
      {
        key: 'fullHand',
        title: 'Full Hand',
        buttonLabel: 'Full Hand',
        successMessage: target => `You reached ${target} with your full hand.`,
      },
      {
        key: 'fingertips',
        title: 'Only Fingertips',
        buttonLabel: 'Fingertips',
        successMessage: target => `You reached ${target} with your fingertips.`,
      },
      {
        key: 'tiptoes',
        title: 'Tiptoes',
        buttonLabel: 'Tiptoes',
        successMessage: target => `You reached ${target} on tiptoes.`,
      },
      {
        key: 'jump',
        title: 'Jump',
        buttonLabel: 'Jump',
        successMessage: target => `You reached ${target} when you jumped.`,
      },
    ]

    const setupScreen = document.querySelector('#setup-screen')
    const gameScreen = document.querySelector('#game-screen')
    const setupForm = document.querySelector('#setup-form')
    const setupError = document.querySelector('#setup-error')
    const decimalInputs = document.querySelectorAll('[data-decimal]')
    const actionButtons = document.querySelectorAll('.action-button')
    const ruleList = document.querySelector('#rule-list')
    const gameHeightInput = document.querySelector('#game-height')
    const gameMessage = document.querySelector('#game-message')
    const winPanel = document.querySelector('#win-panel')
    const activeAction = document.querySelector('#active-action')
    const activeRule = document.querySelector('#active-rule')
    const targetThing = document.querySelector('#target-thing')
    const targetName = document.querySelector('#target-name')
    const player = document.querySelector('#player')
    const heightGuide = document.querySelector('#height-guide')
    const failOverlay = document.querySelector('#fail-overlay')
    const resetGameButton = document.querySelector('#reset-game')

    let gameState = null
    let failTimer = 0

    const formatDecimalInput = input => {
      const value = input.value.trim()

      if (!value.length) return

      const parsed = Number(value)

      if (!Number.isFinite(parsed) || parsed < 0) return

      input.value = parsed.toFixed(2)
    }

    const setGameMessage = (text, tone = 'neutral') => {
      gameMessage.textContent = text
      gameMessage.dataset.tone = tone
    }

    const buildHeightGuide = maxHeight => {
      const steps = Math.max(6, Math.ceil(maxHeight))
      const marks = []

      for (let value = steps; value >= 0; value -= 1) {
        marks.push(`<span style="bottom:${(value / steps) * 100}%">${value}</span>`)
      }

      heightGuide.innerHTML = marks.join('')
    }

    const heightToPixels = height => {
      if (!gameState) return 72

      const maxHeight = Math.max(1, gameState.maxHeight)
      const usableSpace = 380
      const clampedHeight = Math.max(0, Math.min(height, maxHeight))

      return 32 + (clampedHeight / maxHeight) * usableSpace
    }

    const updatePlayer = height => {
      const playerHeight = Math.max(88, heightToPixels(height))
      player.style.height = `${playerHeight}px`
    }

    const updateTarget = actionKey => {
      if (!gameState) return

      const action = gameState[actionKey]
      const meta = reachActions.find(item => item.key === actionKey)
      const targetBottom = heightToPixels(action.height)

      targetThing.style.bottom = `${targetBottom}px`
      targetName.style.bottom = `${targetBottom + 48}px`
      targetName.textContent = action.label
      activeAction.textContent = meta.title
      activeRule.textContent = `${action.label} at ${action.height.toFixed(2)}`

      actionButtons.forEach(button => {
        button.classList.toggle('is-active', button.dataset.action === actionKey)
      })
    }

    const renderRuleList = () => {
      if (!gameState) {
        ruleList.innerHTML = ''
        return
      }

      const fragment = document.createDocumentFragment()

      reachActions.forEach(action => {
        const rule = gameState[action.key]
        const row = document.createElement('div')
        const title = document.createElement('span')
        const value = document.createElement('strong')

        row.className = 'rule-item'
        title.textContent = action.title
        value.textContent = `${rule.label} · ${rule.height.toFixed(2)}`

        row.append(title, value)
        fragment.appendChild(row)
      })

      ruleList.replaceChildren(fragment)
    }

    const clearToSetup = () => {
      clearTimeout(failTimer)
      failOverlay.hidden = true
      gameScreen.hidden = true
      setupScreen.hidden = false
      winPanel.hidden = true
      setupForm.reset()
      decimalInputs.forEach(input => {
        input.value = ''
      })
      gameHeightInput.value = ''
      ruleList.innerHTML = ''
      targetName.textContent = 'Black thing'
      targetName.style.bottom = '320px'
      targetThing.style.bottom = '272px'
      activeAction.textContent = 'Only Fingertips'
      activeRule.textContent = 'Black thing at 0.00'
      setGameMessage('Type a whole-number height and press an action button.')
      updatePlayer(0)
      gameState = null
      setupError.hidden = true
      setupError.textContent = ''
    }

    const triggerFail = () => {
      if (!gameState || !failOverlay.hidden) return

      failOverlay.hidden = false
      setGameMessage('FAIL! Resetting the whole game...', 'fail')

      failTimer = window.setTimeout(() => {
        clearToSetup()
      }, 5000)
    }

    const sanitizeWholeNumber = () => {
      const nextValue = gameHeightInput.value.replace(/[^\d]/g, '')

      if (nextValue !== gameHeightInput.value) {
        gameHeightInput.value = nextValue
      }

      const parsed = Number(nextValue)

      if (Number.isFinite(parsed)) {
        updatePlayer(parsed)

        if (gameState && parsed > gameState.bumpHead.height) {
          triggerFail()
        }
      } else {
        updatePlayer(0)
      }
    }

    const collectRules = () => {
      const nextState = {}
      let maxHeight = 1

      for (const action of reachActions) {
        const targetInput = setupForm.querySelector(`[name="${action.key}Target"]`)
        const heightInput = setupForm.querySelector(`[name="${action.key}Height"]`)
        const label = targetInput.value.trim()
        const height = Number(heightInput.value)

        if (!label.length) {
          return {error: `Add what ${action.title.toLowerCase()} reaches first.`}
        }

        if (!Number.isFinite(height) || height < 0) {
          return {error: `Add a valid height for ${action.title}.`}
        }

        targetInput.value = label
        heightInput.value = height.toFixed(2)
        nextState[action.key] = {label, height}
        maxHeight = Math.max(maxHeight, height)
      }

      nextState.maxHeight = maxHeight + 1

      return {state: nextState}
    }

    decimalInputs.forEach(input => {
      input.addEventListener('blur', () => formatDecimalInput(input))
    })

    setupForm.addEventListener('submit', event => {
      event.preventDefault()
      const result = collectRules()

      if (result.error) {
        setupError.hidden = false
        setupError.textContent = result.error
        return
      }

      gameState = result.state
      setupError.hidden = true
      setupError.textContent = ''
      renderRuleList()
      buildHeightGuide(gameState.maxHeight)
      setupScreen.hidden = true
      gameScreen.hidden = false
      winPanel.hidden = true
      gameHeightInput.value = ''
      setGameMessage('Type a whole-number height and press an action button.')
      updatePlayer(0)

      actionButtons.forEach(button => {
        const action = gameState[button.dataset.action]
        const meta = reachActions.find(item => item.key === button.dataset.action)
        button.textContent = `${meta.buttonLabel}: ${action.label}`
      })

      updateTarget('fingertips')
      gameHeightInput.focus()
      window.scrollTo({top: 0, behavior: 'smooth'})
    })

    gameHeightInput.addEventListener('input', sanitizeWholeNumber)

    actionButtons.forEach(button => {
      button.addEventListener('click', () => {
        if (!gameState || failOverlay.hidden === false) return

        const actionKey = button.dataset.action
        const meta = reachActions.find(action => action.key === actionKey)
        const currentHeight = Number.parseInt(gameHeightInput.value, 10)

        updateTarget(actionKey)

        if (!Number.isFinite(currentHeight)) {
          setGameMessage('Type a whole-number height first.', 'warning')
          return
        }

        if (currentHeight > gameState.bumpHead.height) {
          triggerFail()
          return
        }

        const rule = gameState[actionKey]

        if (currentHeight < rule.height) {
          winPanel.hidden = true
          setGameMessage(`It didn't reach ${rule.label}.`, 'warning')
          return
        }

        setGameMessage(meta.successMessage(rule.label), 'success')

        if (actionKey === 'fingertips') {
          winPanel.hidden = false
        } else {
          winPanel.hidden = true
        }
      })
    })

    resetGameButton.addEventListener('click', clearToSetup)

    clearToSetup()
  </script>

  <style is:global>
    body {
      margin: 0;
    }

    .reach-page {
      min-height: 100vh;
      padding: 2rem 1rem 7rem;
      background:
        radial-gradient(circle at top, rgb(255 237 196 / 0.7), transparent 35%),
        linear-gradient(180deg, rgb(247 251 255) 0%, rgb(222 234 255) 55%, rgb(255 248 232) 100%);
      color: rgb(26 32 44);
      font-family: 'Avenir Next', 'Trebuchet MS', sans-serif;
    }

    .panel {
      width: min(1100px, 100%);
      margin: 0 auto;
      padding: 1.5rem;
      border-radius: 32px;
      background: rgb(255 255 255 / 0.82);
      border: 1px solid rgb(36 64 112 / 0.12);
      box-shadow: 0 24px 80px rgb(36 64 112 / 0.18);
      backdrop-filter: blur(18px);
    }

    .headline {
      max-width: 760px;
      margin-bottom: 1.5rem;
    }

    .eyebrow {
      margin: 0 0 0.45rem;
      color: rgb(24 88 150);
      font-size: 0.85rem;
      font-weight: 800;
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }

    .reach-page h1,
    .reach-page h2,
    .reach-page p {
      margin: 0;
    }

    .headline h1 {
      font-size: clamp(2rem, 4vw, 3.4rem);
      line-height: 1.04;
      color: rgb(13 29 56);
    }

    .lede {
      margin-top: 0.85rem;
      font-size: 1.05rem;
      line-height: 1.6;
      color: rgb(67 84 113);
    }

    .setup-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
      gap: 1rem;
    }

    .setup-card {
      display: grid;
      gap: 0.9rem;
      padding: 1rem;
      border-radius: 24px;
      background: linear-gradient(180deg, rgb(246 249 255), rgb(233 242 255));
      border: 1px solid rgb(36 64 112 / 0.12);
    }

    .setup-card h2 {
      font-size: 1.2rem;
      color: rgb(21 48 90);
    }

    .reach-page label {
      display: grid;
      gap: 0.45rem;
      font-weight: 700;
      color: rgb(39 57 87);
    }

    .reach-page label span {
      font-size: 0.92rem;
      line-height: 1.4;
    }

    .reach-page input {
      width: 100%;
      border: 2px solid rgb(177 198 230);
      border-radius: 18px;
      padding: 0.8rem 0.95rem;
      font-size: 1rem;
      color: rgb(18 32 59);
      background: rgb(255 255 255 / 0.95);
      transition:
        border-color 0.2s ease,
        box-shadow 0.2s ease,
        transform 0.2s ease;
    }

    .reach-page input:focus {
      outline: none;
      border-color: rgb(24 88 150);
      box-shadow: 0 0 0 4px rgb(24 88 150 / 0.14);
      transform: translateY(-1px);
    }

    .button-row {
      margin-top: 1rem;
      display: flex;
      justify-content: flex-start;
    }

    .primary-button,
    .secondary-button,
    .action-button {
      border: 0;
      cursor: pointer;
      transition:
        transform 0.2s ease,
        box-shadow 0.2s ease,
        background 0.2s ease;
      font-family: inherit;
    }

    .primary-button,
    .secondary-button {
      padding: 0.95rem 1.4rem;
      border-radius: 999px;
      font-size: 1rem;
      font-weight: 800;
    }

    .primary-button {
      color: white;
      background: linear-gradient(135deg, rgb(24 88 150), rgb(10 126 174));
      box-shadow: 0 16px 30px rgb(24 88 150 / 0.28);
    }

    .secondary-button {
      color: rgb(21 48 90);
      background: rgb(232 239 251);
    }

    .primary-button:hover,
    .secondary-button:hover,
    .action-button:hover {
      transform: translateY(-2px);
    }

    .helper-text {
      margin-top: 1rem;
      color: rgb(86 101 131);
      font-size: 0.96rem;
      line-height: 1.5;
    }

    .message {
      margin-top: 1rem;
      min-height: 1.5rem;
      font-weight: 800;
      color: rgb(42 57 81);
    }

    .message[data-tone='success'] {
      color: rgb(11 126 71);
    }

    .message[data-tone='warning'] {
      color: rgb(180 96 18);
    }

    .message[data-tone='fail'],
    .message.error {
      color: rgb(197 43 43);
    }

    .game-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.4fr) minmax(320px, 0.9fr);
      gap: 1.2rem;
      align-items: start;
    }

    .play-area {
      position: relative;
      min-height: 520px;
      overflow: hidden;
      border-radius: 28px;
      border: 1px solid rgb(36 64 112 / 0.12);
      background:
        linear-gradient(180deg, rgb(225 238 255) 0%, rgb(248 250 255) 50%, rgb(255 244 223) 100%);
    }

    .height-guide {
      position: absolute;
      inset: 1rem auto 1rem 0.75rem;
      width: 56px;
      border-right: 2px dashed rgb(24 88 150 / 0.28);
    }

    .height-guide span {
      position: absolute;
      right: 0.6rem;
      transform: translateY(50%);
      font-size: 0.78rem;
      font-weight: 800;
      color: rgb(44 71 116);
    }

    .target-thing {
      position: absolute;
      right: 14%;
      width: 104px;
      height: 30px;
      border-radius: 14px;
      background: rgb(0 0 0);
      box-shadow: 0 18px 40px rgb(0 0 0 / 0.28);
      transition: bottom 0.25s ease;
    }

    .target-name {
      position: absolute;
      right: 12%;
      width: 140px;
      text-align: center;
      font-weight: 800;
      color: rgb(9 19 36);
      transition: bottom 0.25s ease;
    }

    .player {
      position: absolute;
      left: 18%;
      bottom: 24px;
      width: 94px;
      display: grid;
      grid-template-rows: auto 1fr;
      justify-items: center;
      transition: height 0.2s ease;
    }

    .player-head {
      width: 54px;
      height: 54px;
      border-radius: 50%;
      background: linear-gradient(180deg, rgb(255 218 175), rgb(244 184 120));
      border: 3px solid rgb(39 57 87 / 0.12);
      box-shadow: 0 10px 22px rgb(90 58 24 / 0.18);
    }

    .player-body {
      width: 26px;
      height: calc(100% - 54px);
      min-height: 34px;
      margin-top: 0.5rem;
      border-radius: 20px 20px 14px 14px;
      background:
        linear-gradient(
          180deg,
          rgb(232 82 82) 0 18%,
          rgb(30 95 184) 18% 70%,
          rgb(55 62 84) 70% 100%
        );
      position: relative;
      box-shadow: 0 12px 24px rgb(30 95 184 / 0.16);
    }

    .player-body::before,
    .player-body::after {
      content: '';
      position: absolute;
      top: 18%;
      width: 26px;
      height: 8px;
      border-radius: 999px;
      background: rgb(244 184 120);
    }

    .player-body::before {
      right: calc(100% - 4px);
      transform: rotate(20deg);
      transform-origin: right center;
    }

    .player-body::after {
      left: calc(100% - 4px);
      transform: rotate(-20deg);
      transform-origin: left center;
    }

    .floor {
      position: absolute;
      inset: auto 0 0;
      height: 28px;
      background:
        repeating-linear-gradient(
          90deg,
          rgb(201 154 94) 0 16px,
          rgb(190 142 81) 16px 32px
        );
      border-top: 3px solid rgb(141 97 43);
    }

    .control-panel {
      padding: 1rem;
      border-radius: 28px;
      background: linear-gradient(180deg, rgb(244 248 255), rgb(255 250 239));
      border: 1px solid rgb(36 64 112 / 0.12);
    }

    .readout {
      padding: 1rem;
      border-radius: 22px;
      background: rgb(255 255 255 / 0.88);
      border: 1px solid rgb(36 64 112 / 0.08);
    }

    .readout-label {
      font-size: 0.78rem;
      font-weight: 900;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgb(24 88 150);
    }

    .readout-title {
      margin-top: 0.35rem;
      font-size: 1.35rem;
      font-weight: 900;
      color: rgb(12 31 62);
    }

    .readout-value {
      margin-top: 0.35rem;
      color: rgb(67 84 113);
      line-height: 1.5;
    }

    .game-input {
      margin-top: 1rem;
    }

    .actions {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 0.8rem;
      margin-top: 1rem;
    }

    .action-button {
      padding: 0.95rem 1rem;
      border-radius: 20px;
      font-size: 0.96rem;
      font-weight: 900;
      color: rgb(21 48 90);
      background: rgb(229 237 251);
      box-shadow: inset 0 0 0 1px rgb(36 64 112 / 0.08);
    }

    .action-button.is-active {
      color: white;
      background: linear-gradient(135deg, rgb(232 82 82), rgb(255 133 69));
      box-shadow: 0 16px 26px rgb(232 82 82 / 0.24);
    }

    .rule-list {
      display: grid;
      gap: 0.65rem;
      margin-top: 1rem;
    }

    .rule-item {
      display: flex;
      justify-content: space-between;
      gap: 0.8rem;
      padding: 0.7rem 0.9rem;
      border-radius: 18px;
      background: rgb(255 255 255 / 0.8);
      font-size: 0.94rem;
      color: rgb(48 66 96);
    }

    .rule-item strong {
      color: rgb(12 31 62);
    }

    .win-panel {
      margin-top: 1rem;
      padding: 1rem;
      border-radius: 22px;
      background: rgb(228 255 236);
      border: 1px solid rgb(11 126 71 / 0.2);
    }

    .win-panel p {
      margin-bottom: 0.65rem;
      font-weight: 900;
      color: rgb(7 92 51);
    }

    .win-panel a {
      color: rgb(9 74 137);
      font-weight: 800;
      text-decoration-thickness: 2px;
    }

    .fail-overlay {
      position: fixed;
      inset: 0;
      display: grid;
      place-items: center;
      background: rgb(255 255 255 / 0.74);
      backdrop-filter: blur(8px);
      z-index: 2000;
    }

    .fail-overlay[hidden] {
      display: none;
    }

    .fail-text {
      color: rgb(226 28 28);
      font-family: Helvetica, Arial, sans-serif;
      font-size: 100pt;
