---
import Layout from '@/layouts/Layout.astro'
---

<Layout title="Camila">
  <main class="camila-shell">
    <section class="hero">
      <p class="eyebrow">Video Game</p>
      <h1>Camila</h1>
      <p class="rating" aria-label="Camila rating four out of five stars">★★★★☆</p>
      <p class="intro">
        The camera is upside down on purpose, so everybody looks like they are
        standing on the ceiling. The live preview stays upside down, but the
        saved film comes out right side up with sound.
      </p>
    </section>

    <section class="studio">
      <div class="stage-card">
        <div class="stage-header">
          <div>
            <h2>Ceiling Camera</h2>
            <p>Start the camera, record a clip, and make your videos.</p>
          </div>
          <p class="status" id="statusText" aria-live="polite">Ready</p>
        </div>

        <div class="stage-frame">
          <canvas id="previewCanvas" class="preview" aria-label="Camera preview"></canvas>
          <canvas id="outputCanvas" class="output-canvas" aria-hidden="true"></canvas>
          <video id="sourceVideo" class="source-video" autoplay muted playsinline></video>
        </div>

        <div class="camera-row">
          <label class="camera-picker">
            <span>Camera</span>
            <select id="cameraFacingSelect" class="picker-input">
              <option value="front">Front camera</option>
              <option value="back">Back camera</option>
            </select>
          </label>
        </div>

        <div class="controls">
          <button id="startButton" class="button button-primary" type="button">
            Start Camera
          </button>
          <button id="recordButton" class="button button-record" type="button" disabled>
            Record
          </button>
          <button id="stopButton" class="button" type="button" disabled>
            Stop
          </button>
          <button id="resetButton" class="button" type="button">
            Reset
          </button>
        </div>
      </div>

      <div class="saved-card">
        <div class="saved-header">
          <div>
            <h2>Last Video</h2>
            <p>Your saved clip plays right side up and keeps the sound.</p>
          </div>
        </div>

        <video
          id="playbackVideo"
          class="playback"
          controls
          playsinline
          preload="metadata"
        ></video>

        <div class="controls">
          <button id="shareButton" class="button button-primary" type="button" disabled>
            Share
          </button>
          <button id="saveButton" class="button" type="button" disabled>
            Save Video
          </button>
        </div>
      </div>
    </section>
  </main>

  <style>
    :global(body) {
      margin: 0;
      background:
        radial-gradient(circle at top, rgba(255, 226, 164, 0.28), transparent 34%),
        linear-gradient(180deg, #11253f 0%, #17345a 42%, #f4efe4 42%, #f7f1e5 100%);
      color: #142033;
      font-family:
        "Avenir Next Condensed",
        "Trebuchet MS",
        "Gill Sans",
        sans-serif;
    }

    .camila-shell {
      min-height: 100svh;
      padding: 5.5rem 1.25rem 2rem;
    }

    .hero {
      max-width: 42rem;
      margin: 0 auto 1.5rem;
      text-align: center;
    }

    .eyebrow {
      margin: 0;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #f7f1e5;
    }

    h1,
    h2,
    p {
      margin: 0;
    }

    h1 {
      margin-top: 0.35rem;
      font-size: clamp(2.8rem, 7vw, 5.2rem);
      line-height: 0.95;
      color: #fff7e8;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      text-shadow: 0 10px 26px rgba(8, 18, 31, 0.28);
    }

    .intro {
      margin: 0.9rem auto 0;
      max-width: 34rem;
      font-size: 1.05rem;
      line-height: 1.5;
      color: rgba(255, 247, 232, 0.92);
    }

    .rating {
      margin-top: 0.55rem;
      font-size: 1.4rem;
      letter-spacing: 0.2em;
      color: #ffd36c;
      text-shadow: 0 4px 16px rgba(9, 20, 34, 0.22);
    }

    .studio {
      display: grid;
      gap: 1rem;
      max-width: 72rem;
      margin: 0 auto;
    }

    .stage-card,
    .saved-card {
      border: 1px solid rgba(20, 32, 51, 0.12);
      border-radius: 1.75rem;
      background: rgba(255, 249, 239, 0.94);
      box-shadow: 0 26px 60px rgba(18, 34, 53, 0.16);
      overflow: hidden;
    }

    .stage-header,
    .saved-header {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: start;
      padding: 1.2rem 1.2rem 0;
    }

    .stage-header p,
    .saved-header p {
      color: #445064;
      line-height: 1.45;
    }

    .status {
      flex-shrink: 0;
      padding: 0.55rem 0.8rem;
      border-radius: 999px;
      background: #17345a;
      color: #fff7e8;
      font-weight: 700;
      font-size: 0.92rem;
    }

    .stage-frame {
      padding: 1rem 1rem 0;
    }

    .preview,
    .playback {
      display: block;
      width: 100%;
      height: clamp(18rem, 42vw, 32rem);
      background:
        linear-gradient(135deg, rgba(255, 209, 110, 0.18), rgba(30, 102, 174, 0.24)),
        #0e1a2b;
      border-radius: 1.4rem;
      object-fit: cover;
    }

    .source-video {
      display: none;
    }

    .output-canvas {
      display: none;
    }

    .camera-row {
      padding: 0.9rem 1rem 0;
    }

    .camera-picker {
      display: inline-flex;
      align-items: center;
      gap: 0.7rem;
      flex-wrap: wrap;
      color: #17345a;
      font-weight: 700;
    }

    .camera-picker span {
      font-size: 0.95rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .picker-input {
      appearance: none;
      border: 0;
      border-radius: 999px;
      padding: 0.8rem 2.8rem 0.8rem 1rem;
      background:
        linear-gradient(135deg, rgba(214, 227, 241, 0.96), rgba(193, 213, 236, 0.96));
      color: #17345a;
      font: inherit;
      font-weight: 700;
      cursor: pointer;
    }

    .playback {
      margin: 1rem;
      width: calc(100% - 2rem);
    }

    .controls {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      padding: 1rem 1rem 1.1rem;
    }

    .button {
      appearance: none;
      border: 0;
      border-radius: 999px;
      padding: 0.9rem 1.2rem;
      background: #d8e3ee;
      color: #17345a;
      font: inherit;
      font-weight: 700;
      cursor: pointer;
      transition:
        transform 140ms ease,
        opacity 140ms ease,
        background 140ms ease;
    }

    .button:hover:enabled {
      transform: translateY(-1px);
    }

    .button:disabled {
      opacity: 0.45;
      cursor: not-allowed;
      transform: none;
    }

    .button-primary {
      background: #17345a;
      color: #fff7e8;
    }

    .button-record {
      background: #c74634;
      color: #fff7e8;
    }

    @media (min-width: 60rem) {
      .studio {
        grid-template-columns: minmax(0, 1.2fr) minmax(19rem, 0.8fr);
        align-items: start;
      }

      .playback {
        aspect-ratio: 4 / 5;
      }
    }
  </style>

  <script>
    const previewCanvas = document.getElementById('previewCanvas')
    const outputCanvas = document.getElementById('outputCanvas')
    const sourceVideo = document.getElementById('sourceVideo')
    const playbackVideo = document.getElementById('playbackVideo')
    const statusText = document.getElementById('statusText')
    const startButton = document.getElementById('startButton')
    const recordButton = document.getElementById('recordButton')
    const stopButton = document.getElementById('stopButton')
    const cameraFacingSelect = document.getElementById('cameraFacingSelect')
    const shareButton = document.getElementById('shareButton')
    const saveButton = document.getElementById('saveButton')
    const resetButton = document.getElementById('resetButton')

    const previewContext = previewCanvas.getContext('2d')
    const outputContext = outputCanvas.getContext('2d')

    const state = {
      cameraStream: null,
      audioStream: null,
      mediaRecorder: null,
      chunks: [],
      recordedBlob: null,
      playbackUrl: '',
      downloadUrls: new Set(),
      drawFrameId: 0,
      isDrawing: false,
      isRecording: false,
      mimeType: '',
    }

    const setStatus = text => {
      statusText.textContent = text
    }

    const getCameraConstraints = () => {
      const selected = cameraFacingSelect?.value === 'back' ? 'environment' : 'user'
      return {
        facingMode: { ideal: selected },
      }
    }

    const pickMimeType = () => {
      const choices = [
        'video/mp4',
        'video/webm;codecs=vp9,opus',
        'video/webm;codecs=vp8,opus',
        'video/webm',
      ]

      return choices.find(type => MediaRecorder.isTypeSupported(type)) || ''
    }

    const revokePlaybackUrl = () => {
      if (!state.playbackUrl) return
      URL.revokeObjectURL(state.playbackUrl)
      state.playbackUrl = ''
    }

    const cleanupDownloadUrls = () => {
      state.downloadUrls.forEach(url => URL.revokeObjectURL(url))
      state.downloadUrls.clear()
    }

    const stopTracks = stream => {
      stream?.getTracks().forEach(track => track.stop())
    }

    const clearRecording = () => {
      state.recordedBlob = null
      shareButton.disabled = true
      saveButton.disabled = true
      playbackVideo.removeAttribute('src')
      playbackVideo.load()
      revokePlaybackUrl()
    }

    const stopDrawing = () => {
      if (state.drawFrameId) {
        cancelAnimationFrame(state.drawFrameId)
        state.drawFrameId = 0
      }
      state.isDrawing = false
    }

    const drawPreview = () => {
      if (!previewContext || !outputContext || sourceVideo.readyState < 2) {
        state.drawFrameId = requestAnimationFrame(drawPreview)
        return
      }

      const { width, height } = previewCanvas
      previewContext.clearRect(0, 0, width, height)
      previewContext.save()
      previewContext.translate(width, height)
      previewContext.rotate(Math.PI)
      previewContext.drawImage(sourceVideo, 0, 0, width, height)
      previewContext.restore()

      outputContext.clearRect(0, 0, width, height)
      outputContext.drawImage(sourceVideo, 0, 0, width, height)
      state.drawFrameId = requestAnimationFrame(drawPreview)
    }

    const startDrawing = () => {
      if (state.isDrawing) return
      state.isDrawing = true
      drawPreview()
    }

    const configureCanvas = () => {
      const width = sourceVideo.videoWidth || 720
      const height = sourceVideo.videoHeight || 1280
      previewCanvas.width = width
      previewCanvas.height = height
      outputCanvas.width = width
      outputCanvas.height = height
      startDrawing()
    }

    const resetRecorderState = () => {
      if (state.mediaRecorder && state.isRecording) {
        state.mediaRecorder.ondataavailable = null
        state.mediaRecorder.onstop = null
        state.mediaRecorder.onerror = null
        try {
          state.mediaRecorder.stop()
        } catch {
          // Ignore stop errors during reset.
        }
      }

      state.mediaRecorder = null
      state.isRecording = false
      state.chunks = []
      recordButton.textContent = 'Record'
      recordButton.disabled = !state.cameraStream
      stopButton.disabled = true
    }

    const stopCameraSession = () => {
      resetRecorderState()
      stopDrawing()
      stopTracks(state.cameraStream)
      state.cameraStream = null
      sourceVideo.srcObject = null
      previewContext?.clearRect(0, 0, previewCanvas.width, previewCanvas.height)
      outputContext?.clearRect(0, 0, outputCanvas.width, outputCanvas.height)
      startButton.disabled = false
      recordButton.disabled = true
    }

    const fullReset = () => {
      stopCameraSession()
      stopTracks(state.audioStream)
      state.audioStream = null
      clearRecording()
      setStatus('Ready')
    }

    const ensureAudioStream = async () => {
      if (state.audioStream?.getAudioTracks().some(track => track.readyState === 'live')) {
        return state.audioStream
      }

      const stream = await navigator.mediaDevices.getUserMedia({
        audio: true,
      })

      state.audioStream = stream
      return stream
    }

    const buildRecordingStream = async () => {
      const audioStream = await ensureAudioStream()
      const canvasStream = outputCanvas.captureStream(30)
      const videoTracks = canvasStream.getVideoTracks()
      const audioTracks = audioStream.getAudioTracks().map(track => track.clone())
      return new MediaStream([...videoTracks, ...audioTracks])
    }

    const showRecording = blob => {
      revokePlaybackUrl()
      state.playbackUrl = URL.createObjectURL(blob)
      playbackVideo.src = state.playbackUrl
      shareButton.disabled = false
      saveButton.disabled = false
    }

    const startCamera = async () => {
      if (!navigator.mediaDevices?.getUserMedia) {
        setStatus('Camera not supported')
        return
      }

      stopCameraSession()
      setStatus('Requesting camera...')

      try {
        const stream = await navigator.mediaDevices.getUserMedia({
          video: getCameraConstraints(),
        })

        state.cameraStream = stream
        sourceVideo.srcObject = stream
        sourceVideo.playsInline = true
        sourceVideo.muted = true
        await sourceVideo.play().catch(() => {})

        if (sourceVideo.readyState < 1) {
          await new Promise(resolve => {
            sourceVideo.onloadedmetadata = () => resolve()
          })
        }

        configureCanvas()
        startButton.disabled = true
        recordButton.disabled = false
        setStatus('Camera ready upside down')
      } catch (error) {
        console.error('Camera start failed', error)
        setStatus('Camera blocked - check browser camera permission')
      }
    }

    const startRecording = () => {
      if (!state.cameraStream || state.isRecording) return

      ;(async () => {
        clearRecording()
        state.chunks = []
        state.mimeType = pickMimeType()

        let recordingStream
        try {
          recordingStream = await buildRecordingStream()
        } catch (error) {
          console.error('Microphone start failed', error)
          setStatus('Microphone blocked - allow mic to record sound')
          return
        }

        state.mediaRecorder = new MediaRecorder(
          recordingStream,
          state.mimeType ? { mimeType: state.mimeType } : undefined,
        )

        const recordedType = state.mediaRecorder.mimeType || state.mimeType || 'video/webm'

        state.mediaRecorder.ondataavailable = event => {
          if (event.data?.size) {
            state.chunks.push(event.data)
          }
        }

        state.mediaRecorder.onstop = () => {
          state.recordedBlob = new Blob(state.chunks, { type: recordedType })
          state.mediaRecorder = null
          state.isRecording = false
          stopTracks(recordingStream)
          recordButton.textContent = 'Record'
          stopButton.disabled = true
          recordButton.disabled = false
          showRecording(state.recordedBlob)
          setStatus('Film ready to save')
        }

        state.mediaRecorder.onerror = error => {
          console.error('Recording failed', error)
          setStatus('Recording failed')
          resetRecorderState()
          stopTracks(recordingStream)
        }

        // Record from a non-flipped canvas so the final film is right side up.
        state.mediaRecorder.start(250)
        state.isRecording = true
        recordButton.textContent = 'Recording...'
        recordButton.disabled = true
        stopButton.disabled = false
        setStatus('Recording right side up film with sound')
      })()
    }

    const stopRecording = () => {
      if (!state.mediaRecorder || !state.isRecording) return
      state.mediaRecorder.requestData()
      state.mediaRecorder.stop()
      setStatus('Finishing video...')
    }

    const buildFile = () => {
      if (!state.recordedBlob) return null
      const extension = state.recordedBlob.type.includes('mp4') ? 'mp4' : 'webm'
      const stamp = new Date().toISOString().replace(/[:.]/g, '-')
      return new File([state.recordedBlob], `Camila-${stamp}.${extension}`, {
        type: state.recordedBlob.type || 'video/webm',
      })
    }

    const saveVideo = () => {
      const file = buildFile()
      if (!file) return

      const downloadUrl = URL.createObjectURL(file)
      state.downloadUrls.add(downloadUrl)
      const link = document.createElement('a')
      link.href = downloadUrl
      link.download = file.name
      document.body.appendChild(link)
      link.click()
      link.remove()
      // Keep the object URL alive long enough for larger high-quality files to finish.
      setTimeout(() => {
        URL.revokeObjectURL(downloadUrl)
        state.downloadUrls.delete(downloadUrl)
      }, 60000)
      setStatus('Video saved')
    }

    const shareVideo = async () => {
      const file = buildFile()
      if (!file) return

      try {
        if (navigator.canShare && navigator.canShare({ files: [file] })) {
          await navigator.share({
            files: [file],
            title: 'Camila',
          })
          setStatus('Video shared')
          return
        }
      } catch (error) {
        console.error('Share failed', error)
      }

      saveVideo()
    }

    startButton.addEventListener('click', startCamera)
    recordButton.addEventListener('click', startRecording)
    stopButton.addEventListener('click', stopRecording)
    cameraFacingSelect.addEventListener('change', () => {
      if (state.cameraStream) {
        startCamera()
      }
    })
    shareButton.addEventListener('click', shareVideo)
    saveButton.addEventListener('click', saveVideo)
    resetButton.addEventListener('click', fullReset)

    window.addEventListener('pagehide', () => {
      cleanupDownloadUrls()
      fullReset()
    })
  </script>
</Layout>
