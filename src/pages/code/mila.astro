      </div>
    </details>
    <h2>You're almost there, just talk about Recha</h2>
    <input placeholder="Postpon" type="text" />
    <h1>1 more thing!!!</h1>
    <h3>were you on the roof?</h3>
    <button type="reset">Yes</button>
    <button>No</button>
    <h1>End</h1>
