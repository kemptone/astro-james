  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
  </head>
  <body>
    <Menu />
    <h1>how many feet is each thing? measure</h1>
    <input type="text" /> Fan circle
    <br />
    <input type="text" /> Corner
    <br />
    <input type="text" /> Absolute corner (2)
    <br />
    <input type="text" /> Skylight window
    <br />
    <input type="text" /> Tippy top <input
      placeholder="Tippy top"
      type="text"
    />
    <br />
    <input type="text" /> Half slope
    <br />
    <input type="text" />
    <input type="checkbox" name="" id="" />
    <br />
    <textarea placeholder="Notes" name="" id="" rows="10"></textarea>
    <h2>Prizer</h2>
    <h4>Tell us the turkey type you are</h4>
    <select name="" id="">
      <option value=""> </option>
      <option value="">Tiny Turkey</option>
      <option value="">Slight Turkey</option>
      <option selected value="">Default</option>
      <option value="">Profesional Turkey</option>
      <option value="">Extreme Turkey</option>
      <option value="">X Turkey</option>
