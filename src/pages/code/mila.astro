        <h5>what is your rare hog's name?</h5>
      </div>
    </details>
    <button>Name app</button>
    <input value="128 128 255" type="color" name="" id="" />
    <i>Book Of The Name</i>
    <h3>Dark Library</h3>
    <input type="file" name="" id="" />
    <h6>tell us the best part</h6>
    <textarea name="" id="" cols="30" rows="10"></textarea>
    <br />
    <button></button>
    <br />
    <button></button>
    <br />
    <button></button>
    <br />
    <button></button>
    <br />
    <button></button>
    <input placeholder="Code" type="text" />
    <h4>Hint:</h4>
    <h6>open Z</h6>
    <input type="text" />
    <h2>you've passed!</h2>
    <html xmlns="http://www.w3.org/1999/xhtml"></html>
    <h2>You won!!!</h2>
    play <input type="text" /> all the time to unlock <i>way</i> down here
