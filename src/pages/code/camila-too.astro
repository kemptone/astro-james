---
import Layout from '@/layouts/Layout.astro'
---

<Layout title="Camila Too">
  <main class="camila-shell">
    <section class="hero">
      <p class="eyebrow">Photo Game</p>
      <h1>Camila Too</h1>
      <p class="rating" aria-label="Camila Too rating four out of five stars">★★★★☆</p>
      <p class="intro">
        The live camera is upside down on purpose. When you snap a photo, it
        spins 180 degrees back to right side up like a magic trick.
      </p>
    </section>

    <section class="studio">
      <div class="stage-card">
        <div class="stage-header">
          <div>
            <h2>Ceiling Camera</h2>
            <p>Start the camera and snap a picture from the upside-down view.</p>
          </div>
          <p class="status" id="statusText" aria-live="polite">Ready</p>
        </div>

        <div class="stage-frame">
          <canvas id="previewCanvas" class="preview" aria-label="Camera preview"></canvas>
          <video id="sourceVideo" class="source-video" autoplay muted playsinline></video>
        </div>

        <div class="camera-row">
          <label class="camera-picker">
            <span>Camera</span>
            <select id="cameraFacingSelect" class="picker-input">
              <option value="front">Front camera</option>
              <option value="back">Back camera</option>
            </select>
          </label>
        </div>

        <div class="controls">
          <button id="startButton" class="button button-primary" type="button">
            Start Camera
          </button>
          <button id="captureButton" class="button button-record" type="button" disabled>
            Take Photo
          </button>
          <button id="resetButton" class="button" type="button">
            Reset
          </button>
        </div>
      </div>

      <div class="saved-card">
        <div class="saved-header">
          <div>
            <h2>Magic Photo</h2>
            <p>This photo stays on this page and does not send anywhere.</p>
          </div>
        </div>

        <div class="playback photo-stage">
          <img
            id="capturedPhoto"
            class="captured-photo"
            alt="Latest magic photo"
          />
          <p id="photoPlaceholder" class="photo-placeholder">
            Take a photo to watch it flip back upright.
          </p>
        </div>
      </div>
    </section>
  </main>

  <style>
    :global(body) {
      margin: 0;
      background:
        radial-gradient(circle at top, rgba(255, 226, 164, 0.28), transparent 34%),
        linear-gradient(180deg, #11253f 0%, #17345a 42%, #f4efe4 42%, #f7f1e5 100%);
      color: #142033;
      font-family:
        "Avenir Next Condensed",
        "Trebuchet MS",
        "Gill Sans",
        sans-serif;
    }

    .camila-shell {
      min-height: 100svh;
      padding: 5.5rem 1.25rem 2rem;
    }

    .hero {
      max-width: 42rem;
      margin: 0 auto 1.5rem;
      text-align: center;
    }

    .eyebrow {
      margin: 0;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #f7f1e5;
    }

    h1,
    h2,
    p {
      margin: 0;
    }

    h1 {
      margin-top: 0.35rem;
      font-size: clamp(2.8rem, 7vw, 5.2rem);
      line-height: 0.95;
      color: #fff7e8;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      text-shadow: 0 10px 26px rgba(8, 18, 31, 0.28);
    }

    .intro {
      margin: 0.9rem auto 0;
      max-width: 34rem;
      font-size: 1.05rem;
      line-height: 1.5;
      color: rgba(255, 247, 232, 0.92);
    }

    .rating {
      margin-top: 0.55rem;
      font-size: 1.4rem;
      letter-spacing: 0.2em;
      color: #ffd36c;
      text-shadow: 0 4px 16px rgba(9, 20, 34, 0.22);
    }

    .studio {
      display: grid;
      gap: 1rem;
      max-width: 72rem;
      margin: 0 auto;
    }

    .stage-card,
    .saved-card {
      border: 1px solid rgba(20, 32, 51, 0.12);
      border-radius: 1.75rem;
      background: rgba(255, 249, 239, 0.94);
      box-shadow: 0 26px 60px rgba(18, 34, 53, 0.16);
      overflow: hidden;
    }

    .stage-header,
    .saved-header {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: start;
      padding: 1.2rem 1.2rem 0;
    }

    .stage-header p,
    .saved-header p {
      color: #445064;
      line-height: 1.45;
    }

    .status {
      flex-shrink: 0;
      padding: 0.55rem 0.8rem;
      border-radius: 999px;
      background: #17345a;
      color: #fff7e8;
      font-weight: 700;
      font-size: 0.92rem;
    }

    .stage-frame {
      padding: 1rem 1rem 0;
    }

    .preview,
    .playback {
      display: block;
      width: 100%;
      height: clamp(18rem, 42vw, 32rem);
      background:
        linear-gradient(135deg, rgba(255, 209, 110, 0.18), rgba(30, 102, 174, 0.24)),
        #0e1a2b;
      border-radius: 1.4rem;
      object-fit: cover;
    }

    .source-video {
      display: none;
    }

    .camera-row {
      padding: 0.9rem 1rem 0;
    }

    .camera-picker {
      display: inline-flex;
      align-items: center;
      gap: 0.7rem;
      flex-wrap: wrap;
      color: #17345a;
      font-weight: 700;
    }

    .camera-picker span {
      font-size: 0.95rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .picker-input {
      appearance: none;
      border: 0;
      border-radius: 999px;
      padding: 0.8rem 2.8rem 0.8rem 1rem;
      background:
        linear-gradient(135deg, rgba(214, 227, 241, 0.96), rgba(193, 213, 236, 0.96));
      color: #17345a;
      font: inherit;
      font-weight: 700;
      cursor: pointer;
    }

    .playback {
      margin: 1rem;
      width: calc(100% - 2rem);
    }

    .photo-stage {
      position: relative;
      overflow: hidden;
      display: grid;
      place-items: center;
    }

    .captured-photo {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: none;
      transform-origin: center center;
      backface-visibility: hidden;
      filter: saturate(1.04);
    }

    .captured-photo.is-visible {
      display: block;
    }

    .captured-photo.is-spinning {
      animation: magic-flip 5s cubic-bezier(0.2, 0.9, 0.18, 1);
    }

    .photo-placeholder {
      position: absolute;
      inset: auto 1.25rem 1.25rem;
      margin: 0;
      padding: 0.7rem 1rem;
      border-radius: 999px;
      background: rgba(20, 32, 51, 0.78);
      color: #fff7e8;
      font-weight: 700;
      text-align: center;
      box-shadow: 0 12px 30px rgba(8, 18, 31, 0.2);
    }

    .photo-placeholder.is-hidden {
      display: none;
    }

    @keyframes magic-flip {
      0% {
        transform: rotate(180deg) scale(0.94);
      }

      65% {
        transform: rotate(-12deg) scale(1);
      }

      100% {
        transform: rotate(0deg) scale(1);
      }
    }

    .controls {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      padding: 1rem 1rem 1.1rem;
    }

    .button {
      appearance: none;
      border: 0;
      border-radius: 999px;
      padding: 0.9rem 1.2rem;
      background: #d8e3ee;
      color: #17345a;
      font: inherit;
      font-weight: 700;
      cursor: pointer;
      transition:
        transform 140ms ease,
        opacity 140ms ease,
        background 140ms ease;
    }

    .button:hover:enabled {
      transform: translateY(-1px);
    }

    .button:disabled {
      opacity: 0.45;
      cursor: not-allowed;
      transform: none;
    }

    .button-primary {
      background: #17345a;
      color: #fff7e8;
    }

    .button-record {
      background: #c74634;
      color: #fff7e8;
    }

    @media (min-width: 60rem) {
      .studio {
        grid-template-columns: minmax(0, 1.2fr) minmax(19rem, 0.8fr);
        align-items: start;
      }

      .playback {
        aspect-ratio: 4 / 5;
      }
    }
  </style>

  <script>
    const previewCanvas = document.getElementById('previewCanvas')
    const sourceVideo = document.getElementById('sourceVideo')
    const capturedPhoto = document.getElementById('capturedPhoto')
    const photoPlaceholder = document.getElementById('photoPlaceholder')
    const statusText = document.getElementById('statusText')
    const startButton = document.getElementById('startButton')
    const captureButton = document.getElementById('captureButton')
    const cameraFacingSelect = document.getElementById('cameraFacingSelect')
    const resetButton = document.getElementById('resetButton')

    const previewContext = previewCanvas.getContext('2d')
    const snapshotCanvas = document.createElement('canvas')
    const snapshotContext = snapshotCanvas.getContext('2d')

    const state = {
      cameraStream: null,
      drawFrameId: 0,
      isDrawing: false,
    }

    const setStatus = text => {
      statusText.textContent = text
    }

    const getCameraConstraints = () => {
      const selected = cameraFacingSelect?.value === 'back' ? 'environment' : 'user'
      return {
        facingMode: { ideal: selected },
      }
    }

    const stopTracks = stream => {
      stream?.getTracks().forEach(track => track.stop())
    }

    const clearPhoto = () => {
      capturedPhoto.removeAttribute('src')
      capturedPhoto.classList.remove('is-visible', 'is-spinning')
      photoPlaceholder.classList.remove('is-hidden')
    }

    const stopDrawing = () => {
      if (state.drawFrameId) {
        cancelAnimationFrame(state.drawFrameId)
        state.drawFrameId = 0
      }
      state.isDrawing = false
    }

    const drawPreview = () => {
      if (!previewContext || sourceVideo.readyState < 2) {
        state.drawFrameId = requestAnimationFrame(drawPreview)
        return
      }

      const { width, height } = previewCanvas
      previewContext.clearRect(0, 0, width, height)
      previewContext.save()
      previewContext.translate(width, height)
      previewContext.rotate(Math.PI)
      previewContext.drawImage(sourceVideo, 0, 0, width, height)
      previewContext.restore()
      state.drawFrameId = requestAnimationFrame(drawPreview)
    }

    const startDrawing = () => {
      if (state.isDrawing) return
      state.isDrawing = true
      drawPreview()
    }

    const configureCanvas = () => {
      const width = sourceVideo.videoWidth || 720
      const height = sourceVideo.videoHeight || 1280
      previewCanvas.width = width
      previewCanvas.height = height
      snapshotCanvas.width = width
      snapshotCanvas.height = height
      startDrawing()
    }

    const stopCameraSession = () => {
      stopDrawing()
      stopTracks(state.cameraStream)
      state.cameraStream = null
      sourceVideo.srcObject = null
      previewContext?.clearRect(0, 0, previewCanvas.width, previewCanvas.height)
      startButton.disabled = false
      captureButton.disabled = true
    }

    const fullReset = () => {
      stopCameraSession()
      clearPhoto()
      setStatus('Ready')
    }

    const startCamera = async () => {
      if (!navigator.mediaDevices?.getUserMedia) {
        setStatus('Camera not supported')
        return
      }

      stopCameraSession()
      setStatus('Requesting camera...')

      try {
        const stream = await navigator.mediaDevices.getUserMedia({
          video: getCameraConstraints(),
        })

        state.cameraStream = stream
        sourceVideo.srcObject = stream
        sourceVideo.playsInline = true
        sourceVideo.muted = true
        await sourceVideo.play().catch(() => {})

        if (sourceVideo.readyState < 1) {
          await new Promise(resolve => {
            sourceVideo.onloadedmetadata = () => resolve()
          })
        }

        configureCanvas()
        startButton.disabled = true
        captureButton.disabled = false
        setStatus('Camera ready upside down')
      } catch (error) {
        console.error('Camera start failed', error)
        setStatus('Camera blocked - check browser camera permission')
      }
    }

    const takePhoto = () => {
      if (!state.cameraStream || sourceVideo.readyState < 2 || !snapshotContext) {
        setStatus('Wait for the camera first')
        return
      }

      const width = snapshotCanvas.width || sourceVideo.videoWidth || 720
      const height = snapshotCanvas.height || sourceVideo.videoHeight || 1280
      snapshotCanvas.width = width
      snapshotCanvas.height = height
      snapshotContext.clearRect(0, 0, width, height)
      snapshotContext.drawImage(sourceVideo, 0, 0, width, height)

      const dataUrl = snapshotCanvas.toDataURL('image/jpeg', 0.92)
      capturedPhoto.classList.remove('is-spinning')
      capturedPhoto.src = dataUrl
      capturedPhoto.classList.add('is-visible')
      photoPlaceholder.classList.add('is-hidden')

      // Restart the flip so each new photo gets the same trick effect.
      void capturedPhoto.offsetWidth
      capturedPhoto.classList.add('is-spinning')
      setStatus('Magic photo flipped right side up')
    }

    startButton.addEventListener('click', startCamera)
    captureButton.addEventListener('click', takePhoto)
    cameraFacingSelect.addEventListener('change', () => {
      if (state.cameraStream) {
        startCamera()
      }
    })
    resetButton.addEventListener('click', fullReset)

    window.addEventListener('pagehide', fullReset)
  </script>
</Layout>
