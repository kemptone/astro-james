---
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Color Fader</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: system-ui, sans-serif;
        background: #1a1a2e;
        color: #eee;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      #display {
        flex: 1;
        display: flex;
        min-height: 60vh;
        transition: none;
      }

      #left-half, #right-half {
        flex: 1;
        transition: background-color 1s linear;
      }

      #controls {
        background: #16213e;
        padding: 20px;
        border-top: 2px solid #0f3460;
      }

      .control-section {
        margin-bottom: 16px;
      }

      .control-section h3 {
        margin-bottom: 8px;
        font-size: 14px;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #e94560;
      }

      .rgb-row {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
      }

      .rgb-row label {
        font-size: 13px;
        font-weight: bold;
        width: 16px;
      }

      .rgb-row input[type="number"] {
        width: 64px;
        padding: 6px 8px;
        border: 1px solid #0f3460;
        border-radius: 4px;
        background: #1a1a2e;
        color: #eee;
        font-size: 14px;
        text-align: center;
      }

      .rgb-row input[type="number"]:focus {
        outline: none;
        border-color: #e94560;
      }

      .preview-swatch {
        width: 36px;
        height: 36px;
        border-radius: 4px;
        border: 2px solid #333;
        display: inline-block;
      }

      .add-section {
        display: flex;
        gap: 20px;
        align-items: flex-end;
        flex-wrap: wrap;
      }

      .side-inputs {
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .side-inputs h4 {
        font-size: 12px;
        color: #aaa;
        margin-bottom: 2px;
      }

      button {
        padding: 8px 20px;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-size: 14px;
        font-weight: bold;
      }

      #add-btn {
        background: #e94560;
        color: white;
        align-self: center;
      }

      #add-btn:hover {
        background: #c73652;
      }

      #clear-btn {
        background: #333;
        color: #ccc;
        align-self: center;
      }

      #clear-btn:hover {
        background: #444;
      }

      #start-btn {
        background: #0f3460;
        color: white;
        align-self: center;
      }

      #start-btn:hover {
        background: #1a4a7a;
      }

      #color-list {
        margin-top: 12px;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .color-entry {
        display: flex;
        align-items: center;
        gap: 6px;
        background: #1a1a2e;
        padding: 6px 10px;
        border-radius: 4px;
        font-size: 12px;
        border: 1px solid #0f3460;
      }

      .color-entry .swatch {
        width: 20px;
        height: 20px;
        border-radius: 3px;
        border: 1px solid #555;
      }

      .color-entry .remove-btn {
        background: none;
        border: none;
        color: #e94560;
        cursor: pointer;
        font-size: 16px;
        padding: 0 4px;
        line-height: 1;
      }

      .status {
        margin-top: 8px;
        font-size: 13px;
        color: #888;
      }

      .arrow {
        font-size: 18px;
        color: #555;
        align-self: center;
      }
    </style>
  </head>
  <body>
    <div id="display">
      <div id="left-half"></div>
      <div id="right-half"></div>
    </div>

    <div id="controls">
      <div class="control-section">
        <h3>Screen Color (starting color)</h3>
        <div class="rgb-row">
          <label style="color:#f66;">R</label>
          <input type="number" id="screen-r" min="0" max="255" value="0" />
          <label style="color:#6f6;">G</label>
          <input type="number" id="screen-g" min="0" max="255" value="0" />
          <label style="color:#66f;">B</label>
          <input type="number" id="screen-b" min="0" max="255" value="0" />
          <div id="screen-preview" class="preview-swatch"></div>
          <button id="set-screen-btn">Set Screen</button>
        </div>
      </div>

      <div class="control-section">
        <h3>Add Color Step</h3>
        <div class="add-section">
          <div class="side-inputs">
            <h4>Left Side</h4>
            <div class="rgb-row">
              <label style="color:#f66;">R</label>
              <input type="number" id="left-r" min="0" max="255" value="0" />
              <label style="color:#6f6;">G</label>
              <input type="number" id="left-g" min="0" max="255" value="0" />
              <label style="color:#66f;">B</label>
              <input type="number" id="left-b" min="0" max="255" value="0" />
              <div id="left-preview" class="preview-swatch"></div>
            </div>
          </div>

          <div class="side-inputs">
            <h4>Right Side</h4>
            <div class="rgb-row">
              <label style="color:#f66;">R</label>
              <input type="number" id="right-r" min="0" max="255" value="0" />
              <label style="color:#6f6;">G</label>
              <input type="number" id="right-g" min="0" max="255" value="0" />
              <label style="color:#66f;">B</label>
              <input type="number" id="right-b" min="0" max="255" value="0" />
              <div id="right-preview" class="preview-swatch"></div>
            </div>
          </div>

          <button id="add-btn">Add</button>
          <button id="clear-btn">Clear All</button>
          <button id="start-btn">Start</button>
        </div>
      </div>

      <div id="color-list"></div>
      <div class="status" id="status">Add colors and press Start to begin fading.</div>
    </div>

    <script>
      const leftHalf = document.getElementById('left-half');
      const rightHalf = document.getElementById('right-half');
      const colorList = document.getElementById('color-list');
      const status = document.getElementById('status');

      const screenR = document.getElementById('screen-r');
      const screenG = document.getElementById('screen-g');
      const screenB = document.getElementById('screen-b');
      const screenPreview = document.getElementById('screen-preview');

      const leftR = document.getElementById('left-r');
      const leftG = document.getElementById('left-g');
      const leftB = document.getElementById('left-b');
      const leftPreview = document.getElementById('left-preview');

      const rightR = document.getElementById('right-r');
      const rightG = document.getElementById('right-g');
      const rightB = document.getElementById('right-b');
      const rightPreview = document.getElementById('right-preview');

      let steps = [];
      let running = false;
      let animationId = null;
      let currentIndex = 0;
      let fadeStart = 0;

      let currentLeft = { r: 0, g: 0, b: 0 };
      let currentRight = { r: 0, g: 0, b: 0 };

      function clamp(v) {
        return Math.max(0, Math.min(255, Math.round(Number(v) || 0)));
      }

      function rgbStr(c) {
        return `rgb(${c.r}, ${c.g}, ${c.b})`;
      }

      function updateScreenPreview() {
        screenPreview.style.backgroundColor = `rgb(${clamp(screenR.value)}, ${clamp(screenG.value)}, ${clamp(screenB.value)})`;
      }

      function updateLeftPreview() {
        leftPreview.style.backgroundColor = `rgb(${clamp(leftR.value)}, ${clamp(leftG.value)}, ${clamp(leftB.value)})`;
      }

      function updateRightPreview() {
        rightPreview.style.backgroundColor = `rgb(${clamp(rightR.value)}, ${clamp(rightG.value)}, ${clamp(rightB.value)})`;
      }

      [screenR, screenG, screenB].forEach(el => el.addEventListener('input', updateScreenPreview));
      [leftR, leftG, leftB].forEach(el => el.addEventListener('input', updateLeftPreview));
      [rightR, rightG, rightB].forEach(el => el.addEventListener('input', updateRightPreview));

      updateScreenPreview();
      updateLeftPreview();
      updateRightPreview();

      // Set initial screen color
      document.getElementById('set-screen-btn').addEventListener('click', () => {
        const r = clamp(screenR.value);
        const g = clamp(screenG.value);
        const b = clamp(screenB.value);
        currentLeft = { r, g, b };
        currentRight = { r, g, b };
        leftHalf.style.transition = 'none';
        rightHalf.style.transition = 'none';
        leftHalf.style.backgroundColor = rgbStr(currentLeft);
        rightHalf.style.backgroundColor = rgbStr(currentRight);
        status.textContent = `Screen set to rgb(${r}, ${g}, ${b})`;
      });

      // Add a color step
      document.getElementById('add-btn').addEventListener('click', () => {
        const left = { r: clamp(leftR.value), g: clamp(leftG.value), b: clamp(leftB.value) };
        const right = { r: clamp(rightR.value), g: clamp(rightG.value), b: clamp(rightB.value) };
        steps.push({ left, right });
        renderList();
        status.textContent = `${steps.length} color step(s) added.`;
      });

      // Clear all
      document.getElementById('clear-btn').addEventListener('click', () => {
        steps = [];
        running = false;
        currentIndex = 0;
        if (animationId) cancelAnimationFrame(animationId);
        leftHalf.style.transition = 'none';
        rightHalf.style.transition = 'none';
        renderList();
        document.getElementById('start-btn').textContent = 'Start';
        status.textContent = 'Cleared. Add colors and press Start.';
      });

      // Start / Stop
      document.getElementById('start-btn').addEventListener('click', () => {
        if (running) {
          running = false;
          if (animationId) cancelAnimationFrame(animationId);
          document.getElementById('start-btn').textContent = 'Start';
          leftHalf.style.transition = 'none';
          rightHalf.style.transition = 'none';
          status.textContent = 'Stopped.';
          return;
        }

        if (steps.length === 0) {
          status.textContent = 'Add at least one color step first.';
          return;
        }

        running = true;
        currentIndex = 0;
        document.getElementById('start-btn').textContent = 'Stop';
        startFading();
      });

      function startFading() {
        // Use CSS transitions for smooth 1-second fades
        leftHalf.style.transition = 'background-color 1s linear';
        rightHalf.style.transition = 'background-color 1s linear';

        function nextStep() {
          if (!running) return;

          const step = steps[currentIndex];
          leftHalf.style.backgroundColor = rgbStr(step.left);
          rightHalf.style.backgroundColor = rgbStr(step.right);
          currentLeft = { ...step.left };
          currentRight = { ...step.right };

          status.textContent = `Fading to step ${currentIndex + 1} of ${steps.length} — L: rgb(${step.left.r},${step.left.g},${step.left.b}) R: rgb(${step.right.r},${step.right.g},${step.right.b})`;

          currentIndex = (currentIndex + 1) % steps.length;

          setTimeout(() => {
            if (running) nextStep();
          }, 1000);
        }

        nextStep();
      }

      function renderList() {
        colorList.innerHTML = '';
        steps.forEach((step, i) => {
          const entry = document.createElement('div');
          entry.className = 'color-entry';

          const lSwatch = document.createElement('div');
          lSwatch.className = 'swatch';
          lSwatch.style.backgroundColor = rgbStr(step.left);

          const rSwatch = document.createElement('div');
          rSwatch.className = 'swatch';
          rSwatch.style.backgroundColor = rgbStr(step.right);

          const text = document.createElement('span');
          const same = step.left.r === step.right.r && step.left.g === step.right.g && step.left.b === step.right.b;
          if (same) {
            text.textContent = `#${i + 1}: (${step.left.r},${step.left.g},${step.left.b}) full`;
          } else {
            text.textContent = `#${i + 1}: L(${step.left.r},${step.left.g},${step.left.b}) R(${step.right.r},${step.right.g},${step.right.b})`;
          }

          const removeBtn = document.createElement('button');
          removeBtn.className = 'remove-btn';
          removeBtn.textContent = '×';
          removeBtn.addEventListener('click', () => {
            steps.splice(i, 1);
            renderList();
            status.textContent = `${steps.length} color step(s) remaining.`;
          });

          entry.appendChild(lSwatch);
          entry.appendChild(rSwatch);
          entry.appendChild(text);
          entry.appendChild(removeBtn);
          colorList.appendChild(entry);
        });
      }

      // Set initial black screen
      leftHalf.style.backgroundColor = 'rgb(0,0,0)';
      rightHalf.style.backgroundColor = 'rgb(0,0,0)';
    </script>
  </body>
</html>
