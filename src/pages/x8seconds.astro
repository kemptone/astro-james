---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Number Race | Shooting To the Moon">
  <main class="race-page">
    <section class="hero">
      <p class="eyebrow">Number Race</p>
      <h1>Shooting To the Moon with powers and your own number.</h1>
      <p class="lede">
        Pick <strong>2^n</strong>, <strong>5^n</strong>, or
        <strong>8 × your number</strong>, then launch a race that lasts exactly
        <strong>1 minute</strong>. Bigger finish lines fly faster because the
        timer always stays locked to one minute.
      </p>
    </section>

    <section class="game-grid">
      <article class="panel setup-panel">
        <div class="panel-head">
          <div>
            <p class="eyebrow">Setup</p>
            <h2>Choose your moon shot</h2>
          </div>
          <p class="panel-note">
            One race. One minute. One lane moving all the way to the finish.
          </p>
        </div>

        <form id="race-form" class="setup-form">
          <section class="choice-card" aria-labelledby="base-title">
            <div class="choice-copy">
              <p class="eyebrow" id="base-title">Mode</p>
              <h2>Pick your race type</h2>
            </div>

            <div class="base-grid" role="group" aria-labelledby="base-title">
              <button type="button" class="base-button" data-mode="pow2" data-active="true">
                2 to the power
              </button>
              <button type="button" class="base-button" data-mode="pow5" data-active="false">
                5 to the power
              </button>
              <button type="button" class="base-button wide-button" data-mode="times8" data-active="false">
                8 x your number
              </button>
            </div>
          </section>

          <label class="field">
            <span id="value-label">Exponent</span>
            <input
              id="value-input"
              name="raceValue"
              type="number"
              min="0"
              step="1"
              inputmode="numeric"
              value="24"
              placeholder="24"
            />
          </label>

          <section class="race-box" aria-labelledby="race-title">
            <div class="race-copy">
              <p class="eyebrow" id="race-title">Race Time</p>
              <h2>1 minute</h2>
              <p class="panel-note">
                The timer never changes. Bigger finish lines simply make the
                board move faster.
              </p>
            </div>

            <div class="race-controls">
              <button type="button" class="ghost-button" data-value-change="1" id="change-1">
                +1 power
              </button>
              <button type="button" class="ghost-button" data-value-change="5" id="change-2">
                +5 powers
              </button>
              <button type="button" class="ghost-button" data-value-change="10" id="change-3">
                +10 powers
              </button>
              <button type="button" class="ghost-button" id="reset-value">
                Reset to 24
              </button>
            </div>
          </section>

          <div class="preview-card">
            <span class="preview-label">Preview</span>
            <strong id="preview-readout">2^24 = secret finish line</strong>
            <p id="preview-note" class="preview-note">
              This race goes 1 by 1 for one minute, just extremely fast.
            </p>
          </div>

          <div class="form-actions">
            <button type="submit" class="submit-button">Launch the race</button>
            <button type="button" class="ghost-button stop-button" id="stop-race" hidden>
              Stop race
            </button>
          </div>
        </form>
      </article>

      <article class="panel result-panel">
        <div class="panel-head">
          <div>
            <p class="eyebrow">Live Race</p>
            <h2>One wide board, one timer</h2>
          </div>
          <p class="panel-note">
            The lane does not show the changing number. The timer is what gets
            it to the finish.
          </p>
        </div>

        <div id="empty-state" class="empty-state">
          Pick a base, choose an exponent, then press launch to start the
          1-minute timer race.
        </div>

        <div id="result-shell" class="result-shell" hidden>
          <section class="track-card race-board">
            <div class="board-top">
              <article class="summary-card board-chip">
                <span class="summary-label">Formula</span>
                <strong id="summary-power">2^24</strong>
              </article>

              <article class="summary-card board-chip">
                <span class="summary-label">Finish line</span>
                <strong id="summary-finish">Secret finish line</strong>
              </article>

              <article class="summary-card board-chip">
                <span class="summary-label">Moon Speed</span>
                <strong id="summary-speed">279,621 per second</strong>
              </article>
            </div>

            <div class="track-head">
              <p class="eyebrow">Single Wide Lane</p>
              <h3 id="live-step-label">Waiting on launch</h3>
            </div>

            <div class="board-lane-shell">
              <div class="board-lane">
                <div class="track-labels">
                  <span class="track-label">Start: 1</span>
                  <span class="track-label" id="live-finish-note">Finish: secret</span>
                </div>

                <div class="lane-track">
                  <div class="lane-stream" aria-hidden="true">
                    <div id="lane-stream-track" class="lane-stream-track">
                      <span>1</span>
                      <span>2</span>
                      <span>3</span>
                      <span>4</span>
                      <span>5</span>
                      <span>6</span>
                      <span>7</span>
                      <span>8</span>
                    </div>
                  </div>
                  <span id="live-progress-fill" class="lane-fill"></span>
                  <span id="lane-runner" class="lane-runner" aria-hidden="true"></span>
                </div>
              </div>
            </div>

            <div class="board-bottom">
              <div class="clock-box">
                <span class="summary-label">Moon Clock</span>
                <strong id="live-count-label" class="count-readout">1</strong>
                <strong id="live-time-label" class="clock-readout">1:00 remaining</strong>
              </div>

              <p id="live-status-note" class="live-support">
                The timer carries the race all the way to the finish.
              </p>
            </div>
          </section>
        </div>
      </article>
    </section>
  </main>

  <script is:inline>
    const DEFAULT_MODE = 'pow2'
    const DEFAULT_VALUE = 24
    const DEFAULT_TIMES8_VALUE = 100
    const MIN_RACE_VALUE = 0
    const RACE_DURATION_MS = 60000
    const SLOWDOWN_START_MS = 50000
    const FINAL_CRAWL_START_MS = 59000
    const BIGINT_PROGRESS_SCALE = 1000000n

    const MODE_CONFIG = {
      pow2: {
        title: '2 to the power',
        inputLabel: 'Exponent',
        previewLabel: value => `2^${value}`,
        summaryLabel: value => `2^${value}`,
        finishValue: value => 2n ** BigInt(value),
        resetValue: DEFAULT_VALUE,
        changeLabels: ['+1 power', '+5 powers', '+10 powers'],
        changeValues: [1, 5, 10],
        resetLabel: `Reset to ${DEFAULT_VALUE}`,
      },
      pow5: {
        title: '5 to the power',
        inputLabel: 'Exponent',
        previewLabel: value => `5^${value}`,
        summaryLabel: value => `5^${value}`,
        finishValue: value => 5n ** BigInt(value),
        resetValue: DEFAULT_VALUE,
        changeLabels: ['+1 power', '+5 powers', '+10 powers'],
        changeValues: [1, 5, 10],
        resetLabel: `Reset to ${DEFAULT_VALUE}`,
      },
      times8: {
        title: '8 x your number',
        inputLabel: 'Your number',
        previewLabel: value => `8 x ${formatBigInt(BigInt(value))}`,
        summaryLabel: value => `8 x ${formatBigInt(BigInt(value))}`,
        finishValue: value => BigInt(value) * 8n,
        resetValue: DEFAULT_TIMES8_VALUE,
        changeLabels: ['+1 number', '+10 numbers', '+100 numbers'],
        changeValues: [1, 10, 100],
        resetLabel: `Reset to ${DEFAULT_TIMES8_VALUE}`,
      },
    }

    const state = {
      mode: DEFAULT_MODE,
      raceValue: DEFAULT_VALUE,
      animationToken: 0,
      frameId: 0,
    }

    const form = document.querySelector('#race-form')
    const valueInput = document.querySelector('#value-input')
    const valueLabel = document.querySelector('#value-label')
    const previewReadout = document.querySelector('#preview-readout')
    const previewNote = document.querySelector('#preview-note')
    const emptyState = document.querySelector('#empty-state')
    const resultShell = document.querySelector('#result-shell')
    const summaryPower = document.querySelector('#summary-power')
    const summaryFinish = document.querySelector('#summary-finish')
    const summarySpeed = document.querySelector('#summary-speed')
    const liveStepLabel = document.querySelector('#live-step-label')
    const liveCountLabel = document.querySelector('#live-count-label')
    const liveTimeLabel = document.querySelector('#live-time-label')
    const liveFinishNote = document.querySelector('#live-finish-note')
    const liveStatusNote = document.querySelector('#live-status-note')
    const liveProgressFill = document.querySelector('#live-progress-fill')
    const laneRunner = document.querySelector('#lane-runner')
    const laneStreamTrack = document.querySelector('#lane-stream-track')
    const resetValueButton = document.querySelector('#reset-value')
    const change1Button = document.querySelector('#change-1')
    const change2Button = document.querySelector('#change-2')
    const change3Button = document.querySelector('#change-3')
    const stopRaceButton = document.querySelector('#stop-race')
    const submitButton = document.querySelector('.submit-button')
    const modeButtons = Array.from(document.querySelectorAll('[data-mode]'))
    const valueButtons = Array.from(
      document.querySelectorAll('[data-value-change]'),
    )

    function getCurrentModeConfig() {
      return MODE_CONFIG[state.mode]
    }

    function clampRaceValue(value) {
      return Math.max(MIN_RACE_VALUE, value)
    }

    function getRaceValue() {
      const rawText = valueInput.value.trim()

      if (rawText === '') {
        return getCurrentModeConfig().resetValue
      }

      const parsed = Math.floor(Number(rawText))

      if (!Number.isFinite(parsed)) {
        return getCurrentModeConfig().resetValue
      }

      return clampRaceValue(parsed)
    }

    function normalizeRaceValueInput() {
      valueInput.value = String(getRaceValue())
    }

    function formatBigInt(value) {
      const text = value.toString()

      return text.replace(/\B(?=(\d{3})+(?!\d))/g, ',')
    }

    function formatPower(base, exponent) {
      return `${base}^${exponent}`
    }

    function getPowerValue(base, exponent) {
      return BigInt(base) ** BigInt(exponent)
    }

    function divideAndRoundUp(value, divisor) {
      const divisorBigInt = BigInt(divisor)

      return (value + divisorBigInt - 1n) / divisorBigInt
    }

    function getSpeedLabel(finishValue) {
      return `${formatBigInt(divideAndRoundUp(finishValue, 60))} per second`
    }

    function getDigitCount(value) {
      return value.toString().length
    }

    function getTickerDurationMs(finishValue) {
      const digits = getDigitCount(finishValue)

      return Math.max(320, 1450 - (digits * 38))
    }

    function buildLaneStream(finishValue) {
      const limit = Math.min(12, Math.max(8, getDigitCount(finishValue) + 2))
      const values = []

      for (let index = 1; index <= limit; index += 1) {
        values.push(String(index))
      }

      return values.concat(values).map(value => `<span>${value}</span>`).join('')
    }

    function formatClock(milliseconds) {
      const totalSeconds = Math.max(0, Math.ceil(milliseconds / 1000))
      const minutes = Math.floor(totalSeconds / 60)
      const seconds = totalSeconds % 60

      return `${minutes}:${String(seconds).padStart(2, '0')}`
    }

    function updateModeButtons() {
      modeButtons.forEach(button => {
        const buttonMode = button.getAttribute('data-mode')
        button.setAttribute(
          'data-active',
          buttonMode === state.mode ? 'true' : 'false',
        )
      })
    }

    function updateControlsForMode() {
      const config = getCurrentModeConfig()

      valueLabel.textContent = config.inputLabel
      change1Button.textContent = config.changeLabels[0]
      change2Button.textContent = config.changeLabels[1]
      change3Button.textContent = config.changeLabels[2]
      change1Button.setAttribute('data-value-change', String(config.changeValues[0]))
      change2Button.setAttribute('data-value-change', String(config.changeValues[1]))
      change3Button.setAttribute('data-value-change', String(config.changeValues[2]))
      resetValueButton.textContent = config.resetLabel
    }

    function formatFormula(value) {
      return getCurrentModeConfig().summaryLabel(value)
    }

    function getFinishValue(value) {
      return getCurrentModeConfig().finishValue(value)
    }

    function buildGrowingNumberStream(finishValue) {
      const steps = 10
      const values = []

      for (let index = 1; index <= steps; index += 1) {
        const scaled = (finishValue * BigInt(index)) / BigInt(steps)
        values.push(formatBigInt(scaled > 0n ? scaled : 1n))
      }

      return values.concat(values).map(value => `<span>${value}</span>`).join('')
    }

    function clampUnitInterval(value) {
      return Math.max(0, Math.min(1, value))
    }

    function getEaseOutRatio(progress, power) {
      const safeProgress = clampUnitInterval(progress)

      return 1 - ((1 - safeProgress) ** power)
    }

    function interpolateBigInt(startValue, endValue, scaledRatio) {
      const ratio = BigInt(Math.max(0, Math.min(Number(BIGINT_PROGRESS_SCALE), scaledRatio)))

      return startValue + (((endValue - startValue) * ratio) / BIGINT_PROGRESS_SCALE)
    }

    function getScaledRatio(value) {
      return Math.floor(clampUnitInterval(value) * Number(BIGINT_PROGRESS_SCALE))
    }

    function getCurrentCount(elapsed, finishValue) {
      if (finishValue <= 1n) {
        return 1n
      }

      const safeElapsed = Math.max(0, Math.min(RACE_DURATION_MS, elapsed))
      const finalCrawlValue = finishValue - 1n
      const slowdownTarget = interpolateBigInt(
        1n,
        finalCrawlValue,
        getScaledRatio(0.97),
      )

      if (safeElapsed < SLOWDOWN_START_MS) {
        return interpolateBigInt(
          1n,
          slowdownTarget,
          getScaledRatio(getEaseOutRatio(safeElapsed / SLOWDOWN_START_MS, 4)),
        )
      }

      if (safeElapsed < FINAL_CRAWL_START_MS) {
        return interpolateBigInt(
          slowdownTarget,
          finalCrawlValue,
          getScaledRatio(
            getEaseOutRatio(
              (safeElapsed - SLOWDOWN_START_MS) / (FINAL_CRAWL_START_MS - SLOWDOWN_START_MS),
              2.8,
            ),
          ),
        )
      }

      return finalCrawlValue
    }

    function getProgressPercent(currentCount, finishValue) {
      if (finishValue <= 1n) {
        return 100
      }

      return Number((currentCount * 10000n) / finishValue) / 100
    }

    function updatePreview() {
      state.raceValue = getRaceValue()
      const finishValue = getFinishValue(state.raceValue)
      const formula = formatFormula(state.raceValue)

      previewReadout.textContent =
        `${formula} = secret finish line`
      previewNote.textContent =
        finishValue <= 1n
          ? 'This one starts and finishes at 1, so the timer is already done.'
          : `This 1-minute race goes 1 by 1 toward a secret finish line at about ${getSpeedLabel(finishValue)}. It blasts early, slows after 50 seconds, and crawls in the final second.`
    }

    function stopAnimation() {
      state.animationToken += 1

      if (state.frameId) {
        cancelAnimationFrame(state.frameId)
        state.frameId = 0
      }
    }

    function setRunningState(isRunning) {
      submitButton.disabled = isRunning
      submitButton.textContent = isRunning ? 'Racing to the moon...' : 'Launch the race'
      stopRaceButton.hidden = !isRunning
    }

    function resetResults() {
      stopAnimation()
      emptyState.hidden = false
      resultShell.hidden = true
      liveProgressFill.style.width = '0%'
      laneRunner.style.left = '0%'
      laneStreamTrack.style.animationPlayState = 'paused'
      liveCountLabel.textContent = '1'
      liveTimeLabel.textContent = '1:00 remaining'
      setRunningState(false)
    }

    function updateLiveView(formula, elapsed, finishValue) {
      const currentCount =
        elapsed >= RACE_DURATION_MS
          ? finishValue
          : getCurrentCount(elapsed, finishValue)
      const progressPercent = Math.max(
        0,
        Math.min(100, getProgressPercent(currentCount, finishValue)),
      )

      liveStepLabel.textContent =
        finishValue <= 1n
          ? 'Start and finish are the same'
          : `Counting 1 by 1 toward ${formula}`
      liveFinishNote.textContent = 'Finish: secret'
      liveStatusNote.textContent =
        elapsed >= RACE_DURATION_MS
          ? `Touchdown at the secret finish for ${formula}.`
          : elapsed >= FINAL_CRAWL_START_MS
            ? `Moon clock count: ${formatBigInt(currentCount)}. Final crawl now: about 1 number per second.`
            : elapsed >= SLOWDOWN_START_MS
              ? `Moon clock count: ${formatBigInt(currentCount)}. The race is slowing down for the last stretch.`
              : `Moon clock count: ${formatBigInt(currentCount)}. The finish line stays secret.`
      liveCountLabel.textContent = formatBigInt(currentCount)
      liveTimeLabel.textContent =
        elapsed >= RACE_DURATION_MS
          ? 'Touchdown at the moon'
          : `${formatClock(RACE_DURATION_MS - elapsed)} remaining`

      liveProgressFill.style.width = `${progressPercent}%`
      laneRunner.style.left = `${progressPercent}%`
    }

    function finishRace(formula, finishValue) {
      updateLiveView(formula, RACE_DURATION_MS, finishValue)
      setRunningState(false)
      state.frameId = 0
    }

    function startRace(raceValue) {
      stopAnimation()
      const token = state.animationToken
      const finishValue = getFinishValue(raceValue)
      const formula = formatFormula(raceValue)
      const startedAt = performance.now()
      const laneTickerDurationMs = getTickerDurationMs(finishValue)

      summaryPower.textContent = formula
      summaryFinish.textContent = 'Secret finish line'
      summarySpeed.textContent = getSpeedLabel(finishValue)

      emptyState.hidden = true
      resultShell.hidden = false
      laneStreamTrack.innerHTML = buildGrowingNumberStream(finishValue)
      laneStreamTrack.style.setProperty('--ticker-duration', `${laneTickerDurationMs}ms`)
      laneStreamTrack.style.animationPlayState = 'paused'
      updateLiveView(formula, 0, finishValue)
      setRunningState(true)

      if (finishValue <= 1n) {
        finishRace(formula, finishValue)
        return
      }

      function tick(now) {
        if (token !== state.animationToken) {
          return
        }

        const elapsed = Math.min(RACE_DURATION_MS, now - startedAt)
        updateLiveView(formula, elapsed, finishValue)

        if (elapsed >= RACE_DURATION_MS) {
          finishRace(formula, finishValue)
          return
        }

        state.frameId = requestAnimationFrame(tick)
      }

      state.frameId = requestAnimationFrame(tick)
    }

    modeButtons.forEach(button => {
      button.addEventListener('click', () => {
        state.mode = button.getAttribute('data-mode') || DEFAULT_MODE
        valueInput.value = String(getCurrentModeConfig().resetValue)
        updateModeButtons()
        updateControlsForMode()
        updatePreview()
      })
    })

    valueButtons.forEach(button => {
      button.addEventListener('click', () => {
        const change = Number(button.getAttribute('data-value-change') || '0')
        valueInput.value = String(clampRaceValue(getRaceValue() + change))
        updatePreview()
      })
    })

    resetValueButton.addEventListener('click', () => {
      valueInput.value = String(getCurrentModeConfig().resetValue)
      updatePreview()
    })

    stopRaceButton.addEventListener('click', () => {
      resetResults()
    })

    valueInput.addEventListener('input', () => {
      updatePreview()
    })

    valueInput.addEventListener('blur', () => {
      normalizeRaceValueInput()
      updatePreview()
    })

    form.addEventListener('submit', event => {
      event.preventDefault()
      normalizeRaceValueInput()
      updatePreview()
      startRace(getRaceValue())
    })

    updateModeButtons()
    updateControlsForMode()
    updatePreview()
  </script>
</Layout>

<style>
  :root {
    color-scheme: light;
    --panel: rgba(255, 252, 246, 0.9);
    --ink: #191510;
    --muted: #6f6252;
    --accent: #126e5c;
    --accent-deep: #0c4f43;
    --warm: #cf7b32;
    --line: rgba(25, 21, 16, 0.1);
    --progress: #1d8f63;
    --progress-soft: #93dfc0;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    color: var(--ink);
    background:
      radial-gradient(circle at top, rgba(255, 255, 255, 0.82), transparent 30%),
      linear-gradient(180deg, #f6efe2 0%, #ebddc5 42%, #decca8 100%);
    font-family: 'Avenir Next', 'Trebuchet MS', 'Segoe UI', sans-serif;
  }

  .race-page {
    width: min(1960px, calc(100% - 1rem));
    margin: 0 auto;
    padding: 2rem 0 5rem;
  }

  .hero,
  .panel {
    border: 2px solid var(--line);
    border-radius: 28px;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.78), rgba(255, 245, 228, 0.72)),
      var(--panel);
    box-shadow: 0 22px 60px rgba(77, 49, 18, 0.12);
  }

  .hero {
    padding: 1.8rem;
    margin-bottom: 1.2rem;
  }

  .eyebrow {
    margin: 0 0 0.35rem;
    font-size: 0.82rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 800;
    color: var(--accent-deep);
  }

  h1,
  h2,
  h3,
  p {
    margin: 0;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3.8rem);
    line-height: 0.94;
  }

  .lede {
    max-width: 58rem;
    margin-top: 0.95rem;
    font-size: 1.05rem;
    line-height: 1.6;
    color: #3f352b;
  }

  .game-grid {
    display: grid;
    grid-template-columns: minmax(320px, 420px) minmax(0, 1fr);
    gap: 1rem;
    align-items: start;
  }

  .panel {
    padding: 1.4rem;
  }

  .panel-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: start;
    margin-bottom: 1rem;
  }

  .panel-head h2 {
    font-size: 1.55rem;
  }

  .panel-note {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.45;
  }

  .setup-form,
  .choice-card,
  .race-box,
  .track-card,
  .summary-card,
  .preview-card,
  .empty-state {
    border-radius: 24px;
    border: 1px solid rgba(18, 110, 92, 0.12);
    background: rgba(255, 255, 255, 0.78);
  }

  .setup-form {
    display: grid;
    gap: 1rem;
  }

  .choice-card,
  .race-box {
    padding: 1rem;
    display: grid;
    gap: 1rem;
  }

  .choice-copy h2,
  .race-copy h2 {
    font-size: clamp(1.9rem, 5vw, 3rem);
    line-height: 1;
  }

  .base-grid,
  .race-controls,
  .form-actions {
    display: grid;
    gap: 0.75rem;
  }

  .base-grid,
  .form-actions {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .wide-button {
    grid-column: 1 / -1;
  }

  .race-controls {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .base-button,
  .ghost-button,
  .submit-button {
    border: 0;
    border-radius: 999px;
    font: inherit;
    font-weight: 800;
    cursor: pointer;
    transition:
      transform 0.18s ease,
      background 0.18s ease,
      box-shadow 0.18s ease;
  }

  .base-button {
    padding: 0.95rem 1rem;
    background: rgba(18, 110, 92, 0.08);
    color: var(--accent-deep);
  }

  .base-button[data-active='true'] {
    background: linear-gradient(135deg, var(--accent) 0%, var(--warm) 100%);
    color: white;
    box-shadow: 0 14px 28px rgba(18, 110, 92, 0.18);
  }

  .field {
    display: grid;
    gap: 0.45rem;
    font-weight: 700;
  }

  .field span {
    font-size: 0.95rem;
  }

  .field input {
    width: 100%;
    border: 2px solid rgba(25, 21, 16, 0.12);
    border-radius: 18px;
    padding: 0.95rem 1rem;
    font: inherit;
    font-size: 1.35rem;
