---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Mila Weekday Game">
  <style>
    :root {
      --ink: #1f2a37;
      --paper: #fffdf7;
      --sky: #dff1ff;
      --sky-strong: #4f8fc8;
      --gold: #ffe59a;
      --peach: #ffe3cf;
      --line: #cbd5e1;
      --panel: rgba(255, 255, 255, 0.9);
      --shadow: 0 20px 45px rgba(60, 90, 120, 0.16);
    }

    main {
      max-width: 1180px;
      margin: 0 auto;
      padding: 2rem 1.25rem 3rem;
      color: var(--ink);
      font-family:
        "Avenir Next",
        "Trebuchet MS",
        sans-serif;
    }

    .hero {
      padding: 1.75rem;
      border-radius: 28px;
      background:
        radial-gradient(circle at top right, rgba(255, 255, 255, 0.95), transparent 36%),
        linear-gradient(135deg, var(--sky), var(--gold));
      box-shadow: var(--shadow);
      margin-bottom: 1.5rem;
    }

    h1 {
      margin: 0 0 0.75rem;
      font-size: clamp(2.2rem, 5vw, 3.4rem);
      line-height: 1;
      letter-spacing: -0.04em;
    }

    .hero p,
    .rules li {
      font-size: 1.05rem;
      line-height: 1.55;
    }

    .rules {
      margin: 1rem 0 0;
      padding-left: 1.1rem;
    }

    .layout {
      display: grid;
      gap: 1.25rem;
      grid-template-columns: minmax(0, 360px) minmax(0, 1fr);
      align-items: start;
    }

    .panel {
      background: var(--panel);
      border: 1px solid rgba(148, 163, 184, 0.45);
      border-radius: 24px;
      padding: 1.25rem;
      box-shadow: var(--shadow);
      backdrop-filter: blur(8px);
    }

    .panel h2 {
      margin: 0 0 1rem;
      font-size: 1.25rem;
    }

    .hidden {
      display: none;
    }

    .form-grid {
      display: grid;
      gap: 1rem;
    }

    label {
      display: grid;
      gap: 0.45rem;
      font-weight: 700;
    }

    input[type='text'] {
      width: 100%;
      border: 2px solid var(--line);
      border-radius: 16px;
      padding: 0.85rem 1rem;
      font-size: 1rem;
      color: var(--ink);
      background: #fff;
    }

    input[type='text']:focus {
      outline: none;
      border-color: var(--sky-strong);
      box-shadow: 0 0 0 4px rgba(79, 143, 200, 0.16);
    }

    .helper {
      margin: 0;
      color: #475569;
      font-size: 0.95rem;
      line-height: 1.5;
    }

    .button-row {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    button {
      border: 0;
      border-radius: 999px;
      padding: 0.85rem 1.2rem;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      color: #102033;
      background: linear-gradient(135deg, #9fd3ff, #ffe08b);
      box-shadow: 0 10px 24px rgba(79, 143, 200, 0.2);
    }

    button.secondary {
      background: linear-gradient(135deg, #ffd2ba, #ffeec0);
    }

    .message {
      min-height: 1.5rem;
      margin: 0;
      font-weight: 700;
      color: #b45309;
    }

    .name-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 0.7rem;
    }

    .name-card {
      border: 1px solid rgba(148, 163, 184, 0.45);
      border-radius: 18px;
      padding: 0.85rem 1rem;
      background: linear-gradient(180deg, #ffffff, #fff7e8);
    }

    .name-card strong {
      display: block;
      font-size: 1.02rem;
      margin-bottom: 0.25rem;
    }

    .name-card span {
      display: block;
      color: #475569;
      font-size: 0.94rem;
    }

    .weekday-grid {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 1rem;
    }

    .weekday-card {
      border-radius: 20px;
      border: 1px solid rgba(148, 163, 184, 0.45);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(253, 248, 238, 0.95));
      overflow: hidden;
      min-height: 280px;
    }

    .weekday-card h3 {
      margin: 0;
      padding: 1rem;
      font-size: 1rem;
      background: linear-gradient(135deg, #4f8fc8, #70a9dd);
      color: white;
    }

    .weekday-card ul {
      list-style: none;
      margin: 0;
      padding: 0.9rem;
      display: grid;
      gap: 0.65rem;
    }

    .weekday-card li {
      border-radius: 14px;
      padding: 0.65rem 0.75rem;
      background: var(--paper);
      border: 1px solid rgba(148, 163, 184, 0.35);
      font-weight: 700;
    }

    .weekday-card a {
      color: #1d4ed8;
      text-decoration: underline;
      font-weight: 700;
    }

    .empty {
      color: #64748b;
      font-style: italic;
      font-weight: 600;
    }

    @media (max-width: 1024px) {
      .layout {
        grid-template-columns: 1fr;
      }

      .weekday-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 640px) {
      main {
        padding-inline: 0.9rem;
      }

      .hero,
      .panel {
        border-radius: 20px;
      }

      .weekday-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <main>
    <section class="hero">
      <h1>Mila's Weekday Game</h1>
      <p>
        Add a name, then type which weekdays it is not there. This game only
        uses the five weekdays: Monday, Tuesday, Wednesday, Thursday, and
        Friday.
      </p>
      <ul class="rules">
        <li><strong>1</strong> is Monday, <strong>2</strong> is Tuesday, <strong>3</strong> is Wednesday, <strong>4</strong> is Thursday, and <strong>5</strong> is Friday.</li>
        <li>Leave weekdays blank to put a name on all five weekdays.</li>
        <li>If a number is there, that means the name is not there on that weekday.</li>
        <li><strong>12345</strong> means the name is out of all weekdays but still stays in the full name list.</li>
        <li><strong>123456</strong> is not available because this game only uses 1 to 5.</li>
        <li><strong>Add Name</strong> stores what you made. <strong>Submit</strong> shows the full list and generates the weekdays from everything you made.</li>
      </ul>
    </section>

    <div class="layout">
      <section class="panel">
        <h2>Add A Name</h2>
        <div class="form-grid">
          <label for="nameInput">
            Name
            <input
              id="nameInput"
              type="text"
              placeholder="Type a name"
              autocomplete="off"
            />
          </label>

          <label for="weekdayInput">
            Weekdays Not There
            <input
              id="weekdayInput"
              type="text"
              inputmode="numeric"
              placeholder="Blank, 3, 15, or 12345"
              autocomplete="off"
            />
          </label>

          <p class="helper">
            Use only the numbers 1, 2, 3, 4, and 5. Example: <strong>3</strong>
            means not there on Wednesday.
          </p>

          <div class="button-row">
            <button id="addNameButton" type="button">Add Name</button>
            <button id="submitWeekButton" type="button">Submit</button>
            <button id="resetButton" class="secondary" type="button">Reset Game</button>
          </div>

          <p class="message" id="messageText"></p>
        </div>

        <section id="allNamesSection" class="hidden" style="margin-top: 1.5rem;">
          <h2>Every Name You Made</h2>
          <ul class="name-list" id="allNamesList">
            <li class="empty">No names yet.</li>
          </ul>
        </section>
      </section>

      <section class="panel hidden" id="weekdaySection">
        <h2>Weekday Lists</h2>
        <div class="weekday-grid" id="weekdayGrid"></div>
      </section>
    </div>
  </main>

  <script>
    const weekdayMap = {
      '1': 'Monday',
      '2': 'Tuesday',
      '3': 'Wednesday',
      '4': 'Thursday',
      '5': 'Friday',
    };

    const allWeekdays = Object.keys(weekdayMap);
    const entries = [];

    const nameInput = document.getElementById('nameInput');
    const weekdayInput = document.getElementById('weekdayInput');
    const addNameButton = document.getElementById('addNameButton');
    const submitWeekButton = document.getElementById('submitWeekButton');
    const resetButton = document.getElementById('resetButton');
    const messageText = document.getElementById('messageText');
    const allNamesSection = document.getElementById('allNamesSection');
    const allNamesList = document.getElementById('allNamesList');
    const weekdaySection = document.getElementById('weekdaySection');
    const weekdayGrid = document.getElementById('weekdayGrid');
    let weekHasBeenSubmitted = false;

    function normalizeWeekdays(value) {
      const compact = value.replace(/\s+/g, '');

      if (!compact) {
        return {
          ok: true,
          weekdays: [...allWeekdays],
        };
      }

      if (!/^[1-5]+$/.test(compact)) {
        return {
          ok: false,
          error: 'Use only 1, 2, 3, 4, and 5. 6 is not available in this game.',
        };
      }

      const missingDays = [...new Set(compact.split(''))].sort();
      const weekdays = allWeekdays.filter(day => !missingDays.includes(day));

      return {
        ok: true,
        weekdays,
      };
    }

    function setMessage(text) {
      messageText.textContent = text;
    }

    function escapeHtml(value) {
      return value
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');
    }

    function renderAllNames() {
      if (entries.length === 0) {
        allNamesList.innerHTML = '<li class="empty">No names yet.</li>';
        return;
      }

      allNamesList.innerHTML = entries
        .map(entry => {
          return `
            <li class="name-card">
              <strong>${escapeHtml(entry.name)}</strong>
            </li>
          `;
        })
        .join('');
    }

    function renderWeekdays() {
      weekdayGrid.innerHTML = allWeekdays
        .map(dayNumber => {
          const names = entries.filter(entry => entry.weekdays.includes(dayNumber));
          const listMarkup = names.length
            ? names.map(entry => `<li>${escapeHtml(entry.name)}</li>`).join('')
            : '<li><a href="/bible">Bible</a></li>';

          return `
            <section class="weekday-card">
              <h3>${weekdayMap[dayNumber]}</h3>
              <ul>${listMarkup}</ul>
            </section>
          `;
        })
        .join('');
    }

    function renderGame() {
      allNamesSection.classList.toggle('hidden', !weekHasBeenSubmitted);
      weekdaySection.classList.toggle('hidden', !weekHasBeenSubmitted);
      renderAllNames();

      if (weekHasBeenSubmitted) {
        renderWeekdays();
      } else {
        weekdayGrid.innerHTML = '';
      }
    }

    function addEntry() {
      const name = nameInput.value.trim();
      const normalized = normalizeWeekdays(weekdayInput.value);

      if (!name) {
        setMessage('Type a name before adding it.');
        nameInput.focus();
        return;
      }

      if (!normalized.ok) {
        setMessage(normalized.error);
        weekdayInput.focus();
        return;
      }

      entries.push({
        id: Date.now(),
        name,
        weekdays: normalized.weekdays,
      });

      weekHasBeenSubmitted = false;
      nameInput.value = '';
      weekdayInput.value = '';
      setMessage(`${name} was added. Press Submit to generate the weekdays.`);
      renderGame();
      nameInput.focus();
    }

    function submitWeek() {
      weekHasBeenSubmitted = true;
      setMessage('The weekdays were generated.');
      renderGame();
    }

    addNameButton.addEventListener('click', addEntry);
    submitWeekButton.addEventListener('click', submitWeek);

    [nameInput, weekdayInput].forEach(input => {
      input.addEventListener('keydown', event => {
        if (event.key === 'Enter') {
          addEntry();
        }
      });
    });

    resetButton.addEventListener('click', () => {
      entries.length = 0;
      weekHasBeenSubmitted = false;
      nameInput.value = '';
      weekdayInput.value = '';
      setMessage('The weekday game was reset.');
      renderGame();
      nameInput.focus();
    });

    renderGame();
  </script>
</Layout>
