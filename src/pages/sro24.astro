---
import Menu from '@/components/menu.astro'

// sro24 - Movie clip game
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SRO24 - Movie Clip Game</title>
  </head>
  <body>
    <Menu />

    <main class="shell">
      <section class="hero card">
        <div class="hero-copy">
          <p class="eyebrow">SRO24 movie game</p>
          <h1>Press any minute, or make your own clip.</h1>
          <p class="hero-text">
            Version 1 makes one-minute slices. Version 2 lets you choose a start and end time.
            If the end is earlier than the start, the clip goes in reverse. If both times match,
            it makes a screenshot instead.
          </p>
        </div>

        <div class="hero-side">
          <div class="checkbox-pill">
            <input type="checkbox" id="gameCheckbox" checked disabled />
            <label for="gameCheckbox">Game active</label>
          </div>
          <div class="season-list">
            <p><strong>Decorations</strong></p>
            <p>Halloween: September 20 - November 2</p>
            <p>Thanksgiving: November 3 - November 30</p>
            <p>Christmas: December 1 - January 2</p>
          </div>
        </div>
      </section>

      <section class="workspace">
        <section class="card control-card">
          <div class="section-heading">
            <p class="eyebrow">Movie loader</p>
            <h2>Search a movie preview, or load a whole movie source</h2>
            <p class="section-copy">
              Search for a real title like <strong>The Lion King</strong> or tap one from the
              quick shelf. The page will load a legal movie preview automatically, with no file
              picker needed. If you want clips from anywhere in the whole movie, load the built-in
              full movie demo or your own full video source and the clip range can go all the way
              to the real duration.
            </p>
          </div>

          <div class="search-panel">
            <div class="search-row">
              <label class="search-label">
                Search any movie
                <input id="movieTitle" type="text" placeholder="The Lion King" maxlength="120" />
              </label>
              <button id="searchMovies" type="button">Search movies</button>
            </div>

            <div id="searchResultsStatus" class="soft-panel">
              Search for a real movie title and click a result to load its preview.
            </div>

            <div id="searchResults" class="search-results" hidden></div>
          </div>

          <div class="whole-source-cta soft-panel">
            <strong>Whole movie mode</strong>
            <p>
              Load a full movie URL or a movie file if you want clips from 0:00 up to the real
              end of the movie, like 30 minutes or longer.
            </p>
            <div class="whole-source-cta-actions">
              <button id="loadWholeMovieDemo" type="button">Load full movie demo</button>
              <button id="focusWholeSource" class="ghost" type="button">Use whole movie source</button>
            </div>
            <p class="whole-source-demo-copy">
              Built-in demo: <strong>Night of the Living Dead</strong> (1968), a full public-domain
              movie that runs about 1:35:53 and creates 96 minute buttons automatically.
            </p>
          </div>

          <div class="movie-shelf-wrap">
            <div class="movie-shelf-heading">
              <p class="eyebrow">Quick shelf</p>
              <p class="section-copy">Tap one and it will search and load that movie automatically.</p>
            </div>
            <div id="movieShelf" class="movie-shelf"></div>
          </div>

          <details id="sourceTools" class="source-tools" open>
            <summary>Whole movie source tools</summary>
            <p class="section-copy">
              This is the full-length path. Once a whole movie source is loaded, minute buttons and
              custom timing can use any time up to the movie's real end. Search results stay on
              legal preview footage unless you load a full movie source here.
            </p>

            <div class="custom-grid load-grid">
              <label>
                Full movie URL
                <input
                  id="movieUrl"
                  type="text"
                  placeholder="https://example.com/full-movie.mp4"
                  inputmode="url"
                />
              </label>
              <div class="fallback-actions">
                <button id="loadMovieUrl" type="button">Load whole movie URL</button>
              </div>
            </div>

            <div class="upload-row">
              <label class="file-picker" for="movieFile">
                <span>Choose whole movie file</span>
                <input id="movieFile" type="file" accept="video/*" />
              </label>
              <button id="clearMovie" class="ghost" type="button">Clear movie</button>
            </div>
          </details>

          <div class="stats-grid">
            <article class="stat-box">
              <span class="stat-label">Source mode</span>
              <strong id="sourceModeValue">No source</strong>
            </article>
            <article class="stat-box">
              <span class="stat-label">Movie</span>
              <strong id="movieName">No movie yet</strong>
            </article>
            <article class="stat-box">
              <span class="stat-label">Duration</span>
              <strong id="movieDuration">0:00</strong>
            </article>
            <article class="stat-box">
              <span class="stat-label">Minute clips</span>
              <strong id="minuteCount">0</strong>
            </article>
            <article class="stat-box">
              <span class="stat-label">Clip range</span>
              <strong id="sourceRangeValue">0:00 to 0:00</strong>
            </article>
          </div>

          <div class="player-frame">
            <div id="sourceLoader" class="source-loader" hidden>
              <div class="source-loader-art">
                <img id="sourceLoaderPoster" alt="Loading movie poster" hidden />
                <div id="sourceLoaderPosterFallback" class="source-loader-fallback">Movie</div>
              </div>
              <div class="loader-wheel"></div>
              <p id="sourceLoaderText">Loading movie source...</p>
            </div>
            <div id="movieSourceCard" class="movie-source-card" hidden>
              <div class="movie-source-art">
                <img id="movieSourcePoster" alt="Movie source poster" hidden />
                <div id="movieSourcePosterFallback" class="movie-source-fallback">Movie</div>
              </div>
              <div class="movie-source-copy">
                <p class="movie-source-label">Movie source loaded</p>
                <h3 id="movieSourceHeading">Movie title</h3>
                <p id="movieSourceMeta">Ready for clip buttons and minute buttons.</p>
                <div class="movie-source-spinner">
                  <span class="mini-wheel"></span>
                  <span>Source spinning and ready</span>
                </div>
              </div>
            </div>
            <video id="moviePreview" controls playsinline preload="metadata"></video>
            <div id="playerEmpty" class="player-empty">
              Search a movie and click it to watch a legal preview here. If you want whole-movie
              clip exports all the way to the movie's real end, load the full movie demo or your
              own full video source with the whole movie tools above.
            </div>
          </div>
        </section>

        <section class="card tool-card">
          <div class="section-heading">
            <p class="eyebrow">Version 1</p>
            <h2>One-minute buttons</h2>
            <p class="section-copy">
              `1` goes from the beginning to 1 minute. `2` goes from 1 minute to 2 minutes. The
              last button can be less than one minute when the movie ends early. Search results cut
              one-minute preview clips. Your own full video source cuts one-minute movie clips.
            </p>
          </div>

          <div id="minuteButtonsEmpty" class="soft-panel">
            Load a movie first. Then every minute becomes a button you can press.
          </div>
          <div id="minuteButtons" class="minute-grid" hidden></div>
        </section>

        <section class="card tool-card">
          <div class="section-heading">
            <p class="eyebrow">Version 2</p>
            <h2>Custom start and end</h2>
            <p class="section-copy">
              Use `M:SS` or `H:MM:SS`. If the end is past the start, it makes a normal clip. If the
              end is earlier than the start, it makes a reverse clip. If both match, it makes a
              screenshot for Photos. Search mode clips the loaded preview video. Whole-movie clips
              require your own full video source.
            </p>
          </div>

          <div class="custom-grid">
            <label>
              Start time
              <input id="startTime" type="text" placeholder="59:32" inputmode="numeric" />
            </label>
            <label>
              End time
              <input id="endTime" type="text" placeholder="56:44" inputmode="numeric" />
            </label>
          </div>

          <div class="button-row">
            <button id="makeCustomClip" type="button">Make result</button>
            <button id="fillWholeMovie" class="ghost" type="button">Whole loaded video</button>
            <button id="jumpToStart" class="ghost" type="button">Jump video to start</button>
          </div>

          <div id="selectionSummary" class="soft-panel">
            No movie loaded yet.
          </div>
        </section>

        <section class="card output-card">
          <div class="section-heading">
            <p class="eyebrow">Result</p>
            <h2>Clip or screenshot output</h2>
          </div>

          <div id="statusBanner" class="status-banner">Pick a movie to begin.</div>

          <div class="result-stage">
            <div id="resultEmpty" class="result-empty">
              Your finished clip or screenshot will show up here.
            </div>

            <video id="resultVideo" controls playsinline hidden></video>
            <img id="resultImage" alt="Movie screenshot result" hidden />
          </div>

          <div class="result-meta">
            <strong id="resultTitle">Nothing exported yet</strong>
            <p id="resultDetails">
              Choose a minute button or enter custom times after loading a preview or your own
              video source.
            </p>
          </div>

          <div class="button-row">
            <button id="saveResult" type="button" disabled>Save result</button>
            <button id="shareResult" class="ghost" type="button" disabled>Share result</button>
          </div>
        </section>
      </section>
    </main>

    <script>
      const fileInput = document.getElementById('movieFile')
      const movieTitleInput = document.getElementById('movieTitle')
      const searchMoviesButton = document.getElementById('searchMovies')
      const searchResultsStatus = document.getElementById('searchResultsStatus')
      const searchResults = document.getElementById('searchResults')
      const sourceTools = document.getElementById('sourceTools')
      const loadWholeMovieDemoButton = document.getElementById('loadWholeMovieDemo')
      const focusWholeSourceButton = document.getElementById('focusWholeSource')
      const movieUrlInput = document.getElementById('movieUrl')
      const loadMovieUrlButton = document.getElementById('loadMovieUrl')
      const clearMovieButton = document.getElementById('clearMovie')
      const movieShelf = document.getElementById('movieShelf')
      const sourceLoader = document.getElementById('sourceLoader')
      const sourceLoaderText = document.getElementById('sourceLoaderText')
      const sourceLoaderPoster = document.getElementById('sourceLoaderPoster')
      const sourceLoaderPosterFallback = document.getElementById('sourceLoaderPosterFallback')
      const movieSourceCard = document.getElementById('movieSourceCard')
      const movieSourcePoster = document.getElementById('movieSourcePoster')
      const movieSourcePosterFallback = document.getElementById('movieSourcePosterFallback')
      const movieSourceHeading = document.getElementById('movieSourceHeading')
      const movieSourceMeta = document.getElementById('movieSourceMeta')
      const moviePreview = document.getElementById('moviePreview')
      const playerEmpty = document.getElementById('playerEmpty')
      const sourceModeValue = document.getElementById('sourceModeValue')
      const sourceRangeValue = document.getElementById('sourceRangeValue')
      const movieName = document.getElementById('movieName')
      const movieDuration = document.getElementById('movieDuration')
      const minuteCount = document.getElementById('minuteCount')
      const minuteButtons = document.getElementById('minuteButtons')
      const minuteButtonsEmpty = document.getElementById('minuteButtonsEmpty')
      const startTimeInput = document.getElementById('startTime')
      const endTimeInput = document.getElementById('endTime')
      const makeCustomClipButton = document.getElementById('makeCustomClip')
      const fillWholeMovieButton = document.getElementById('fillWholeMovie')
      const jumpToStartButton = document.getElementById('jumpToStart')
      const selectionSummary = document.getElementById('selectionSummary')
      const statusBanner = document.getElementById('statusBanner')
      const resultEmpty = document.getElementById('resultEmpty')
      const resultVideo = document.getElementById('resultVideo')
      const resultImage = document.getElementById('resultImage')
      const resultTitle = document.getElementById('resultTitle')
      const resultDetails = document.getElementById('resultDetails')
      const saveResultButton = document.getElementById('saveResult')
      const shareResultButton = document.getElementById('shareResult')

      const moviePresets = [
        { title: 'Home Alone', accent: 'accent-red', year: '1990', description: 'Kevin turns being left home alone into a full Christmas defense mission.' },
        { title: 'The Lion King', accent: 'accent-gold', year: '1994', description: 'Simba grows up, faces his past, and returns to fight for Pride Rock.' },
        { title: 'Toy Story', accent: 'accent-blue', year: '1995', description: 'Woody and Buzz crash into a toy-sized adventure and have to get back home.' },
        { title: 'Spirited Away', accent: 'accent-sky', year: '2001', description: 'Chihiro enters a magical bathhouse world and works to save her parents.' },
        { title: 'Frozen', accent: 'accent-ice', year: '2013', description: 'Anna chases Elsa across the snow to mend their bond and save Arendelle.' },
        { title: 'Back to the Future', accent: 'accent-plum', year: '1985', description: 'Marty lands in 1955 and has to repair the timeline before he disappears.' },
        { title: 'Harry Potter', accent: 'accent-sage', year: '2001', description: 'A young wizard starts Hogwarts and is pulled into a much darker mystery.' },
        { title: 'The Wizard of Oz', accent: 'accent-emerald', year: '1939', description: 'Dorothy follows the yellow brick road toward home and the Emerald City.' },
      ]

      const wholeMovieDemo = {
        title: 'Night of the Living Dead',
        year: '1968',
        runtimeLabel: '1:35:53',
        minuteButtons: 96,
        description: 'A full public-domain movie source built in for whole-movie clipping demos.',
        url: 'https://upload.wikimedia.org/wikipedia/commons/2/24/Night_of_the_Living_Dead_%281968%29.webm',
      }

      const state = {
        selectedMovieTitle: 'Home Alone',
        movieFile: null,
        movieUrl: '',
        duration: 0,
        searching: false,
        searchResults: [],
        sourceKind: 'none',
        watchMode: 'none',
        sourceArtwork: '',
        exportBlob: null,
        exportUrl: '',
        exportName: '',
        exportKind: '',
        exportType: '',
        busy: false,
      }

      const mimeCandidates = [
        'video/mp4',
        'video/webm;codecs=vp9',
        'video/webm;codecs=vp8',
        'video/webm',
      ]

      function hasLoadedSource() {
        return !!state.movieUrl
      }

      function isPreviewSource() {
        return state.sourceKind === 'preview'
      }

      function hasUserVideoSource() {
        return state.sourceKind === 'file' || state.sourceKind === 'direct-url'
      }

      function currentSourceKindLabel() {
        return isPreviewSource() ? 'preview' : 'video'
      }

      function formatClipRangeText() {
        if (!state.duration) {
          return '0:00 to 0:00'
        }

        return `0:00 to ${formatClock(state.duration)}`
      }

      function openWholeMovieTools(shouldFocusUrl = false) {
        if (sourceTools) {
          sourceTools.open = true
        }

        if (shouldFocusUrl) {
          movieUrlInput.focus()
          movieUrlInput.select()
        }
      }

      function updateSourceFacts() {
        if (!hasLoadedSource()) {
          sourceModeValue.textContent = 'No source'
          sourceRangeValue.textContent = '0:00 to 0:00'
          return
        }

        sourceModeValue.textContent = isPreviewSource() ? 'Preview source' : 'Whole movie source'
        sourceRangeValue.textContent = formatClipRangeText()
      }

      function rangePastEndMessage(kind = 'collapse') {
        const sourceLabel = currentSourceKindLabel()
        const ending = formatClock(state.duration)

        if (kind === 'start') {
          return isPreviewSource()
            ? `That start time is past the end of this ${sourceLabel}. It only runs to ${ending}. Pick earlier times or load your own full video source.`
            : `That start time is past the end of this whole movie source. It only runs to ${ending}. Pick earlier times.`
        }

        return isPreviewSource()
          ? `Those times fall past the end of this ${sourceLabel}. It only runs to ${ending}. Pick earlier times or load your own full video source.`
          : `Those times fall past the end of this whole movie source. It only runs to ${ending}. Pick earlier times.`
      }

      function updateActionButtonLabels() {
        if (isPreviewSource()) {
          makeCustomClipButton.textContent = 'Make preview result'
          fillWholeMovieButton.textContent = 'Whole preview'
          jumpToStartButton.textContent = 'Jump preview to start'
          return
        }

        makeCustomClipButton.textContent = 'Make result'
        fillWholeMovieButton.textContent = 'Whole loaded video'
        jumpToStartButton.textContent = 'Jump video to start'
      }

      function getTimerValues() {
        return {
          startValue: parseTimeValue(startTimeInput.value),
          endValue: parseTimeValue(endTimeInput.value),
        }
      }

      function hasBothTimers() {
        const { startValue, endValue } = getTimerValues()
        return startValue !== null && endValue !== null
      }

      function updateCustomButtonsState() {
        const ready = hasBothTimers()
        makeCustomClipButton.disabled = state.busy || !ready
        fillWholeMovieButton.disabled = state.busy || !ready
        jumpToStartButton.disabled = state.busy || !ready
      }

      function setBusy(isBusy) {
        state.busy = isBusy
        searchMoviesButton.disabled = isBusy || state.searching
        loadMovieUrlButton.disabled = isBusy || state.searching
        loadWholeMovieDemoButton.disabled = isBusy || state.searching
        clearMovieButton.disabled = isBusy || !hasLoadedSource()
        saveResultButton.disabled = isBusy || !state.exportBlob
        shareResultButton.disabled = isBusy || !state.exportBlob
        updateCustomButtonsState()

        const minuteActionButtons = minuteButtons.querySelectorAll('button')
        minuteActionButtons.forEach(button => {
          button.disabled = isBusy || !hasLoadedSource()
        })

        const searchActionButtons = searchResults.querySelectorAll('button')
        searchActionButtons.forEach(button => {
          button.disabled = button.dataset.intrinsicDisabled === 'true' ? true : isBusy || state.searching
        })

        const shelfButtons = movieShelf.querySelectorAll('button')
        shelfButtons.forEach(button => {
          button.disabled = isBusy || state.searching
        })
      }

      function setStatus(message, tone = 'neutral') {
        statusBanner.textContent = message
        statusBanner.dataset.tone = tone
      }

      function setSearchStatus(message) {
        searchResultsStatus.textContent = message
      }

      function setSearching(isSearching) {
        state.searching = isSearching
        searchMoviesButton.disabled = isSearching || state.busy
        loadMovieUrlButton.disabled = isSearching || state.busy
        loadWholeMovieDemoButton.disabled = isSearching || state.busy
        const searchActionButtons = searchResults.querySelectorAll('button')
        searchActionButtons.forEach(button => {
          button.disabled = button.dataset.intrinsicDisabled === 'true' ? true : isSearching || state.busy
        })
        const shelfButtons = movieShelf.querySelectorAll('button')
        shelfButtons.forEach(button => {
          button.disabled = isSearching || state.busy
        })
      }

      function currentMovieTitle() {
        const typed = String(movieTitleInput.value || '').trim()
        return typed || state.selectedMovieTitle || 'Movie'
      }

      function proxyMovieUrl(url) {
        return `/api/movie-preview?url=${encodeURIComponent(url)}`
      }

      function estimatedMovieDuration(title) {
        const text = String(title || '').toLowerCase()
        if (text.includes('short')) return 1800
        if (text.includes('fantasia') || text.includes('harry potter')) return 9000
        if (text.includes('lion king') || text.includes('home alone')) return 6300
        return 7200
      }

      function nextFrame() {
        return new Promise(resolve => requestAnimationFrame(() => requestAnimationFrame(resolve)))
      }

      function setLoaderArtwork(movie) {
        const artwork =
          movie && Object.prototype.hasOwnProperty.call(movie, 'artwork')
            ? movie.artwork || ''
            : state.sourceArtwork || ''
        if (artwork) {
          sourceLoaderPoster.src = artwork
          sourceLoaderPoster.hidden = false
          sourceLoaderPosterFallback.hidden = true
        } else {
          sourceLoaderPoster.removeAttribute('src')
          sourceLoaderPoster.hidden = true
          sourceLoaderPosterFallback.hidden = false
          sourceLoaderPosterFallback.textContent = movie?.title || currentMovieTitle()
        }
      }

      function showSourceLoader(message, movie = null) {
        sourceLoaderText.textContent = message
        setLoaderArtwork(movie)
        sourceLoader.hidden = false
        movieSourceCard.hidden = true
        moviePreview.hidden = true
        playerEmpty.hidden = true
      }

      function hideSourceLoader() {
        sourceLoader.hidden = true
      }

      function restorePlayerVisualState() {
        hideSourceLoader()

        if (hasLoadedSource()) {
          movieSourceCard.hidden = true
          moviePreview.hidden = false
          playerEmpty.hidden = true
          return
        }

        movieSourceCard.hidden = true
        moviePreview.hidden = true
        playerEmpty.hidden = false
      }

      function showCatalogSourceCard(movie) {
        state.sourceArtwork = movie.artwork || ''
        if (state.sourceArtwork) {
          movieSourcePoster.src = state.sourceArtwork
          movieSourcePoster.hidden = false
          movieSourcePosterFallback.hidden = true
        } else {
          movieSourcePoster.removeAttribute('src')
          movieSourcePoster.hidden = true
          movieSourcePosterFallback.hidden = false
          movieSourcePosterFallback.textContent = movie.title
        }

        movieSourceHeading.textContent = movie.title
        movieSourceMeta.textContent = `Minute buttons are ready for about ${formatClock(state.duration)} of movie time.`
        movieSourceCard.hidden = false
        moviePreview.hidden = true
        playerEmpty.hidden = true
      }

      function normalizeMovieResult(item) {
        return {
          id: String(item.pageid || item.title),
          title: item.title || 'Movie',
          year: item.year || '',
          genre: item.category || 'Movie',
          artwork: item.thumbnail || '',
          previewUrl: item.previewUrl || '',
          previewTitle: item.previewTitle || '',
          exactPreviewMatch: Boolean(item.exactPreviewMatch),
          trackViewUrl: item.pageUrl || '',
          description: item.description || 'No description yet.',
          durationSeconds: Number(item.durationSeconds) || 0,
        }
      }

      function renderSearchResults() {
        searchResults.innerHTML = ''

        if (!state.searchResults.length) {
          searchResults.hidden = true
          return
        }

        searchResults.hidden = false

        state.searchResults.forEach(movie => {
          const card = document.createElement('article')
          card.className = 'search-card'
          const hasPreview = !!movie.previewUrl
          const previewSourceNote =
            hasPreview && movie.previewTitle && movie.previewTitle !== movie.title
              ? `<p class="search-preview-note">Preview source: ${movie.previewTitle}</p>`
              : ''
          const previewButton = `<button type="button" data-action="preview" data-intrinsic-disabled="${hasPreview ? 'false' : 'true'}" ${hasPreview ? '' : 'disabled'}>${hasPreview ? 'Watch preview' : 'Preview unavailable'}</button>`
          const appleLink = movie.trackViewUrl
            ? `<a href="${movie.trackViewUrl}" target="_blank" rel="noreferrer">Open listing</a>`
            : ''

          card.innerHTML = `
            <div class="search-poster-wrap">
              ${movie.artwork ? `<img src="${movie.artwork}" alt="${movie.title} poster" class="search-poster" />` : `<div class="search-poster placeholder">No poster</div>`}
            </div>
            <div class="search-copy">
              <div class="search-topline">
                <strong>${movie.title}</strong>
                <span>${movie.year || 'Year unknown'}</span>
              </div>
              <p class="search-genre">${movie.genre}${movie.durationSeconds ? ` • ${formatClock(movie.durationSeconds)}` : ''}</p>
              ${previewSourceNote}
              <p class="search-description">${movie.description}</p>
              <div class="search-actions">
                ${previewButton}
                ${appleLink}
              </div>
            </div>
          `

          const previewLocator = card.querySelector('button[data-action="preview"]')
          previewLocator?.addEventListener('click', () => {
            if (movie.previewUrl) {
              loadSearchMovie(movie)
            }
          })

          searchResults.appendChild(card)
        })
      }

      async function searchMovies(term = currentMovieTitle(), { autoLoadFirst = false } = {}) {
        const query = String(term || '').trim()

        if (!query) {
          setSearchStatus('Type a movie title first.')
          setStatus('Type a movie title first.', 'error')
          return
        }

        setSearching(true)
        if (autoLoadFirst) {
          showSourceLoader(`Searching for ${query}...`, { title: query, artwork: '' })
          setStatus(`Searching for ${query}...`, 'working')
        }
        setSearchStatus(`Searching real movies for ${query}...`)

        try {
          const response = await fetch(`/api/movie-search?term=${encodeURIComponent(query)}`)

          if (!response.ok) {
            throw new Error('Movie search failed.')
          }

          const payload = await response.json()
          const results = Array.isArray(payload.results) ? payload.results.map(normalizeMovieResult) : []
          const exact = []
          const partial = []

          results.forEach(movie => {
            if (movie.title.toLowerCase() === query.toLowerCase()) {
              exact.push(movie)
            } else {
              partial.push(movie)
            }
          })

          state.searchResults = [...exact, ...partial]
          renderSearchResults()

          if (!state.searchResults.length) {
            if (autoLoadFirst) {
              restorePlayerVisualState()
            }
            setSearchStatus(`No movies showed up for ${query}. Try another title.`)
            setStatus('No movie results yet. Try another title.', 'error')
            return
          }

          setSearchStatus(
            `Found ${state.searchResults.length} movie results for ${query}. Click one to load a legal preview.`
          )
          setStatus('Movie results are ready. Click one to load its preview.', 'success')

          if (autoLoadFirst) {
            const firstPlayableMovie = state.searchResults.find(movie => movie.previewUrl)
            if (firstPlayableMovie) {
              await loadSearchMovie(firstPlayableMovie)
            } else {
              restorePlayerVisualState()
              setStatus('No real movie preview was available for that title. Try another result.', 'error')
            }
          }
        } catch (error) {
          console.error(error)
          state.searchResults = []
          renderSearchResults()
          if (autoLoadFirst) {
            restorePlayerVisualState()
          }
          setSearchStatus('Movie search could not load right now.')
          setStatus('Movie search could not load right now.', 'error')
        } finally {
          setSearching(false)
        }
      }

      async function loadSearchMovie(movie) {
        movieTitleInput.value = movie.title
        state.selectedMovieTitle = movie.title
