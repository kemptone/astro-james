            movie.previewTitle && movie.previewTitle !== movie.title
              ? `${movie.title} preview loaded from ${movie.previewTitle}. Minute buttons and custom timing will clip that preview video.`
              : `${movie.title} preview loaded. Minute buttons and custom timing will clip this preview video.`,
