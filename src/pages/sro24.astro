        display: grid;
        place-items: center;
        padding: 1.5rem;
      }

      .source-loader {
        gap: 0.85rem;
        color: white;
        text-align: center;
        background: radial-gradient(circle at center, rgba(111, 70, 111, 0.78), rgba(11, 13, 16, 0.96));
      }

      .source-loader-art {
        display: grid;
        place-items: center;
        animation: loader-bob 900ms ease-in-out infinite alternate;
      }

      .source-loader-art img,
      .source-loader-fallback {
        width: 170px;
        height: 246px;
        border-radius: 24px;
        object-fit: cover;
        box-shadow: 0 18px 34px rgba(0, 0, 0, 0.36);
        animation: poster-spin 1200ms linear infinite;
      }

      .source-loader-fallback {
        display: grid;
        place-items: center;
        text-align: center;
        padding: 1rem;
        font-size: 2rem;
        font-weight: 900;
        background: linear-gradient(145deg, rgba(216, 91, 115, 0.95), rgba(108, 142, 217, 0.95));
      }

      .loader-wheel,
      .mini-wheel {
        display: inline-block;
        border-radius: 50%;
        border: 6px solid rgba(255, 255, 255, 0.18);
        border-top-color: #f0b44d;
        animation: spin-wheel 900ms linear infinite;
      }

      .loader-wheel {
        width: 72px;
        height: 72px;
      }

      .mini-wheel {
        width: 18px;
        height: 18px;
        border-width: 3px;
      }

      .movie-source-card {
        grid-template-columns: 220px minmax(0, 1fr);
        gap: 1.25rem;
        align-items: center;
        background:
          linear-gradient(135deg, rgba(18, 20, 25, 0.95), rgba(89, 58, 95, 0.92));
        color: white;
      }

      .movie-source-art {
        display: flex;
        justify-content: center;
      }

      .movie-source-art img,
      .movie-source-fallback {
        width: 220px;
        height: 320px;
        border-radius: 24px;
        object-fit: cover;
        box-shadow: 0 16px 30px rgba(0, 0, 0, 0.35);
      }

      .movie-source-fallback {
        display: grid;
        place-items: center;
        text-align: center;
        padding: 1rem;
        font-size: 2rem;
        font-weight: 900;
        background: linear-gradient(145deg, rgba(216, 91, 115, 0.9), rgba(108, 142, 217, 0.92));
      }

      .movie-source-copy {
        display: grid;
        gap: 0.8rem;
        align-content: center;
      }

      .movie-source-label {
        font-size: 0.92rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.72);
      }

      .movie-source-copy h3 {
        margin: 0;
        font-size: clamp(2rem, 4vw, 3.6rem);
        line-height: 0.95;
      }

      .movie-source-copy p {
        color: rgba(255, 255, 255, 0.82);
        line-height: 1.6;
      }

      .movie-source-spinner {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        width: fit-content;
        padding: 0.8rem 1rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.14);
      }

      @keyframes spin-wheel {
        to {
          transform: rotate(360deg);
        }
      }

      @keyframes poster-spin {
        from {
          transform: rotateY(0deg) rotateZ(0deg) scale(0.96);
        }
        50% {
          transform: rotateY(180deg) rotateZ(2deg) scale(1);
        }
        to {
          transform: rotateY(360deg) rotateZ(0deg) scale(0.96);
        }
      }

      @keyframes loader-bob {
        from {
          transform: translateY(-4px);
        }
        to {
          transform: translateY(8px);
        }
      }

      .player-empty,
      .result-empty {
        display: grid;
        place-items: center;
        min-height: 220px;
        padding: 1.2rem;
        text-align: center;
        line-height: 1.6;
      }

      .result-stage {
        position: relative;
        min-height: 220px;
      }

      .soft-panel,
      .result-meta,
      .status-banner {
        padding: 1rem 1.1rem;
      }

      .minute-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
        gap: 0.85rem;
      }

      .minute-button {
        display: grid;
        gap: 0.35rem;
        text-align: left;
        min-height: 122px;
        border-radius: 24px;
        background:
          linear-gradient(160deg, rgba(255, 255, 255, 0.95), rgba(235, 223, 255, 0.96));
        color: var(--ink);
        border: 1px solid rgba(111, 70, 111, 0.12);
        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.4);
      }

      .minute-button strong {
        font-size: 1.5rem;
      }

      .minute-button span,
      .minute-button em {
        font-style: normal;
        color: rgba(29, 32, 38, 0.72);
      }

      .custom-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.9rem;
        margin-bottom: 1rem;
      }

      .load-grid {
        margin-bottom: 1rem;
      }

      .source-tools {
        margin-bottom: 1rem;
        padding: 0.9rem 1rem 1rem;
        border-radius: 24px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.75);
      }

      .source-tools summary {
        cursor: pointer;
        font-weight: 800;
        list-style: none;
      }

      .source-tools summary::-webkit-details-marker {
        display: none;
      }

      .source-tools[open] summary {
        margin-bottom: 0.8rem;
      }

      .fallback-actions {
        display: flex;
        align-items: end;
      }

      label {
        display: grid;
        gap: 0.45rem;
        font-weight: 700;
      }

      input[type='text'] {
        width: 100%;
        padding: 0.95rem 1rem;
        border-radius: 18px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.96);
      }

      .status-banner {
        margin-bottom: 1rem;
        font-weight: 700;
      }

      .status-banner[data-tone='success'] {
        background: rgba(144, 181, 159, 0.22);
        border-color: rgba(144, 181, 159, 0.5);
      }

      .status-banner[data-tone='error'] {
        background: rgba(216, 91, 115, 0.18);
        border-color: rgba(216, 91, 115, 0.38);
      }

      .status-banner[data-tone='working'] {
        background: rgba(240, 180, 77, 0.22);
        border-color: rgba(240, 180, 77, 0.46);
      }

      .result-meta {
        display: grid;
        gap: 0.35rem;
        margin: 1rem 0;
      }

      @media (max-width: 900px) {
        .hero {
          grid-template-columns: 1fr;
        }

        .stats-grid,
        .custom-grid,
        .search-row {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 720px) {
        .shell {
          width: min(100%, calc(100% - 1rem));
          padding-bottom: 2rem;
        }

        .hero,
        .control-card,
        .tool-card,
        .output-card {
          padding: 1.1rem;
        }

        h1 {
          font-size: 2.2rem;
        }

        .player-frame,
        .player-frame video {
          min-height: 220px;
        }

        .minute-grid {
          grid-template-columns: 1fr 1fr;
        }

        .search-card {
          grid-template-columns: 96px minmax(0, 1fr);
        }

        .search-poster,
        .search-poster.placeholder {
          width: 96px;
          height: 140px;
        }

        .movie-source-card {
          grid-template-columns: 1fr;
          justify-items: center;
          text-align: center;
        }

        .movie-source-art img,
        .movie-source-fallback {
          width: 160px;
          height: 232px;
        }

        .movie-source-spinner {
          justify-self: center;
        }
      }

      @media (max-width: 520px) {
        .minute-grid {
          grid-template-columns: 1fr;
        }

        .upload-row,
        .button-row {
          flex-direction: column;
        }

        button,
        .file-picker {
          width: 100%;
        }
      }
    </style>
  </body>
</html>
