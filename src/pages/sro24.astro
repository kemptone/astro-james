      function renderMovieShelf() {
        movieShelf.innerHTML = ''

        moviePresets.forEach((preset, index) => {
          const button = document.createElement('button')
          button.type = 'button'
          button.className = `shelf-card ${preset.accent}`
          button.dataset.selected = preset.title === state.selectedMovieTitle ? 'true' : 'false'
          button.innerHTML =
            `<span class="shelf-number">${String(index + 1).padStart(2, '0')}</span><strong>${preset.title}</strong><span class="shelf-year">${preset.year}</span><p>${preset.description}</p><em>Pick this movie</em>`

          button.addEventListener('click', () => {
            state.selectedMovieTitle = preset.title
            movieTitleInput.value = preset.title
            renderMovieShelf()
            movieName.textContent = hasLoadedSource() ? currentMovieTitle() : `${preset.title} selected`
            searchMovies(preset.title, { autoLoadFirst: true })
          })

          movieShelf.appendChild(button)
        })
      }

      function formatClock(totalSeconds) {
        const rounded = Math.max(0, Math.floor(totalSeconds))
        const hours = Math.floor(rounded / 3600)
        const minutes = Math.floor((rounded % 3600) / 60)
        const seconds = rounded % 60

        if (hours > 0) {
          return `${hours}:${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`
        }

        return `${minutes}:${String(seconds).padStart(2, '0')}`
      }

      function formatSpan(start, end) {
        return `${formatClock(start)} to ${formatClock(end)}`
      }

      function parseTimeValue(value) {
        const text = String(value || '').trim()
        if (!text) return null

        if (/^\d+$/.test(text)) {
          return Number(text)
        }

        const parts = text.split(':').map(part => part.trim())
        if (parts.some(part => part === '' || !/^\d+$/.test(part))) {
          return null
        }

        if (parts.length === 2) {
          return Number(parts[0]) * 60 + Number(parts[1])
        }

        if (parts.length === 3) {
          return Number(parts[0]) * 3600 + Number(parts[1]) * 60 + Number(parts[2])
        }

        return null
      }

      function clampToDuration(seconds) {
        if (!Number.isFinite(seconds)) return 0
        return Math.min(Math.max(seconds, 0), state.duration)
      }

      function pickMimeType() {
        return mimeCandidates.find(type => MediaRecorder.isTypeSupported(type)) || 'video/webm'
      }

      function waitForEvent(target, eventName) {
        return new Promise(resolve => {
          target.addEventListener(eventName, resolve, { once: true })
        })
      }

      function delay(ms) {
        return new Promise(resolve => window.setTimeout(resolve, ms))
      }

      function waitForMetadata(video) {
        if (video.readyState >= 1) {
          return Promise.resolve()
        }

        return waitForEvent(video, 'loadedmetadata')
      }

      function updateSelectionSummary() {
        const { startValue, endValue } = getTimerValues()

        if (startValue === null || endValue === null) {
          if (isPreviewSource()) {
            selectionSummary.textContent =
              'Set both timer boxes to enable the buttons below. This preview mode exports preview clips, and matching times make a screenshot.'
            updateCustomButtonsState()
            return
          }

          if (!hasLoadedSource()) {
            selectionSummary.textContent = 'Set both timer boxes to enable the buttons below.'
            updateCustomButtonsState()
            return
          }

          selectionSummary.textContent = 'Enter a start and end time like 1:20 or 1:34:04.'
          updateCustomButtonsState()
          return
        }

        const start = clampToDuration(startValue)
        const end = clampToDuration(endValue)

        if (!hasLoadedSource()) {
          if (startValue === endValue) {
            selectionSummary.textContent =
              `Both timers are set to ${formatClock(startValue)}. The buttons below are ready, and a loaded video source can turn that into a screenshot.`
            updateCustomButtonsState()
            return
          }

          const rawDirection = endValue > startValue ? 'forward' : 'reverse'
          const rawSpan = Math.abs(endValue - startValue)
          selectionSummary.textContent =
            `Both timers are set from ${formatClock(startValue)} to ${formatClock(endValue)}. The buttons below are ready, and a loaded video source can turn that into a ${rawDirection} clip of ${formatClock(rawSpan)}.`
          updateCustomButtonsState()
          return
        }

        if (startValue > state.duration) {
          selectionSummary.textContent = rangePastEndMessage('start')
          updateCustomButtonsState()
          return
        }

        if (startValue !== endValue && start === end) {
          selectionSummary.textContent = rangePastEndMessage('collapse')
          updateCustomButtonsState()
          return
        }

        if (start === end) {
          selectionSummary.textContent = isPreviewSource()
            ? `Same start and end at ${formatClock(start)}. This will export a preview screenshot.`
            : `Same start and end at ${formatClock(start)}. This will export a screenshot.`
          updateCustomButtonsState()
          return
        }

        const direction = end > start ? 'forward' : 'reverse'
        const span = Math.abs(end - start)
        const clippedAtEnd = endValue > state.duration && end > start
        selectionSummary.textContent = isPreviewSource()
          ? `This will export a ${direction} preview clip from ${formatSpan(start, end)}. Clip length: ${formatClock(span)}.${clippedAtEnd ? ` This preview ends at ${formatClock(end)}.` : ''} Search results only use preview footage, not the whole movie.`
          : `This will export a ${direction} clip from ${formatSpan(start, end)}. Clip length: ${formatClock(span)}.${clippedAtEnd ? ` This movie ends at ${formatClock(end)}.` : ''} Whole movie mode can use any time in ${formatClipRangeText()}.`
        updateCustomButtonsState()
      }

      function resetResult() {
        if (state.exportUrl) {
          URL.revokeObjectURL(state.exportUrl)
        }

        state.exportBlob = null
        state.exportUrl = ''
        state.exportName = ''
        state.exportKind = ''
        state.exportType = ''

        resultVideo.pause()
        resultVideo.removeAttribute('src')
        resultVideo.load()
        resultVideo.hidden = true
        resultImage.removeAttribute('src')
        resultImage.hidden = true
        resultEmpty.hidden = false
        resultTitle.textContent = 'Nothing exported yet'
        resultDetails.textContent = 'Choose a minute button or enter custom times after loading a preview or your own video source.'
        setBusy(false)
      }

      function teardownMovie() {
        resetResult()

        if (state.movieUrl.startsWith('blob:')) {
          URL.revokeObjectURL(state.movieUrl)
        }

        state.movieFile = null
        state.movieUrl = ''
        state.duration = 0
        state.sourceKind = 'none'
        state.watchMode = 'none'

        fileInput.value = ''
        movieUrlInput.value = ''
        state.sourceArtwork = ''
        hideSourceLoader()
        movieSourceCard.hidden = true
        movieSourcePoster.removeAttribute('src')
        movieSourcePoster.hidden = true
        movieSourcePosterFallback.hidden = false
        moviePreview.pause()
        moviePreview.removeAttribute('src')
        moviePreview.load()
        moviePreview.hidden = true
        playerEmpty.hidden = false
        minuteButtons.innerHTML = ''
        minuteButtons.hidden = true
        minuteButtonsEmpty.hidden = false
        movieName.textContent = `${currentMovieTitle()} selected`
        movieDuration.textContent = '0:00'
        minuteCount.textContent = '0'
        updateSourceFacts()
        startTimeInput.value = ''
        endTimeInput.value = ''
        updateActionButtonLabels()
        updateSelectionSummary()
        setStatus('Pick a movie to begin.', 'neutral')
        setBusy(false)
      }

      function renderMinuteButtons() {
        minuteButtons.innerHTML = ''

        if (!state.duration) {
          minuteButtons.hidden = true
          minuteButtonsEmpty.hidden = false
          minuteCount.textContent = '0'
          return
        }

        const totalButtons = Math.ceil(state.duration / 60)
        minuteCount.textContent = String(totalButtons)
        minuteButtons.hidden = false
        minuteButtonsEmpty.hidden = true

        for (let index = 0; index < totalButtons; index += 1) {
          const start = index * 60
          const end = Math.min((index + 1) * 60, state.duration)
          const clipLength = end - start
          const button = document.createElement('button')
          button.type = 'button'
          button.className = 'minute-button'
          button.innerHTML =
            `<strong>${index + 1}</strong><span>${formatSpan(start, end)}</span><em>${formatClock(clipLength)}</em>`

          button.addEventListener('click', () => {
            startTimeInput.value = formatClock(start)
            endTimeInput.value = formatClock(end)
            updateSelectionSummary()
            exportRange(start, end, `Minute ${index + 1}`)
          })

          minuteButtons.appendChild(button)
        }

        setBusy(state.busy)
      }

      async function loadMovie({
        file = null,
        url = '',
        label = '',
        keepLoader = false,
        sourceKind = 'direct-url',
      }) {
        teardownMovie()

        if (file) {
          state.movieFile = file
          state.movieUrl = URL.createObjectURL(file)
          state.sourceKind = sourceKind
        } else if (url) {
          state.movieFile = null
          state.movieUrl = url
          state.sourceKind = sourceKind
        } else {
          throw new Error('No movie source was provided.')
        }

        state.watchMode = 'clip'
        movieSourceCard.hidden = true
        if (!keepLoader) {
          hideSourceLoader()
        }
        moviePreview.src = state.movieUrl
        moviePreview.crossOrigin = 'anonymous'
        await waitForMetadata(moviePreview)

        state.duration = Number.isFinite(moviePreview.duration) ? moviePreview.duration : 0
        hideSourceLoader()
        moviePreview.hidden = false
        playerEmpty.hidden = true
        movieName.textContent = isPreviewSource() ? `${currentMovieTitle()} preview` : currentMovieTitle()
        movieDuration.textContent = formatClock(state.duration)
        updateSourceFacts()
        startTimeInput.value = '0:00'
        endTimeInput.value = formatClock(state.duration)
        updateActionButtonLabels()
        renderMinuteButtons()
        updateSelectionSummary()
        setStatus(
          isPreviewSource()
            ? `${currentMovieTitle()} preview loaded. Choose a minute button or make a custom preview clip.`
            : `${currentMovieTitle()} whole movie source loaded. You can clip anywhere from 0:00 to ${formatClock(state.duration)}.`,
          'success'
        )
        setBusy(false)
      }

      async function withVideoFrame(atTime, callback) {
        const helperVideo = document.createElement('video')
        helperVideo.src = state.movieUrl
        helperVideo.preload = 'auto'
        helperVideo.crossOrigin = 'anonymous'
        helperVideo.muted = true
        helperVideo.playsInline = true

        try {
          await waitForMetadata(helperVideo)

          const safeTime = Math.min(Math.max(atTime, 0), Math.max(helperVideo.duration - 0.02, 0))
          helperVideo.currentTime = safeTime
          await waitForEvent(helperVideo, 'seeked')

          return await callback(helperVideo)
        } finally {
          helperVideo.pause()
          helperVideo.removeAttribute('src')
          helperVideo.load()
        }
      }

      function buildCanvasForVideo(video) {
        const maxWidth = 960
        const width = video.videoWidth || 640
        const height = video.videoHeight || 360
        const ratio = width / height || 16 / 9
        const canvas = document.createElement('canvas')

        if (width > maxWidth) {
          canvas.width = maxWidth
          canvas.height = Math.round(maxWidth / ratio)
        } else {
          canvas.width = width
          canvas.height = height
        }

        return canvas
      }

      async function createScreenshotBlob(atTime) {
        return withVideoFrame(atTime, video => {
          const canvas = buildCanvasForVideo(video)
          const context = canvas.getContext('2d')

          if (!context) {
            throw new Error('Canvas is not available for screenshots.')
          }

          context.drawImage(video, 0, 0, canvas.width, canvas.height)

          return new Promise((resolve, reject) => {
            canvas.toBlob(blob => {
              if (!blob) {
                reject(new Error('Screenshot export failed.'))
                return
              }

              resolve(blob)
            }, 'image/png')
          })
        })
      }

      async function createForwardClipBlob(start, end) {
        return withVideoFrame(start, async video => {
          const canvas = buildCanvasForVideo(video)
          const context = canvas.getContext('2d')

          if (!context) {
            throw new Error('Canvas is not available for clip export.')
          }

          const fps = 30
          const mimeType = pickMimeType()
          const stream = canvas.captureStream(fps)
          const recorder = new MediaRecorder(
            stream,
            mimeType ? { mimeType, videoBitsPerSecond: 3_000_000 } : undefined,
          )
          const chunks = []
          let finished = false

          const stopRecorder = () => {
            if (finished) return
            finished = true
            window.cancelAnimationFrame(animationFrame)
            video.pause()
            window.clearInterval(limitWatcher)
            window.setTimeout(() => recorder.stop(), 120)
          }

          recorder.ondataavailable = event => {
            if (event.data && event.data.size > 0) {
              chunks.push(event.data)
            }
          }

          const stopPromise = new Promise((resolve, reject) => {
            recorder.onstop = () => resolve(new Blob(chunks, { type: recorder.mimeType || mimeType || 'video/webm' }))
            recorder.onerror = () => reject(new Error('Movie clip recording failed.'))
          })

          context.drawImage(video, 0, 0, canvas.width, canvas.height)
          recorder.start()

          let animationFrame = 0
          const draw = () => {
            if (!finished) {
              context.drawImage(video, 0, 0, canvas.width, canvas.height)
              animationFrame = window.requestAnimationFrame(draw)
            }
          }

          draw()
          video.muted = true
          await video.play()

          const limitWatcher = window.setInterval(() => {
            if (video.currentTime >= end || video.ended) {
              stopRecorder()
            }
          }, 50)

          const blob = await stopPromise
          stream.getTracks().forEach(track => track.stop())
          return blob
        })
      }

      async function createReverseClipBlob(start, end) {
        return withVideoFrame(start, async video => {
          const canvas = buildCanvasForVideo(video)
          const context = canvas.getContext('2d')

          if (!context) {
            throw new Error('Canvas is not available for reverse clip export.')
          }

          const fps = 12
          const frameStep = 1 / fps
          const mimeType = pickMimeType()
          const stream = canvas.captureStream(fps)
          const recorder = new MediaRecorder(
            stream,
            mimeType ? { mimeType, videoBitsPerSecond: 3_000_000 } : undefined,
          )
          const chunks = []

          recorder.ondataavailable = event => {
            if (event.data && event.data.size > 0) {
              chunks.push(event.data)
            }
          }

          const stopPromise = new Promise((resolve, reject) => {
            recorder.onstop = () => resolve(new Blob(chunks, { type: recorder.mimeType || mimeType || 'video/webm' }))
            recorder.onerror = () => reject(new Error('Reverse clip recording failed.'))
          })

          recorder.start()

          for (let stamp = start; stamp >= end; stamp -= frameStep) {
            const safeStamp = Math.max(end, Math.min(stamp, Math.max(video.duration - 0.02, 0)))
            video.currentTime = safeStamp
            await waitForEvent(video, 'seeked')
            context.drawImage(video, 0, 0, canvas.width, canvas.height)
            await delay(1000 / fps)
          }

          window.setTimeout(() => recorder.stop(), 120)
          const blob = await stopPromise
          stream.getTracks().forEach(track => track.stop())
          return blob
        })
      }

      function wrapCanvasText(context, text, maxWidth) {
        const words = String(text || '').split(/\s+/).filter(Boolean)
        const lines = []
        let current = ''

        words.forEach(word => {
          const candidate = current ? `${current} ${word}` : word
          if (context.measureText(candidate).width <= maxWidth || !current) {
            current = candidate
          } else {
            lines.push(current)
            current = word
          }
        })

        if (current) {
          lines.push(current)
        }

        return lines
      }

      function roundedRectPath(context, x, y, width, height, radius) {
        context.beginPath()
        context.moveTo(x + radius, y)
        context.lineTo(x + width - radius, y)
        context.quadraticCurveTo(x + width, y, x + width, y + radius)
        context.lineTo(x + width, y + height - radius)
        context.quadraticCurveTo(x + width, y + height, x + width - radius, y + height)
        context.lineTo(x + radius, y + height)
        context.quadraticCurveTo(x, y + height, x, y + height - radius)
        context.lineTo(x, y + radius)
        context.quadraticCurveTo(x, y, x + radius, y)
        context.closePath()
      }

      async function loadCatalogArtwork() {
        if (!state.sourceArtwork) return null

        return new Promise(resolve => {
          const image = new Image()
          image.crossOrigin = 'anonymous'
          image.onload = () => resolve(image)
          image.onerror = () => resolve(null)
          image.src = state.sourceArtwork
        })
      }

      function drawCatalogFrame(context, { start, end, label, progress, artworkImage }) {
        const direction = end === start ? 'Screenshot' : end > start ? 'Forward clip' : 'Reverse clip'
        const span = Math.abs(end - start)
        const currentStamp = start + (end - start) * progress
        const width = 1280
        const height = 720

        const gradient = context.createLinearGradient(0, 0, width, height)
        gradient.addColorStop(0, '#1d2026')
        gradient.addColorStop(0.5, '#6f466f')
        gradient.addColorStop(1, '#d85b73')
        context.fillStyle = gradient
        context.fillRect(0, 0, width, height)

        context.fillStyle = 'rgba(255,255,255,0.12)'
        for (let x = 24; x < width; x += 86) {
          context.fillRect(x, 24, 48, 18)
          context.fillRect(x, height - 42, 48, 18)
        }

        context.fillStyle = `rgba(255,255,255,${0.1 + progress * 0.06})`
        context.beginPath()
        context.arc(1060 - progress * 120, 140 + progress * 40, 120 + progress * 12, 0, Math.PI * 2)
        context.fill()

        context.fillStyle = '#fff7ef'
        roundedRectPath(context, 110, 92, width - 220, height - 184, 34)
        context.fill()

        context.save()
        roundedRectPath(context, 150, 150, 260, 376, 30)
        context.clip()
        if (artworkImage) {
          context.drawImage(artworkImage, 150, 150, 260, 376)
        } else {
          const fallback = context.createLinearGradient(150, 150, 410, 526)
          fallback.addColorStop(0, '#d85b73')
          fallback.addColorStop(1, '#6c8ed9')
          context.fillStyle = fallback
          context.fillRect(150, 150, 260, 376)
          context.fillStyle = 'rgba(255,255,255,0.94)'
          context.font = '900 42px Trebuchet MS'
          context.textAlign = 'center'
          const titleLines = wrapCanvasText(context, currentMovieTitle(), 190).slice(0, 4)
          titleLines.forEach((line, index) => {
            context.fillText(line, 280, 260 + index * 52)
          })
          context.textAlign = 'left'
        }
        context.restore()

        context.strokeStyle = '#d85b73'
        context.lineWidth = 10
        roundedRectPath(context, 150, 150, 260, 376, 30)
        context.stroke()

        context.fillStyle = '#1d2026'
        context.font = '800 34px Trebuchet MS'
        context.fillText('SRO24 smart movie source', 470, 176)

        context.font = '900 68px Trebuchet MS'
        const titleLines = wrapCanvasText(context, currentMovieTitle(), 580).slice(0, 2)
        titleLines.forEach((line, index) => {
          context.fillText(line, 470, 260 + index * 76)
        })

        context.font = '700 30px Trebuchet MS'
        context.fillStyle = '#6f466f'
        context.fillText(`${label} • ${direction}`, 470, titleLines.length > 1 ? 412 : 340)

        context.fillStyle = '#1d2026'
        context.font = '700 42px Trebuchet MS'
        const rowTop = titleLines.length > 1 ? 486 : 414
        context.fillText(`Start: ${formatClock(start)}`, 470, rowTop)
        context.fillText(`End: ${formatClock(end)}`, 470, rowTop + 62)
        context.fillText(`Length: ${formatClock(span)}`, 470, rowTop + 124)

        context.font = '800 26px Trebuchet MS'
        context.fillStyle = '#434758'
        context.fillText(`Now previewing: ${formatClock(currentStamp)}`, 470, rowTop + 188)

        const barX = 470
        const barY = rowTop + 226
        const barWidth = 560
        const barHeight = 22

        context.fillStyle = 'rgba(29,32,38,0.14)'
        roundedRectPath(context, barX, barY, barWidth, barHeight, 11)
        context.fill()

        const fillWidth = Math.max(18, barWidth * progress)
        const barGradient = context.createLinearGradient(barX, barY, barX + barWidth, barY)
        barGradient.addColorStop(0, '#f0b44d')
        barGradient.addColorStop(1, '#d85b73')
        context.fillStyle = barGradient
        roundedRectPath(context, barX, barY, fillWidth, barHeight, 11)
        context.fill()

        const handleX = barX + barWidth * progress
        context.fillStyle = '#1d2026'
        context.beginPath()
        context.arc(handleX, barY + barHeight / 2, 16, 0, Math.PI * 2)
        context.fill()
        context.fillStyle = '#fff7ef'
        context.beginPath()
        context.arc(handleX, barY + barHeight / 2, 7, 0, Math.PI * 2)
        context.fill()

        context.font = '800 24px Trebuchet MS'
        context.fillStyle = '#1d2026'
        context.fillText(formatClock(start), barX, barY + 58)
        context.textAlign = 'right'
        context.fillText(formatClock(end), barX + barWidth, barY + 58)
        context.textAlign = 'left'

        context.fillStyle = '#6f466f'
        context.font = '700 22px Trebuchet MS'
        context.fillText(
          direction === 'Reverse clip' ? 'Smart reverse rendering' : 'Smart clip rendering',
          470,
          barY + 108
        )
      }

      async function createCatalogResultBlob(start, end, label) {
        const canvas = document.createElement('canvas')
        canvas.width = 1280
        canvas.height = 720
        const context = canvas.getContext('2d')

        if (!context) {
          throw new Error('Canvas is not available for movie cards.')
        }

        const artworkImage = await loadCatalogArtwork()
        drawCatalogFrame(context, { start, end, label, progress: 1, artworkImage })

        return new Promise((resolve, reject) => {
          canvas.toBlob(blob => {
            if (!blob) {
              reject(new Error('Movie card export failed.'))
              return
            }

            resolve(blob)
          }, 'image/png')
        })
      }

      async function createCatalogClipBlob(start, end, label) {
        const canvas = document.createElement('canvas')
        canvas.width = 1280
        canvas.height = 720
        const context = canvas.getContext('2d')

        if (!context) {
          throw new Error('Canvas is not available for movie clip cards.')
        }

        const fps = 12
        const mimeType = pickMimeType()
        const stream = canvas.captureStream(fps)
        const recorder = new MediaRecorder(
          stream,
          mimeType ? { mimeType, videoBitsPerSecond: 2_500_000 } : undefined,
        )
        const chunks = []
        const artworkImage = await loadCatalogArtwork()
        const span = Math.abs(end - start)
        const clipDurationMs = Math.min(5200, Math.max(2200, 1200 + span * 22))
        const totalFrames = Math.max(24, Math.round((clipDurationMs / 1000) * fps))

        recorder.ondataavailable = event => {
          if (event.data && event.data.size > 0) {
            chunks.push(event.data)
          }
        }

        const stopPromise = new Promise((resolve, reject) => {
          recorder.onstop = () => resolve(new Blob(chunks, { type: recorder.mimeType || mimeType || 'video/webm' }))
          recorder.onerror = () => reject(new Error('Smart movie clip export failed.'))
        })

        recorder.start()

        for (let frame = 0; frame < totalFrames; frame += 1) {
          const progress = totalFrames === 1 ? 1 : frame / (totalFrames - 1)
          drawCatalogFrame(context, { start, end, label, progress, artworkImage })
          await delay(1000 / fps)
        }

        window.setTimeout(() => recorder.stop(), 160)
        const blob = await stopPromise
        stream.getTracks().forEach(track => track.stop())
        return blob
      }

      function prepareResultDisplay({ title, details, previewKind = '', previewUrl = '' }) {
        if (state.exportUrl) {
          URL.revokeObjectURL(state.exportUrl)
        }

        state.exportBlob = null
        state.exportUrl = ''
        state.exportName = ''
        state.exportKind = ''
        state.exportType = ''

        resultVideo.pause()
        resultVideo.removeAttribute('src')
        resultVideo.load()
        resultVideo.hidden = true
        resultImage.removeAttribute('src')
        resultImage.hidden = true
        resultEmpty.hidden = false

        if (previewKind === 'image' && previewUrl) {
          resultImage.src = previewUrl
          resultImage.hidden = false
          resultEmpty.hidden = true
        }

        resultTitle.textContent = title
        resultDetails.textContent = details
      }

      function createCatalogPreviewUrl(start, end, label) {
        const canvas = document.createElement('canvas')
        canvas.width = 1280
        canvas.height = 720
        const context = canvas.getContext('2d')

        if (!context) {
          return ''
        }

        const progress = start === end ? 1 : end > start ? 0 : 1
        drawCatalogFrame(context, { start, end, label, progress, artworkImage: null })
        return canvas.toDataURL('image/png')
      }

      function setExportResult({ blob, kind, title, details, extension }) {
        prepareResultDisplay({ title, details })

        state.exportBlob = blob
        state.exportKind = kind
        state.exportType = blob.type
        state.exportName = `${title.replace(/\s+/g, '-').toLowerCase()}.${extension}`
        state.exportUrl = URL.createObjectURL(blob)

        if (kind === 'image') {
          resultImage.src = state.exportUrl
          resultImage.hidden = false
        } else {
          resultVideo.src = state.exportUrl
          resultVideo.hidden = false
          resultVideo.currentTime = 0
          resultVideo.play().catch(() => {
            resultVideo.pause()
            resultVideo.currentTime = 0
          })
        }

        resultEmpty.hidden = true
        resultTitle.textContent = title
        resultDetails.textContent = details
        autoDownloadResult()
        setBusy(false)
      }

      function autoDownloadResult() {
        if (!state.exportUrl || !state.exportName) return

        const link = document.createElement('a')
        link.href = state.exportUrl
        link.download = state.exportName
        document.body.appendChild(link)
        link.click()
        document.body.removeChild(link)
      }

      async function exportRange(startInput, endInput, label = 'Custom result') {
        if (state.busy) return

        try {
          if (!hasLoadedSource()) {
            throw new Error('Load a preview or your own video source first.')
          }

          const start = clampToDuration(startInput)
          const end = clampToDuration(endInput)
          const previewPrefix = isPreviewSource() ? 'preview ' : ''
          const screenshotTitle = `${currentMovieTitle()} ${label} ${previewPrefix}screenshot`
          const clipTitle = `${currentMovieTitle()} ${label} ${previewPrefix}clip`
          const reverseClipTitle = `${currentMovieTitle()} ${label} ${previewPrefix}reverse clip`

          if (startInput > state.duration) {
            if (isPreviewSource()) {
              openWholeMovieTools(true)
            }
            throw new Error(rangePastEndMessage('start'))
          }

          if (startInput !== endInput && start === end) {
            if (isPreviewSource()) {
              openWholeMovieTools(true)
            }
            throw new Error(rangePastEndMessage('collapse'))
          }

          setBusy(true)

          if (start === end) {
            prepareResultDisplay({
              title: screenshotTitle,
              details: `${isPreviewSource() ? 'Preview s' : 'S'}creenshot at ${formatClock(start)}.`,
            })
            setStatus(
              `Making ${isPreviewSource() ? 'preview ' : ''}screenshot at ${formatClock(start)}...`,
              'working'
            )
            await nextFrame()
            const screenshotBlob = await createScreenshotBlob(start)
            setExportResult({
              blob: screenshotBlob,
              kind: 'image',
              title: screenshotTitle,
              details: `${isPreviewSource() ? 'Preview s' : 'S'}creenshot captured at ${formatClock(start)}.`,
              extension: 'png',
            })
            setStatus(isPreviewSource() ? 'Preview screenshot downloaded.' : 'Screenshot downloaded.', 'success')
            return
          }

          if (end > start) {
            prepareResultDisplay({
              title: clipTitle,
              details: `Forward ${previewPrefix}clip from ${formatSpan(start, end)}.`,
            })
            setStatus(`Making ${previewPrefix}clip from ${formatSpan(start, end)}...`, 'working')
            await nextFrame()
            const clipBlob = await createForwardClipBlob(start, end)
            setExportResult({
              blob: clipBlob,
              kind: 'video',
              title: clipTitle,
              details: `Forward ${previewPrefix}clip from ${formatSpan(start, end)}.`,
              extension: clipBlob.type.includes('mp4') ? 'mp4' : 'webm',
            })
            setStatus(isPreviewSource() ? 'Preview clip downloaded.' : 'Forward clip downloaded.', 'success')
            return
          }

          prepareResultDisplay({
            title: reverseClipTitle,
            details: `Reverse ${previewPrefix}clip from ${formatClock(start)} down to ${formatClock(end)}.`,
          })
          setStatus(`Making reverse ${previewPrefix}clip from ${formatSpan(start, end)}...`, 'working')
          await nextFrame()
          const reverseBlob = await createReverseClipBlob(start, end)
          setExportResult({
            blob: reverseBlob,
            kind: 'video',
            title: reverseClipTitle,
            details: `Reverse ${previewPrefix}clip from ${formatClock(start)} down to ${formatClock(end)}.`,
            extension: reverseBlob.type.includes('mp4') ? 'mp4' : 'webm',
          })
          setStatus(isPreviewSource() ? 'Reverse preview clip downloaded.' : 'Reverse clip downloaded.', 'success')
        } catch (error) {
          console.error(error)
          setStatus(error instanceof Error ? error.message : 'Export failed.', 'error')
          setBusy(false)
        }
      }

      async function saveOrShareResult(mode) {
        if (!state.exportBlob) return

        const file = new File([state.exportBlob], state.exportName || 'sro24-export', {
          type: state.exportType || state.exportBlob.type,
        })

        if (mode === 'share') {
          try {
            if (navigator.canShare && navigator.canShare({ files: [file] })) {
              await navigator.share({
                files: [file],
                title: state.exportKind === 'image' ? 'SRO24 screenshot' : 'SRO24 clip',
              })
              setStatus('Shared. Use Save Image or Save Video in the share sheet if you want it in Photos.', 'success')
              return
            }
          } catch (error) {
            console.error(error)
          }
        } else {
          try {
            if (navigator.canShare && navigator.canShare({ files: [file] })) {
              await navigator.share({
                files: [file],
                title: state.exportKind === 'image' ? 'SRO24 screenshot' : 'SRO24 clip',
              })
              setStatus('Share sheet opened. Choose Save Image or Save Video there.', 'success')
              return
            }
          } catch (error) {
            console.error(error)
          }
        }

        autoDownloadResult()
        setStatus(state.exportKind === 'image' ? 'Screenshot downloaded.' : 'Clip downloaded.', 'success')
      }

      fileInput.addEventListener('change', event => {
        const [file] = event.target.files || []
        if (file) {
          if (!String(movieTitleInput.value || '').trim()) {
            movieTitleInput.value = state.selectedMovieTitle
          }

          loadMovie({ file, sourceKind: 'file' }).catch(error => {
            console.error(error)
            teardownMovie()
            setStatus('That movie could not be loaded.', 'error')
          })
        }
      })

      searchMoviesButton.addEventListener('click', () => {
        searchMovies(movieTitleInput.value)
      })

      movieTitleInput.addEventListener('keydown', event => {
        if (event.key === 'Enter') {
          event.preventDefault()
          searchMovies(movieTitleInput.value)
        }
      })

      loadMovieUrlButton.addEventListener('click', () => {
        const typedUrl = String(movieUrlInput.value || '').trim()

        if (!typedUrl) {
          setStatus('Paste a direct video URL first.', 'error')
          return
        }

        if (!/^https?:\/\//i.test(typedUrl)) {
          setStatus('Use a full URL that starts with http:// or https://.', 'error')
          return
        }

        if (!String(movieTitleInput.value || '').trim()) {
          movieTitleInput.value = state.selectedMovieTitle
        }

        loadMovie({ url: typedUrl, label: currentMovieTitle(), sourceKind: 'direct-url' }).catch(error => {
          console.error(error)
          teardownMovie()
          setStatus('That movie URL could not be loaded.', 'error')
        })
      })

      clearMovieButton.addEventListener('click', () => {
        teardownMovie()
      })

      loadWholeMovieDemoButton.addEventListener('click', () => {
        loadWholeMovieDemo()
      })

      focusWholeSourceButton.addEventListener('click', () => {
        openWholeMovieTools(true)
        setStatus('Whole movie tools are ready. Load a full video URL or movie file to use the full runtime.', 'success')
      })

      makeCustomClipButton.addEventListener('click', () => {
        const startValue = parseTimeValue(startTimeInput.value)
        const endValue = parseTimeValue(endTimeInput.value)

        if (startValue === null || endValue === null) {
          setStatus('Enter valid times like 59:32 or 1:34:04.', 'error')
          updateSelectionSummary()
          return
        }

        if (!hasLoadedSource()) {
          openWholeMovieTools(true)
          setStatus('Load a movie preview or your own video source after setting both timers if you want to make a clip.', 'error')
          updateSelectionSummary()
          return
        }

        updateSelectionSummary()
        exportRange(startValue, endValue)
      })

      fillWholeMovieButton.addEventListener('click', () => {
        if (!hasLoadedSource()) {
          openWholeMovieTools(true)
          setStatus('Load a movie preview or your own video source first if you want full timing.', 'error')
          return
        }

        startTimeInput.value = '0:00'
        endTimeInput.value = formatClock(state.duration)
        updateSelectionSummary()
        setStatus(
          isPreviewSource()
            ? 'Whole preview timing is ready.'
            : hasUserVideoSource()
              ? `Whole movie timing is ready from 0:00 to ${formatClock(state.duration)}.`
              : 'Whole timing is ready.',
          'success'
        )
      })

      jumpToStartButton.addEventListener('click', async () => {
        const startValue = parseTimeValue(startTimeInput.value)
        if (startValue === null) {
          setStatus('Enter a valid start time first.', 'error')
          return
        }

        if (!hasLoadedSource()) {
          openWholeMovieTools(true)
          setStatus('Load a movie preview or your own video source first if you want to jump to the start.', 'error')
          return
        }

        moviePreview.currentTime = clampToDuration(startValue)
        moviePreview.play().catch(() => {
          moviePreview.pause()
        })
      })

      startTimeInput.addEventListener('input', updateSelectionSummary)
      endTimeInput.addEventListener('input', updateSelectionSummary)
      movieTitleInput.addEventListener('input', () => {
        const typed = String(movieTitleInput.value || '').trim()
        if (typed) {
          state.selectedMovieTitle = typed
        }
        renderMovieShelf()
        if (!hasLoadedSource()) {
          movieName.textContent = typed ? `${typed} selected` : 'No movie yet'
        }
      })
      saveResultButton.addEventListener('click', () => saveOrShareResult('save'))
      shareResultButton.addEventListener('click', () => saveOrShareResult('share'))

      movieTitleInput.value = state.selectedMovieTitle
      renderMovieShelf()
      updateSourceFacts()
      teardownMovie()
    </script>

