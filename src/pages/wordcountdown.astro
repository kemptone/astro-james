---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Word Countdown Game">
  <main class="wordcountdown-page">
    <section class="hero panel">
      <div>
        <p class="eyebrow">Word Countdown Game</p>
        <h1>You can see when every word begins and when it ends.</h1>
        <p class="lede">
          Add a word, choose a <strong>From</strong> second and a
          <strong>To</strong> second, and the word will wait, appear, and then
          disappear on time.
        </p>
      </div>

      <div class="example-callout">
        <p class="example-label">Example</p>
        <p class="example-copy">
          If you add <strong>Wash</strong> with <strong>From 5</strong> and
          <strong>To 10</strong>, it waits 5 seconds, shows up, and is gone at
          10 seconds.
        </p>
      </div>
    </section>

    <section class="builder-grid">
      <form id="word-form" class="panel composer" novalidate>
        <div class="section-heading">
          <p class="eyebrow">Make A Word</p>
          <h2>Add it to the timer.</h2>
        </div>

        <div class="form-grid">
          <label>
            <span>Word</span>
            <input
              id="word-input"
              name="word"
              type="text"
              placeholder="Wash"
              autocomplete="off"
              maxlength="40"
            />
          </label>

          <label>
            <span>From</span>
            <input
              id="from-input"
              name="from"
              type="number"
              min="0"
              step="0.1"
              value="5"
              inputmode="decimal"
            />
          </label>

          <label>
            <span>To</span>
            <input
              id="to-input"
              name="to"
              type="number"
              min="0"
              step="0.1"
              value="10"
              inputmode="decimal"
            />
          </label>
        </div>

        <div class="missing-letter-box">
          <div class="checkbox-row">
            <label class="checkbox-label" for="remove-letter-checkbox">
              <input
                id="remove-letter-checkbox"
                name="removeLetter"
                type="checkbox"
              />
              <span>Missing-letter mode</span>
            </label>

            <label class="pick-letter">
              <span>Picked letter</span>
              <input
                id="letter-input"
                name="letter"
                type="text"
                value="A"
                maxlength="1"
                autocomplete="off"
              />
            </label>
          </div>

          <div class="preview-grid">
            <div class="preview-card">
              <p class="preview-label">Instead demo</p>
              <p class="preview-line">
                <span class="before">Instead</span>
                <span class="arrow">-></span>
                <span id="instead-preview" class="after">Instead</span>
              </p>
            </div>

            <div class="preview-card">
              <p class="preview-label">Your word preview</p>
              <p class="preview-line">
                <span id="word-preview-before" class="before">Wash</span>
                <span class="arrow">-></span>
                <span id="word-preview-after" class="after">Wash</span>
              </p>
            </div>
          </div>

          <p class="help-copy">
            Turn the checkbox on to remove the picked letter from the word. If
            10 saved words are missing the same letter, the vacation unlock
            appears.
          </p>
        </div>

        <p id="form-message" class="message" aria-live="polite">
          Add words and keep stacking the timeline.
        </p>

        <div class="action-row">
          <button type="submit" class="primary-button">Add Word</button>
          <button id="reset-button" type="button" class="secondary-button">
            Reset Game
          </button>
        </div>
      </form>

      <aside class="panel stats-panel">
        <div class="section-heading">
          <p class="eyebrow">Live Counts</p>
          <h2>The game tells you what is happening now.</h2>
        </div>

        <div class="stats-grid">
          <article class="stat-card">
            <p class="stat-label">Total words</p>
            <p id="total-count" class="stat-value">0</p>
          </article>

          <article class="stat-card">
            <p class="stat-label">Showing now</p>
            <p id="live-count" class="stat-value">0</p>
          </article>

          <article class="stat-card">
            <p class="stat-label">Waiting</p>
            <p id="waiting-count" class="stat-value">0</p>
          </article>

          <article class="stat-card">
            <p class="stat-label">Gone</p>
            <p id="expired-count" class="stat-value">0</p>
          </article>
        </div>

        <div class="letter-summary">
          <p class="letter-summary-label">Same missing letter</p>
          <p id="letter-summary" class="letter-summary-value">
            No matching missing-letter streak yet.
          </p>
          <div id="letter-chip-list" class="letter-chip-list"></div>
        </div>
      </aside>
    </section>

    <section class="panel live-panel">
      <div class="section-heading">
        <p class="eyebrow">On Screen</p>
        <h2>These are the words showing right now.</h2>
      </div>

      <div id="live-words" class="live-words" aria-live="polite"></div>
    </section>

    <section class="panel history-panel">
      <div class="section-heading">
        <p class="eyebrow">Every Single Word</p>
        <h2>You can always see the list and when each word ends.</h2>
      </div>

      <div id="history-list" class="history-list"></div>
    </section>

    <section class="unlock-grid">
      <article id="photo-card" class="panel unlock-card locked">
        <div class="unlock-header">
          <div>
            <p class="eyebrow">Unlock 1</p>
            <h2>2010 memory photo</h2>
          </div>
          <p id="photo-status" class="unlock-status">Locked: 0 / 10 words</p>
        </div>

        <div class="memory-polaroid">
          <div class="memory-art" aria-hidden="true">
            <div class="memory-glow"></div>
            <div class="memory-head"></div>
            <div class="memory-body"></div>
            <div class="memory-spark one"></div>
            <div class="memory-spark two"></div>
            <div class="memory-spark three"></div>
          </div>

          <p class="memory-name">Aysia barrozo keen</p>
          <p class="memory-time">November 7, 2010 at 8:52 PM</p>
        </div>
      </article>

      <article id="vacation-card" class="panel unlock-card locked">
        <div class="unlock-header">
          <div>
            <p class="eyebrow">Unlock 2</p>
            <h2>Vacation singer video</h2>
          </div>
          <p id="vacation-status" class="unlock-status">
            Locked: 0 / 10 matching missing-letter words
          </p>
        </div>

        <div class="vacation-stage" aria-hidden="true">
          <div class="sun"></div>
          <div class="wave wave-one"></div>
          <div class="wave wave-two"></div>
          <div class="palm">
            <span class="trunk"></span>
            <span class="leaf one"></span>
            <span class="leaf two"></span>
            <span class="leaf three"></span>
          </div>
          <div class="singer">
            <span class="head"></span>
            <span class="body"></span>
            <span class="arm"></span>
            <span class="mic"></span>
          </div>
          <div class="equalizer">
            <span></span>
            <span></span>
            <span></span>
            <span></span>
            <span></span>
          </div>
          <p class="lyric">"hey i'm on vacation"</p>
        </div>

        <p id="vacation-footnote" class="unlock-footnote">
          Make 10 words miss the same letter to start the singer.
        </p>
      </article>
    </section>
  </main>
</Layout>

<style>
  @font-face {
    font-family: 'Short Stack';
    src: url('/Short_Stack/ShortStack-Regular.ttf') format('truetype');
    font-display: swap;
  }

  @font-face {
    font-family: 'Cooper Hewitt';
    src: url('/CooperHewitt-WebFonts-public/CooperHewitt-Book.woff')
      format('woff');
    font-display: swap;
  }

  :root {
    --page-bg:
      radial-gradient(circle at top, rgba(255, 245, 214, 0.9), transparent 35%),
      linear-gradient(180deg, #fff5d7 0%, #ffd7a8 100%);
    --ink: #203241;
    --ink-soft: #5b6b77;
    --panel: rgba(255, 252, 244, 0.92);
    --line: rgba(32, 50, 65, 0.14);
    --accent: #ff7a59;
    --accent-deep: #e24b2b;
    --teal: #158b8d;
    --gold: #ffbf47;
    --shadow: 0 18px 40px rgba(54, 39, 21, 0.16);
  }

  .wordcountdown-page {
    min-height: 100vh;
    padding: 2rem 1.25rem 6rem;
    background: var(--page-bg);
    color: var(--ink);
    font-family: 'Cooper Hewitt', system-ui, sans-serif;
  }

  .panel {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 28px;
    box-shadow: var(--shadow);
    backdrop-filter: blur(12px);
  }

  .hero,
  .builder-grid,
  .live-panel,
  .history-panel,
  .unlock-grid {
    width: min(1120px, 100%);
    margin: 0 auto 1.5rem;
  }

  .hero {
    padding: 2rem;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 1.25rem;
    align-items: end;
  }

  .eyebrow {
    margin-bottom: 0.35rem;
    font-size: 0.82rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-deep);
  }

  h1,
  h2 {
    font-family: 'Short Stack', cursive;
    line-height: 1.08;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3.75rem);
    margin-bottom: 0.9rem;
  }

  h2 {
    font-size: clamp(1.35rem, 3vw, 2.1rem);
    margin-bottom: 0.25rem;
  }

  .lede,
  .example-copy,
  .help-copy,
  .unlock-footnote,
  .message,
  .letter-summary-value {
    font-size: 1rem;
    color: var(--ink-soft);
  }

  .example-callout {
    padding: 1.25rem;
    border-radius: 22px;
    background:
      linear-gradient(135deg, rgba(255, 122, 89, 0.16), rgba(21, 139, 141, 0.1));
    border: 1px solid rgba(226, 75, 43, 0.16);
  }

  .example-label,
  .preview-label,
  .stat-label,
  .letter-summary-label,
  .unlock-status {
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .builder-grid,
  .unlock-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .composer,
  .stats-panel,
  .live-panel,
  .history-panel,
  .unlock-card {
    padding: 1.5rem;
  }

  .section-heading {
    margin-bottom: 1rem;
  }

  .form-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) repeat(2, minmax(140px, 1fr));
    gap: 0.9rem;
    margin-bottom: 1rem;
  }

  label,
  .pick-letter {
    display: grid;
    gap: 0.35rem;
  }

  label span,
  .pick-letter span {
    font-size: 0.9rem;
    color: var(--ink-soft);
  }

  input[type='text'],
  input[type='number'] {
    width: 100%;
    border: 1px solid rgba(32, 50, 65, 0.18);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.95);
    padding: 0.95rem 1rem;
    color: var(--ink);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.9);
  }

  input:focus {
    outline: 3px solid rgba(21, 139, 141, 0.16);
    border-color: var(--teal);
  }

  .missing-letter-box {
    padding: 1rem;
    border-radius: 22px;
    background: rgba(21, 139, 141, 0.08);
    border: 1px solid rgba(21, 139, 141, 0.12);
  }

  .checkbox-row {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.9rem;
    flex-wrap: wrap;
  }

  .checkbox-label {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    font-size: 1rem;
    color: var(--ink);
  }

  .checkbox-label input {
    width: 1.15rem;
    height: 1.15rem;
    accent-color: var(--accent);
  }

  .pick-letter {
    grid-template-columns: 1fr;
    width: 120px;
  }

  .pick-letter input {
    text-align: center;
    font-size: 1.1rem;
    font-weight: 700;
  }

  .preview-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
    margin-bottom: 0.85rem;
  }

  .preview-card {
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.82);
    padding: 0.95rem 1rem;
    border: 1px solid rgba(32, 50, 65, 0.08);
  }

  .preview-line {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: 'Short Stack', cursive;
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    color: var(--ink);
    word-break: break-word;
  }

  .preview-line .before {
    opacity: 0.65;
  }

  .preview-line .arrow {
    color: var(--accent-deep);
  }

  .preview-line .after {
    color: var(--teal);
  }

  .message {
    margin: 1rem 0 0;
    min-height: 1.5rem;
  }

  .message.is-error {
    color: #a4221b;
  }

  .message.is-success {
    color: #106b63;
  }

  .action-row {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  .primary-button,
  .secondary-button {
    border: none;
    border-radius: 999px;
    padding: 0.95rem 1.4rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition:
      transform 160ms ease,
      box-shadow 160ms ease,
      background 160ms ease;
  }

  .primary-button {
    background: linear-gradient(135deg, var(--accent), var(--accent-deep));
    color: white;
    box-shadow: 0 12px 24px rgba(226, 75, 43, 0.22);
  }

  .secondary-button {
    background: rgba(32, 50, 65, 0.08);
    color: var(--ink);
  }

  .primary-button:hover,
  .secondary-button:hover {
    transform: translateY(-1px);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
    margin-bottom: 1rem;
  }

  .stat-card {
    padding: 1rem;
    border-radius: 20px;
    background: white;
    border: 1px solid rgba(32, 50, 65, 0.08);
  }

  .stat-value {
    font-family: 'Short Stack', cursive;
    font-size: clamp(1.75rem, 3vw, 2.4rem);
    color: var(--ink);
  }

  .letter-summary {
    padding: 1rem;
    border-radius: 22px;
    background:
      linear-gradient(135deg, rgba(255, 191, 71, 0.2), rgba(255, 255, 255, 0.72));
    border: 1px solid rgba(255, 191, 71, 0.25);
  }

  .letter-chip-list,
  .live-words {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .letter-chip {
    padding: 0.45rem 0.7rem;
    border-radius: 999px;
    background: rgba(32, 50, 65, 0.08);
    color: var(--ink);
    font-size: 0.92rem;
  }

  .live-panel {
    min-height: 150px;
  }

  .live-words.is-empty,
  .history-list.is-empty {
    display: grid;
    place-items: center;
    min-height: 120px;
    border: 1px dashed rgba(32, 50, 65, 0.2);
    border-radius: 24px;
    color: var(--ink-soft);
    background: rgba(255, 255, 255, 0.5);
    text-align: center;
    padding: 1rem;
  }

  .live-word {
    min-width: 190px;
    padding: 1rem;
    border-radius: 22px;
    background:
      linear-gradient(145deg, rgba(21, 139, 141, 0.14), rgba(255, 255, 255, 0.96));
    border: 1px solid rgba(21, 139, 141, 0.15);
  }

  .live-word-title {
    font-family: 'Short Stack', cursive;
    font-size: 1.35rem;
    line-height: 1.1;
    margin-bottom: 0.35rem;
  }

  .live-word-meta {
    font-size: 0.92rem;
    color: var(--ink-soft);
  }

  .history-list {
    display: grid;
    gap: 0.85rem;
  }

  .history-row {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
    padding: 1rem 1.1rem;
    border-radius: 22px;
    border: 1px solid rgba(32, 50, 65, 0.08);
    background: rgba(255, 255, 255, 0.8);
  }

  .history-word {
    display: flex;
    gap: 0.55rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .history-word strong {
    font-family: 'Short Stack', cursive;
    font-size: 1.2rem;
    font-weight: 400;
  }

  .history-word .transformed {
    color: var(--teal);
  }

  .history-word .separator {
    color: var(--accent-deep);
  }

  .history-meta,
  .history-timing {
    font-size: 0.94rem;
    color: var(--ink-soft);
  }

  .status-pill {
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
  }

  .status-pill.waiting {
    background: rgba(255, 191, 71, 0.24);
    color: #8a5b00;
  }

  .status-pill.live {
    background: rgba(21, 139, 141, 0.18);
    color: #106b63;
  }

  .status-pill.expired {
    background: rgba(32, 50, 65, 0.12);
    color: var(--ink-soft);
  }

  .unlock-card {
    position: relative;
    overflow: hidden;
  }

  .unlock-header {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .unlock-status {
    color: var(--ink-soft);
    text-align: right;
  }

  .locked .memory-polaroid,
  .locked .vacation-stage {
    filter: blur(14px) saturate(0.6);
    transform: scale(0.98);
  }

  .unlocked .memory-polaroid,
  .unlocked .vacation-stage {
    filter: none;
    transform: none;
  }

  .memory-polaroid {
    max-width: 360px;
    margin: 0 auto;
    padding: 1rem 1rem 1.2rem;
    border-radius: 22px;
    background: white;
    box-shadow: 0 14px 34px rgba(45, 28, 11, 0.18);
    transition:
      filter 200ms ease,
      transform 200ms ease;
  }

  .memory-art {
    position: relative;
    aspect-ratio: 4 / 4.7;
    border-radius: 18px;
    background:
      radial-gradient(circle at 50% 15%, rgba(255, 255, 255, 0.9), transparent 26%),
      linear-gradient(180deg, #9fd3ff 0%, #ffe7b0 65%, #fba979 100%);
    overflow: hidden;
    margin-bottom: 1rem;
  }

  .memory-glow {
    position: absolute;
    inset: auto 50% 20% 50%;
    width: 180px;
    height: 180px;
    transform: translate(-50%, 0);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.32);
    filter: blur(16px);
  }

  .memory-head,
  .memory-body {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(52, 46, 62, 0.9);
  }

  .memory-head {
    top: 26%;
    width: 106px;
    height: 116px;
    border-radius: 46% 46% 42% 42%;
  }

  .memory-body {
    bottom: 0;
    width: 210px;
    height: 200px;
    border-radius: 40% 40% 0 0;
  }

  .memory-spark {
    position: absolute;
    width: 14px;
    height: 14px;
    background: rgba(255, 255, 255, 0.72);
    border-radius: 999px;
    animation: sparkle 2.6s infinite ease-in-out;
  }

  .memory-spark.one {
    top: 18%;
    left: 22%;
  }

  .memory-spark.two {
    top: 30%;
    right: 18%;
    animation-delay: 0.6s;
  }

  .memory-spark.three {
    top: 14%;
    right: 30%;
    animation-delay: 1.1s;
  }

  .memory-name,
  .memory-time {
    text-align: center;
  }

  .memory-name {
    font-family: 'Short Stack', cursive;
    font-size: 1.3rem;
    margin-bottom: 0.2rem;
  }

  .memory-time {
    color: var(--ink-soft);
  }

  .vacation-stage {
    position: relative;
    min-height: 320px;
    border-radius: 24px;
    overflow: hidden;
    background:
      linear-gradient(180deg, #80d6ff 0%, #ffd977 60%, #ffb06f 100%);
    transition:
      filter 200ms ease,
      transform 200ms ease;
  }

  .sun {
    position: absolute;
    top: 38px;
    right: 42px;
    width: 94px;
    height: 94px;
    border-radius: 999px;
    background: #fff1a8;
    box-shadow: 0 0 0 18px rgba(255, 241, 168, 0.18);
  }

  .wave {
    position: absolute;
    left: -10%;
    width: 120%;
    border-radius: 50%;
    background: rgba(0, 149, 214, 0.32);
  }

  .wave-one {
    bottom: 58px;
    height: 90px;
  }

  .wave-two {
    bottom: 22px;
    height: 110px;
    background: rgba(0, 122, 181, 0.4);
  }

  .palm {
    position: absolute;
    left: 28px;
    bottom: 68px;
    width: 96px;
    height: 180px;
  }

  .palm .trunk {
    position: absolute;
    left: 32px;
    bottom: 0;
    width: 18px;
    height: 132px;
    border-radius: 999px;
    background: #8a5a2b;
    transform: skew(-9deg);
  }

  .palm .leaf {
    position: absolute;
    left: 16px;
    top: 12px;
    width: 74px;
    height: 18px;
    border-radius: 999px;
    background: #2f9f6b;
    transform-origin: left center;
  }

  .palm .leaf.one {
    transform: rotate(-28deg);
  }

  .palm .leaf.two {
    transform: rotate(8deg);
  }

  .palm .leaf.three {
    transform: rotate(32deg);
  }

  .singer {
    position: absolute;
    left: 50%;
    bottom: 78px;
    width: 90px;
    height: 168px;
    transform: translateX(-50%);
    animation: sway 1.8s infinite ease-in-out;
  }

  .singer .head,
  .singer .body,
  .singer .arm {
    position: absolute;
    background: #2f3952;
  }

  .singer .head {
    top: 0;
    left: 24px;
    width: 42px;
    height: 42px;
    border-radius: 999px;
  }

  .singer .body {
    top: 38px;
    left: 20px;
    width: 50px;
    height: 88px;
    border-radius: 28px 28px 16px 16px;
  }

  .singer .arm {
    top: 58px;
    left: 52px;
    width: 48px;
    height: 12px;
    border-radius: 999px;
    transform: rotate(-14deg);
    transform-origin: left center;
  }

  .singer .mic {
    position: absolute;
    top: 18px;
    right: -6px;
    width: 8px;
    height: 108px;
    border-radius: 999px;
    background: #202020;
  }

  .equalizer {
    position: absolute;
    right: 24px;
    bottom: 96px;
    display: flex;
    align-items: end;
    gap: 8px;
    height: 70px;
  }

  .equalizer span {
    width: 10px;
    border-radius: 999px;
    background: white;
    animation: bounce-bars 1s infinite ease-in-out;
  }

  .equalizer span:nth-child(1) {
    height: 28px;
  }

  .equalizer span:nth-child(2) {
    height: 54px;
    animation-delay: 0.1s;
  }

  .equalizer span:nth-child(3) {
    height: 38px;
    animation-delay: 0.2s;
  }

  .equalizer span:nth-child(4) {
    height: 64px;
    animation-delay: 0.3s;
  }

  .equalizer span:nth-child(5) {
    height: 24px;
    animation-delay: 0.4s;
  }

  .lyric {
    position: absolute;
    left: 50%;
    bottom: 18px;
    transform: translateX(-50%);
    width: calc(100% - 2rem);
    text-align: center;
    font-family: 'Short Stack', cursive;
    font-size: clamp(1.15rem, 2.5vw, 1.5rem);
    color: white;
    text-shadow: 0 2px 10px rgba(19, 38, 59, 0.3);
  }

  @keyframes sparkle {
    0%,
    100% {
      transform: scale(0.7);
      opacity: 0.45;
    }
    50% {
      transform: scale(1.1);
      opacity: 1;
    }
  }

  @keyframes sway {
    0%,
    100% {
      transform: translateX(-50%) rotate(-2deg);
    }
    50% {
      transform: translateX(-50%) rotate(2deg);
    }
  }

  @keyframes bounce-bars {
    0%,
    100% {
      transform: scaleY(0.7);
      opacity: 0.72;
    }
    50% {
      transform: scaleY(1.15);
      opacity: 1;
    }
  }

  @media (max-width: 900px) {
    .hero,
    .builder-grid,
    .unlock-grid,
    .form-grid,
    .preview-grid {
      grid-template-columns: 1fr;
    }

    .history-row {
      grid-template-columns: 1fr;
      gap: 0.55rem;
    }

    .unlock-header {
      flex-direction: column;
      align-items: start;
    }

    .unlock-status {
      text-align: left;
    }
  }

  @media (max-width: 640px) {
    .wordcountdown-page {
      padding-inline: 0.85rem;
    }

    .hero,
    .composer,
    .stats-panel,
    .live-panel,
    .history-panel,
    .unlock-card {
      padding: 1.15rem;
      border-radius: 24px;
    }

    .checkbox-row,
    .action-row {
      align-items: stretch;
    }

    .pick-letter {
      width: 100%;
    }

    .stats-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>

<script>
  type Entry = {
    id: number
    originalWord: string
    displayWord: string
    fromSeconds: number
    toSeconds: number
    createdAt: number
    startAt: number
    endAt: number
    missingLetter: string | null
    changedByMissingLetter: boolean
  }

  if (typeof window !== 'undefined') {
    const form = document.querySelector('#word-form') as HTMLFormElement | null
    const wordInput = document.querySelector('#word-input') as HTMLInputElement | null
    const fromInput = document.querySelector('#from-input') as HTMLInputElement | null
    const toInput = document.querySelector('#to-input') as HTMLInputElement | null
    const removeLetterCheckbox = document.querySelector(
      '#remove-letter-checkbox',
    ) as HTMLInputElement | null
    const letterInput = document.querySelector(
      '#letter-input',
    ) as HTMLInputElement | null
    const formMessage = document.querySelector('#form-message') as HTMLParagraphElement | null
    const liveWords = document.querySelector('#live-words') as HTMLDivElement | null
    const historyList = document.querySelector('#history-list') as HTMLDivElement | null
    const totalCount = document.querySelector('#total-count') as HTMLParagraphElement | null
    const liveCount = document.querySelector('#live-count') as HTMLParagraphElement | null
    const waitingCount = document.querySelector('#waiting-count') as HTMLParagraphElement | null
    const expiredCount = document.querySelector('#expired-count') as HTMLParagraphElement | null
    const letterSummary = document.querySelector('#letter-summary') as HTMLParagraphElement | null
    const letterChipList = document.querySelector(
      '#letter-chip-list',
    ) as HTMLDivElement | null
    const photoCard = document.querySelector('#photo-card') as HTMLElement | null
    const photoStatus = document.querySelector('#photo-status') as HTMLParagraphElement | null
    const vacationCard = document.querySelector('#vacation-card') as HTMLElement | null
    const vacationStatus = document.querySelector(
      '#vacation-status',
    ) as HTMLParagraphElement | null
    const vacationFootnote = document.querySelector(
      '#vacation-footnote',
    ) as HTMLParagraphElement | null
    const insteadPreview = document.querySelector('#instead-preview') as HTMLSpanElement | null
    const wordPreviewBefore = document.querySelector(
      '#word-preview-before',
    ) as HTMLSpanElement | null
    const wordPreviewAfter = document.querySelector(
      '#word-preview-after',
    ) as HTMLSpanElement | null
    const resetButton = document.querySelector('#reset-button') as HTMLButtonElement | null

    const entries: Entry[] = []
    let nextId = 1

    const escapeHtml = (value: string) =>
      value
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;')

    const escapeRegExp = (value: string) =>
      value.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')

    const formatSeconds = (seconds: number) => {
      if (!Number.isFinite(seconds)) return '0.0s'
      return `${Math.max(0, seconds).toFixed(1)}s`
    }

    const getPickedLetter = () => {
      const raw = letterInput?.value.trim() || 'A'
      return raw.charAt(0).toUpperCase()
    }

    const removePickedLetterFromWord = (word: string, pickedLetter: string) => {
      if (!pickedLetter) return word

      const pattern = new RegExp(escapeRegExp(pickedLetter), 'gi')
      return word.replace(pattern, '')
    }

    const setMessage = (text: string, kind: 'error' | 'success' | 'idle' = 'idle') => {
      if (!formMessage) return
      formMessage.textContent = text
      formMessage.classList.remove('is-error', 'is-success')
      if (kind === 'error') formMessage.classList.add('is-error')
      if (kind === 'success') formMessage.classList.add('is-success')
    }

    const getStatus = (entry: Entry, now: number) => {
      if (now < entry.startAt) return 'waiting'
      if (now < entry.endAt) return 'live'
      return 'expired'
    }

    const updatePreview = () => {
      const pickedLetter = getPickedLetter()
      const missingLetterMode = removeLetterCheckbox?.checked ?? false
      const wordValue = wordInput?.value.trim() || 'Wash'
      const insteadValue = missingLetterMode
        ? removePickedLetterFromWord('Instead', pickedLetter)
        : 'Instead'
      const previewWord = missingLetterMode
        ? removePickedLetterFromWord(wordValue, pickedLetter)
        : wordValue

      if (letterInput && letterInput.value !== pickedLetter) {
        letterInput.value = pickedLetter
      }

      if (insteadPreview) {
        insteadPreview.textContent = insteadValue || '(empty)'
      }

      if (wordPreviewBefore) {
        wordPreviewBefore.textContent = wordValue
      }

      if (wordPreviewAfter) {
        wordPreviewAfter.textContent = previewWord || '(empty)'
      }
    }

    const render = () => {
      const now = Date.now()
      const waitingEntries = entries.filter(entry => getStatus(entry, now) === 'waiting')
      const liveEntries = entries.filter(entry => getStatus(entry, now) === 'live')
      const expiredEntries = entries.filter(entry => getStatus(entry, now) === 'expired')

      if (totalCount) totalCount.textContent = String(entries.length)
      if (liveCount) liveCount.textContent = String(liveEntries.length)
      if (waitingCount) waitingCount.textContent = String(waitingEntries.length)
      if (expiredCount) expiredCount.textContent = String(expiredEntries.length)

      if (liveWords) {
        if (liveEntries.length === 0) {
          liveWords.className = 'live-words is-empty'
          liveWords.innerHTML =
            '<p>No words are showing yet. Add one, or wait for the next From time.</p>'
        } else {
          liveWords.className = 'live-words'
          liveWords.innerHTML = liveEntries
            .map(entry => {
              const remainingSeconds = (entry.endAt - now) / 1000
              const letterLabel = entry.changedByMissingLetter && entry.missingLetter
                ? `Missing ${entry.missingLetter}`
                : 'Normal word'

              return `
                <article class="live-word">
                  <p class="live-word-title">${escapeHtml(entry.displayWord || '(empty)')}</p>
                  <p class="live-word-meta">Gone in ${formatSeconds(remainingSeconds)}</p>
                  <p class="live-word-meta">${escapeHtml(letterLabel)}</p>
                </article>
              `
            })
            .join('')
        }
      }

      if (historyList) {
        if (entries.length === 0) {
          historyList.className = 'history-list is-empty'
          historyList.innerHTML =
            '<p>Your list of words will appear here with waiting time and ending time.</p>'
        } else {
          historyList.className = 'history-list'
          historyList.innerHTML = [...entries]
            .reverse()
            .map(entry => {
              const status = getStatus(entry, now)
              let timingText = ''

              if (status === 'waiting') {
                timingText = `Starts in ${formatSeconds((entry.startAt - now) / 1000)}`
              } else if (status === 'live') {
                timingText = `Ends in ${formatSeconds((entry.endAt - now) / 1000)}`
              } else {
                timingText = `Ended ${formatSeconds((now - entry.endAt) / 1000)} ago`
              }

              const wordPair =
                entry.displayWord !== entry.originalWord
                  ? `
                    <strong>${escapeHtml(entry.originalWord)}</strong>
                    <span class="separator">-></span>
                    <strong class="transformed">${escapeHtml(entry.displayWord || '(empty)')}</strong>
                  `
                  : `<strong>${escapeHtml(entry.displayWord || '(empty)')}</strong>`

              const missingMeta =
                entry.changedByMissingLetter && entry.missingLetter
                  ? `Missing letter ${escapeHtml(entry.missingLetter)}`
                  : 'No missing-letter change'

              return `
                <article class="history-row">
                  <div class="history-word">
                    ${wordPair}
                  </div>
                  <div class="history-meta">
                    <p>From ${formatSeconds(entry.fromSeconds)} to ${formatSeconds(entry.toSeconds)}</p>
                    <p>${escapeHtml(missingMeta)}</p>
                  </div>
                  <div class="history-timing">
                    <p class="status-pill ${status}">${status}</p>
                    <p>${timingText}</p>
                  </div>
                </article>
              `
            })
            .join('')
        }
      }

      const missingLetterCounts = new Map<string, number>()
      entries.forEach(entry => {
        if (!entry.changedByMissingLetter || !entry.missingLetter) return
        missingLetterCounts.set(
          entry.missingLetter,
          (missingLetterCounts.get(entry.missingLetter) || 0) + 1,
        )
      })

      const sortedLetterCounts = [...missingLetterCounts.entries()].sort((left, right) => {
        if (right[1] !== left[1]) return right[1] - left[1]
        return left[0].localeCompare(right[0])
      })

      const topLetter = sortedLetterCounts[0]

      if (letterSummary) {
        letterSummary.textContent = topLetter
          ? `${topLetter[0]} is leading with ${topLetter[1]} missing-letter word${topLetter[1] === 1 ? '' : 's'}.`
          : 'No matching missing-letter streak yet.'
      }

      if (letterChipList) {
        if (sortedLetterCounts.length === 0) {
          letterChipList.innerHTML = ''
        } else {
          letterChipList.innerHTML = sortedLetterCounts
            .map(
              ([letter, count]) =>
                `<span class="letter-chip">${escapeHtml(letter)}: ${count}</span>`,
            )
            .join('')
        }
      }

      const photoUnlocked = entries.length >= 10
      photoCard?.classList.toggle('locked', !photoUnlocked)
      photoCard?.classList.toggle('unlocked', photoUnlocked)
      if (photoStatus) {
        photoStatus.textContent = photoUnlocked
          ? 'Unlocked: memory photo ready'
          : `Locked: ${entries.length} / 10 words`
      }

      const topLetterCount = topLetter?.[1] || 0
      const vacationUnlocked = topLetterCount >= 10
      vacationCard?.classList.toggle('locked', !vacationUnlocked)
      vacationCard?.classList.toggle('unlocked', vacationUnlocked)
      if (vacationStatus) {
        vacationStatus.textContent = vacationUnlocked
          ? `Unlocked: ${topLetter?.[0]} reached 10 matching words`
          : `Locked: ${topLetterCount} / 10 matching missing-letter words`
      }

      if (vacationFootnote) {
        vacationFootnote.textContent = vacationUnlocked
          ? `The vacation singer unlocked because ${topLetter?.[0]} is missing from 10 words.`
          : 'Make 10 words miss the same letter to start the singer.'
      }
    }

    form?.addEventListener('submit', event => {
      event.preventDefault()

      const originalWord = wordInput?.value.trim() || ''
      const fromSeconds = Number(fromInput?.value)
      const toSeconds = Number(toInput?.value)
      const missingLetterMode = removeLetterCheckbox?.checked ?? false
      const pickedLetter = getPickedLetter()

      if (!originalWord) {
        setMessage('Type a word before adding it.', 'error')
        return
      }

      if (!Number.isFinite(fromSeconds) || fromSeconds < 0) {
        setMessage('From needs to be 0 or more.', 'error')
        return
      }

      if (!Number.isFinite(toSeconds) || toSeconds <= fromSeconds) {
        setMessage('To needs to be bigger than From.', 'error')
        return
      }

      if (missingLetterMode && !/^[A-Z]$/i.test(pickedLetter)) {
        setMessage('Pick one letter for missing-letter mode.', 'error')
        return
      }

      const transformedWord = missingLetterMode
        ? removePickedLetterFromWord(originalWord, pickedLetter)
        : originalWord
      const createdAt = Date.now()

      entries.push({
        id: nextId++,
        originalWord,
        displayWord: transformedWord,
        fromSeconds,
        toSeconds,
        createdAt,
        startAt: createdAt + fromSeconds * 1000,
        endAt: createdAt + toSeconds * 1000,
        missingLetter: missingLetterMode ? pickedLetter : null,
        changedByMissingLetter:
          missingLetterMode && transformedWord.toLowerCase() !== originalWord.toLowerCase(),
      })

      if (wordInput) wordInput.value = ''

      updatePreview()
      render()

      const finalWord = transformedWord || '(empty)'
      setMessage(
        `Added ${finalWord}. It will wait ${formatSeconds(fromSeconds)} and end at ${formatSeconds(toSeconds)}.`,
        'success',
      )
    })

    resetButton?.addEventListener('click', () => {
      entries.splice(0, entries.length)
      nextId = 1
      if (wordInput) wordInput.value = ''
      setMessage('The game is reset. Start adding words again.')
      updatePreview()
      render()
    })

    wordInput?.addEventListener('input', updatePreview)
    letterInput?.addEventListener('input', updatePreview)
    removeLetterCheckbox?.addEventListener('change', updatePreview)

    updatePreview()
    render()
    window.setInterval(render, 250)
  }
</script>
